<ملف رقم="٦٢"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٠٩٤٦٤'>وَذٰلِكَ <صفحة رقم="٦٢"/> أَنْ تَضْرِبَ الْخَمْسَةَ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٠٦٧٤٢'>حَتَّى يَكُونَ جَذْرُ خَمْسَةٍ وَسَبْعُونَ فِي جَذْرِ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٤٧٥٥٨'>فَاضْرِبْ خَمْسَةً وَسَبْعِينَ فِي خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٩٢٠٧'>فَيَكُونُ أَلْفًا وَثَمَانِي مِائَةٍ وَخَمْسَةً وَسَبْعِينَ</مقطع>
  <مقطع هوية='٦٠٣٦٨'>فَخُذْ جَذْرَ ذٰلِكَ فَهُوَ تَكْسِيرُهَا وَهُوَ ثَلاَثَةٌ وَأَرْبَعُونَ وَشَيْءٌ قَلِيلٌ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٤٨٤٢٨' عرض="0.5" ملف="../figures/fig062"/>

  <مقطع هوية='٨٤٣٦٦'>وَقَدْ تَكُونُ مِنْ هَذِهِ الْزَوَايَا الْحَادَّةِ مُخْتَلِفَةَ الْأَضْلَاعِ</مقطع>
  <مقطع هوية='٥٥٥٣٨'>فَاعْلَمْ أَنَّ تَكْسِيرَهَا يُعْلَمُ مِنْ قَبْلِ مَسْقَطِ حَجَرِهَا وَعَمُودِهَا</مقطع>
  <مقطع هوية='٨٣٣١٦'>وَهِيَ أَنْ تَكُونَ مُثَلَّثَةً مِنْ جَانِبِ خَمْسَةِ عَشَرَ ذِرَاعًا</مقطع>
  <مقطع هوية='٣١٨٠٨'>وَمِنْ جَانِبِ أَرْبَعَةِ عَشَرَ ذِرَاعًا</مقطع>
  <مقطع هوية='٢١٥٥٦'>وَمِنْ جَانِبِ ثَلاثَةِ عَشَرَ ذِرَاعًا</مقطع>
  <مقطع هوية='٧٥٣٩٩'>فَإِذَا أَرَدْتَ عِلْمَ مَسْقَطِ حَجَرِهَا فَاجْعَلِ القَاعِدَةَ أَيِ الجَوَانِبِ شِئْتَ</مقطع>
  <مقطع هوية='١١٨٨٧'>فَجَعَلْنَاهَا أَرْبَعَةَ عَشَرَ وَهُوَ مَسْقَطُ الحَجَرِ</مقطع>
  <مقطع هوية='٦٥٨٤٦'>فَسَقَطَ حَجَرُهَا يَقَعُ مِنْهَا عَلَى شَيْءٍ مِمَّا يَلِي</مقطع>
  <مقطع هوية='٥٥٨٨٥'>أَيِ الضِّلعَيْنِ شِئْتَ فَجَعَلْنَا الشَّيْءَ مِمَّا يَلِي الثَّلاَثَةَ عَشَرَ</مقطع>
  <مقطع هوية='٩٣٨٠٦'>فَضَرَبْنَاهُ فِي مِثْلِهِ فَصَارَ مَالًا</مقطع>
  <مقطع هوية='٢٦٨٠٤'>وَنَقَصْنَاهُ مِنْ ثَلاَثَةَ عَشَرَ فِي مِثْلِهَا وَهُوَ مِائَةٌ وَتِسْعَةٌ وَسِتُّونَ</مقطع>
  <مقطع هوية='٢٤٤٧٣'>فَصَارَ ذٰلِكَ مِائَةً وَتِسْعَةً وَسِتِّينَ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٤٣٢٩٨'>فَعَلِمْنَا أَنَّ جَذْرَهَا هُوَ الْعَمُودُ وَقَدْ بَقِيَ لَنَا مِنَ القَاعِدَةِ أَرْبَعَةَ عَشَرَ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='١١٢٩٥'>فَضَرَبْنَاهُ فِي مِثْلِهِ فَصَارَ مِائَةً وَسِتَّةً وَتِسْعِينَ وَمَالًا إِلَّا ثَمَانِيَةً وَعِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٥٤٣٢'>فَنَقَصْنَاهُ مِنَ الْخَمْسَةَ عَشَرَ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٠٥٢٦٦'>فَبَقِيَ تِسْعَةً وَعِشْرُونَ دِرْهَمًا وَثَمَانِيَةً وَعِشْرُونَ شَيْئًا إِلَّا مَالًا</مقطع>
  <مقطع هوية='٥٠٢٣٥'>وَجَذْرُهَا هُوَ الْعَمُودُ فَلَمَّا صَارَ جَذْرُهَا هَذَا الْعَمُودُ</مقطع>
  <مقطع هوية='٢٦٨٥٣'>وَجَذْرُ مِائَةٍ وَتِسْعَةٍ وَسِتِّيْنَ إِلَّا مَالًا هُوَ الْعَمُودُ أَيْضًا</مقطع>
  <مقطع هوية='٢٦٤٨٤'>عَلِمْنَا أَنَّهُمَا مُتَسَاوِيَانِ</مقطع>
</ملف>
