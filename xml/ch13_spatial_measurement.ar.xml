<فصل هوية='٨٦٥١١'

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <عنوان>بَابُ الْمِسَاحَةِ</عنوان>

  <مقطع هوية='٠٥٧٤٣'>اعْلَمْ أَنَّ مَعْنَى <قبس>وَاحِدٍ فِي وَاحِدٍ</قبس>
  إِنَّمَا هِيَ <ص مفتاح="مسح!مساحة">مِسَاحَةٌ</ص></مقطع>
  <مقطع هوية='٣٦٧٤٨'>وَمَعْنَاهُ ذِرَاعٌ فِي ذِرَاعٍ</مقطع>

  <قسم هوية='١٥٣٩٣'>
    <عنوان>[السَّطْحُ الْمُتَسَاوِي الأَضْلَاعِ]</عنوان>
  </قسم>
  <مقطع هوية='٤٦٤٣٤'>فَكُلُّ <شدة>سَطْحٍ مُتَسَاوِي الأَضْلَاعِ وَالزَّوَايَا</شدة>
  يَكُونُ مِنْ كُلِّ جَانِبِهِ <صفحة رقم="٥٥"/> وَاحِدٌ</مقطع>
  <!-- p055 -->
  <مقطع هوية='٥٦٨٦٣'>فَإنَّ السَّطْحَ كُلَّهُ وَاحِدٌ</مقطع>
  <مقطع هوية='٤٦٤٠٧'>فَإنْ كَانَ مِنْ كُلِّ جانِبٍ اثْنَانِ وَهُوَ مُتَسَاوِ الأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٠٦٨٥٣'>فَالسَّطْحُ كُلُّهُ أَرْبَعَةُ أَمْثَالِ السَّطْحِ
  الَّذِي هُوَ ذِرَاعٌ فِي ذِرَاعٍ</مقطع>

  <مقطع هوية='١٣٧٥١'>وَكَذَلكَ ثَلاثَةٌ فِي ثَلاثَةٍ وَمَا زَادَ عَلَى ذَلكَ أَوْ نَقَصَ</مقطع>
  <مقطع هوية='٩٠٠٧٥'>وَكَذَلكَ نِصْفٌ فِي نِصْفٍ وَغَيْرُ ذَلكَ مِنَ الْكُسُورِ فَعَلَى هذا</مقطع>

  <مقطع هوية='٥٨٩٥٩'>وَكُلُّ سَطْحٍ مُرَبَّعٍ يَكُونُ مِنْ كُلِّ جانِبٍ نِصْفُ ذِرَاعٍ</مقطع>
  <مقطع هوية='٩٨٠٤٢'>فَهُوَ مِثْلُ رُبْعِ السَّطْحِ الَّذِي هُوَ مِنْ كُلِّ جانِبٍ ذِرَاعٌ</مقطع>

  <مقطع هوية='٠٥٧١٤'>وَكَذٰلِكَ ثُلُثٌ فِي ثُلُثٍ وَرُبُعٌ فِي رُبُعٍ وَخُمْسٌ فِي خُمْسٍ</مقطع>
  <مقطع هوية='١٩٠٥٩'>وَثُلُثَانِ فِي نِصْفٍ أَوْ أَقَلَّ مِنْ ذَلكَ أَوْ أَكْثَرَ فَعَلَى حِسَابِهِ</مقطع>

  <مقطع هوية='٧٧٣٩٦'>وَكُلُّ <شدة>سَطْحٍ مُرَبَّعٍ مُتَسَاوِي الْأَضْلَاعِ</شدة></مقطع>
  <مقطع هوية='٧١٧٦٩'>فَإِنَّ أَحَدَ أَضْلَاعِهِ فِي وَاحِدٍ جَذْرُهُ</مقطع>
  <مقطع هوية='٦٥٩٩٣'>وَفِي اثْنَيْنِ جَذْرَاهُ</مقطع>
  <مقطع هوية='٣٧٦٢٧'>صَغُرَ هَذَا السَّطْحُ أَوْ كَبُرَ</مقطع>

  <!-- <قسم هوية='٦٢٤١٦'> -->
  <!--   <عنوان>[الْمُثَلَّثُ]</عنوان> -->
  <!-- </قسم> -->
  <مقطع هوية='١٧٢٩٥'>وَكُلُّ <شدة>مُثَلَّثٍ مُتَسَاوِي الْأَضْلَاعِ</شدة></مقطع>
  <مقطع هوية='٨٠٦٦١'>فَإِنْ ضَرَبْتَ عَمُودَهُ وَنِصْفَ الْقَاعِدَةِ الَّتِي يَقَعُ عَلَيْهَا الْعَمُودُ</مقطع>
  <مقطع هوية='٨٥٩٣٨'>هُوَ تَكْسِيرُ ذَلكَ الْمُثَلَّثِ</مقطع>

  <!-- <قسم هوية='٤٤٤٤١'> -->
  <!--   <عنوان>[الْمُعَيَّن]</عنوان> -->
  <!-- </قسم> -->
  <مقطع هوية='٩٠٠٣٨'>وَكُلُّ <شدة>مَعَيَّنَةٍ مُتَسَاوِيَةِ الأَضْلاعِ</شدة></مقطع>
  <مقطع هوية='٤١٠٤٣'>فَإِنَّ ضَرْبَكَ أَحَدَ القُطْرَيْنِ فِي نِصْفِ الآخَرِ هُوَ تَكْسِيرُهَا</مقطع>

  <قسم هوية='٤٢٧٢٩'>
    <عنوان>[الْمُدَوَّرَةُ]</عنوان>
  </قسم>
  <مقطع هوية='٧٥٧٤٩'>وَكُلُّ <شدة>مُدَوَّرَةٍ</شدة> فَإِنَّ ضَرْبَكَ القُطْرَ فِي ثَلاثَةٍ وَسُبُعٍ</مقطع>
  <!-- p056 -->
  <مقطع هوية='١٦٦٣٢'>هُوَ الدَّوْرُ <صفحة رقم="٥٦"/> الَّذِى يُحِيطُ بِهَا</مقطع>
  <مقطع هوية='٥٠٧٧٦'>وَهُوَ اصْطِلَاحٌ بَيْنَ النَّاسِ مِنْ غَيْرِ اضْطِرَارٍ</مقطع>
  <مقطع هوية='٤٩٩٥٠'>وَلِأَهْلِ الْهِنْدِ <!-- الهَنْدَسَةِ --> فِيهِ قَوْلَانِ آخَرَانِ</مقطع>
  <مقطع هوية='٩٦٤٢٨'>أَحَدُهُمَا أَن تَضْرِبَ الْقُطْرَ فِى مِثْلِهِ ثُمَّ فِى عَشَرَةٍ</مقطع>
  <مقطع هوية='١٦٨٧٣'>ثُمَّ تَأْخُذُ جَذْرَ مَا اجْتَمَعَ فَمَا كَانَ هُوَ الدَّوْرُ</مقطع>
  <مقطع هوية='٤٠٣٨٢'>وَالْقَوْلُ الثَّانِى لِأَهْلِ النُّجُومِ مِنْهُمْ</مقطع>
  <مقطع هوية='١٤٢٧٨'>وَهُوَ أَن تَضْرِبَ الْقُطْرَ فِى اثْنَيْنِ وَسِتِّينَ أَلْفًا وَثَمَانِمِائَةٍ وَاثْنَيْنِ وَثَلاَثِينَ</مقطع>
  <مقطع هوية='٤٩٧٢٠'>ثُمَّ تَقْسِمُ ذٰلِكَ عَلَى عِشْرِينَ أَلْفًا فَمَا خَرَجَ فَهُوَ الدَّوْرُ</مقطع>
  <مقطع هوية='٢١٦٧٨'>وَكُلُّ ذٰلِكَ قَرِيبٌ بَعْضُهُ مِنْ بَعْضٍ</مقطع>

  <مقطع هوية='٧٢١٧٤'>وَالدَّوْرُ إِذَا قَسَمْتَهُ عَلَى ثَلاثَةٍ وَسُبْعٍ يَخْرُجُ الْقُطْرُ</مقطع>
  <مقطع هوية='٧٣٦٣٥'>وَكُلُّ مُدَوَّرَةٍ فَإِنَّ نِصْفَ الْقُطْرِ فِي نِصْفِ الدَّوْرِ هُوَ التَّكْسِيرُ</مقطع>
  <مقطع هوية='٦٠٨٣١'>لِأَنَّ كُلَّ ذَاتِ أَضْلَاعٍ وَزَوَايَا مُتَسَاوِيَةٍ مِنَ الْمُثَلَّثَاتِ وَالْمُرَبَّعَاتِ وَالْمُخَمَّسَاتِ وَمَا فَوْقَ ذٰلِكَ</مقطع>
  <مقطع هوية='٧٥٢٨٦'>فَإِنَّ ضَرْبَكَ نِصْفَ مَا يُحِيطُ بِهِ فِي نِصْفِ قُطْرٍ أَوْسَعَ دَائِرَةٍ يَقَعُ فِيهَا تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٤٤٠٠٠'>وَكُلُّ مُدَوَّرَةٍ فَإِنَّ قُطْرَهَا مَضْرُوبًا فِي نَفْسِهِ مَنْقُوصًا مِنْهُ سُبْعُهُ وَنِصْفُ سُبْعِهِ</مقطع>
  <مقطع هوية='٥٥٧٢٣'>هُوَ تَكْسِيرُهَا وَهُوَ مُوَافِقٌ لِلْبَابِ الْأَوَّلِ</مقطع>

  <قسم هوية='٧٥٠٩٠'>
    <عنوان>[الْقِطْعَةُ مِن الْمُدَوَّرَةِ]</عنوان>
  </قسم>
  <مقطع هوية='٥٨٧٥٦'>وَكُلُّ قِطْعَةٍ مِنْ مُدَوَّرَةٍ مُشَبَّهَةٍ بِقَوْسٍ</مقطع>
  <مقطع هوية='٤٠٩٢١'>فَلَا بُدَّ أَنْ تَكُونَ مِثْلَ نِصْفِ مُدَوَّرَةٍ</مقطع>
  <مقطع هوية='٢٢٠٦١'>أَوْ أَقَلَّ مِنْ نِصْفِ مُدَوَّرَةٍ أَوْ أَكْثَرَ مِنْ نِصْفِ مُدَوَّرَةٍ</مقطع>
  <مقطع هوية='٤٠٨٤٤'>وَالدَّلِيلُ عَلَى ذٰلِكَ أَنَّ سَهْمَ الْقَوْسِ</مقطع>
  <مقطع هوية='٤٦٢٣٥'>إِذَا كَانَ مِثْلَ نِصْفِ الْوَتَرِ فَهِيَ نِصْفُ مُدَوَّرَةٍ سَوِيًّا</مقطع>
  <مقطع هوية='٤٦٧٣٤'>وَإِذَا كَانَ أَقَلَّ مِنْ نِصْفِ الْوَتَرِ</مقطع>
  <مقطع هوية='١٢٢٥٨'>فَهِيَ أَقَلُّ مِنْ نِصْفِ مُدَوَّرَةٍ</مقطع>
  <مقطع هوية='٧٩٥٢٨'>وَإِذَا كَانَ السَّهْمُ أَكْثَرَ مِنْ نِصْفِ الْوَتَرِ</مقطع>
  <مقطع هوية='٨٤٩٦٣'>فَهِيَ أَكْثَرُ مِنْ نِصْفِ مُدَوَّرَةٍ</مقطع>

  <مقطع هوية='١٢٦٧٧'><شدة>وَإِذَا أَرَدْتَ أَنْ تَعْرِفَ</شدة> مِنْ أَيِّ دَائِرَةٍ هِيَ</مقطع>
  <مقطع هوية='٣٠٤٤٢'>فَاضْرِبْ نِصْفَ الْوَتَرِ فِي مِثْلِهِ وَاقْسِمْهُ عَلَى السَّهْمِ</مقطع>
  <مقطع هوية='٦٧٦٨٧'>وَزِدْ مَا خَرَجَ عَلَى السَّهْمِ فَمَا بَلَغَ</مقطع>
  <!-- p057 -->
  <مقطع هوية='١٩٩٨٢'>فَهُوَ قُطْرُ الْمُدَوَّرَةِ <صفحة رقم="٥٧"/> الَّتِي تِلْكَ الْقَوْسُ مِنْهَا</مقطع>
  <مقطع هوية='٢٨٧٩١'><شدة>فَإِنْ أَرَدْتَ أَنْ تَعْرِفَ</شدة> تَكْسِيرَ الْقَوْسِ</مقطع>
  <مقطع هوية='٣١٩٥٣'>فَاضْرِبْ نِصْفَ قُطْرِ الْمُدَوَّرَةِ فِي نِصْفِ الْقَوْسِ</مقطع>
  <مقطع هوية='٠٩١٢٧'> وَاحْفَظْ مَا خَرَجَ</مقطع>
  <مقطع هوية='٥٦٦٨٨'>ثُمَّ انْقُصْ سَهْمَ الْقَوْسِ مِنْ نِصْفِ قُطْرِ الْمُدَوَّرَةِ</مقطع>
  <مقطع هوية='٧٢٧٥٩'>إِنْ كَانَتِ الْقَوْسُ أَقَلَّ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٨٣٦٥٦'>وَإِنْ كَانَتْ أَكْثَرَ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٦١٢١٩'>فَانْقُصْ نِصْفَ قَطْرِ الْمَدُورَةِ مِنْ سَهْمِ الْقَوْسِ</مقطع>
  <مقطع هوية='٤٥٠٤٥'>ثُمَّ اضْرِبْ مَا بَقِيَ فِي نِصْفِ وَتَرِ الْقَوْسِ</مقطع>
  <مقطع هوية='١٤٣٣١'>وَانْقُصْهُ مِمَّا حَفِظْتَ إِنْ كَانَتِ الْقَوْسُ أَقَلَّ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٩٥٤٦٨'>أَوْ زِدْهُ عَلَيْهِ إِنْ كَانَتِ الْقَوْسُ أَكْثَرَ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٦٨٨٨٥'>فَمَا بَلَغَ بَعْدَ الزِّيَادَةِ أَوِ النَّقْصَانِ فَهُوَ تَكْسِيرُ الْقَوْسِ</مقطع>

  <مقطع هوية='٩٠٦٥٥'><شدة>وَكُلُّ مُجَسَّمٍ مُرَبَّعٍ</شدة></مقطع>
  <مقطع هوية='٢٤٨١٦'>فَإنَّ ضَرْبَكَ الطُّولَ فِي الْعَرْضِ ثُمَّ فِي الْعُمْقِ هُوَ التَّكْسِيرُ</مقطع>
  <مقطع هوية='٨٤٧٦٦'>فَإنْ كَانَ عَلَى غَيْرِ تَرْبِيعٍ وَكَانَ مُدَوَّرًا أَوْ مُثَلَّثًا أَوْ غَيْرَ ذٰلِكَ</مقطع>
  <مقطع هوية='٠٥١٦٩'>إِلَّا أَنَّ عُمْقَهُ عَلَى الْاستِوَاءِ وَالْمُوازَاةِ</مقطع>
  <مقطع هوية='٧٩٢٧٢'>فَإنَّ مِسَاحَةَ ذٰلِكَ أَنْ تَمْسَحَ سَطْحَهُ فَتَعْرِفَ تَكْسِيرَهُ</مقطع>
  <مقطع هوية='٠٨٩٢٩'>فَمَا كَانَ ضَرَبْتَهُ فِي الْعُمْقِ فَهُوَ التَّكْسِيرُ</مقطع>

  <مقطع هوية='٨٤٩٨١'><شدة>وَأَمَّا الْمَخْرُوطُ مِنَ الْمُثَلَّثِ وَالْمُدَوَّرِ وَالْمُرَبَّعِ</شدة></مقطع>
  <مقطع هوية='٢٨٠١٨'>فَإِنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ ثُلُثِ مَسَاحَةِ أَسْفَلِهِ فِي عَمُودِهِ هُوَ تَكْسِيرُهُ</مقطع>

  <رأس/>
  <مقطع هوية='٢١٨٣٠'><ص مفتاح="علم!اعْلَمْ">وَاعْلَمْ</ص>
  أَنَّ كُلَّ <شدة>مُثَلَّثٍ قَائِمِ الزَّاَوِيَةِ</شدة></مقطع>
  <مقطع هوية='٠٢٨٨٠'>فَإِنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ الضِّلَعَيْنِ الأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٢٩٥٥٨'>كُلُّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ مَجْمُوعَيْنِ</مقطع>
  <مقطع هوية='٧٣٥٧٤'>مِثْلَ الَّذِي يَكُونُ مِنْ ضَرْبِ الضِّلَعِ الأَطْوَلِ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٦٥١٠٢'><قياس مفتاح="برهان">وَبُرْهَانُ ذٰلِكَ</قياس> أَنَّا نَجْعَلُ سَطْحًا مُرَبَّعًا مُتَسَاوِيَ الأَضْلَاعِ وَالزَّوَايَا عَلَيْهِ <سطح>اٮ <ج/> د</سطح></مقطع>
  <مقطع هوية='٩٩٨٧٣'>ثُمَّ نَقْطَعُ <خط>ا<ج/></خط> نِصْفَيْنِ
  عَلَى نُقْطَةِ <نقطة><ه/></نقطة></مقطع>
  <مقطع هوية='٥٧٠٢٦'>ثُمَّ نُخْرِجُهُ إِلَى <نقطة>ز</نقطة></مقطع>
  <مقطع هوية='٠١٥٤١'>ثُمَّ نَقْطَعُ ضِلَعَ [ا ٮ] نِصْفَيْنِ عَلَى نُقْطَةِ [ط]</مقطع>
  <مقطع هوية='٦٧٢٥٠'>وَنُخْرِجُهُ إِلَى نُقْطَةِ [ح]</مقطع>
  <!-- p058 -->
  <مقطع هوية='٣٥١٩٩'><صفحة رقم="٥٨"/> فَصَارَ سَطْحُ <سطح>اٮ <ج/> د</سطح> أَرْبَعَةَ سُطُوحٍ مُتَسَاوِيَةِ الأَضْلَاعِ وَالزَّوَايَا وَالمِسَاحَةِ</مقطع>
  <مقطع هوية='٠٩٢٠٩'>وَهِيَ سَطْحُ <سطح>ا <ك/></سطح>
  وَسَطْحُ <سطح><ج/> <ك/></سطح>
  وَسَطْحُ <سطح>ٮ <ك/></سطح>
  وَسَطْحُ <سطح>د <ك/></سطح></مقطع>
  <مقطع هوية='٢٦٧٦٣'>ثُمَّ نُخْرِجُ مِن نُقْطَةِ <نقطة>ه</نقطة>
  إِلَى نُقْطَةِ <نقطة>ط</نقطة> خَطًّا
  يَقْطَعُ سَطْحَ <سطح>ا <ك/></سطح> نِصْفَيْنِ</مقطع>
  <مقطع هوية='٣٧٤٣١'>فَحَدَثَ مِنَ السَّطْحِ مُثَلَّثَانِ
  وَهُمَا مُثَلَّثَا <مثلث>ا ط <ه/></مثلث>
  وَ<مثلث><ه/> <ك/> ط</مثلث></مقطع>
  <مقطع هوية='٤٢٧٢٠'>فَقَدْ تَبَيَّنَ لَنَا أَنَّ <خط>اط</خط> نِصْفُ <خط>اٮ</خط></مقطع>
  <مقطع هوية='٦٢٤٩٤'>وَ <خط>ا<ه/></خط> مِثْلُهُ وَهُوَ نِصْفُ <خط>ا<ج/></خط></مقطع>
  <مقطع هوية='٢١٢٥٣'>وَوَتْرُهُمَا خَطُّ <خط>ط <ه/></خط> عَلَى زَاوِيَةٍ قَائِمَةٍ</مقطع>
  <مقطع هوية='٠٩٣٥٢'>وَكَذٰلِكَ نُخْرِجُ خُطُوطًا
  مِن <نقطة>ط</نقطة> إِلَى <نقطة>ز</نقطة>
  وَمِن <نقطة>ز</نقطة> إِلَى <نقطة>ح</نقطة>
  وَمِن <نقطة>ح</نقطة> إِلَى <نقطة><ه/></نقطة></مقطع>
  <مقطع هوية='٩١٧٦٩'>فَيَحْدُثُ مِنْ جَمِيعِ الْمُرَبَّعَةِ ثَمَانِي مُثَلَّثَاتٍ مُتَسَاوِيَاتٍ</مقطع>
  <مقطع هوية='٨٧٥٠٥'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ أَرْبَعَةً مِنْهَا نِصْفُ السَّطْحِ الْأَعْظَمِ الَّذِي هُوَ [ا د]</مقطع>
  <مقطع هوية='١٣٩٢٩'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ ضِلَعَ [ا ط] فِي نَفْسِهِ تَكْسِيرُ مُثَلَّثَيْنِ</مقطع>
  <مقطع هوية='١١٠٤٤'>وَ [ا ه] تَكْسِيرُ مُثَلَّثَيْنِ مِثْلَهُمَا</مقطع>
  <مقطع هوية='٩٤٧٩٤'>فَيَكُونُ جَمِيعُ ذٰلِكَ تَكْسِيرَ أَرْبَعَ مُثَلَّثَاتٍ</مقطع>
  <مقطع هوية='٠٣٦٠٨'>وَضِلَعُ [ه ط] فِي نَفْسِهِ أَيْضًا تَكْسِيرُ أَرْبَعِ مُثَلَّثَاتٍ أُخَرَ</مقطع>
  <مقطع هوية='١٢٣٩٠'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ [ا ط] فِي نَفْسِهِ وَ[ا ه] فِي نَفْسِهِ مَجْمُوعَيْنِ</مقطع>
  <مقطع هوية='٠٨٥٦١'>مِثْلَ الَّذِي يَكُونُ مِنْ ضَرْبِ [ط ه] فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٠٨٧٤٤'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ وَهَذِهِ صُورَتُهُ</مقطع>
  <صورة هوية='٧٤٦٥٧' عرض="0.7" ملف="../figures/fig058"/>
  <!-- p059 -->
  <قسم هوية='٣٢٢٧٣'>
    <عنوان>[الْمُرَبَّعاتُ]</عنوان>
  </قسم>
  <مقطع هوية='١١٨١٤'><صفحة رقم="٥٩"/> أَعْلَمُ أَنْ الْمُرَبَّعَاتِ خَمْسَةٌ أَجْنَاسٌ</مقطع>
  <مقطع هوية='٨٠٤٨٩'><شدة>فَمِنْهَا</شدة> مُسْتَوِيَةُ الْأَضْلَاعِ قَائِمَةُ الزَّوَايَا</مقطع>
  <مقطع هوية='١٣٠٩٩'><شدة>وَالثَّانِيَةُ</شدة> قَائِمَةُ الزَّوَايَا مُخْتَلِفَةُ الْأَضْلَاعِ طُولُهَا أَكْثَرُ مِنْ عَرْضِهَا</مقطع>
  <مقطع هوية='٦٥٨٤٩'><شدة>وَالثَّالِثَةُ</شدة> تُسَمَّى الْمُعَيَّنَةَ وَهِيَ الَّتِي اسْتَوَتْ أَضْلَاعُهَا وَاخْتَلَفَتْ زَوَايَاهَا</مقطع>
  <مقطع هوية='١٩١٤٤'><شدة>وَالرَّابِعَةُ</شدة> الْمُشَبَّهَةُ بِالْمُعَيَّنَةِ وَهِيَ الَّتِي طُولُهَا وَعَرْضُهَا مُخْتَلِفَانِ وَزَوَايَاهَا مُخْتَلِفَةٌ</مقطع>
  <مقطع هوية='٦٩٦٢٨'>غَيْرَ أَنَّ الطُّولَيْنِ مُتَسَاوِيَانِ وَالْعَرْضَيْنِ مُتَسَاوِيَيْنِ أَيْضًا</مقطع>
  <مقطع هوية='٠٦١٢٦'><شدة>وَالْخَامِسَةُ</شدة> الْمُخْتَلِفَةُ الْأَضْلَاعِ وَالزَّوَايَا</مقطع>

  <رأس/>
  <مقطع هوية='٠٧١٩٠'>فَمَا كَانَ مِنَ <شدة>الْمُرَبَّعَاتِ مُسْتَوِيَةَ</شدة> الْأَضْلَاعِ قَائِمَةَ الزَّوَايَا</مقطع>
  <مقطع هوية='٣٦٥٢٦'>أَوْ مُخْتَلِفَةَ الْأَضْلَاعِ قَائِمَةَ الزَّوَايَا</مقطع>
  <مقطع هوية='٧٣٠٧٣'>فَإِنَّ تَكْسِيرَهَا أَنْ تَضْرِبَ الطُّولَ فِي الْعَرْضِ فَمَا بَلَغَ فَهُوَ التَّكْسِيرُ</مقطع>

  <مقطع هوية='٩٤٦٤١'>وَمِثَالُ ذٰلِكَ أَرْضٌ مُرَبَّعَةٌ مِنْ كُلِّ جَانِبٍ خَمْسَةُ أَذْرُعٍ</مقطع>
  <مقطع هوية='٢٥٩٦٨'>تَكْسِيرُهَا خَمْسَةٌ وَعِشْرُونَ ذِرَاعًا وَهَذِهِ صُورَتُهَا</مقطع>

  <صورة هوية='٥٧٧٤٧' عرض="0.7" ملف="../figures/fig059a"/>

  <رأس/>
  <مقطع هوية='٤٢٤٢٤'>وَالثَّانِيَةُ أَرْضٌ مُرَبَّعَةٌ طُولُهَا ثَمَانِيَةُ أَذْرُعٍ ثَمَانِيَةُ أَذْرُعٍ وَالْعَرْضَانِ سِتَّةٌ سِتَّةٌ</مقطع>
  <مقطع هوية='٤٨٢٢٣'>فَتَكْسِيرُهَا أَنْ تَضْرِبَ سِتَّةً فِي ثَمَانِيَةٍ فَيَكُونُ ثَمَانِيَةً وَأَرْبَعِينَ ذِرَاعًا</مقطع>
  <مقطع هوية='٣٤٤٧٠'>وَذٰلِكَ تَكْسِيرُهَا وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٧٨٨١١' عرض="0.6" ملف="../figures/fig059b"/>

  <رأس/>
  <مقطع هوية='٣٧١٥٤'>وَأَمَّا <شدة>الْمُعَيَّنَةُ الْمُسْتَوِيَةُ</شدة> الْأَضْلَاعِ الَّتِي كُلُّ جَانِبٍ مِنْهَا <صفحة رقم="٦٠"/> خَمْسَةُ أَذْرُعٍ</مقطع>
  <!-- p060 -->
  <مقطع هوية='٤٣٣٩٥'>وَأَحَدُ قُطْرَيْهَا ثَمانِيَةٌ وَالْآخَرُ سِتَّةُ أَذْرُعٍ</مقطع>

  <مقطع هوية='٧٣٥٢٧'>فَاعْلَمْ أَنَّ تَكْسِيرَهَا أَنْ تَعْرِفَ الْقُطْرَيْنِ أَوْ أَحَدَهُمَا</مقطع>
  <مقطع هوية='٥٤٩٥٢'>فَإِنْ عَرَفْتَ الْقُطْرَيْنِ جَمِيعًا</مقطع>
  <مقطع هوية='٢٦٩٧١'>فَإِنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ أَحَدِهُمَا فِي نِصْفِ الْآخَرِ هُوَ تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٥٠٢٩٦'>وَذٰلِكَ أَنْ تَضْرِبَ ثَمَانِيَةَ فِي ثَلاثَةٍ أَوْ أَرْبَعَةَ فِي سِتَّةٍ</مقطع>
  <مقطع هوية='٧٥٢٤١'>فَيَكُونُ أَرْبَعَةً وَعِشْرِينَ ذِرَاعًا وَهُوَ تَكْسِيرُهَا</مقطع>

  <مقطع هوية='١٨٦١٩'>فَإِنْ عَرَفْتَ قُطْرًا وَاحِدًا فَقَدْ عَلِمْتَ أَنَّهَا مُثَلَّثَتانِ</مقطع>
  <مقطع هوية='٩٣٢٦٦'>كُلُّ وَاحِدَةٍ مِنْهُمَا ضِلَعاهَا خَمْسَةُ أَذْرُعٍ</مقطع>
  <مقطع هوية='٣١٦٧٢'>وَالضِّلَعُ الثَّالِثُ هُوَ قُطْرُهَا</مقطع>
  <مقطع هوية='٣١٩٢١'>فَاحْسُبْهَا عَلَى حِسَابِ الْمُثَلَّثَاتِ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٠٨٨٤٢' عرض="0.6" ملف="../figures/fig060a"/>

  <مقطع هوية='٢٢٤١١'>وَأَمَّا <شدة>المُشَبَّهَةُ بِالْمُعَيَّنَةِ</شدة> فَعَلَى مِثالِ الْمُعَيَّنَةِ</مقطع>

  <مقطع هوية='٦٥٥٥٩'>وَأَمَّا <شدة>سَائِرُ الْمُرَبَّعَاتِ</شدة></مقطع>
  <مقطع هوية='٦٣٨٧١'>فَإِنَّمَا يُعْرَفُ تَكْسِيرُهَا مِن قَبْلِ الْقُطْرِ فَيَخْرُجُ إِلَى حِسَابِ الْمُثَلَّثَاتِ</مقطع>
  <مقطع هوية='٠٧٠٨٤'>فَاعْلَمْ ذٰلِكَ وَهَذِهِ صُورَةُ الْمُشَبَّهَةِ بِالْمُعَيَّنَةِ</مقطع>
  <صورة هوية='٤١٨٨٧' عرض="1.0" ملف="../figures/fig060b"/>

  <قسم هوية='٣٢٢٧'>
    <عنوان>[الْمُثَلَّثاتُ]</عنوان>
  </قسم>
  <مقطع هوية='١٠٤٥٥'>وَأَمَّا الْمُثَلَّثَاتُ فَهِيَ ثَلاثَةُ أَجْنَاسٍ الْقَائِمَةُ وَالْحَادَّةُ وَالْمُنْفَرِجَةُ</مقطع>

  <مقطع هوية='٦٠٤٧٥'>فَأَمَّا <شدة>الْقَائِمَةُ</شدة>
  إِذَا ضَرَبْتَ ضِلَعَيْهَا الْأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٧٩٩٠٧'>كُلَّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ وَجَمَعْتَهُمَا</مقطع>
  <مقطع هوية='٤٨٢٥٦'>كَانَ ذٰلِكَ مِثَالَ ضِلَعِهَا الْأَطْوَلِ مَضْرُوبًا فِي نَفْسِهِ</مقطع>

  <مقطع هوية='٦٧٣٩٨'>وَأَمَّا <شدة>الْحَادَّةُ</شدة> فَكُلُّ مُثَلَّثَةٍ
  إِذَا ضَرَبْتَ ضِلَعَيْهَا الْأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٥٩٠٣٩'>كُلَّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ ثُمَّ جَمَعْتَهُمَا</مقطع>
  <مقطع هوية='٥٧٩٠٥'>كَانَا أَكْثَرَ مِنَ الضِّلَعِ الْأَطْوَلِ مَضْرُوبًا فِي نَفْسِهِ</مقطع>
  <!-- p061 -->
  <مقطع هوية='٤١٢١٢'>وَأَمَّا <شدة>الْمُنْفَرِجَةُ</شدة> فَهِيَ <صفحة رقم="٦١"/> كُلُّ مُثَلَّثَةٍ إِذَا ضَرَبْتَ ضِلَعَيْهَا الأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٥٤٨٨٥'>كُلَّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ وَجَمَعْتَهُمَا</مقطع>
  <مقطع هوية='٠٨٢٥٦'>كَانَا أَقَلَّ مِنَ الضِّلَعِ الأَطْوَلِ مَضْرُوبًا فِي نَفْسِهِ</مقطع>

  <مقطع هوية='٦٦٥٣٥'>فَأَمَّا <شدة>القَائِمَةُ الزَّوَايَا</شدة>
  فَهِيَ الَّتِي لَهَا عَمُودَانِ وَقُطْرٌ</مقطع>
  <مقطع هوية='٠٨٥٠١'> وَهِيَ نِصْفُ مُرَبَّعَةٍ تَكْسِيرُهَا أَنْ تَضْرِبَ أَحَدَ الضِّلَعَيْنِ الْمُحِيطَيْنِ بِالزَّاوِيَةِ القَائِمَةِ فِي نِصْفِ الآخَرِ</مقطع>
  <مقطع هوية='٩٢٨٨٥'>فَمَا بَلَغَ ذٰلِكَ فَهُوَ تَكْسِيرُهَا</مقطع>

  <مقطع هوية='٢٦٥١١'>وَمِثَالُ ذٰلِكَ مُثَلَّثَةٌ قَائِمَةُ الزَّاوِيَةِ</مقطع>
  <مقطع هوية='٠٥٦٠٤'>ضِلَعٌ مِنْهَا سِتَّةُ أَذْرُعٍ وَضِلَعٌ مِنْهَا ثَمَانِيَةُ أَذْرُعٍ وَالْقُطْرُ عَشَرَةٌ</مقطع>
  <مقطع هوية='٢١٧٣٩'>فَحِسَابُ ذٰلِكَ أَنْ تَضْرِبَ سِتَّةً فِي أَرْبَعَةٍ</مقطع>
  <مقطع هوية='٣٤٧٤٦'>فَيَكُونُ أَرْبَعَةً وَعِشْرِينَ ذِرَاعًا وَهُوَ تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٦٤٢٢٣'>وَإِنْ أَحْبَبْتَ أَنْ تَحْسُبَهَا بِالْعَمُودِ</مقطع>
  <مقطع هوية='٥٠٣٣٦'>فَإِنَّ عَمُودَهَا لَا يَقَعُ إِلَّا عَلَى الضِّلَعِ الْأَطْوَلِ</مقطع>
  <مقطع هوية='٧٩٧٠٦'>لِأَنَّ الضِّلَعَيْنِ الْقَصِيرَيْنِ عَمُودَانِ</مقطع>
  <مقطع هوية='٠٥٧١٦'>فَإِنْ أَرَدْتَ ذٰلِكَ فَاضْرِبْ عَمُودَهَا فِي نِصْفِ الْقَاعِدَةِ</مقطع>
  <مقطع هوية='١١٨٠٩'>فَمَا كَانَ فَهُوَ تَكْسِيرُهَا وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='١٩٨٠٢' عرض="0.4" ملف="../figures/fig061"/>

  <مقطع هوية='٢٢٣٢٠'>وَأَمَّا الْجِنْسُ الثَّانِي <شدة>فَالْمُثَلَّثَةُ الْمُتَسَاوِيَةُ الْأَضْلَاعِ حَادَّةُ الزَّوَايَا</شدة></مقطع>

  <مقطع هوية='١٠١٣٥'>مِنْ كُلِّ جَانِبٍ عَشَرَةُ أَذْرُعٍ</مقطع>
  <مقطع هوية='١٥٤٥٨'>فَإِنَّ تَكْسِيرَهَا يُعْرَفُ مِنْ قَبْلِ عَمُودِهَا وَمَسْقَطِ حَجَرِهَا</مقطع>
  <مقطع هوية='١٧٥٩٨'>وَاعْلَمْ أَنَّ كُلَّ ضِلْعَيْنِ مُسْتَوِيَيْنِ مِنْ مُثَلَّثَةٍ</مقطع>
  <مقطع هوية='١٢٦٥٠'>يَخْرُجُ بَيْنَهُمَا عَمُودٌ عَلَى قَاعِدَةٍ</مقطع>
  <مقطع هوية='٥٦٣٢٣'>فَإِنَّ مَسْقَطَ حَجَرِ الْعَمُودِ يَقَعُ عَلَى زَاوِيَةٍ قَائِمَةٍ</مقطع>
  <مقطع هوية='٣٥٦٠٤'>وَيَقَعُ عَلَى نِصْفِ الْقَاعِدَةِ سَوَاءً إِذَا اسْتَوَى الضِّلْعَانِ</مقطع>
  <مقطع هوية='١٢٧٥٣'>فَإِنِ اخْتَلَفَا خَالَفَ مَسْقَطُ الْحَجَرِ عَنْ نِصْفِ الْقَاعِدَةِ</مقطع>
  <مقطع هوية='٥٠٤٤٠'>وَلَكِنْ قَدْ عَلِمْنَا أَنَّ مَسْقَطَ حَجَرِ هَذِهِ الْمُثَلَّثَةِ عَلَى أَيِّ أَضْلَاعِهَا جَعَلْتَهُ</مقطع>
  <مقطع هوية='٧١٠٦٢'>لَا يَقَعُ إِلَّا عَلَى نَصْفِهِ فَذٰلِكَ خَمْسَةُ أَذْرُعٍ</مقطع>

  <مقطع هوية='٨٣٧٠٤'>فَمَعْرِفَةُ الْعَمُودِ أَنْ تَضْرِبَ الْخَمْسَةَ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٢٣٧٠٧'>وَتَضْرِبَ أَحَدَ الضِّلَعَيْنِ فِي مِثْلِه</مقطع>
  <مقطع هوية='١٥٢٥٥'>وَهُوَ عَشَرَةٌ فَيَكُونُ مِائَةً فَتَنْقُصُ مِنْهَا مَبْلَغَ الْخَمْسَةِ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٦٢٤٨٠'>وَهُوَ خَمْسَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٠٧٠٨٩'>فَيَبْقَى خَمْسَةٌ وَسَبْعُونَ فَخُذْ جَذْرَ ذٰلِكَ فَهُوَ الْعَمُودُ</مقطع>
  <مقطع هوية='٩٦٢١٠'>وَقَدْ صَارَ ضِلَعًا عَلَى مُثَلَّثَتَيْنِ قَائِمَتَيْنِ</مقطع>
  <مقطع هوية='٣٩١٠٥'>فَإِنْ أَرَدْتَ التَّكْسِيرَ فَاضْرِبْ جَذْرَ الْخَمْسَةِ وَالسَّبْعِينَ فِي نِصْفِ الْقَاعِدَةِ وَهُوَ خَمْسَةٌ</مقطع>
  <!-- p062 -->
  <مقطع هوية='٠٩٤٦٤'>وَذٰلِكَ <صفحة رقم="٦٢"/> أَنْ تَضْرِبَ الْخَمْسَةَ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٠٦٧٤٢'>حَتَّى يَكُونَ جَذْرُ خَمْسَةٍ وَسَبْعُونَ فِي جَذْرِ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٤٧٥٥٨'>فَاضْرِبْ خَمْسَةً وَسَبْعِينَ فِي خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٩٢٠٧'>فَيَكُونُ أَلْفًا وَثَمَانِي مِائَةٍ وَخَمْسَةً وَسَبْعِينَ</مقطع>
  <مقطع هوية='٦٠٣٦٨'>فَخُذْ جَذْرَ ذٰلِكَ فَهُوَ تَكْسِيرُهَا وَهُوَ ثَلاَثَةٌ وَأَرْبَعُونَ وَشَيْءٌ قَلِيلٌ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٤٨٤٢٨' عرض="0.5" ملف="../figures/fig062"/>

  <مقطع هوية='٨٤٣٦٦'>وَقَدْ تَكُونُ مِنْ هَذِهِ الْزَوَايَا الْحَادَّةِ مُخْتَلِفَةَ الْأَضْلَاعِ</مقطع>
  <مقطع هوية='٥٥٥٣٨'>فَاعْلَمْ أَنَّ تَكْسِيرَهَا يُعْلَمُ مِنْ قَبْلِ مَسْقَطِ حَجَرِهَا وَعَمُودِهَا</مقطع>
  <مقطع هوية='٨٣٣١٦'>وَهِيَ أَنْ تَكُونَ مُثَلَّثَةً مِنْ جَانِبِ خَمْسَةِ عَشَرَ ذِرَاعًا</مقطع>
  <مقطع هوية='٣١٨٠٨'>وَمِنْ جَانِبِ أَرْبَعَةِ عَشَرَ ذِرَاعًا</مقطع>
  <مقطع هوية='٢١٥٥٦'>وَمِنْ جَانِبِ ثَلاثَةِ عَشَرَ ذِرَاعًا</مقطع>
  <مقطع هوية='٧٥٣٩٩'>فَإِذَا أَرَدْتَ عِلْمَ مَسْقَطِ حَجَرِهَا فَاجْعَلِ القَاعِدَةَ أَيِ الجَوَانِبِ شِئْتَ</مقطع>
  <مقطع هوية='١١٨٨٧'>فَجَعَلْنَاهَا أَرْبَعَةَ عَشَرَ وَهُوَ مَسْقَطُ الحَجَرِ</مقطع>
  <مقطع هوية='٦٥٨٤٦'>فَسَقَطَ حَجَرُهَا يَقَعُ مِنْهَا عَلَى شَيْءٍ مِمَّا يَلِي</مقطع>
  <مقطع هوية='٥٥٨٨٥'>أَيِ الضِّلعَيْنِ شِئْتَ فَجَعَلْنَا الشَّيْءَ مِمَّا يَلِي الثَّلاَثَةَ عَشَرَ</مقطع>
  <مقطع هوية='٩٣٨٠٦'>فَضَرَبْنَاهُ فِي مِثْلِهِ فَصَارَ مَالًا</مقطع>
  <مقطع هوية='٢٦٨٠٤'>وَنَقَصْنَاهُ مِنْ ثَلاَثَةَ عَشَرَ فِي مِثْلِهَا وَهُوَ مِائَةٌ وَتِسْعَةٌ وَسِتُّونَ</مقطع>
  <مقطع هوية='٢٤٤٧٣'>فَصَارَ ذٰلِكَ مِائَةً وَتِسْعَةً وَسِتِّينَ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٤٣٢٩٨'>فَعَلِمْنَا أَنَّ جَذْرَهَا هُوَ الْعَمُودُ وَقَدْ بَقِيَ لَنَا مِنَ القَاعِدَةِ أَرْبَعَةَ عَشَرَ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='١١٢٩٥'>فَضَرَبْنَاهُ فِي مِثْلِهِ فَصَارَ مِائَةً وَسِتَّةً وَتِسْعِينَ وَمَالًا إِلَّا ثَمَانِيَةً وَعِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٥٤٣٢'>فَنَقَصْنَاهُ مِنَ الْخَمْسَةَ عَشَرَ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٠٥٢٦٦'>فَبَقِيَ تِسْعَةً وَعِشْرُونَ دِرْهَمًا وَثَمَانِيَةً وَعِشْرُونَ شَيْئًا إِلَّا مَالًا</مقطع>
  <مقطع هوية='٥٠٢٣٥'>وَجَذْرُهَا هُوَ الْعَمُودُ فَلَمَّا صَارَ جَذْرُهَا هَذَا الْعَمُودُ</مقطع>
  <مقطع هوية='٢٦٨٥٣'>وَجَذْرُ مِائَةٍ وَتِسْعَةٍ وَسِتِّيْنَ إِلَّا مَالًا هُوَ الْعَمُودُ أَيْضًا</مقطع>
  <مقطع هوية='٢٦٤٨٤'>عَلِمْنَا أَنَّهُمَا مُتَسَاوِيَانِ</مقطع>
  <!-- p063 -->
  <مقطع هوية='٧١٥٣٩'><مقابلة>فَقَابِلْ بِهِمَا</مقابلة> <صفحة رقم="٦٣"/> وَهُوَ أَنْ تُلْقِي مَالًا بِمَالٍ لِأنَّ الْمَالَيْنِ نَاقِصَانِ</مقطع>
  <مقطع هوية='١٩٢٤٩'>فَيَبْقَى تِسْعَةٌ وَعِشْرُونَ وَثَمَانِيَةٌ وَعِشْرُونَ شَيْئًا تَعْدِلُ مِائَةً وَتِسْعَةً وَسِتِّينَ</مقطع>
  <مقطع هوية='٨٦٤٧٥'>فَأَلْقِ تِسْعَةً وَعِشْرِينَ مِنْ مِائَةٍ وَتِسْعَةٍ وَسِتِّينَ</مقطع>
  <مقطع هوية='٢٨٥١٦'>فَيَبْقَى مِائَةٌ وَأَرْبَعُونَ تَعْدِلُ ثَمَانِيَةً وَعِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٦٩٩٥٨'>فَالْشَّيْءُ الْوَاحِدُ خَمْسَةٌ وَهُوَ مَسْقَطُ الْحَجَرِ مِمَّا يَلِي الثَّلَاثَةَ عَشَرَ</مقطع>
  <مقطع هوية='٤٨٥٥٤'>وَتَمَامُ الْقَاعِدَةِ مَا عَلَى الضِّلْعِ الْآخَرِ فَهُوَ تِسْعَةٌ</مقطع>
  <مقطع هوية='٧٤٧٢٠'>فَإِذَا أَرَدْتَ أَنْ تَعْرِفَ الْعَمُودَ</مقطع>
  <مقطع هوية='٩٣٥٩٦'>فَاضْرِبْ هَذِهِ الْخَمْسَةَ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٣٩٩٢٥'>وَانْقُصْهَا مِنَ الضِّلَعِ الَّذِي يَلِيهَا مَضْرُوبًا فِي مَثْلِهِ وَهُوَ ثَلاثَةَ عَشَرَ</مقطع>
  <مقطع هوية='٥٠٤٠٥'>فَيَبْقَى مِائَةً وَأَرْبَعَةً وَأَرْبَعُونَ</مقطع>
  <مقطع هوية='٧٥٣٦٩'>فَجَذْرُ ذٰلِكَ هُوَ الْعُمُودُ وَهُوَ اثْنَا عَشَرَ</مقطع>
  <مقطع هوية='٢٩٢٩٥'>وَالْعُمُودُ أَبَدًا يَقَعُ عَلَى الْقَاعِدَةِ عَلَى زَاوِيَتَيْنِ قَائِمَتَيْنِ</مقطع>
  <مقطع هوية='٣٢٣٣٩'>وَلِذٰلِكَ سُمِّيَ عُمُودًا لِأَنَّهُ مُسْتَوٍ</مقطع>
  <مقطع هوية='٤٦٦٣٧'>فَاضْرِبْ الْعُمُودَ فِي نِصْفِ الْقَاعِدَةِ وَهُوَ سَبْعَةٌ</مقطع>
  <مقطع هوية='٢٢٠٦٤'>فَيَكُونُ أَرْبَعَةً وَثَمَانِينَ وَذٰلِكَ تَكْسِيرُهَا وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٨٩١٧٤' عرض="0.5" ملف="../figures/fig063"/>

  <مقطع هوية='١٣٥٠٥'>وَالْجِنْسُ الثَّالِثُ <شدة>الْمُنْفَرِجَةُ</شدة></مقطع>
  <مقطع هوية='٦٥٥٤٩'>وَهِيَ الَّتِي لَهَا زَاوِيَةٌ مُنفَرِجَةٌ وَهِيَ مُثَلَّثَةٌ مِنْ كُلِّ جَانِبٍ عَدَدٌ مُخْتَلِفٌ</مقطع>
  <مقطع هوية='١٨٤١٥'>وَهِيَ مِنْ جَانِبٍ سِتَّةٌ وَمِنْ جَانِبٍ خَمْسَةٌ وَمِنْ جَانِبٍ تِسْعَةٌ</مقطع>
  <مقطع هوية='٩٨٨٩٥'>فَمَعْرِفَةُ تَكْسِيرِ هَذِهِ مِنْ قَبْلِ عَمُودِهَا وَمَسْقَطِ حَجَرِهَا</مقطع>
  <مقطع هوية='٨١٣٧٨'>وَلَا يَقَعُ مَسْقَطُ هَذِهِ الْمُثَلَّثَةِ فِي جَوْفِهَا إِلَّا عَلَى الضِّلَعِ الأَطْوَلِ فَاجْعَلْهُ قَاعِدَةً</مقطع>
  <مقطع هوية='٤٩٧٨٢'>وَلَوْ جَعَلْتَ أَحَدَ الضِّلَعينِ الأَقْصَرَيْنِ قَاعِدَةً لَوَقَعَ مَسْقَطُ حَجَرِهَا خَارِجَهَا</مقطع>
  <مقطع هوية='١١٤٠٤'>وَعِلْمُ مَسْقَطِ حَجَرِهَا وَعَمُودِهَا عَلَى مِثَالِ مَا عَمَلْتُ لَكَ فِي الْحَادَّةِ</مقطع>
  <مقطع هوية='٣٦٧٦٠'>وَعَلَى ذٰلِكَ الْقِيَاسِ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٢٧٣٠٥' عرض="0.8" ملف="../figures/fig064a"/>

  <قسم هوية='٤١٥١٠'>
    <عنوان>[الْمُدَوَّراتُ]</عنوان>
  </قسم>
  <مقطع هوية='٣٤٥٨١'>وَأَمَّا <شدة>لِلْمُدَوَّرَاتِ</شدة> الَّتِي فَرَغْنَا مِنْ صِفَتِهَا وَتَكْسِيرِهَا فِي <صفحة رقم="٦٤"/> صَدْرِ الْكِتَابِ</مقطع>
  <!-- p064 -->
  <مقطع هوية='١٤٣٢٥'>فِيهَا مُدَوَّرَةٌ قُطرُهَا سَبْعَةُ أَذْرُعٍ وَيُحِيطُ بِهَا اثْنَانِ وَعِشْرُونَ أَذْرُعًا</مقطع>
  <مقطع هوية='٧٦٥٧٢'>فَإِنَّ تَكْسِيرَهَا أَنْ تَضْرِبَ نِصْفَ الْقُطْرِ وَهُوَ ثَلاثَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٢٠٢٠٣'>فِي نِصْفِ الدَّوْرِ الَّذِي يُحِيطُ بِهَا وَهُوَ أَحَدَ عَشَرَ</مقطع>
  <مقطع هوية='٣٦٥٦٥'>فَيَكُونُ ثَمَانِيَةً وَثَلاثِينَ وَنِصْفًا وَهُوَ تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٩٢٨٩٨'>فَإِنْ أَحْبَبْتَ فَاضْرِبْ الْقُطْرَ وَهُوَ سَبْعَةٌ فِي مِثْلِهِ فَيَكُونُ تِسْعَةً وَأَرْبَعِينَ</مقطع>
  <مقطع هوية='٩٠١٥٩'>فَانْقُصْ مِنْهَا سُبُعَهَا وَنِصْفَ سُبُعَهَا وَهُوَ عَشَرَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٤٢٦٠٨'>فَيَبْقَى ثَمَانِيَةٌ وَثَلاثُونَ وَنِصْفٌ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٩٨٤٥٠' عرض="0.5" ملف="../figures/fig064b"/>

  <قسم هوية='٢٠٨٧٤'>
    <عنوان>[الْمَخْروطاتُ]</عنوان>
  </قسم>
  <مقطع هوية='٢٩٣٤٦'>فَإِنْ قَالَ عَمُودٌ مَخْرُوطٌ أَسْفَلُهُ أَرْبَعَةُ أَذْرُعٍ فِي أَرْبَعَةِ أَذْرُعٍ</مقطع>
  <مقطع هوية='٣٩١٧٥'>وَارْتِفَاعُهُ عَشَرَةُ أَذْرُعٍ وَرَأْسُهُ ذِرَاعَانِ فِي ذِرَاعَيْنِ</مقطع>
  <مقطع هوية='١٤١٣٤'>وَقَدْ كُنَّا بَيَّنَّا أَنَّ كُلَّ مَخْرُوطٍ مُحَدَّدِ الرَّأْسِ</مقطع>
  <مقطع هوية='١٥١٥٣'>فَإِنَّ ثُلُثَ تَكْسِيرِ أَسْفَلِهِ مَضْرُوبًا فِي عَمُودِهِ هُوَ تَكْسِيرُهُ</مقطع>
  <مقطع هوية='٧٩٩٣٨'>فَلَمَّا صَارَ هَذَا غَيْرَ مُحَدَّدٍ أَرَدْنَا أَنْ نَعْلَمَ</مقطع>
  <مقطع هوية='١٨٧٢٤'>كَمْ يَرْتَفِعُ حَتَّى يَفْنَى رَأْسُهُ فَيَكُونَ لَا رَأْسَ لَهُ</مقطع>
  <مقطع هوية='٧٢١٠٥'>فَعَلِمْنَا أَنَّ هَذِهِ الْعَشَرَةَ</مقطع>
  <مقطع هوية='٤٢٣١٠'>مِنَ الطُّولِ كُلِّهَا كَقَدْرِ الْإِثْنَيْنِ مِنَ الْأَرْبَعَةِ</مقطع>
  <مقطع هوية='٥٨٥٨٩'>فَالْإِثْنَانِ نِصْفُ الْأَرْبَعَةِ فَإِذَا كَانَ ذٰلِكَ كَذٰلِكَ فَالْعَشَرَةُ نِصْفُ الطُّولِ</مقطع>
  <!-- p065 -->
  <مقطع هوية='٧٥٨٢٤'><صفحة رقم="٦٥"/>وَالطُّولُ كُلُّهُ عِشْرُونَ ذِرَاعًا</مقطع>
  <مقطع هوية='٦٤٥٣١'>فَلَمَّا عَرَفْنَا الطُّولَ أَخَذْنَا ثُلُثَ تَكْسِيرِ الْأَسْفَلِ وَهُوَ خَمْسَةٌ وَثُلُثٌ</مقطع>
  <مقطع هوية='٤٠٩٥٦'>فَضَرَبْنَاهُ فِي الطُّولِ وَهُوَ عِشْرُونَ ذِرَاعًا</مقطع>
  <مقطع هوية='٥٤١٦٢'>فَبَلَغَ ذٰلِكَ مِائَةً وَسِتَّةَ أَذْرُعٍ وَثُلُثَ ذِرَاعٍ</مقطع>
  <مقطع هوية='٤٤٤٧٨'>فَأَرَدْنَا أَنْ نُلْقِيَ مِنْهُ مَا زِدْنَا عَلَيْهِ حَتَّى انْخَرَطَ</مقطع>
  <مقطع هوية='٣٧٥٣٤'>وَهُوَ وَاحِدٌ وَثُلُثٌ الَّذِي هُوَ ثُلُثَ تَكْسِيرِ اِثْنَيْنِ فِي اِثْنَيْنِ فِي عَشَرَةٍ</مقطع>
  <مقطع هوية='٦٦٧٦٣'>وَهُوَ ثَلَاثَةَ عَشَرَ وَثُلُثٌ</مقطع>
  <مقطع هوية='٩٤٩٨٦'>وَذٰلِكَ تَكْسِيرُ مَا زِدْنَا عَلَيْهِ حَتَّى انْخَرَطَ</مقطع>
  <مقطع هوية='٩٨٠٥٦'>فَإِذَا رَفَعْنَا ذٰلِكَ مِن مِائَةٍ وَسِتَّةِ أَذْرُعٍ وَثُلُثِ ذِرَاعٍ</مقطع>
  <مقطع هوية='٤٤٠٦٦'>بَقِيَ ثَلاَثَةٌ وَتَسْعُونَ ذِرَاعًا وَثُلُثٌ</مقطع>
  <مقطع هوية='٢٩٣٠٠'>وَذٰلِكَ تَكْسِيرُ الْعَمُودِ الْمَخْروطِ وَهَذِهِ صُورَتُهُ</مقطع>
  <صورة هوية='٣٨٣٩١' عرض="0.3" ملف="../figures/fig065"/>

  <رأس/>
  <مقطع هوية='٢٩٢٦٨'>وَإِن كَانَ <شدة>الْمَخْرُوطُ مُدَوَّرًا</شدة></مقطع>
  <مقطع هوية='٨٨٣٩٥'>فَأَلْقِ مِن ضَرْبِ قُطْرِهِ فِي نَفْسِهِ سُبُعَهُ وَنِصْفَ سُبُعِهِ</مقطع>
  <مقطع هوية='٩٧٧٣٤'>فَمَا بَقِيَ فَهُوَ تَكْسِيرُهُ</مقطع>

  <رأس/>
  <مقطع هوية='٨١٦٧٠'>فَإِن قِيْلَ <شدة>أَرْضٌ مُثَلَّثَةٌ</شدة> مِن جَانِبِهَا عَشَرَةُ أَذْرُعٍ عَشَرَةُ أَذْرُعٍ</مقطع>
  <مقطع هوية='٢٤٦٢٩'>وَالْقَاعِدَةُ اثْنَا عَشَرَ ذِرَاعًا فِي جَوْفِهَا أَرْضٌ مُرَبَّعَةٌ</مقطع>
  <مقطع هوية='٥٩٦٢٠'>كَمْ كُلُّ جَانِبٍ مِنَ الْمُرَبَّعَةِ</مقطع>
  <مقطع هوية='٣٤٨٤٧'><قياس>فَقِيَاسُ ذٰلِكَ</قياس> أَنْ تَعْرِفَ عَمُودَ الْمُثَلَّثَةِ</مقطع>
  <مقطع هوية='٧٨٤١٧'>وَهُوَ أَنْ تَضْرِبَ نِصْفَ الْقَاعِدَةِ وَهُوَ سِتَّةٌ فِي مِثْلِهِ فَيَكُونُ سِتَّةً وَثَلاَثِينَ</مقطع>
  <مقطع هوية='٤٧٨٠٤'>فَانْقُصْهَا مِنْ أَحَدِ الْجَانِبَيْنِ الْأَقْصَرَيْنِ مَضْرُوبًا فِي مِثْلِهِ وَهُوَ مِائَةٌ</مقطع>
  <مقطع هوية='٠٤٥٨٦'>يَبْقَى أَرْبَعَةٌ وَسِتُّونَ فَخُذْ جَذْرَهَا ثَمَانِيَةٌ وَهُوَ الْعَمُودُ</مقطع>
  <مقطع هوية='٧٥٩٣٥'>وَتَكْسِيرُهَا ثَمَانِيَةٌ وَأَرْبَعُونَ ذِرَاعًا</مقطع>
  <مقطع هوية='١٤٠٧٧'>وَهُوَ ضَرْبُكَ الْعَمُودَ فِي نِصْفِ الْقَاعِدَةِ وَهُوَ سِتَّةٌ</مقطع>
  <مقطع هوية='٥١١٧٤'>فَجَعَلْنَا أَحَدَ جَوَانِبِ الْمُرَبَّعَةِ شَيْئًا وَضَرَبْنَاهُ فِي مِثْلِهِ فَصَارَ مَالًا فَحَفِظْنَاهُ</مقطع>
  <مقطع هوية='٢٥٩٤٨'>ثُمَّ عَلِمْنَا أَنَّهُ قَدْ بَقِيَ لَنَا مَثُلَّثَتَانِ عَنْ جَنْبَتَيِ الْمُرَبَّعَةِ وَمُثَلَّثَةٌ فَوْقَهَا</مقطع>
  <مقطع هوية='٨٢٦١٠'>فَأَمَّا الْمُثَلَّثَتَانِ الَّتَانِ عَلَى جَنْبَتَيْ الْمُرَبَّعَةِ فَهُمَا مُتَسَاوِيَتَانِ</مقطع>
  <مقطع هوية='٧٨٥٠٥'>وَعَمُودَاهُمَا وَاحِدٌ وَهُمَا عَلَى زَاوِيَةٍ قَائِمَةٍ</مقطع>
  <!-- p066 -->
  <مقطع هوية='٦٦٠١٨'>فَتَكْسِيرُهَا أَنْ تَضْرِبَ شَيْئًا فِي سِتَّةٍ إِلَّا
  <صفحة رقم="٦٦"/> نِصْفُ شَيْءٍ</مقطع>
  <مقطع هوية='٠٥٠٠٨'>فَيَكُونُ سِتَّةَ أَشْيَاءَ إِلَّا نِصْفَ مَالٍ</مقطع>
  <مقطع هوية='٦٩٤٦٢'>وَهُوَ تَكْسِيرُ المُثَلَّثَتَيْنِ جَمِيعًا اللَّتَيْنِ هُمَا عَلَى جَنْبَيْ المُرَبَّعَةِ</مقطع>
  <مقطع هوية='٠٤٧٤٦'>فَأَمَّا تَكْسِيرُ المُثَلَّثَةِ الْعُلْيَا</مقطع>
  <مقطع هوية='٦٨٠٤٨'>فَهُوَ أَنْ تَضْرِبَ ثَمَانِيَةً غَيْرَ شَيْءٍ وَهُوَ الْعَمُودُ فِي نِصْفِ شَيْءٍ</مقطع>
  <مقطع هوية='١٨٩٩٩'>فَيَكُونُ أَرْبَعَةَ أَشْيَاءَ إِلَّا نِصْفَ مَالٍ فَهَذَا هُوَ تَكْسِيرُ الْمُرَبَّعَةِ</مقطع>
  <مقطع هوية='١١٧١٤'>وَتَكْسِيرُ الثَّلاثِ مُثَلَّثَاتٍ وَهُوَ عَشَرَةُ أَشْيَاءَ تَعْدِلُ ثَمَانِيَةً وَأَرْبَعِينَ</مقطع>
  <مقطع هوية='٦٩٧٨١'>هُوَ تَكْسِيرُ المُثَلَّثَةِ الْعُظْمَى</مقطع>
  <مقطع هوية='٧٨٤٧٨'>فَالشَّيْءُ الْوَاحِدُ مِنْ ذٰلِكَ أَرْبَعَةُ أَذْرُعٍ وَأَرْبَعَةُ أَخْمَاسٍ ذِرَاعٍ</مقطع>
  <مقطع هوية='٢٠٨٤٩'>وَهُوَ كُلُّ جَانِبٍ مِنَ الْمُرَبَّعَةِ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٤٣٢٥٥' عرض="0.8" ملف="../figures/fig066"/>

</فصل>
