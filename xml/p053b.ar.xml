<ملف رقم="٥٣"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <فصل هوية='٦٢٢٤٧'>
    <عنوان>بَابُ الْمُعَامَلَاتِ</عنوان>
  </فصل>

  <مقطع هوية='٠١٠٦٦'>اِعْلَمْ أَنَّ مُعَامَلَاتِ النَّاسِ كُلَّهَا</مقطع>
  <مقطع هوية='٧٧٠٠٧'>فَمِنَ الْبَيْعِ وَالشِّرَى وَالصَّرْفِ وَالْإِيجَارَةِ وَغَيْرِ ذٰلِكَ</مقطع>
  <مقطع هوية='٩١٨٦١'>عَلَى وَجْهَيْنِ بِأَرْبَعَةِ أَعدادٍ يُلْفَظُ بِهَا السَّائِلُ</مقطع>
  <مقطع هوية='٧٤٦٢٩'>وَهِيَ الْمُسَعَّرُ وَالسِّعْرُ وَالثَّمَنُ وَالْمُثَمَّنُ</مقطع>
  <مقطع هوية='٨١١٤١'>فَالعَدَدُ الَّذِي هُوَ الْمُسَعَّرُ مُبَايِنٌ لِلْعَدَدِ الَّذِي هُوَ الثَّمَنُ</مقطع>
  <مقطع هوية='٨٧٩٧٣'>وَالعَدَدُ الَّذِي هُوَ السِّعْرُ مُبَايِنٌ لِلْعَدَدِ الَّذِي هُوَ الْمُثَمَّنُ</مقطع>
  <مقطع هوية='٨٧٤٣٨'>وَهَذِهِ الْأَرْبَعَةُ الْأَعدادِ ثَلاثَةٌ مِنْهَا أَبَدًا ظَاهِرَةٌ مَعْلُومَةٌ</مقطع>
  <مقطع هوية='٥٦٩١١'>وَواحِدٌ مِنْهَا مَجْهُولٌ وَهُوَ الَّذِي فِي قَوْلِ الْقَائِلِ <حرف>كَمْ</حرف> وَعَنْهُ يُسْأَلُ السَّائِلُ</مقطع>

  <مقطع هوية='٦٤٩٧٦'><قياس>وَالْقِيَاسُ فِي ذٰلِكَ</قياس> أَنْ تَنْظُرَ إِلَى الثَّلاَثَةِ الْأَعدادِ الظَّاهِرَةِ</مقطع>
  <مقطع هوية='٩٥٤١٧'>فَلَا بُدَّ أَنْ يَكُونَ مِنْهَا اثْنَانِ كُلُّ وَاحِدٍ مِنْهُمَا مُبَايِنٌ لِصَاحِبِهِ</مقطع>
  <مقطع هوية='٣٥٨٩٨'>فَتَضْرِبُ الْعَدَدَيْنِ الظَّاهِرَيْنِ الْمُتَبَايِنَيْنِ كُلُّ وَاحِدٍ مِنْهُمَا فِي صَاحِبِهِ فَمَا بَلَغَ</مقطع>
  <مقطع هوية='٦٠٥٥٢'>فَاقْسِمْهُ عَلَى الْعَدَدِ الْآخَرِ الظَّاهِرِ الَّذِي مُتَبَايِنُهُ مَجْهُولٌ</مقطع>
  <مقطع هوية='٧٧٧٧٠'>فَمَا خَرَجَ لَكَ فَهُوَ الْعَدَدُ الْمَجْهُولُ الَّذِي يُسْأَلُ عَنْهُ السَّائِلُ</مقطع>
  <مقطع هوية='٨٠١٨٣'>وَهُوَ مُبَايِنٌ لِلْعَدَدِ الَّذِي قَسَمتَ عَلَيْهِ</مقطع>

</ملف>
