<فصل هوية='٦٧١٦٦'

  xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <عنوان>[إضْعافُ الْجُذورِ]</عنوان>

  <قسم هوية='٨٠٠٨٤'>
    <عنوان>[مَبادِء]</عنوان>
  </قسم>
  <مقطع هوية='٧٥٠٨٢'><ص مفتاح="علم!اعْلَمْ">وَاعْلَمْ</ص> أَنَّ كُلَّ جَذْرِ مَالٍ مَعْلُومٍ أَوْ أَصَمَّ
  تُرِيدُ أَنْ تُضْعِفَهُ</مقطع>
  <مقطع هوية='٥٧٩٠٣'>وَمَعْنَى إِضْعَافِكَ إِيَّاهُ أَنْ تَضْرِبَهُ فِي اثْنَيْنِ</مقطع>
  <!-- p031a -->
  <مقطع هوية='٧٦٥٩٣'>فَيَنْبَغِي <صفحة رقم="٣١"/> أَنْ تَضْرِبَ <تعبير>اثْنَيْنِ فِي اثْنَيْنِ ثُمَّ فِي الْمَالِ</تعبير></مقطع>
  <مقطع هوية='٠١٥٤٤'>فَيَصِيرُ جَذْرُ مَا اجْتَمَعَ مَثَلَيْ جَذْرِ ذٰلِكَ الْمَالِ</مقطع>

  <مقطع هوية='٥٥٨٤٥'>وَإِنْ أَرَدْتَ <تعبير>ثَلاَثَةَ أَمْثَالِهِ</تعبير></مقطع>
  <مقطع هوية='٧٦٣٥٤'>فَاضْرِبْ ثَلاَثَةً فِي ثَلاَثَةٍ ثُمَّ فِي الْمَالِ</مقطع>
  <مقطع هوية='٦٨٧٢٨'>فَيَكُونُ جَذْرُ مَا اجْتَمَعَ ثَلَاثَةَ أَمْثَالِ جَذْرِ ذٰلِكَ الْمَالِ الْأَوَّلِ</مقطع>

  <مقطع هوية='٣٩٧٨٨'>وَكَذٰلِكَ مَا زَادَ مِنَ الْإضْعَافِ أَوْ نَقَصَ فَعَلَى هَذَا الْمِثَالِ نَفْسِهِ</مقطع>

  <مقطع هوية='٣٦٥٣٥'>وَإِنْ أَرَدْتَ أَنْ تَأْخُذَ <تعبير>نِصْفَ جَذْرِ مَالٍ</تعبير></مقطع>
  <مقطع هوية='٩٤٨٢٢'>فَيَنْبَغِي أَنْ تَضْرِبَ نِصْفًا فِي نِصْفٍ فَيَكُونَ رُبْعًا ثُمَّ فِي الْمَالِ</مقطع>
  <مقطع هوية='٣٥٧٢٦'>فَيَكُونَ جَذْرُ مَا اجْتَمَعَ مِثْلَ نِصْفِ جَذْرِ ذَلِكَ الْمَالِ</مقطع>

  <مقطع هوية='٥٧٠٨١'>وَكَذٰلِكَ يَكُونُ ثُلُثُهُ أَوْ رُبْعُهُ
  أَوْ أَقَلُّ مِنْ ذَلكَ أَوْ أَكْثَرُ</مقطع>
  <مقطع هوية='٩٢٩٨٥'>بَالِغًا مَا بَلَغَ فِي النُّقْصَانِ وَإِلَاضْعَافِ</مقطع>

  <قسم هوية='٦٦٥٢٢'>
    <عنوان>[أمْثِلة]</عنوان>
  </قسم>
  <مقطع هوية='٧٣٩٥٩'>وَمِثَالُ ذٰلِكَ إِذا أَرَدْتَ أَنْ <تعبير>تُضْعِفَ جَذْرَ تِسْعَةٍ</تعبير></مقطع>
  <مقطع هوية='٣٦٨٢٣'>ضَرَبْتَ اثنَيْنِ فِي اثنَيْنِ ثُمَّ فِي تِسْعَةٍ</مقطع>
  <مقطع هوية='٢٣٩٠٢'>فَيَكُونَ ذٰلِكَ سِتَّةً وَئَلَاثِيْنَ</مقطع>
  <مقطع هوية='١٥٦١٨'>فَخُذْ جَذْرَهَا يَكُونَ سِتَّةً وَهُوَ <!-- كَجَذْرِ -->
  ضِعْفُ جَذْرِ تِسْعَةٍ</مقطع>

  <مقطع هوية='٠٤٩٠٧'>وَكَمَا أَنَّكَ إِذَا أَرَدْتَ أَنْ <تعبير>تُضْعِفَ جَذْرَ تِسْعَةٍ ثَلاثَ مَرَّاتٍ</تعبير></مقطع>
  <مقطع هوية='٥٩٤٦٧'>ضَرَبْتَ ثَلاثَةً فِي ثَلاثَةٍ ثُمَّ فِي تِسْعَةٍ فَيَكُونَ أَحَدًا وَثَمَانِينَ</مقطع>
  <مقطع هوية='٤٨١٠٦'>فَخُذْ جَذْرَهَا تِسْعَةً وَذٰلِكَ جَذْرُ تِسْعَةٍ مُضَاعَفًَا ثَلاثَ مَرَّاتٍ</مقطع>

  <مقطع هوية='٥٢٥٣٩'>فَإِنْ أَرَدْتَ أَنْ تَأْخُذَ <تعبير>نِصْفَ جَذْرِ تِسْعَةٍ</تعبير></مقطع>
  <مقطع هوية='٤١٥٥٥'>فَإِنَّكَ تَضْرِبُ نِصْفًا فِي نِصْفٍ فَيَكُونَ رُبْعًا</مقطع>
  <مقطع هوية='٣٤٨٧٤'>ثُمَّ تَضْرِبُ رُبْعًا فِي تِسْعَةٍ فَيَكُونَ اثْنَيْنِ وَرُبْعًا</مقطع>
  <مقطع هوية='٦١٩٩٧'>فَتَأْخُذُ جَذْرَهَا وَهُوَ وَاحِدٌ وَنِصْفٌ وَهُوَ نِصْفُ جَذْرِ تِسْعَةٍ</مقطع>

  <رأس/>
  <مقطع هوية='٢٩٠٢٦'>وَكَذٰلِكَ مَا زَادَ أَوْ نَقَصَ مِنَ
  <ص مفتاح="علم!معلوم">الْمَعْلُومِ</ص> وَ<ص مفتاح="صمم!أصمّ">الْأَصَمِّ</ص> فَهَذَا طَرِيقُهُ</مقطع>

</فصل>
