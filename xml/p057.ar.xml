<ملف رقم="٥٧"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='١٩٩٨٢'>فَهُوَ الْقُطْرُ الْمُدَوَّرَةُ <صفحة رقم="٥٧"/> الَّتِي تِلْكَ الْقَوْسُ مِنْهَا</مقطع>
  <مقطع هوية='٢٨٧٩١'><شدة>فَإِنْ أَرَدْتَ أَنْ تَعْرِفَ</شدة> تَكْسِيرَ الْقَوْسِ</مقطع>
  <مقطع هوية='٣١٩٥٣'>فَاضْرِبْ نِصْفَ قُطْرِ الْمُدَوَّرَةِ فِي نِصْفِ الْقَوْسِ</مقطع>
  <مقطع هوية='٠٩١٢٧'> وَاحْفَظْ مَا خَرَجَ</مقطع>
  <مقطع هوية='٥٦٦٨٨'>ثُمَّ انْقُصْ سَهْمَ الْقَوْسِ مِنْ نِصْفِ قُطْرِ الْمُدَوَّرَةِ</مقطع>
  <مقطع هوية='٧٢٧٥٩'>إِنْ كَانَتِ الْقَوْسُ أَقَلَّ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٨٣٦٥٦'>وَإِنْ كَانَتْ أَكْثَرَ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٦١٢١٩'>فَانْقُصْ نِصْفَ قَطْرِ الْمَدُورَةِ مِنْ سَهْمِ الْقَوْسِ</مقطع>
  <مقطع هوية='٤٥٠٤٥'>ثُمَّ اضْرِبْ مَا بَقِيَ فِي نِصْفِ وَتَرِ الْقَوْسِ</مقطع>
  <مقطع هوية='١٤٣٣١'>وَانْقُصْهُ مِمَّا حَفِظْتَ إِنْ كَانَتِ الْقَوْسُ أَقَلَّ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٩٥٤٦٨'>أَوْ زِدْهُ عَلَيْهِ إِنْ كَانَتِ الْقَوْسُ أَكْثَرَ مِنْ نِصْفِ مَدُورَةٍ</مقطع>
  <مقطع هوية='٦٨٨٨٥'>فَمَا بَلَغَ بَعْدَ الزِّيَادَةِ أَوِ النَّقْصَانِ فَهُوَ تَكْسِيرُ الْقَوْسِ</مقطع>

  <مقطع هوية='٩٠٦٥٥'><شدة>وَكُلُّ مُجَسَّمٍ مُرَبَّعٍ</شدة></مقطع>
  <مقطع هوية='٢٤٨١٦'>فَإنَّ ضَرْبَكَ الطُّولَ فِي الْعَرْضِ ثُمَّ فِي الْعُمْقِ هُوَ التَّكْسِيرُ</مقطع>
  <مقطع هوية='٨٤٧٦٦'>فَإنْ كَانَ عَلَى غَيْرِ تَرْبِيعٍ وَكَانَ مُدَوَّرًا أَوْ مُثَلَّثًا أَوْ غَيْرَ ذٰلِكَ</مقطع>
  <مقطع هوية='٠٥١٦٩'>إِلَّا أَنَّ عُمْقَهُ عَلَى الْاستِوَاءِ وَالْمُوازَاةِ</مقطع>
  <مقطع هوية='٧٩٢٧٢'>فَإنَّ مِسَاحَةَ ذٰلِكَ أَنْ تَمْسَحَ سَطْحَهُ فَتَعْرِفَ تَكْسِيرَهُ</مقطع>
  <مقطع هوية='٠٨٩٢٩'>فَمَا كَانَ ضَرَبْتَهُ فِي الْعُمْقِ وَهُوَ التَّكْسِيرُ</مقطع>

  <مقطع هوية='٨٤٩٨١'><شدة>وَأَمَّا الْمَخْرُوطُ وَالْمُدَوَّرُ مِنَ الْمُثَلَّثِ وَالْمُرَبَّعِ</شدة></مقطع>
  <مقطع هوية='٢٨٠١٨'>فَإِنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ ثُلُثِ مَسَاحَةِ أَسْفَلِهِ فِي عَمُودِهِ</مقطع>
  <مقطع هوية='٠٢٩٦٤'>هُوَ تَكْسِيرُهُ</مقطع>
  <مقطع هوية='٢١٨٣٠'>وَاعْلَمْ أَنَّ كُلَّ مُثَلَّثٍ قَائِمِ الزَّاَوِيَةِ</مقطع>
  <مقطع هوية='٠٢٨٨٠'>فَإِنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ الضِّلَعَيْنِ الأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٢٩٥٥٨'>كُلُّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ مَجْمُوعَيْنِ</مقطع>
  <مقطع هوية='٧٣٥٧٤'>مِثْلَ الَّذِي يَكُونُ مِنْ ضَرْبِ الضِّلَعِ الأَطْوَلِ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٦٥١٠٢'><قياس>وَبُرْهَانُ ذٰلِكَ</قياس> أَنَّا نَجْعَلُ سَطْحًا مُرَبَّعًا مُتَسَاوِيَ الأَضْلَاعِ وَالزَّوَايَا عَلَيْهِ [ا ٮ] [ج د]</مقطع>
  <مقطع هوية='٩٩٨٧٣'>ثُمَّ نَقْطَعُ [ا ج] نِصْفَيْنِ عَلَى نُقْطَةِ [ه]</مقطع>
  <مقطع هوية='٥٧٠٢٦'>ثُمَّ نُخْرِجُهُ إِلَى [ز]</مقطع>
  <مقطع هوية='٠١٥٤١'>ثُمَّ نَقْطَعُ ضِلَعَ [ا ٮ] نِصْفَيْنِ عَلَى نُقْطَةِ [ط]</مقطع>
  <مقطع هوية='٦٧٢٥٠'>وَنُخْرِجُهُ إِلَى نُقْطَةِ [ح]</مقطع>
</ملف>
