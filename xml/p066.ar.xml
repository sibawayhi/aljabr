<ملف رقم="٦٦"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٦٦٠١٨'>فَتَكْسِيرُهَا أَنْ تَضْرِبَ شَيْئًا فِي سِتَّةٍ إِلَّا <صفحة رقم="٦٦"/> نِصْفُ شَيْءٍ</مقطع>
  <مقطع هوية='٠٥٠٠٨'>فَيَكُونُ سِتَّةَ أَشْيَاءَ إِلَّا نِصْفَ مَالٍ</مقطع>
  <مقطع هوية='٦٩٤٦٢'>وَهُوَ تَكْسِيرُ المُثَلَّثَتَيْنِ جَمِيعًا اللَّتَيْنِ هُمَا عَلَى جَنْبَيْ المُرَبَّعَةِ</مقطع>
  <مقطع هوية='٠٤٧٤٦'>فَأَمَّا تَكْسِيرُ المُثَلَّثَةِ الْعُلْيَا</مقطع>
  <مقطع هوية='٦٨٠٤٨'>فَهُوَ أَنْ تَضْرِبَ ثَمَانِيَةً غَيْرَ شَيْءٍ وَهُوَ الْعَمُودُ فِي نِصْفِ شَيْءٍ</مقطع>
  <مقطع هوية='١٨٩٩٩'>فَيَكُونُ أَرْبَعَةَ أَشْيَاءَ إِلَّا نِصْفَ مَالٍ فَهَذَا هُوَ تَكْسِيرُ الْمُرَبَّعَةِ</مقطع>
  <مقطع هوية='١١٧١٤'>وَتَكْسِيرُ الثَّلاثِ مُثَلَّثَاتٍ وَهُوَ عَشَرَةُ أَشْيَاءَ تَعْدِلُ ثَمَانِيَةً وَأَرْبَعِينَ</مقطع>
  <مقطع هوية='٦٩٧٨١'>هُوَ تَكْسِيرُ المُثَلَّثَةِ الْعُظْمَى</مقطع>
  <مقطع هوية='٧٨٤٧٨'>فَالشَّيْءُ الْوَاحِدُ مِنْ ذٰلِكَ أَرْبَعَةُ أَذْرُعٍ وَأَرْبَعَةُ أَخْمَاسٍ ذِرَاعٍ</مقطع>
  <مقطع هوية='٢٠٨٤٩'>وَهُوَ كُلُّ جَانِبٍ مِنَ الْمُرَبَّعَةِ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٤٣٢٥٥' عرض="0.8" ملف="../figures/fig066"/>
</ملف>
