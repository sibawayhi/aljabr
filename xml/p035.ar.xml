<ملف رقم="٣٥"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٠٤٨٣٢'><قياس>فَقِيَاسُهَا</قياس> أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةَ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٢٨٤٨٠'>فَتَضْرِبُ شَيْئًا فِي عَشَرَةٍ إِلَّا شَيْئًا فَكُونَ عَشَرَةَ أَشْيَاءَ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٩٨٢٢٦'>ثُمَّ تَضْرِبُهُ فِي أَرْبَعَةٍ لِقَوْلِكَ أَرْبَعَ مَرَّاتٍ</مقطع>
  <مقطع هوية='٤٢٧٦٧'>فَيَكُونَ أَرْبَعَةَ أَمْثَالِ الْمَضْرُوبِ مِنْ أَحَدِ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='١٨٢٦٤'>وَالْآخَرُ فَيَكُونُ ذٰلِكَ أَرْبَعِينَ شَيْئًا إِلَّا أَرْبَعَةَ أَمْوَالٍ</مقطع>
  <مقطع هوية='٥١٦٩٩'>ثُمَّ تَضْرِبُ شَيْئًا فِي شَيْءٍ وَهُوَ أَحَدُ الْقِسْمَيْنِ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٤٣٥٣٣'>فَيَكُونُ مَالًا يَعْدِلُ أَرْبَعِينَ شَيْئًا إِلَّا أَرْبَعَةَ أَمْوَالٍ</مقطع>
  <مقطع هوية='٩١٤٤٩'>فَاجْبُرْهَا بِالْأَرْبَعَةِ الْأَمْوَالِ وَزِدْهَا عَلَى الْمَالِ</مقطع>
  <مقطع هوية='٤١٥٧٦'>فَيَكُونُ أَرْبَعِينَ شَيْئًا تَعْدِلُ خَمْسَةَ أَمْوَالٍ</مقطع>
  <مقطع هوية='٠٧٨٧٨'>فَالْمَالُ الْواحِدُ يَعْدِلُ ثَمَانِيَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٢٦٥١٤'>وَهُوَ أَرْبَعَةٌ وَسِتُّونَ جَذْرُهَا ثَمَانِيَةٌ</مقطع>
  <مقطع هوية='٢٥٩٥٨'>وَهُوَ أَحَدُ الْقِسْمَيْنِ الْمَضْرُوبِ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٦٣٥٦٠'>وَالْبَاقِي مِنَ الْعَشَرَةِ اثْنَاُنِ وَهُوَ الْقِسْمُ الآخَرُ</مقطع>
  <مقطع هوية='٠٢١٣١'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٨٥٧٨٠'>وَهِيَ أَمْوَالٌ تُعَدِّلُ جُذُورًا</مقطع>
  <مقطع هوية='٦٧٠٤٦'>فَاعْلَمْ ذٰلِكَ</مقطع>

  <مسألة هوية='٢٢٣٧٢'>الْمَسْأَلةُ الثَّانِيَةُ</مسألة>
  <مقطع هوية='٤٨٣٩٩'>وَالمَسْألَةُ الثَّانِيَةُ عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ فَضَرَبْتُ كُلَّ قِسْمٍ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٢٠٥٤٦'>ثُمَّ ضَرَبْتُ الْعَشَرَةَ فِي نَفْسِهَا</مقطع>
  <مقطع هوية='٠٨٩٥٧'>فَكانَ مَا اجْتَمَعَ مِنْ ضَرْبِ الْعَشَرَةِ فِي نَفْسِهَا</مقطع>
  <مقطع هوية='٤٩٧٧٨'>مِثْلَ أَحَدِ الْقِسْمَيْنِ مَضْرُوبًا فِي نَفْسِهِ مَرَّتَيْنِ وَسَبْعَةَ أَتْسَاعِ مَرَّةٍ</مقطع>
  <مقطع هوية='٤٥٦٥١'>أَوْ مِثْلَ الآخَرِ مَضْرُوبًا فِي نَفْسِهِ سِتَّ مَرَّاتٍ وَرُبُعَ مَرَّةٍ</مقطع>

  <مقطع هوية='٣٨٧٠٦'><قياس>فَقِيَاسُ ذٰلِكَ</قياس> أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةً إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٢٣٣٧٩'>فَتَضْرِبُ الشَّيْءَ فِي نَفْسِهِ فَيَكُونُ مَالًا</مقطع>
  <مقطع هوية='٣٧٢٨٨'>ثُمَّ فِي اثْنَيْنِ وَسَبْعَةَ أَتْسَاعٍ</مقطع>
  <مقطع هوية='٦٠٩٦٣'>فَيَكُونُ مَالَيْنِ وَسَبْعَةَ أَتْسَاعِ مَالٍ</مقطع>
  <مقطع هوية='١١٧٣٧'>ثُمَّ تَضْرِبُ الْعَشَرَةَ فِي مِثْلِهَا فَتَكُونُ مِائَةً تُعَادِلُ مَالَيْنِ وَسَبْعَةَ أَتْسَاعِ مَالٍ</مقطع>

</ملف>
