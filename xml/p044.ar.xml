<ملف رقم="٤٤"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٩١٥٧٤'>فَتَقُولُ بَاعَ الأَرْبَعَةَ <صفحة رقم="٤٤"/>كُلُّ وَاحِدٍ بِأَرْبَعَةِ أَجْزَاءِ مِنْ ثَلَاثَةَ عَشَرَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٠٥٦١٧'>وَبَاعَ السِّتَّةَ كُلَّ وَاحِدٍ بِجُزْأَيْنِ مِنْ ثَلَاثَةَ عَشَرَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٨٠١٥٥'>فَبَلَغَ ذٰلِكَ ثَمَانِيَةً وَعِشْرِينَ جُزْئًا مِنْ ثَلَاثَةَ عَشَرَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٦١٥٣٧'>وَذٰلِكَ مِثْلُ فَضْلِ مَا بَيْنَ الْكَيْلَيْنِ وَهُوَ قَفِيرَانِ</مقطع>
  <مقطع هوية='٧٨٢٩٣'>فَصَرْفُهُمَا سِتَّةً وَعِشْرُونَ جُزْءًا</مقطع>
  <مقطع هوية='١٤٦٧٤'>وَفَضْلُ مَا بَيْنَ السِّعْرَيْنِ وَهُوَ جُزْءَانِ فَذٰلِكَ ثَمَانِيَةٌ وَعِشْرُونَ جُزْءًا</مقطع>

  <مقطع هوية='٣١٨٩٧'>فَإنْ قَالَ <معادلة>مَالانِ بَيْنَهُمَا دِرْهَمَانِ
  قَسَمْتَ الْقَلِيلَ عَلَى الْكَثِيرِ فَأَصَابَ الْقِسْمَ نِصْفُ دِرْهَمٍ</معادلة></مقطع>
  <مقطع هوية='٥٥٩٢٤'>فَاجْعَلْ أَحَدَ الْمَالَيْنِ شَيْئًا وَالْآخَرَ شَيْئًا وَدِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٥٣٣٠٢'>فَلَمَّا قَسَمْتَ شَيْئًا على شَيْءٍ وَدِرْهَمَيْنِ
  خَرَجَ الْقِسْمُ نِصْفَ دِرْهَمٍ</مقطع>
  <مقطع هوية='٦٣٢٩٢'>وَقَدْ عَلِمْتَ أَنَّكَ مَتَى ضَرَبْتَ مَا خَرَجَ لَكَ مِنَ الْقِسْمِ فِي الْمَقْسُومِ عَلَيْهِ</مقطع>
  <مقطع هوية='٧٣٩٥٢'>عَادَ مَالُكَ الَّذِي قَسَمْتَهُ وَهُوَ شَيْءٌ</مقطع>
  <مقطع هوية='٦٦١٠٢'>فَقُلْ شَيْءٌ وَدِرْهَمَانِ فِي النِّصْفِ الَّذِي هُوَ الْقِسْمُ</مقطع>
  <مقطع هوية='٦٩١١٤'>فَيَكُونُ نِصْفَ شَيْءٍ وَدِرْهَمًا تَعْدِلُ الشَّيْءَ</مقطع>
  <مقطع هوية='٢٧٠٦٩'>فَأَلْقَيْتَ نِصْفَ شَيْءٍ بِنِصْفِ شَيْءٍ وَبَقِيَ دِرْهَمٌ يَعْدِلُ نِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٢٠٠٧٣'>فَأضْعِفْهُ يَكُونَ الشَّيْءُ يَعْدِلُ دِرْهَمَيْنِ وَالْآخَرُ أَرْبَعَةَ</مقطع>

  <مقطع هوية='١٩١٥٦'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  وَضَرَبْتَ أَحَدُهُمَا فِي عَشَرَةٍ وَالْقِسْمُ الآخَرُ فِي نَفْسِهِ فَاسْتَوَيَا</معادلة></مقطع>
  <مقطع هوية='٥٨٢٥٩'><قياس>فَإِنْ قِيَاسُهُ</قياس> أَنْ تَضْرِبَ شَيْئًا فِي عَشَرَةٍ فَيَكُونَ عَشَرَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٧٤١٠٠'>ثُمَّ تَضْرِبَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا فَتَكُونَ مَائَةً وَمَالا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٩٦٤٠٤'>تَعْدِلُ الْعَشَرَةَ الْأَجْذَارَ</مقطع>
  <مقطع هوية='٩٣١٢٢'>فَقَابِلْ بِهَا عَلَى مَا قَدْ وَصَفْتُ لَكَ</مقطع>

  <مقطع هوية='٦٩٢٢٩'>وَكَذٰلِكَ لَوْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  ثُمَّ ضَرَبْتَ أَحَدَهُمَا فِي الْآخَرِ
  ثُمَّ اجْتَمَعْتَ مِنَ الضَّرْبِ عَلَى فَضْلِ مَا بَيْنَ الْقِسْمَيْنِ قَبْلَ أَنْ تَضْرِبَ أَحَدَهُمَا فِي الْآخَرِ
  خَرَجَ خَمْسَةً وَرُبْعًا</معادلة></مقطع>
</ملف>
