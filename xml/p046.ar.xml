<ملف رقم="٤٦"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٣٣١١٥'>فَاقْسِمْ الثَّمَانِينَ <صفحة رقم="٤٦"/>عَلَى الْخَمْسَةِ عَشَرَ فَيَكُونُ خَمْسَةً وَثُلُثًا</مقطع>
  <مقطع هوية='٥٤٣٧٩'>فَذٰلِكَ جَذْرُ الْمَالِ وَالْمَالُ ثَمَانِيَةٌ وَعِشْرُونَ وَأَرْبَعَةٌ اتِّسَاعٌ</مقطع>

  <مقطع هوية='٤٧٧٩٦'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي أَرْبَعَةِ أَمْثَالِهِ فَيَكُونُ عِشْرِينَ</معادلة></مقطع>
  <مقطع هوية='٦٧٧٧٥'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي مِثْلِهِ كَانَ خَمْسَةً وَهُوَ جَذْرُ خَمْسَةٍ</مقطع>

  <مقطع هوية='٧٤٩٣٧'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي ثُلُثِهِ فَيَكُونُ عَشَرَةً</معادلة></مقطع>
  <مقطع هوية='٩٧٠٠٢'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي مِثْلِهِ كَانَ ثَلَاثِينَ فَتَقُولُ الْمَالُ جَذْرُ ثَلَاثِينَ</مقطع>

  <مقطع هوية='٩٢٨٧٨'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي أَرْبَعَةِ أَمْثَالِهِ فَيَعُودُ ثُلُثَ الْمَالِ الأَوَّلِ</معادلة></مقطع>
  <مقطع هوية='٢٩٦٠٢'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي اثْنَيْ عَشَرَ مِثْلَهُ عَادَ الْمَالُ</مقطع>
  <مقطع هوية='٥٨٥٦٨'>وَهُوَ نِصْفُ سُدُسٍ فِي ثُلُثٍ</مقطع>

  <مقطع هوية='٦٦٨٠٣'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي جَذْرِهِ
  فَيَعُودُ ثَلاثَةَ أَمْثَالِ الْمَالِ الأَوَّلِ</معادلة></مقطع>
  <مقطع هوية='١٨٦٨٦'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَ الْجَذْرَ فِي ثُلُثِ الْمَالِ عَادَ الْمَالُ</مقطع>
  <مقطع هوية='٢٢٠٢٣'>فَتَقُولُ هَذَا مَالٌ ثُلُثُهُ جَذْرُهُ وَهُوَ تِسْعَةٌ</مقطع>

  <مقطع هوية='٦٩٧١٦'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ أَرْبَعَةَ أَجْذَارِهِ فِي ثَلاثَةِ أَجْذَارِهِ فَيَعُودُ الْمَالَ وَزِيَادَةُ أَرْبَعَةٍ وَأَرْبَعِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٣٩٩٨١'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ أَرْبَعَةَ أَجْذَارٍ فِي ثَلاثَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٦٧٣٦٣'>فَيَكُونُ اثْنَيْ عَشَرَ مَالًا تَعْدِلُ مَالًا وَأَرْبَعَةً وَأَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٣٢٢٨١'>فَأَلْقِ مِنَ الِاثْنَيْ عَشَرَ الْمَالِ مَالًا فَيَبْقَى أَحَدُ عَشَرَ مَالًا</مقطع>
  <مقطع هوية='٣٩٤٤١'>تَعْدِلُ أَرْبَعَةً وَأَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٥٢٤٧٥'>فَاقْسِمْهَا عَلَيْهَا تَكُنْ أَرْبَعَةً وَهُوَ الْمَالُ</مقطع>

  <مقطع هوية='٠٦٨٣١'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ أَرْبَعَةَ أَجْذَارِهِ فِي خَمْسَةِ أَجْذَارِهِ فَيَعُودُ مِثْلَيْ الْمَالِ وَزِيَادَةَ سِتَّةَ وَثَلاثِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٥٨٧٥٩'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ تَضْرِبُ أَرْبَعَةَ أَجْذَارٍ فِي خَمْسَةِ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٧٣٢٠'>فَيَكُونُ عِشْرِينَ مَالًا تَعْدِلُ مَالَيْنِ وَسِتَّةَ وَثَلاثِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٤٧٤٥٣'>فَتُلْقِي مِنَ الْعِشْرِينَ الْمَالَ مَالَيْنِ بِمَالَيْنِ</مقطع>
  <مقطع هوية='٧٩٢٥٠'>فَتَبْقَى ثَمَانِيَةَ عَشَرَ مَالًا تَعْدِلُ سِتَّةَ وَثَلاثِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٠٣٥٤'>فَتَقْسِمُ سِتَّةَ وَثَلاثِينَ دِرْهَمًا عَلَى ثَمَانِيَةَ عَشَرَ</مقطع>
  <مقطع هوية='١٦٨٨٧'>فَيَكُونُ الْقَسْمُ أَثْنَيْنِ وَهُوَ الْمَالُ</مقطع>

  <مقطع هوية='١٦٦٠٩'>وَكَذٰلِكَ لَوْ قَالَ <معادلة>مَالٌ تَضْرِبُ جَذْرَهُ فِي أَرْبَعَةِ أَجْذَارِهِ فَيَعُودُ ثَلاثَةَ أَمْثَالِ الْمَالِ وَزِيَادَةَ خَمْسِينَ <صفحة رقم="٤٧"/>درهما</معادلة></مقطع>
</ملف>
