<فصل هوية='١١٥٣٠'

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <عنوان>بَابُ الضَّربِ</عنوان>

  <مقطع هوية='٠٤٩٩٧'>وَأَنَا مُخْبِرُكَ كَيْفَ تَضْرِبُ الأَشْيَاءَ</مقطع>
  <مقطع هوية='٩٠١٤٣'>وَهِيَ الْجُذُورُ بَعْضُهَا فِي بَعْضٍ</مقطع>
  <مقطع هوية='٥٠٨٥١'>إِذَا كَانَتْ مُنفَرِدَةً أَوْ كَانَ مَعَهَا عَدَدٌ</مقطع>
  <مقطع هوية='٧٠٧٥١'>أَوْ كَانَ <ص مفتاح="ثني!مُسْتَثْنَى">مُسْتَثْنَى مِنْهَا</ص> عَدَدٌ</مقطع>
  <مقطع هوية='٩٨٢٢٥'>أَوْ كَانَتْ <ص مفتاح="ثني!مُسْتَثْنَاة">مُسْتَثْنَاةً مِنْ</ص> عَدَدٍ</مقطع>
  <مقطع هوية='٧٢٧٦٢'>وَكَيْفَ تَجْمَعُ بَعْضَهَا إِلَى بَعْضٍ</مقطع>
  <مقطع هوية='٨١٩٨٤'>وَكَيْفَ تَنْقُصُ بَعْضَهَا مِنْ بَعْضٍ</مقطع>

  <رأس/>
  <مقطع هوية='٢٢٢٨٦'>اعْلَمْ أَنَّهُ لَا بُدَّ لِكُلِّ عَدَدٍ يُضْرَبُ فِي عَدَدٍ</مقطع>
  <مقطع هوية='٨٨٠٧٢'>مِنْ أَنْ يُضَاعَفَ أَحَدُ الْعَدَدَيْنِ بِقَدْرِ مَا فِي الْآخَرِ مِنَ الْآحَادِ</مقطع>
  <مقطع هوية='٣١٧١٧'>فَإِذَا كَانَتْ عُقُودٌ وَمَعَهَا آحَادٌ
  أَوْ <ص مفتاح="ثني!مُسْتَثْنَى">مُسْتَثْنًى مِنْهَا</ص> آحَادٌ</مقطع>
  <مقطع هوية='١٨٤٢٩'>فَلَا بُدَّ مِنْ ضَرْبِهَا أَرْبَعَ مَرَّاتٍ</مقطع>
  <مقطع هوية='٨٨٢١٨'>الْعُقُودُ فِي الْعُقُودِ وَالْعُقُودُ فِي الْآحَادِ</مقطع>
  <مقطع هوية='٦٢٧٧٠'>وَالْآحَادُ فِي الْعُقُودِ وَالْآحَادُ فِي الْآحَادِ</مقطع>
  <مقطع هوية='١٠٧١٨'>فَإِذَا كَانَتِ الْآحَادُ الَّتِي مَعَ الْعُقُودِ زَائِدَةً جَمِيعًا
  فَالضَّرْبُ الرَّابِعُ زَائِدٌ</مقطع>
  <مقطع هوية='٢٦٠١١'>وَإِذَا كَانَتْ نَاقِصَةً جَمِيعًا فَالضَّرْبُ الرَّابِعُ زَائِدٌ أَيْضًا</مقطع>
  <مقطع هوية='٧٩١٠٧'>وَإِذَا كَانَ أَحَدُهَا زَائِدًا وَالْآخَرُ نَاقِصًا
  فَالضَّرْبُ الرَّابِعُ نَاقِصٌ</مقطع>

  <!-- <قسم هوية='٠٠٢٠٢'> -->
  <!--   <عنوان>أَمْثِلة</عنوان> -->
  <!-- </قسم> -->

  <!-- <مسألة هوية='٧٤٢٢٣' tex="(١٠+١)(١٠+٢)"/> -->
  <مقطع هوية='٧٠٥١٩'>وَهُوَ مِثْلُ <تعبير tex="(١٠+١)(١٠+٢)">عَشَرَةٍ وَواحِدٍ فِي عَشَرَةٍ وَاثْنَيْنَ</تعبير></مقطع>
  <مقطع هوية='٨٧٢٤٤'>فَالْعَشَرَةُ فِي الْعَشَرَةِ مِائَةٌ</مقطع>
  <مقطع هوية='٥٣٠٢٧'>وَالْواحِدُ فِي الْعَشَرَةِ عَشَرَةٌ زَائِدَةٌ</مقطع>
  <مقطع هوية='٣٧٦٧٤'>وَالِاثْنَانِ فِي الْعَشَرَةِ عِشْرُونَ زَائِدَةٌ</مقطع>
  <مقطع هوية='٩٥٦٦٩'>وَالْواحِدُ فِي الِاثْنَيْنِ اثْنَانِ زَائِدَانِ</مقطع>
  <مقطع هوية='٣٦٢٥١'>فَذٰلِكَ كُلُّهُ مِائَةٌ وَاثْنَانِ وَثَلاثُونَ</مقطع>

  <مقطع هوية='٦٥٧٥٠'>وَإِذَا كَانَتْ <تعبير>عَشَرَةٌ إِلَّا وَاحِدًا فِي عَشَرَةٍ إِلَّا وَاحِدًا</تعبير></مقطع>
  <مقطع هوية='٩٥٢٥٤'>فَالْعَشَرَةُ فِي الْعَشَرَةِ مِائَةٌ</مقطع>
  <!-- p028 -->
  <مقطع هوية='٧٩٠٨٨'>وَالْوَاحِدُ <صفحة رقم="٢٨"/> النَّاقِصُ فِي الْعَشَرَةِ عَشَرَةٌ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٦٧٣٣٩'>وَالْوَاحِدُ النَّاقِصُ أَيْضًا فِي الْعَشَرَةِ عَشَرَةٌ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٦٩١٨٢'>فَذٰلِكَ ثَمَانُونَ</مقطع>
  <مقطع هوية='٥٨٣٦٠'>وَالْوَاحِدُ النَّاقِصُ فِي الْوَاحِدِ النَّاقِصِ وَاحِدٌ زَائِدٌ</مقطع>
  <مقطع هوية='٩٦٨٠٨'>فَذٰلِكَ أَحَدٌ وَثَمَانُونَ</مقطع>

  <رأس/>
  <مقطع هوية='١٦٠٢٩'>وَإِذَا كَانَتْ <تعبير>عَشَرَةٌ وَاثْنَانِ فِي عَشَرَةٍ إِلَّا وَاحِدًا</تعبير></مقطع>
  <مقطع هوية='٩٨٩٩٤'>فَالعَشَرَةُ فِي العَشَرَةِ مِائَةٌ</مقطع>
  <مقطع هوية='٨١٨١٣'>وَالْوَاحِدُ النَّاقِصُ فِي العَشَرَةِ عَشَرَةٌ نَاقِصَةٌ</مقطع>
  <مقطع هوية='١٨١٢٠'>وَالِاثْنَانِ الزَّائِدَانِ فِي العَشَرَةِ عِشْرُونَ زَائِدَةٌ</مقطع>
  <مقطع هوية='٩٢٩٧٥'>فَذٰلِكَ مِائَةٌ وَعَشَرَةٌ</مقطع>
  <مقطع هوية='٥٨٠٢٠'>وَالِاثْنَانِ الزَّائِدَانِ فِي الْوَاحِدِ الْمَنْقُوصِ اثْنَانِ نَاقِصَانِ</مقطع>
  <مقطع هوية='٧٨٤٠٨'>فَذٰلِكَ كُلُّهُ مِائَةٌ وَثَمَانِيَةٌ</مقطع>

  <رأس/>
  <مقطع هوية='٨٩٢٥٥'>وَإِنَّمَا بَيَّنْتُ ذٰلِكَ لِتَسْتَدِلَّ بِهِ عَلَى ضَرْبِ الْأَشْيَاءِ بَعْضَهَا فِي بَعْضٍ</مقطع>
  <مقطع هوية='١٩٠٥٧'>إِذَا كَانَ مَعَهَا عَدَدٌ أَوْ اسْتُثْنِيَتْ مِنْ عَدَدٍ أَوْ اسْتُثْنِيَ مِنْهَا عَدَدٌ</مقطع>

  <رأس/>
  <مقطع هوية='٦٩٩١٤'>فَإِذَا قِيْلَ لَكَ <تعبير>عَشَرَةٌ إِلَّا شَيْئًا وَمَعْنَى الشَّيْءِ الْجَذْرُ فِي عَشَرَةٍ</تعبير></مقطع>
  <مقطع هوية='١٦٩٠٤'>فَاضْرِبْ عَشَرَةً فِي عَشَرَةٍ يَكُونُ مِائَةً</مقطع>
  <مقطع هوية='٢٤١٥٠'>وَإِلَّا شَيْئًا فِي عَشَرَةٍ يَكُونُ عَشَرَةَ أَجْذَارٍ نَاقِصَةً</مقطع>
  <مقطع هوية='٨٣٨١٥'>فَيَعْدِلُ مِائَةً إِلَّا عَشَرَةَ أَشْيَاءَ</مقطع>

  <رأس/>
  <مقطع هوية='١٩٤٤٩'>فَإِنْ قَالَ <تعبير>عَشَرَةٌ وَشَيْءٌ فِي عَشَرَةٍ</تعبير></مقطع>
  <مقطع هوية='٦٢٩٠٣'>فَاضْرِبْ عَشَرَةً فِي عَشَرَةٍ يَكُونُ مِائَةً</مقطع>
  <مقطع هوية='٢٣٧٥٧'>وَشَيْئًا فِي عَشَرَةٍ بِعَشَرَةِ أَشْيَاءَ زَائِدَةً</مقطع>
  <مقطع هوية='٠٤٢١٦'>يَكُونُ مِائَةً وَعَشَرَةَ أَشْيَاءَ</مقطع>

  <رأس/>
  <مقطع هوية='٥٨٩٨٧'>وَإِنْ قَالَ <تعبير>عَشَرَةٌ وَشَيْءٌ فِي مِثْلِهَا</تعبير></مقطع>
  <مقطع هوية='٦٢٥٦٦'>قُلْتَ عَشَرَةٌ فِي عَشَرَةٍ مِائَةٌ</مقطع>
  <مقطع هوية='٢٣٩٨٩'>وَعَشَرَةٌ فِي شَيْءٍ بِعَشَرَةِ أَشْيَاءَ</مقطع>
  <مقطع هوية='٦٢٦٧١'>وَعَشَرَةٌ فِي شَيْءٍ بِعَشَرَةِ أَشْيَاءَ أَيْضًا</مقطع>
  <مقطع هوية='٧٨١٢٩'>وَشَيْءٌ فِي شَيْءٍ مَالٌ زَائِدٌ</مقطع>
  <مقطع هوية='٣٢٦٨٤'>فَيَكُونُ ذَلِكَ مِائَةَ دِرْهَمٍ وَعِشْرِينَ شَيْئًا وَمَالًا زَائِدًا</مقطع>

  <رأس/>
  <مقطع هوية='٨٥٥٩١'>وَإِنْ قَالَ <تعبير>عَشَرَةٌ إِلَّا شَيْئًا فِي عَشَرَةٍ إِلَّا شَيْئًا</تعبير></مقطع>
  <مقطع هوية='٥٢٢٤١'>قُلْتَ عَشَرَةٌ فِي عَشَرَةٍ بِمِائَةٍ</مقطع>
  <مقطع هوية='٧٧٣١٠'>وَإِلَّا شَيْئًا فِي عَشَرَةٍ عَشَرَةَ أَشْيَاءَ نَاقِصَةً</مقطع>
  <مقطع هوية='٢٠٢٦٩'>وَإِلَّا شَيْئًا فِي عَشَرَةٍ عَشَرَةَ أَشْيَاءَ نَاقِصَةً</مقطع>
  <مقطع هوية='١٦٦٧٤'>وَإِلَّا شَيْئًا فِي إِلَّا شَيْثًا مَالٌ زَائِدٌ</مقطع>
  <مقطع هوية='٦٦٣١٦'>فَيَكُونُ ذٰلِكَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <!-- p029 -->
  <رأس/>
  <مقطع هوية='٥٥٩٢٨'>وَكَذَلِكَ <صفحة رقم="٢٩"/> لَوْ أَنَّهُ قَالَ لَكَ</مقطع>
  <مقطع هوية='٣٩٨١٣'><تعبير>دِرْهَمٌ إِلَّا سُدُسًا فِي دِرْهَمٍ إِلَّا سُدُسًا</تعبير></مقطع>
  <مقطع هوية='٩٣٤٤٩'>يَكُونُ خَمْسَةَ أَسْدَاسٍ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٣٥٠٩٥'>وَهِيَ خَمْسَةٌ وَعِشْرُونَ جُزْءًا مِنْ سِتَّةٍ وَثَلاثِينَ مِنْ أَجْزَاءِ الدِّرْهَمِ</مقطع>
  <مقطع هوية='٤٤٩٩٤'>وَهُوَ ثُلُثَانِ وَسُدُسُ السُّدُسِ</مقطع>
  <مقطع هوية='١٤٧٤٦'><قياس>وَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ دِرْهَمًا فِي دِرْهَمٍ فَيَكُونَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩٤٤٢٧'>وَإِلَّا سُدُسًا فِي دِرْهَمٍ بِسُدُسٍ نَاقِصٍ</مقطع>
  <مقطع هوية='٠٩٤٣٨'>وَإِلَّا سُدُسًا فِي دِرْهَمٍ بِسُدُسٍ نَاقِصٍ</مقطع>
  <مقطع هوية='٦٩٧٣٠'>فَيَبْقَى ثُلُثَانِ</مقطع>
  <مقطع هوية='٠٤٤٣٩'>وَإِلَّا سُدُسًا فِي سُدُسٍ بِسُدُسِ السُّدُسِ زَائِدًا</مقطع>
  <مقطع هوية='٦٨٣٩٧'>وَذَلِكَ ثُلُثَانِ وَسُدُسُ السُّدُسِ</مقطع>
  <مقطع هوية='٢٥٢٥٠'>ثُمَّ دِرْهَمٌ فِي إِلَّا سُدُسٍ بِسُدُسٍ نَاقِصٍ</مقطع>
  <مقطع هوية='٠١٨٥٠'>ثُمَّ دِرْهَمٌ فِي إِلَّا سُدُسٍ بِسُدُسٍ نَاقِصٍ</مقطع>
  <مقطع هوية='٧٢٦٨٥'>فَيَكُونُ ثُلُثَيِ دِرْهَمٍ</مقطع>
  <مقطع هوية='٩٩٢٩٦'>وَإِلَّا سُدُسًا فِي إِلَّا سُدُسٍ بِسُدُسِ السُّدُسِ زَائِدٍ</مقطع>
  <مقطع هوية='٢٤٤٨٠'>فَذَلِكَ ثُلُثَانِ وَسُدُسُ السُّدُسِ</مقطع>

  <رأس/>
  <مقطع هوية='٣١٠٣٨'>وَإِنْ قَالَ <تعبير>عَشَرَةٌ إِلَّا شَيْئًا فِي عَشَرَةٍ وَشَيْءٍ</تعبير></مقطع>
  <مقطع هوية='٤٤٥٨٢'>قُلْتَ عَشَرَةً فِي عَشَرَةٍ مِائَةً</مقطع>
  <مقطع هوية='٠٥٩١٧'>وَإِلَّا شَيْئًا فِي عَشَرَةٍ عَشَرَةُ أَشْيَاءَ نَاقِصَةً</مقطع>
  <مقطع هوية='٩٥٠٢٥'>وَشَيْءٌ فِي عَشَرَةٍ عَشَرَةُ أَشْيَاءَ زَائِدَةً</مقطع>
  <مقطع هوية='٣٥٠٧١'>وَإِلَّا شَيْئًا فِي شَيْءٍ مَالٌ نَاقِصٌ</مقطع>
  <مقطع هوية='٠٦٢٢٠'>فَيَكُونُ لَكَ مِائَةُ دِرْهَمٍ إِلَّا مَالًا</مقطع>

  <رأس/>
  <مقطع هوية='٥٢٦٧١'>وَإِنْ قَالَ <تعبير>عَشَرَةٌ إِلَّا شَيْئًا فِي شَيْءٍ</تعبير></مقطع>
  <مقطع هوية='٩٠٥٣٥'>قُلْتَ عَشَرَةٌ فِي شَيْءٍ عَشَرَةُ أَشْيَاءَ</مقطع>
  <مقطع هوية='٢٠٤٩٤'>وَإِلَّا شَيْءٍ فِي شَيْءٍ مَالٌ نَاقِصٌ</مقطع>
  <مقطع هوية='٩٠٢٥٦'>فَيَكُونُ عَشَرَةَ أَشْيَاءَ إِلَّا مَالًا</مقطع>

  <رأس/>
  <مقطع هوية='٣٣٠٨٤'>وَإِنْ قَالَ <تعبير>عَشَرَةٌ وَشَيْءٌ فِي شَيْءٍ إِلَّا عَشَرَةً</تعبير></مقطع>
  <مقطع هوية='١٠٥٤٢'>قُلْتَ شَيْءٌ فِي عَشَرَةٍ عَشَرَةُ أَشْيَاءَ زَائِدَةٌ</مقطع>
  <مقطع هوية='٩٨٠١٠'>وَشَيْءٌ فِي شَيْءٍ مَالٌ زَائِدٌ</مقطع>
  <مقطع هوية='٣٧٠٤٩'>وَإِلَّا عَشَرَةً فِي عَشَرَةٍ مِائَةَ دِرْهَمٍ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٩١٠١٥'>وَإِلَّا عَشَرَةً فِي شَيْءٍ بِعَشَرَةِ أَشْيَاءَ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٥٠٠٤٩'>فَتَقُولُ مَالٌ إِلَّا مِائَةَ دِرْهَمٍ بَعْدَ مَا <مقابلة>قَابَلْتَ بِهِ</مقابلة></مقطع>
  <مقطع هوية='٥٤٢٥٧'>وَذَاكَ أَنْ تَطْرَحَ عَشَرَةَ أَشْيَاءَ زَائِدَةً بِعَشَرَةَ أَشْيَاءَ نَاقِصَةً</مقطع>
  <مقطع هوية='٥٦٨٤١'>فَيَبْقَى مَالٌ إِلَّا مِائَةَ دِرْهَمٍ</مقطع>

  <رأس/>
  <مقطع هوية='٩١٣٩٧'>وَإِنْ قَالَ <تعبير>عَشَرَةُ دَرَاهِمَ وَنِصْفُ شَيْءٍ
  فِي نِصْفِ دِرْهَمٍ إِلَّا خَمْسَةَ أَشْيَاءَ</تعبير></مقطع>
  <مقطع هوية='٩٩١٣٤'>قُلْتَ نِصْفُ دِرْهَمٍ فِي عَشَرَةٍ بِخَمْسَةِ دَرَاهِمَ زَائِدَةٍ</مقطع>
  <مقطع هوية='٤٨٥٠٠'>وَنِصْفُ دِرْهَمٍ فِي نِصْفِ شَيْءٍ بِرُبُعِ شَيْءٍ زَائِدٍ</مقطع>
  <مقطع هوية='٤٩٥٧٥'>وَإِلَّا خَمْسَةَ أَشْيَاءَ فِي عَشَرَةَ
  دَرَاهِمَ خَمْسُونَ جَذْرًا نَاقِصَةٌ</مقطع>
  <!-- p030a -->
  <مقطع هوية='١٦٧١١'>فَيَكُونُ جَمِيعُ ذَلِكَ خَمْسَةَ دَرَاهِمَ إِلَّا تِسْعَةً وَأَرْبَعِينَ جَذْرًا <صفحة رقم="٣٠"/> ( شَيْئًا) وَثَلاثَةَ أَرْبَاعِ جَذْرٍ</مقطع>
  <مقطع هوية='١٩٥٦٢'>ثُمَّ تَضْرِبُ خَمْسَةَ أَجْذَارٍ نَاقِصَةً فِي نِصْفِ جَذْرٍ زَائِدٍ</مقطع>
  <مقطع هوية='٩٧٤٧٧'>فَيَكُونُ مَالَيْنِ وَنِصْفًا نَاقِصًا</مقطع>
  <مقطع هوية='٩٣٣٨٩'>فَذٰلِكَ خَمْسَةُ دَرَاهِمَ إِلَّا مَالَيْنِ وَنِصْفًا وَإِلَّا تِسْعَةً وَأَرْبَعِينَ جَذْرًا وَثَلاثَةَ أَرْبَاعِ جَذْرٍ</مقطع>

  <رأس/>
  <مقطع هوية='٨٠٨٨٩'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ وَشَيْءٌ فِي شَيْءٍ إِلَّا عَشَرَةً</معادلة></مقطع>
  <مقطع هوية='٦٠٧٨٧'>فَكَأَنَّهُ قَالَ <تعبير>شَيْءٌ وَعَشَرَةٌ فِي شَيْءٍ إِلَّا عَشَرَةً</تعبير></مقطع>
  <مقطع هوية='٨٨٣١٨'>فَتَقُولُ شَيْءٌ فِي شَيْءٍ مَالٌ زَائِدٌ</مقطع>
  <مقطع هوية='٩٩٨١٩'>وَعَشَرَةٌ فِي شَيْءٍ عَشَرَةُ أَشْيَاءَ زَائِدَةٌ</مقطع>
  <مقطع هوية='٩٨٢٣٥'>وَإِلَّا عَشَرَةً فِي شَيْءٍ عَشَرَةُ أَشْيَاءَ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٥١٨٩٠'>فَذَهَبَتِ الزِّيَادَةُ بِالنُّقْصَانِ وَبَقِيَ الْمَالُ</مقطع>
  <مقطع هوية='٨٥٨٨٨'>وَإِلَّا عَشَرَةً فِي عَشَرَةٍ مِائَةٌ مَنْقُوصَةٌ مِنَ الْمَالِ</مقطع>
  <مقطع هوية='٢٧٤٧٧'>فَجَمِيعُ ذٰلِكَ مَالٌ إِلَّا مِائَةَ دِرْهَمٍ</مقطع>

  <رأس/>
  <مقطع هوية='٩٧٤٣٣'>وَكُلُّ مَا كَانَ مِنَ الضِّرْبِ زَائِدًا وَنَاقِصًا مَثَلُ الْأَشْيَاءِ فِي زِيَادَةِ شَيْءٍ</مقطع>
  <مقطع هوية='٩٨٣٧١'>فَالضَّرْبُ الْأَخِيرُ نَاقِصٌ أَبَدًا</مقطع>
  <مقطع هوية='٢٦٨٥٠'><ص مفتاح="علم!اعْلَمْ">فَاعْلَمْ</ص> ذٰلِكَ وَبِاللهِ التَّوْفِيقُ</مقطع>
</فصل>
