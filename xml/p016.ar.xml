<ملف رقم="١٦"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٤٣٧٩٩'>عَلَى أَنْ <صفحة رقم="١٦"/> أَلَّفْتُ مِنْ كِتَابِ الْجَبْرِ وَالْمُقَابَلَةِ</مقطع>
  <مقطع هوية='١٦٧٨٧'>كِتَابًا مُخْتَصَرًا حَاصِرًا لِلَطِيفِ الْحِسَابِ وَجَلِيلِهِ</مقطع>
  <مقطع هوية='٧١١٥٤'>لِمَا يَلْزَمُ النَّاسَ مِنَ الْحَاجَةِ إلَيْهِ</مقطع>
  <مقطع هوية="٣">فِي مَوَارِيثِهِمْ وَوَصَايَاهُمْ</مقطع>
  <مقطع هوية="٤">وَفِي مُقَاسَمَتِهِمْ وَأَحْكَامِهِمْ وَتِجَارَاتِهِمْ</مقطع>
  <مقطع هوية="٥">وَفِي جَمِيعِ مَا يَتَعَامَلُونَ بِهِ بَيْنَهُمْ مِنْ مِسَاحَةِ الْأَرَضِينَ وَكَرَى الْأَنْهَارِ وَالْهِنْدَسَةِ وَغَيْرِ ذَلِكَ مِنْ وَُجُوهِهِ وَفَنُونِهِ</مقطع>
  <مقطع هوية="٦">مُقَدَّمًا لِحُسْنِ النِّيَّةِ فِيهِ وَرَاجِيًا لِأَنْ يَنْزِلَهُ أَهْلُ االْأَدَبِ بِفَضْلِ مَا اسْتَوْدَعُوا مِنْ نِعْمِ اللَّهِ تَعَالَى</مقطع>
  <مقطع هوية="٧">وَجَلِيلُ آلَائِهِ وَجَمِيلِ بَلَائِهِ عِنْدَهُمْ مَنْزِلَتُهُ</مقطع>
  <مقطع هوية="٨">وَبِاَللَّهِ تَوْفِيقِي فِي هَذَا وَفِي غَيْرِهِ عَلَيْهِ تَوَكَّلْتُ وَهُوَ رَبُّ الْعَرْشِ الْعَظِيمِ</مقطع>
  <مقطع هوية="٩">وَصَلَّى اللَّهُ عَلَى جَمِيعِ الِانْبِيَاءِ وَالْمُرْسَلِينَ</مقطع>

  <فصل هوية='٤٨٩٧٢'>
    <عنوان>[الْأَعْدادُ وضُروبُها]</عنوان>
  </فصل>

    <مقطع هوية='٧٧٣١٨'>وَإِنِّي لَمَّا نَظَرْتُ فِيمَا يَحْتَاجُ الْيهِ النَّاسُ مِنْ الْحِسَابِ</مقطع>
    <مقطع هوية="١١">وَجَدْتُ جَمِيعَ ذَلِكَ عَدَدًا</مقطع>
    <مقطع هوية="١٢">وَوَجَدْتُ جَمِيعَ الْأَعْدَادِ إنَّمَا تَرَكَّبَتْ مِنْ الْوَاحِدِ</مقطع>
    <مقطع هوية="١٣">وَالْوَاحِدُ دَاخِلٌ فِي جَمِيعِ الْأَعْدَادِ</مقطع>
    <مقطع هوية="١٤">وَوَجَدْتُ جَمِيعَ مَا يُلْفَظُ بِهِ مِنْ الْأَعْدَادِ</مقطع>
    <مقطع هوية='٨٠٣٢٨'>مَا جَاوَزَ الْوَاحِدَ إلَى الْعَشَرَةِ يَخْرُجُ مَخْرَجَ الْوَاحِدِ</مقطع>
    <مقطع هوية="١٥">ثُمَّ تُثَنَّى الْعَشَرَةُ وَتُثَلُّثُ كَمَا فُعِلَ بِالْوَاحِدِ فَتَكُونُ مِنْهَا الْعِشْرُونَ وَالثَّلَاثُونَ الَى تَمَامِ الْمِائَةِ</مقطع>
    <مقطع هوية="١٦">ثُمَّ تُثَنَّى الْمِائَةُ وَتُثَلَّثُ كَمَا فُعِلَ بِالْوَاحِدِ وَبِالْعَشَرَةِ إلَى الْأَلْفِ</مقطع>
    <مقطع هوية="١٧">ثُمَّ كَذَلِكَ تَرَدَّدَ الْأَلْفُ عِنْدَ كُلِّ عَقْدٍ إلَى غَايَةِ الْمُدْرَكِ مِنْ الْعَدَدِ</مقطع>

    <رأس/>
    <مقطع هوية="١٨">وَوَجَدْتُ الْأَعْدَادَ الَّتِى يُحْتَاجُ إِلَيْهَا فِي حِسَابِ الْجَبْرِ وَالْمُقَابَلَةِ عَلَى ثَلَاثَةِ ضُرُوبٍ</مقطع>

</ملف>
