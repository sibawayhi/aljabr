<ملف رقم="٥٦"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='١٦٦٣٢'>هُوَ الدَّوْرُ <صفحة رقم="٥٦"/> الَّذِى يُحِيطُ بِهَا</مقطع>
  <مقطع هوية='٥٠٧٧٦'>وَهُوَ اصْطِلَاحٌ بَيْنَ النَّاسِ مِنْ غَيْرِ اضْطِرَارٍ</مقطع>
  <مقطع هوية='٤٩٩٥٠'>وَلِأَهْلِ الهَنْدَسَةِ فِيهِ قَوْلَانِ آخَرَانِ</مقطع>
  <مقطع هوية='٩٦٤٢٨'>أَحَدُهُمَا أَن تَضْرِبَ الْقُطْرَ فِى مِثْلِهِ ثُمَّ فِى عَشَرَةٍ</مقطع>
  <مقطع هوية='١٦٨٧٣'>ثُمَّ تَأْخُذُ جَذْرَ مَا اجْتَمَعَ فَمَا كَانَ هُوَ الدَّوْرُ</مقطع>
  <مقطع هوية='٤٠٣٨٢'>وَالْقَوْلُ الثَّانِى لِأَهْلِ النُّجُومِ مِنْهُمْ</مقطع>
  <مقطع هوية='١٤٢٧٨'>وَهُوَ أَن تَضْرِبَ الْقُطْرَ فِى اثْنَيْنِ وَسِتِّينَ أَلْفًا وَثَمَانِمِائَةٍ وَاثْنَيْنِ وَثَلاَثِينَ</مقطع>
  <مقطع هوية='٤٩٧٢٠'>ثُمَّ تَقْسِمُ ذٰلِكَ عَلَى عِشْرِينَ أَلْفًا فَمَا خَرَجَ فَهُوَ الدَّوْرُ</مقطع>
  <مقطع هوية='٢١٦٧٨'>وَكُلُّ ذٰلِكَ قَرِيبٌ بَعْضُهُ مِنْ بَعْضٍ</مقطع>

  <مقطع هوية='٧٢١٧٤'>وَالدَّوْرُ إِذَا قَسَمْتَهُ عَلَى ثَلاثَةٍ وَسُبْعٍ يَخْرُجُ الْقُطْرُ</مقطع>
  <مقطع هوية='٧٣٦٣٥'>وَكُلُّ مُدَوَّرَةٍ فَإِنَّ نِصْفَ الْقُطْرِ فِي نِصْفِ الدَّوْرِ هُوَ التَّكْسِيرُ</مقطع>
  <مقطع هوية='٦٠٨٣١'>لِأَنَّ كُلَّ ذَاتِ أَضْلَاعٍ وَزَوَايَا مُتَسَاوِيَةٍ مِنَ الْمُثَلَّثَاتِ وَالْمُرَبَّعَاتِ وَالْمُخَمَّسَاتِ وَمَا فَوْقَ ذٰلِكَ</مقطع>
  <مقطع هوية='٧٥٢٨٦'>فَإِنَّ ضَرْبَكَ نِصْفَ مَا يُحِيطُ بِهِ فِي نِصْفِ قُطْرٍ أَوْسَعَ دَائِرَةٍ يَقَعُ فِيهَا تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٤٤٠٠٠'>وَكُلُّ مُدَوَّرَةٍ فَإِنَّ قُطْرَهَا مَضْرُوبًا فِي نَفْسِهِ مَنْقُوصًا مِنْهُ سُبْعُهُ وَنِصْفُ سُبْعِهِ</مقطع>
  <مقطع هوية='٥٥٧٢٣'>هُوَ تَكْسِيرُهَا وَهُوَ مُوَافِقٌ لِلْبَابِ الْأَوَّلِ</مقطع>

  <قسم هوية='٧٥٠٩٠'>
    <عنوان>[الْقِطْعَةُ مِن الْمُدَوَّرَةِ]</عنوان>
  </قسم>
  <مقطع هوية='٥٨٧٥٦'>وَكُلُّ قِطْعَةٍ مِنْ مُدَوَّرَةٍ مُشَبَّهَةٍ بِقَوْسٍ</مقطع>
  <مقطع هوية='٤٠٩٢١'>فَلَا بُدَّ أَنْ تَكُونَ مِثْلَ نِصْفِ مُدَوَّرَةٍ</مقطع>
  <مقطع هوية='٢٢٠٦١'>أَوْ أَقَلَّ مِنْ نِصْفِ مُدَوَّرَةٍ أَوْ أَكْثَرَ مِنْ نِصْفِ مُدَوَّرَةٍ</مقطع>
  <مقطع هوية='٤٠٨٤٤'>وَالدَّلِيلُ عَلَى ذٰلِكَ أَنَّ سَهْمَ الْقَوْسِ</مقطع>
  <مقطع هوية='٤٦٢٣٥'>إِذَا كَانَ مِثْلَ نِصْفِ الْوَتَرِ فَهِيَ نِصْفُ مُدَوَّرَةٍ سَوِيًّا</مقطع>
  <مقطع هوية='٤٦٧٣٤'>وَإِذَا كَانَ أَقَلَّ مِنْ نِصْفِ الْوَتَرِ</مقطع>
  <مقطع هوية='١٢٢٥٨'>فَهِيَ أَقَلُّ مِنْ نِصْفِ مُدَوَّرَةٍ</مقطع>
  <مقطع هوية='٧٩٥٢٨'>وَإِذَا كَانَ السَّهْمُ أَكْثَرَ مِنْ نِصْفِ الْوَتَرِ</مقطع>
  <مقطع هوية='٨٤٩٦٣'>فَهِيَ أَكْثَرُ مِنْ نِصْفِ مُدَوَّرَةٍ</مقطع>

  <مقطع هوية='١٢٦٧٧'><شدة>وَإِذَا أَرَدْتَ أَنْ تَعْرِفَ</شدة> مِنْ أَيِّ دَائِرَةٍ هِيَ</مقطع>
  <مقطع هوية='٣٠٤٤٢'>فَاضْرِبْ نِصْفَ الْوَتَرِ فِي مِثْلِهِ وَاقْسِمْهُ عَلَى السَّهْمِ</مقطع>
  <مقطع هوية='٦٧٦٨٧'>وَزِدْ مَا خَرَجَ عَلَى السَّهْمِ فَمَا بَلَغَ</مقطع>
</ملف>
