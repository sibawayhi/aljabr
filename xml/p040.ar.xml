<ملف رقم="٤٠"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٩٠٥٤١'>ثُمَّ تَجْمَعُ ذٰلِكَ فَيَكُونَ مِائَةً وَمَالَيْنِ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٨٦٩٥٩'>وَقَالَ زِدْتَ عَلَيْهِمَا فَضْلَ مَا بَيْنَهُمَا قَبْلَ أَنْ تَضْرِبَهُمَا</مقطع>
  <مقطع هوية='٧٦٤٧٣'>فَقُلْتَ فَضْلُ مَا بَيْنَهُمَا عَشَرَةٌ إِلَّا شَيْئَيْنِ</مقطع>
  <مقطع هوية='١٩٩٩٨'>فَجَمِيعُ ذٰلِكَ مِائَةٌ وَعَشَرَةٌ وَمَالَانِ
  إِلَّا اثْنَتَيْنِ وَعِشْرِينَ شَيْئًا يَعْدِلُ أَرْبَعَةً وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٠٣٠٥'>فَإِذَا <جبر مفتاح="جبر!جَبَرْتَ">جَبَرْتَ</جبر>
  وَ<مقابلة مفتاح="قبل!قابَلْتَ">قَابَلْتَ</مقابلة> قُلْتَ مِائَةٌ وَعَشَرَةُ دِرَاهِمَ وَمَالَانِ تَعْدِلُ أَرْبَعَةً وَخَمْسِينَ دِرْهَمًا وَاثْنَيْنِ وَعِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='١٨٤٣٦'><ص مفتاح="ردد!اُرْدُدُ">فَارْدُدْ</ص> الْمَالَيْنِ إِلَى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٨٠٣٧٧'>وَهُوَ أَنْ تَأْخُذَ نِصْفَ مَا مَعَكَ فَيَكُونُ خَمْسَةً وَخَمْسِينَ دِرْهَمًا وَمَالًا</مقطع>
  <مقطع هوية='٨٣٢٣١'>تَعْدِلُ سَبْعَةً وَعِشْرِينَ دِرْهَمًا وَأَحَدَ عَشَرَ شَيْئًا</مقطع>
  <مقطع هوية='٥٥٢٧٩'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> سَبْعَةً وَعِشْرِينَ مِنْ خَمْسَةٍ وَخَمْسِينَ يَبْقَى ثَمَانِيَةٌ وَعِشْرُونَ دِرْهَمًا وَمَالًا تَعْدِلُ أَحَدَ عَشَرَ شَيْئًا</مقطع>
  <مقطع هوية='٠٤٠٦٧'>فَنَصِّفْ الأَشْيَاءَ فَيَكُونَ خَمْسَةً وَنِصْفًا</مقطع>
  <مقطع هوية='١٥٨٠٨'>فَاضْرِبْهَا فِي مِثْلِهَا فَيَكُونَ ثَلَاثِينَ وَرُبُعًا</مقطع>
  <مقطع هوية='٨١٦٩٧'>فَانْقُصْ مِنْهَا الثَّمَانِيَةَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ فَيَبْقَى اثْنَانِ وَرُبْعٌ</مقطع>
  <مقطع هوية='٢٢٢٢٤'>فَخُذْ جَذْرَهَا وَهُوَ وَاحِدٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٥٢٤٦١'>فَانْقُصْهُ مِنْ نِصْفِ الأَجْذَارِ</مقطع>
  <مقطع هوية='٧٤٧٩٧'>يَبْقَى أَرْبَعَةٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٤٨٨٩٧'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ فَقَسَمْتُ هَذَا عَلَى هَذَا وَهَذَا عَلَى هَذَا
  فَبَلَغَ ذٰلِكَ دِرْهَمَيْنِ وَسُدْسًا</معادلة></مقطع>
  <مقطع هوية='٢٠٣٥١'><قياس>فَقِيَاسُ ذٰلِكَ</قياس> أَنَّكَ إِذَا ضَرَبْتَ كُلَّ قِسْمٍ فِي نَفْسِهِ ثُمَّ جَمَعْتَهَا</مقطع>
  <مقطع هوية='٤٠٣٩٧'>كَانَ مِثْلَ أَحَدِ القِسْمَيْنِ إِذَا ضَرَبْتَ إِحْدَاهُمَا فِي الآخَرِ</مقطع>
  <مقطع هوية='٩٨٦٤٤'>ثُمَّ ضَرَبْتَ الَّذِي اجْتَمَعَ مَعَكَ مِنَ الضَّرْبِ فِي الَّذِي بَلَغَ القِسْمُ وَهُوَ اثْنَانِ وَسُدْسٌ</مقطع>
  <مقطع هوية='٩٠٠٨٣'>فَاضْرِبْ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا يَكُنْ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٥٢٥٣٥'>وَاضْرِبْ شَيْئًا فِي شَيْءٍ فَيَكُونُ مَالًا</مقطع>

</ملف>
