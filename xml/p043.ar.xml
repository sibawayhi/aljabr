<ملف رقم="٤٣"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٢٩٢٨٠'>فَيَكُونُ الْفَيْنِ وَخَمْسُمِائَةٍ <صفحة رقم="٤٣"/>وَخَمْسِينَ وَرُبْعًا</مقطع>
  <مقطع هوية='١٥٤٠٢'>فَانْقُصْ مِنْهَا الْمِائَةَ فَبَقِيَ أَلْفَانِ وَأَرْبَعُمِائَةٍ وَخَمْسُونَ وَرُبْعٌ</مقطع>
  <مقطع هوية='٩٦٦٣٧'>فَخُذْ جَذْرَهَا وَهُوَ تِسْعَةٌ وَأَرْبَعُونَ وَنِصْفٌ</مقطع>
  <مقطع هوية='٩٢٣٨٧'>فَانْقُصْهَا مِنْ نِصْفِ الْأَجْذَارِ وَهُوَ خَمْسُونَ وَنِصْفٌ</مقطع>
  <مقطع هوية='١٧٠١٤'>فَيَبْقَى وَاحِدٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٣٩٧٤٣'>فَإنْ قَالَ <معادلة>عَشَرَةُ اقْفِرَةٍ حِنْطَةً أَوْ شَعِيرًا
  بِعْتَ كُلَّ وَاحِدٍ مِنْهُمَا بِسِعْرٍ ثُمَّ جَمَعْتَ ثَمَنَهُمَا
  فَكَانَ مَا اجْتَمَعَ مِثْلَ فَضْلِ مَا بَيْنَ السِّعْرَيْنِ وَمِثْلَ مَا بَيْنَ الْكَيْلَيْنِ</معادلة></مقطع>
  <مقطع هوية='١٦٣٨١'>فَخُذْ مَا شِئْتَ فَإِنَّهُ يَجُوزُ فَكَأَنَّكَ أَخَذْتَ أَرْبَعَةً وَسِتَّةً</مقطع>
  <مقطع هوية='٣١٧٩١'>فَقُلْتَ بِعْتُ كُلَّ وَاحِدٍ مِنَ الْأَرْبَعَةِ بِشَيْءٍ</مقطع>
  <مقطع هوية='٣٨٠٧٧'>فَضَرَبَتْ أَرْبَعَةً فِي شَيْءٍ فَصَارَ أَرْبَعَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٧٧٧٩٢'>وَبِعْتُ السِّتَّةَ كُلَّ وَاحِدٍ بِمِثْلِ نِصْفِ الشَّيْءِ الَّذِي بِعْتُ بِهِ الأَرْبَعَةَ</مقطع>
  <مقطع هوية='٩٢٧٠٧'>وَإِنْ شِئْتَ بِثُلُثِهِ وَإِنْ شِئْتَ بِرُبْعِهِ أَوْ مَا شِئْتَ فَإِنَّهُ يَجُوزُ</مقطع>
  <مقطع هوية='٤٤٩٦٠'>فَإِذَا كَانَ بَيْعُكَ الآخَرَ بِنِصْفِ شَيْءٍ فَاضْرِبْ نِصْفَ شَيْءٍ فِي سِتَّةٍ فَيَكُونَ ثَلاَثَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٩٩٩٩٩'>فَاجْمَعْهَا مَعَ الأَرْبَعَةِ الأَشْيَاءَ فَتَكُونَ سَبْعَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٦٤٩٤٤'>تَعْدِلُ مَا بَيْنَ الْكَيْلَيْنِ وَهُوَ قَفِيْزَان</مقطع>
  <مقطع هوية='٨٩٤٩٠'>وَفَضَلَ مَا بَيْنَ السِّعْرَيْنِ وَهُوَ نِصْفُ شَيْءٍ</مقطع>
  <مقطع هوية='٣٤٥٢٥'>فَيَكُونُ سَبْعَةَ أَشْيَاءَ تَعْدِلُ اثْنَيْنِ وَنِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٣٩٠٩٩'>فَأَلْقِ نِصْفَ شَيْءٍ مِمَّا سَبْعَةَ أَشْيَاءَ فَتَبْقَى سِتَّةَ أَشْيَاءَ وَنِصْفُ (شَيْءٍ) تَعْدِلُ دِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٨١١٨٧'>فَالشَّيْءُ الْواحِدُ أَرْبَعَةُ أَجْزَاءٍ مِنْ ثَلَاثَةَ عَشَرَ</مقطع>
</ملف>
