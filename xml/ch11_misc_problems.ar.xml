<فصل هوية='٧٢٨٢٩' صفحة="٣٨"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <عنوان>بَابُ الْمَسَاءِلِ الْمُخْتَلِفَةِ</عنوان>

  <مقطع هوية='٥٠٨٠٦'>فَإِنْ سَأَلَ سَائِلٌ فَقالَ</مقطع>
  <مقطع هوية='١٣٥٤٩'><معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ ثُمَّ ضَرَبْتَ أَحَدَهُمَا فِي الْآخَرِ فَكَانَ وَاحِدًا وَعِشْرِينَ دِرْهَمًا</معادلة></مقطع>
  <!-- p039 -->
  <مقطع هوية='٣٧٠١٦'>فَقَدْ <ص مفتاح="علم!عَلِمْتَ">عَلِمْتَ</ص> أَنَّ أَحَدَ الْقِسْمَيْنِ <صفحة رقم="٣٩"/> مِنَ الْعَشَرَةِ شَيْءٌ وَالْآخَرُ عَشَرَةٌ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٠٧٦٧١'>فَاضْرِبْ شَيْئًا فِي عَشَرَةٍ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٦١٢٥١'>فَيَكُونُ عَشَرَةَ أَشْيَاءَ إِلَّا مَالًا تَعْدِلُ أَحَدًا وَعِشْرِينَ</مقطع>
  <مقطع هوية='٨٠٥٨٤'><جبر مفتاح="جبر!اُجْبُرْ">فَاجْبُرْ</جبر> الْعَشَرَةَ الْأَشْيَاءِ بِالْمَالِ وَزِدْهُ عَلَى الْواحِدِ وَالْعِشْرِينَ</مقطع>
  <مقطع هوية='٠٧٣٧٠'>فَيَكُونُ عَشَرَةَ أَشْيَاءَ تَعْدِلُ أَحَدًا وَعِشْرِينَ دِرْهَمًا وَمَالًا</مقطع>
  <مقطع هوية='٥٩١٦٢'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> نِصْفَ الأَجْذَارِ فَبَقِيَ خَمْسَةً</مقطع>
  <مقطع هوية='٣٦٦٧٧'>فَاصْرِبْهَا فِي مِثْلِهَا تَكُنْ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٢٤٣٦٠'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> مِنْهَا الْواحِدَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ فَيَبْقَى أَرْبَعَةً</مقطع>
  <مقطع هوية='٥٣٢٦٢'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ فَانْقُصْهُ مِنْ نِصْفِ الأَجْذَارِ وَهِيَ خَمْسَةٌ</مقطع>
  <مقطع هوية='١٢٩٨٢'>فَيَبْقَى ثَلاثَةٌ وَذٰلِكَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='١٤٥٧٣'>وَإِنْ شِئْتَ زِدْتَ جَذْرَ الْأَرْبَعَةِ عَلَى نِصْفِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٠١٧٦٩'>فَتَكُونُ سَبْعَةً وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='٦٠١٦١'>وَهَذِهِ الْمَسْأَلَةُ الَّتِي تَعْمَلُ بِالزِّيَادَةِ وَالنُّقْصَانِ</مقطع>

  <مقطع هوية='٤٥٢١٤'>وَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ فَضَرَبْتَ كُلَّ قِسْمٍ فِي نَفْسِهِ ثُمَّ أَلْقَيْتَ الأَقَلَّ مِنَ الأَكْثَرِ فَبَقِيَ أَرْبَعُونَ</معادلة></مقطع>
  <مقطع هوية='٧١٢٢٧'><قياس>قِيَاسُهُ</قياس> أَنْ تَضْرِبَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا فَتَكُونَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٢٨٤١'>وَتَضْرِبَ شَيْئًا فِي شَيْءٍ فَيَكُونَ مَالًا</مقطع>
  <مقطع هوية='٤٢٣٤٣'>فَانْقُصْهُ مِنَ المِائَةِ وَالْمَالِ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٠٦٥٧'>تَبْقَى مِائَةً إِلَّا عِشْرِينَ شَيْئًا تُعَدِّلُ أَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٠٢٠٥١'><جبر مفتاح="جبر!اُجْبُرْ">فَاجْبُرِ</جبر> المِائَةَ بِالْعِشْرِينَ الشَّيْءِ وَزِدْهَا عَلَى الأَرْبَعِينَ</مقطع>
  <مقطع هوية='٨٧٧٦٨'>فَيَكُونَ مِائَةً تَعْدِلُ عِشْرِينَ شَيْئًا وَأَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٨٧٧٤١'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> الْأَرْبَعِينَ مِنَ المِائَةِ فَيَبْقَى سِتُّونَ دِرْهَمًا تَعْدِلُ عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٠٥٥٨٣'>فَالشَّيْءُ الْواحِدُ يَعْدِلُ ثَلاَثَةً وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٢٨٠٢٧'>وَإِن قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  فَضَرَبْتَ كُلَّ قِسْمٍ فِي نَفْسِهِ وَجَمَعْتَهُمَا
  وَزِدْتَ عَلَيْهِمَا فَضْلَ مَا بَيْنَ الْقِسْمَيْنِ مِن قَبْلِ أَنْ تَضْرِبَهُمَا
  فَبَلَغَ ذٰلِكَ أَرْبَعَةً وَخَمْسِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='١٦٥٧٢'><قياس>فَإِنَّ قِيَاسَهُ</قياس></مقطع>
  <مقطع هوية='٥٠٤٠٨'>أَنْ تَضْرِبَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٧٨٧٣٧'>فَتَكُونَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٤٥٢١٧'>وَتَضْرِبَ الشَّيءَ الْبَاقِي مِنَ الْعَشَرَةِ فِي مِثْلِهِ <صفحة رقم="٤٠"/>فَيَكُونَ مَالًا</مقطع>
  <!-- p040 -->
  <مقطع هوية='٩٠٥٤١'>ثُمَّ تَجْمَعُ ذٰلِكَ فَيَكُونَ مِائَةً وَمَالَيْنِ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٨٦٩٥٩'>وَقَالَ زِدْتَ عَلَيْهِمَا فَضْلَ مَا بَيْنَهُمَا قَبْلَ أَنْ تَضْرِبَهُمَا</مقطع>
  <مقطع هوية='٧٦٤٧٣'>فَقُلْتَ فَضْلُ مَا بَيْنَهُمَا عَشَرَةٌ إِلَّا شَيْئَيْنِ</مقطع>
  <مقطع هوية='١٩٩٩٨'>فَجَمِيعُ ذٰلِكَ مِائَةٌ وَعَشَرَةٌ وَمَالَانِ
  إِلَّا اثْنَتَيْنِ وَعِشْرِينَ شَيْئًا يَعْدِلُ أَرْبَعَةً وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٠٣٠٥'>فَإِذَا <جبر مفتاح="جبر!جَبَرْتَ">جَبَرْتَ</جبر>
  وَ<مقابلة مفتاح="قبل!قابَلْتَ">قَابَلْتَ</مقابلة> قُلْتَ مِائَةٌ وَعَشَرَةُ دِرَاهِمَ وَمَالَانِ تَعْدِلُ أَرْبَعَةً وَخَمْسِينَ دِرْهَمًا وَاثْنَيْنِ وَعِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='١٨٤٣٦'><ص مفتاح="ردد!اُرْدُدْ">فَارْدُدْ</ص> الْمَالَيْنِ إِلَى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٨٠٣٧٧'>وَهُوَ أَنْ تَأْخُذَ نِصْفَ مَا مَعَكَ فَيَكُونُ خَمْسَةً وَخَمْسِينَ دِرْهَمًا وَمَالًا</مقطع>
  <مقطع هوية='٨٣٢٣١'>تَعْدِلُ سَبْعَةً وَعِشْرِينَ دِرْهَمًا وَأَحَدَ عَشَرَ شَيْئًا</مقطع>
  <مقطع هوية='٥٥٢٧٩'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> سَبْعَةً وَعِشْرِينَ مِنْ خَمْسَةٍ وَخَمْسِينَ يَبْقَى ثَمَانِيَةٌ وَعِشْرُونَ دِرْهَمًا وَمَالًا تَعْدِلُ أَحَدَ عَشَرَ شَيْئًا</مقطع>
  <مقطع هوية='٠٤٠٦٧'>فَنَصِّفْ الأَشْيَاءَ فَيَكُونَ خَمْسَةً وَنِصْفًا</مقطع>
  <مقطع هوية='١٥٨٠٨'>فَاضْرِبْهَا فِي مِثْلِهَا فَيَكُونَ ثَلَاثِينَ وَرُبُعًا</مقطع>
  <مقطع هوية='٨١٦٩٧'>فَانْقُصْ مِنْهَا الثَّمَانِيَةَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ فَيَبْقَى اثْنَانِ وَرُبْعٌ</مقطع>
  <مقطع هوية='٢٢٢٢٤'>فَخُذْ جَذْرَهَا وَهُوَ وَاحِدٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٥٢٤٦١'>فَانْقُصْهُ مِنْ نِصْفِ الأَجْذَارِ</مقطع>
  <مقطع هوية='٧٤٧٩٧'>يَبْقَى أَرْبَعَةٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٤٨٨٩٧'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  فَقَسَمْتَ هَذَا عَلَى هَذَا وَهَذَا عَلَى هَذَا
  فَبَلَغَ ذٰلِكَ دِرْهَمَيْنِ وَسُدْسًا</معادلة></مقطع>
  <مقطع هوية='٢٠٣٥١'><قياس>فَقِيَاسُ ذٰلِكَ</قياس> أَنَّكَ إِذَا ضَرَبْتَ كُلَّ قِسْمٍ فِي نَفْسِهِ ثُمَّ جَمَعْتَهَا</مقطع>
  <مقطع هوية='٤٠٣٩٧'>كَانَ مِثْلَ أَحَدِ القِسْمَيْنِ إِذَا ضَرَبْتَ إِحْدَاهُمَا فِي الآخَرِ</مقطع>
  <مقطع هوية='٩٨٦٤٤'>ثُمَّ ضَرَبْتَ الَّذِي اجْتَمَعَ مَعَكَ مِنَ الضَّرْبِ فِي الَّذِي بَلَغَ القِسْمُ وَهُوَ اثْنَانِ وَسُدْسٌ</مقطع>
  <مقطع هوية='٩٠٠٨٣'>فَاضْرِبْ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا يَكُنْ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٥٢٥٣٥'>وَاضْرِبْ شَيْئًا فِي شَيْءٍ فَيَكُونَ مَالًا</مقطع>
  <!-- p041 -->
  <مقطع هوية='٥٤٦٣٥'>فَاجْمَعْ ذٰلِكَ فَيَصِيرُ مِائَةً <صفحة رقم="٤١"/>وَمَالِين إِلَّا عَشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٩٨١٨٣'> يَعْدِلُ شَيْئًا مَضْرُوبًا فِي عَشَرَةٍ إِلَّا شَيْئًا وَذٰلِكَ عَشَرَةُ أَشْيَاءَ إِلَّا مَالًا مَضْرُوبًا فِي مَا خَرَجَ مِنَ الْقِسْمَيْنِ وَهُوَ اثْنَانِ وَسُدْسٍ</مقطع>
  <مقطع هوية='٤١٦٣١'>فَيَكُونُ ذٰلِكَ أَحَدًا وَعِشْرِينَ شَيْئًا وَثُلُثَ شَيْءٍ إِلَّا مَالِين وَسُدُسًا</مقطع>
  <مقطع هوية='٨٩٤١٠'>تَعْدِلُ مِائَةً وَمَالِين إِلَّا عَشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٨٦٣٣١'><جبر مفتاح="اُجْبُرْ">فَاجْبُرْ</جبر> ذٰلِكَ وَزِدْ مَالِين وَسُدُسًا عَلَى مِائَةٍ وَمَالِين إِلَّا عَشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٨٢٣٨٨'>وَزِدْ الْعِشْرِينَ الشَّيْءِ النَّاقِصَةَ مِنَ الْمِائَةِ وَالْمَالِين عَلَى الْوَاحِدِ وَالْعِشْرِينَ الشَّيْءِ وَثُلُثِ الشَّيْءِ</مقطع>
  <مقطع هوية='١٧٧٨٩'>فَيَكُونُ مَعَكَ مِائَةً وَأَرْبَعَةَ أَمْوَالٍ وَسُدُسُ مَالٍ تَعْدِلُ أَحَدًا وَأَرْبَعِينَ شَيْئًا وَثُلُثَيْ شَيْءٍ</مقطع>
  <مقطع هوية='٦٣٦٦٦'>فَارْدُدْ ذٰلِكَ إِلَى مَالٍ</مقطع>

  <مقطع هوية='٤٨٦٢٨'>وَقَدْ <ص مفتاح="علم!عَلِمْتَ">عَلِمْتَ</ص> أَنَّ الْمَالَ الْوَاحِدَ مِنْ أَرْبَعَةِ أَمْوَالٍ وَسُدُسٍ هُوَ خُمُسُهَا وَخُمُسُ خُمُسِهَا</مقطع>

  <مقطع هوية='٥٨٠٠٨'>فَخُذْ مِنْ جَمِيعِ مَا مَعَكَ الْخُمُسَ وَخُمُسَ الْخُمُسِ</مقطع>
  <مقطع هوية='٦٧٣٧٨'>فَيَكُونُ مَعَكَ أَرْبَعَةٌ وَعِشْرُونَ وَمَالٌ تَعْدِلُ عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٨١٢٦٩'>لِأَنَّ الْعَشَرَةَ مِنْ أَحَدٍ وَأَرْبَعِينَ شَيْئًا وَثُلُثَ شَيْءٍ خُمُسُهَا وَخُمُسُ خُمُسِهَا</مقطع>
  <مقطع هوية='١٠٢٩٥'>فَنَصِّفْ الْأَجْذَارَ وَهُوَ خَمْسَةٌ وَاضْرِبْهَا فِي مِثْلِهَا فَيَكُونُ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٦٨٠٠٥'>فَانْقُصْ مِنْهَا الْأَرْبَعَةَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ يَبْقَى وَاحِدٌ</مقطع>
  <مقطع هوية='٧٣٨٧٨'>فَخُذْ جَذْرَهُ وَهُوَ وَاحِدٌ فَانْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ وَهِيَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٤٠٤٥٦'>يَبْقَى أَرْبَعَةٌ وَهُوَ أَحَدُ الْقِسْمَيْنَ</مقطع>

  <رأس/>
  <مقطع هوية='١٥٨٧١'><ص مفتاح="علم!اعْلَمْ">وَاعْلَمْ</ص>
  أَنَّ كُلَّ شَيْئَيْنِ تَقْسِمُ هَذَا عَلَى هَذَا وَهَذَا عَلَى هَذَا</مقطع>

  <مقطع هوية='١١٦٢٠'>فَإِنَّكَ إِذَا ضَرَبْتَ الَّذِي يَخْرُجُ مِنْ هَذَا فِي الَّذِي يَخْرُجُ مِنْ هَذَا</مقطع>
  <مقطع هوية='٠٥٣١١'>كَانَ وَاحِدًا أَبَدًا</مقطع>

  <رأس/>
  <مقطع هوية='٤٠٨٩٦'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قَسْمَيْنِ
  وَضَرَبْتَ أَحَدَ الْقِسْمَيْنِ فِي خَمْسَةٍ
  وَقَسَمْتَهُ عَلَى الْآخَرِ
  ثُمَّ الْقَيْتَ نِصْفَ مَا اجْتَمَعَ مَعَكَ
  وَزِدْتَهُ عَلَى الْمَضْرُوبِ فِي خَمْسَةٍ
  فَكَانَ خَمْسِينَ دِرْهَمًا</معادلة></مقطع>

  <مقطع هوية='٩٠٤٨٨'><قياس>فَإِنَّ قِيَاسَ ذٰلِكَ</قياس> أَنْ تَأْخُذَ شَيْئًا مِّنَ الْعَشَرَةِ فَتَضْرِبَهُ فِي خَمْسَةٍ</مقطع>
  <!-- p042 -->
  <مقطع هوية='٢٠٦٣٨'><صفحة رقم="٤٢"/>فَيَكُونَ خَمْسَةَ أَشْيَاءَ مَقْسُومَةً عَلَى الْبَاقِي مِنَ الْعَشَرَةِ وَهُوَ عَشَرَةٌ إِلَّا شَيْئًا مَأْخُوذٌ نِصْفُهَا</مقطع>
  <مقطع هوية='٠٣٧٤٤'>وَ<ص مفتاح="علم!معلوم">مَعْلُومٌ</ص>
  أَنَّكَ إِذَا قَسَمْتَ الْخَمْسَةَ الأَشْيَاءَ عَلَى عَشَرَةٍ إلّا شَيْئًا</مقطع>
  <مقطع هوية='٨٧٢٥١'>وَأَخَذْتَ نِصْفَ مَا خَرَجَ</مقطع>
  <مقطع هوية='٥٣٨٠٠'>كَانَ ذٰلِكَ كَقَسْمِكَ نِصْفَ الْخَمْسَةِ الأَشْيَاءَ عَلَى الْعَشَرَةِ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٨٤٠٧٩'>فَإِذَا أَخَذْتَ نِصْفَ الْخَمْسَةِ الأَشْيَاءَ صَارَ شَيْئَيْنِ وَنِصْفًا</مقطع>
  <مقطع هوية='٦٧٦١٥'>وَهُوَ الَّذِي تُرِيدُ أَنْ تَقْسِمَهُ عَلَى عَشَرَةٍ إلّا شَيْئًا</مقطع>
  <!-- NB: seg 14129 is in Rashed only -->
  <مقطع هوية='١٤١٢٩'>فَهذا شَيْئانِ ونِصْفٌ مَقْسومٌ على عَشَرَةٍ إلّا شَيْئًا<!-- يَخْرُجُ --></مقطع>
  <مقطع هوية='٨٢٤٨٦'>يَعْدِلُ خَمْسِينَ إِلَّا خَمْسَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٣٠٥٦٢'>لِأَنَّهُ قَالَ <قبس>تَضُمُّ إِلَيْهِ أَحَدَ الْقِسْمَيْنِ مَضْرُوبًا فِي خَمْسَةٍ فَيَكُونَ ذٰلِكَ كُلُّهُ خَمْسِينَ</قبس></مقطع>
  <مقطع هوية='٤٦٥٨٥'>وَقَدْ <ص مفتاح="علم!عَلِمْتَ">عَلِمْتَ</ص> أَنَّكَ مَتَى ضَرَبْتَ مَا خَرَجَ لَكَ مِنَ الْقَسْمِ فِي الْمَقْسُومِ عَلَيْهِ عَادَ الْمَالَ</مقطع>
  <مقطع هوية='٥٣١٠٥'>وَمَالُكَ شَيْئَانِ وَنِصْفٌ
  فَاضْرِبْ عَشَرَةً إِلَّا شَيْئًا فِي خَمْسِينَ إِلَّا خَمْسَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٨٦٥٨٩'>فَيَكُونُ ذٰلِكَ خَمْسُمِائَةَ دِرْهَمٍ وَخَمْسَةَ أَمْوَالٍ إِلَّا مِائَةَ شَيْءٍ تَعْدِلُ شَيْئَيْنِ وَنِصْفًا</مقطع>
  <مقطع هوية='٥٢٩١٢'>فَارْدُدْ ذٰلِكَ إِلَى مَالٍ وَاحِدٍ فَيَكُونُ ذٰلِكَ مِائَةَ دِرْهَمٍ وَمَالًا إِلَّا عِشْرِينَ شَيْئًا تَعْدِلُ نِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٣٦٩١٠'><جبر مفتاح="جبر!اُجْبُرْ">فَاجْبُرْ</جبر> ذٰلِكَ الْمِائَةَ وَزِدْ الْعِشْرِينَ الشَّيْءَ عَلَى نِصْفِ الشَّيْءِ</مقطع>
  <مقطع هوية='٠٥٤٦٨'>فَيَصِيرُ مَعَكَ مِائَةَ دِرْهَمٍ وَمَالٌ تَعْدِلُ عِشْرِينَ شَيْئًا وَنِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٠٢٠٥٠'>فَنَصِّفْ الأَشْيَاءَ وَاضْرِبْهَا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٩٩٤٣٨'>وَانْقُصْ مِنْهُ الْمِائَةَ وَخُذْ جَذْرَ مَا بَقِيَ</مقطع>
  <مقطع هوية='٠١٩٨٠'>وَانْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ وَهُوَ عَشَرَةٌ وَرُبُعٌ</مقطع>
  <مقطع هوية='٤٩٣٨٢'>فَيَبْقَى ثَمَانِيَةٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٣٢٠٨٩'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  فَضَرَبْتَ أَحَدَ الْقِسْمَيْنِ فِي نَفْسِهِ
  فَكَانَ مِثْلَ الْآخَرِ إِحْدَى وَثَمَانِينَ مَرَّةً</معادلة></مقطع>

  <مقطع هوية='٩٤٢٧٧'><قياس>فَقِيَاسُ ذٰلِكَ</قياس> أَنْ تَقُولَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٣٨٥٥٨'>بِمِائَةٍ وَمَالٍ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٤٦٦٠'>تَعْدِلُ أَحَدًا وَثَمَانِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٨٦٢٧'><جبر مفتاح="جبر!اُجْبُرْ">فَاجْبُرِ</جبر> الْمِائَةَ وَالْمَالَ بِالْعِشْرِينَ الشَّيْءِ</مقطع>
  <مقطع هوية='٠٥٢٤٠'>وَازِدْهَا عَلَى الْوَاحِدِ وَالثَّمَانِينَ (الشَّيْءِ)</مقطع>
  <مقطع هوية='٣٥٩٦٩'>فَيَكُونُ مِائَةً وَمَالًا تُعَدِّلُ مِائَةَ جَذْرٍ وَجَذْرًا</مقطع>
  <مقطع هوية='١١٩٤٩'>فَانْصِفْ الْأَجْدَارَ فَتَكُونُ خَمْسِينَ</مقطع>
  <مقطع هوية='١٥٣٤٩'>وَاضْرِبْهَا فِي مِثْلِهَا</مقطع>
  <!-- p043 -->
  <مقطع هوية='٢٩٢٨٠'>فَيَكُونُ الْفَيْنِ وَخَمْسُمِائَةٍ <صفحة رقم="٤٣"/>وَخَمْسِينَ وَرُبْعًا</مقطع>
  <مقطع هوية='١٥٤٠٢'>فَانْقُصْ مِنْهَا الْمِائَةَ فَبَقِيَ أَلْفَانِ وَأَرْبَعُمِائَةٍ وَخَمْسُونَ وَرُبْعٌ</مقطع>
  <مقطع هوية='٩٦٦٣٧'>فَخُذْ جَذْرَهَا وَهُوَ تِسْعَةٌ وَأَرْبَعُونَ وَنِصْفٌ</مقطع>
  <مقطع هوية='٩٢٣٨٧'>فَانْقُصْهَا مِنْ نِصْفِ الْأَجْذَارِ وَهُوَ خَمْسُونَ وَنِصْفٌ</مقطع>
  <مقطع هوية='١٧٠١٤'>فَيَبْقَى وَاحِدٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٣٩٧٤٣'>فَإنْ قَالَ <معادلة>عَشَرَةُ اقْفِرَةٍ حِنْطَةً أَوْ شَعِيرًا
  بِعْتَ كُلَّ وَاحِدٍ مِنْهُمَا بِسِعْرٍ ثُمَّ جَمَعْتَ ثَمَنَهُمَا
  فَكَانَ مَا اجْتَمَعَ مِثْلَ فَضْلِ مَا بَيْنَ السِّعْرَيْنِ وَمِثْلَ مَا بَيْنَ الْكَيْلَيْنِ</معادلة></مقطع>
  <مقطع هوية='١٦٣٨١'>فَخُذْ مَا شِئْتَ فَإِنَّهُ يَجُوزُ فَكَأَنَّكَ أَخَذْتَ أَرْبَعَةً وَسِتَّةً</مقطع>
  <مقطع هوية='٣١٧٩١'>فَقُلْتَ بِعْتُ كُلَّ وَاحِدٍ مِنَ الْأَرْبَعَةِ بِشَيْءٍ</مقطع>
  <مقطع هوية='٣٨٠٧٧'>فَضَرَبَتْ أَرْبَعَةً فِي شَيْءٍ فَصَارَ أَرْبَعَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٧٧٧٩٢'>وَبِعْتُ السِّتَّةَ كُلَّ وَاحِدٍ بِمِثْلِ نِصْفِ الشَّيْءِ الَّذِي بِعْتُ بِهِ الأَرْبَعَةَ</مقطع>
  <مقطع هوية='٩٢٧٠٧'>وَإِنْ شِئْتَ بِثُلُثِهِ وَإِنْ شِئْتَ بِرُبْعِهِ أَوْ مَا شِئْتَ فَإِنَّهُ يَجُوزُ</مقطع>
  <مقطع هوية='٤٤٩٦٠'>فَإِذَا كَانَ بَيْعُكَ الآخَرَ بِنِصْفِ شَيْءٍ فَاضْرِبْ نِصْفَ شَيْءٍ فِي سِتَّةٍ فَيَكُونَ ثَلاَثَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٩٩٩٩٩'>فَاجْمَعْهَا مَعَ الأَرْبَعَةِ الأَشْيَاءَ فَتَكُونَ سَبْعَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٦٤٩٤٤'>تَعْدِلُ مَا بَيْنَ الْكَيْلَيْنِ وَهُوَ قَفِيْزَان</مقطع>
  <مقطع هوية='٨٩٤٩٠'>وَفَضَلَ مَا بَيْنَ السِّعْرَيْنِ وَهُوَ نِصْفُ شَيْءٍ</مقطع>
  <مقطع هوية='٣٤٥٢٥'>فَيَكُونُ سَبْعَةَ أَشْيَاءَ تَعْدِلُ اثْنَيْنِ وَنِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٣٩٠٩٩'>فَأَلْقِ نِصْفَ شَيْءٍ مِمَّا سَبْعَةَ أَشْيَاءَ فَتَبْقَى سِتَّةَ أَشْيَاءَ وَنِصْفُ (شَيْءٍ) تَعْدِلُ دِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٨١١٨٧'>فَالشَّيْءُ الْواحِدُ أَرْبَعَةُ أَجْزَاءٍ مِنْ ثَلَاثَةَ عَشَرَ</مقطع>
  <!-- p044 -->
  <مقطع هوية='٩١٥٧٤'>فَتَقُولُ بَاعَ الأَرْبَعَةَ <صفحة رقم="٤٤"/>كُلُّ وَاحِدٍ بِأَرْبَعَةِ أَجْزَاءِ مِنْ ثَلَاثَةَ عَشَرَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٠٥٦١٧'>وَبَاعَ السِّتَّةَ كُلَّ وَاحِدٍ بِجُزْأَيْنِ مِنْ ثَلَاثَةَ عَشَرَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٨٠١٥٥'>فَبَلَغَ ذٰلِكَ ثَمَانِيَةً وَعِشْرِينَ جُزْئًا مِنْ ثَلَاثَةَ عَشَرَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٦١٥٣٧'>وَذٰلِكَ مِثْلُ فَضْلِ مَا بَيْنَ الْكَيْلَيْنِ وَهُوَ قَفِيرَانِ</مقطع>
  <مقطع هوية='٧٨٢٩٣'>فَصَرْفُهُمَا سِتَّةً وَعِشْرُونَ جُزْءًا</مقطع>
  <مقطع هوية='١٤٦٧٤'>وَفَضْلُ مَا بَيْنَ السِّعْرَيْنِ وَهُوَ جُزْءَانِ فَذٰلِكَ ثَمَانِيَةٌ وَعِشْرُونَ جُزْءًا</مقطع>

  <مقطع هوية='٣١٨٩٧'>فَإنْ قَالَ <معادلة>مَالانِ بَيْنَهُمَا دِرْهَمَانِ
  قَسَمْتَ الْقَلِيلَ عَلَى الْكَثِيرِ فَأَصَابَ الْقِسْمَ نِصْفُ دِرْهَمٍ</معادلة></مقطع>
  <مقطع هوية='٥٥٩٢٤'>فَاجْعَلْ أَحَدَ الْمَالَيْنِ شَيْئًا وَالْآخَرَ شَيْئًا وَدِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٥٣٣٠٢'>فَلَمَّا قَسَمْتَ شَيْئًا على شَيْءٍ وَدِرْهَمَيْنِ
  خَرَجَ الْقِسْمُ نِصْفَ دِرْهَمٍ</مقطع>
  <مقطع هوية='٦٣٢٩٢'>وَقَدْ عَلِمْتَ أَنَّكَ مَتَى ضَرَبْتَ مَا خَرَجَ لَكَ مِنَ الْقِسْمِ فِي الْمَقْسُومِ عَلَيْهِ</مقطع>
  <مقطع هوية='٧٣٩٥٢'>عَادَ مَالُكَ الَّذِي قَسَمْتَهُ وَهُوَ شَيْءٌ</مقطع>
  <مقطع هوية='٦٦١٠٢'>فَقُلْ شَيْءٌ وَدِرْهَمَانِ فِي النِّصْفِ الَّذِي هُوَ الْقِسْمُ</مقطع>
  <مقطع هوية='٦٩١١٤'>فَيَكُونُ نِصْفَ شَيْءٍ وَدِرْهَمًا تَعْدِلُ الشَّيْءَ</مقطع>
  <مقطع هوية='٢٧٠٦٩'>فَأَلْقَيْتَ نِصْفَ شَيْءٍ بِنِصْفِ شَيْءٍ وَبَقِيَ دِرْهَمٌ يَعْدِلُ نِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٢٠٠٧٣'>فَأضْعِفْهُ يَكُونَ الشَّيْءُ يَعْدِلُ دِرْهَمَيْنِ وَالْآخَرُ أَرْبَعَةَ</مقطع>

  <مقطع هوية='١٩١٥٦'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  وَضَرَبْتَ أَحَدُهُمَا فِي عَشَرَةٍ وَالْقِسْمُ الآخَرُ فِي نَفْسِهِ فَاسْتَوَيَا</معادلة></مقطع>
  <مقطع هوية='٥٨٢٥٩'><قياس>فَإِنْ قِيَاسُهُ</قياس> أَنْ تَضْرِبَ شَيْئًا فِي عَشَرَةٍ فَيَكُونَ عَشَرَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٧٤١٠٠'>ثُمَّ تَضْرِبَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا فَتَكُونَ مَائَةً وَمَالا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٩٦٤٠٤'>تَعْدِلُ الْعَشَرَةَ الْأَجْذَارَ</مقطع>
  <مقطع هوية='٩٣١٢٢'><مقابلة>فَقَابِلْ بِهَا</مقابلة> عَلَى مَا قَدْ وَصَفْتُ لَكَ</مقطع>

  <مقطع هوية='٦٩٢٢٩'>وَكَذٰلِكَ لَوْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  ثُمَّ ضَرَبْتَ أَحَدَهُمَا فِي الْآخَرِ
  ثُمَّ اجْتَمَعْتَ مِنَ الضَّرْبِ عَلَى فَضْلِ مَا بَيْنَ الْقِسْمَيْنِ قَبْلَ أَنْ تَضْرِبَ أَحَدَهُمَا فِي الْآخَرِ
  خَرَجَ خَمْسَةً وَرُبْعًا</معادلة></مقطع>
  <!-- p045 -->
  <مقطع هوية='٣٦١٠٤'><صفحة رقم="٤٥"/><قياس>فقِيَاسُهُ</قياس> أَنْ تَأْخُذَ شَيْئًا مِنَ الْعَشَرَةِ فَيَبْقَى عَشَرَةً إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٩٨٩٣١'>فَاضْرِبْ أَحَدَهُمَا فِي الْآخَرِ
  فَيَكُونَ عَشَرَةَ أَجْذَارٍ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٠٠٩٦٣'>فَهُوَ مَا خَرَجَ مِنْ ضَرْبِ أَحَدِ الْقِسْمَيْنِ فِي الْآخَرِ</مقطع>
  <مقطع هوية='٥٦٨٣١'>ثُمَّ قَسَمْتَ ذٰلِكَ عَلَى فَضْلِ مَا بَيْنَ الْقِسْمَيْنِ وَهُوَ عَشَرَةٌ إِلَّا شَيْئَيْنِ</مقطع>
  <مقطع هوية='٥٠٩٦١'>فَخَرَجَ مِنَ الْقِسْمِ خَمْسَةٌ وَرُبُعٌ</مقطع>
  <مقطع هوية='٤٨١٤٩'>وَمَتَى ضَرَبْتَ خَمْسَةً وَرُبُعًا فِي عَشَرَةٍ إِلَّا شَيْءٍ</مقطع>
  <مقطع هوية='٧٨٨٥٣'>خَرَجَ لَكَ الْمَالُ الْمَضْرُوبُ وَهُوَ عَشَرَةُ أَشْيَاءَ إِلَّا مَالٍ</مقطع>
  <مقطع هوية='٠٦٣٢٢'>فَاضْرِبْ خَمْسَةً وَرُبُعًا فِي عَشَرَةٍ إِلَّا شَيْئَيْنِ</مقطع>
  <مقطع هوية='٣٠٧٤٠'>يَكُونُ ذٰلِكَ اثْنَيْنِ وَخَمْسِينَ دِرْهَمًا وَنِصْفًا إِلَّا عَشَرَةَ أَجْذَارٍ وَنِصْفًا</مقطع>
  <مقطع هوية='٠٩٢٧٥'>تَعْدِلُ عَشَرَةَ أَجْذَارٍ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٣٤١٧٣'><جبر مفتاح="جبر!اُجْبُرْ">فَاجْبُرِ</جبر> الِاثْنَيْنِ وَالْخَمْسِينَ وَالنِّصْفَ بِالْعَشَرَةِ الْأَجْذَارِ وَالنِّصْفِ</مقطع>
  <مقطع هوية='٦٢١٢١'>وَزِدْهَا عَلَى الْعَشَرَةِ الْأَجْذَارِ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٣١٠٨٩'>ثُمَّ <جبر مفتاح="جبر!اُجْبُرْ">اجْبُرْهَا</جبر> بِالْمَالِ وَزِدْ الْمَالَ عَلَى اثْنَيْنِ وَخَمْسِينَ دِرْهَمًا وَنِصْفٍ</مقطع>
  <مقطع هوية='٢٦٤٦٦'>فَيَكُونُ مَعَكَ عِشْرُونَ جَذْرًا وَنِصْفُ جَذْرٍ تَعْدِلُ اثْنَيْنِ وَخَمْسِينَ دِرْهَمًا وَنِصْفًا وَمَالًا</مقطع>
  <مقطع هوية='٨١٩٧٠'><مقابلة>فَقَابِلْ بِهَا</مقابلة> عَلَى ما فَسَّرْنَا فِي أَوَّلِ الْكِتَابِ</مقطع>

  <مقطع هوية='٢٧٣٤٣'>فَإِنْ قَالَ <معادلة>مَالٌ ثُلُثَا خُمُسِهِ مِثْلَ سُبُعِ جَذْرِه</معادلة></مقطع>
  <مقطع هوية='٧٥١٠١'>فَإِنَّ الْمَالَ كُلَّهُ يَعْدِلُ جَذْرًا وَنِصْفَ سُبُعِ جَذْرٍ</مقطع>
  <مقطع هوية='٢٤١٤٤'>فَالجَذْرُ أَرْبَعَةَ عَشَرَ جُزْءًا مِنْ خُمَسَةَ عَشَرَ مِنَ الْمَالِ</مقطع>
  <مقطع هوية='٧٤٠٧٩'><قياس>وَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ ثُلُثَيْ خُمُسِ مَالٍ فِي سَبْعَةٍ وَنِصْفٍ لِيَتِمَّ الْمَالُ</مقطع>
  <مقطع هوية='٨٧٨٥١'>وَاضْرِبْ مَا مَعَكَ وَهُوَ سُبْعُ جَذْرٍ فِي مِثْلِ ذٰلِكَ</مقطع>
  <مقطع هوية='١٦٥١٦'>فَيَصِيرُ الْمَالُ يَعْدِلُ جَذْرًا وَنِصْفَ سُبْعِ جَذْرٍ</مقطع>
  <مقطع هوية='٨٠٢٥٩'>وَيَصِيرُ جَذْرُهُ وَاحِدًا وَنِصْفَ سُبْعٍ</مقطع>
  <مقطع هوية='٩٠١٥٠'>فَالْمَالُ وَاحِدٌ وَتِسْعَةٌ وَعِشْرُونَ جُزْءً</مقطع>
  <مقطع هوية='٨٥٩٧٥'>مِنْ مِائَةٍ وَسِتَّةٍ وَتِسْعِينَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٨٥٨٨٩'>وَثُلُثَا خُمُسِهِ يَكُونُ ثَلاَثِينَ جُزْءً مِنْ مِائَةٍ وَسِتَّةٍ وَتِسْعِينَ</مقطع>
  <مقطع هوية='٦٥٢٦٢'>وَسُبْعُ جَذْرِهِ أَيْضًا ثَلاَثُونَ جُزْءًا مِنْ مِائَةٍ وَسِتَّةٍ وَتِسْعِينَ</مقطع>

  <مقطع هوية='٧٦٠١٦'>فَإِنْ قَالَ <معادلة>مَالٌ ثَلاثَةُ أَرْبَاعِ خُمُسِهِ
  مِثْلُ أَرْبَعَةِ أَخْمَاسِ جَذْرِهِ</معادلة></مقطع>
  <مقطع هوية='٧٨٥٩٢'><قياس>قِيَاسُهُ</قياس> أَنْ تَزِيدَ عَلَى ثَلاثَةِ أَرْبَاعِ خُمُسِهِ مِثْلَ رُبُعِهَا لِيَكُونَ الْجَذْرُ تَامًّا</مقطع>
  <مقطع هوية='٧٥٨٠٤'>وَذٰلِكَ ثَلاثَةٌ وَثَلاثَةُ أَرْبَاعٍ مِنْ عِشْرِينَ</مقطع>
  <مقطع هوية='٣٩١٣٢'>فَاجْعَلْهَا أَرْبَاعًا كُلَّهَا فَتَكُونُ خَمْسَةَ عَشَرَ مِنْ ثَمَانِينَ</مقطع>
  <!-- p046 -->
  <مقطع هوية='٣٣١١٥'>فَاقْسِمْ الثَّمَانِينَ <صفحة رقم="٤٦"/>عَلَى الْخَمْسَةِ عَشَرَ فَيَكُونُ خَمْسَةً وَثُلُثًا</مقطع>
  <مقطع هوية='٥٤٣٧٩'>فَذٰلِكَ جَذْرُ الْمَالِ وَالْمَالُ ثَمَانِيَةٌ وَعِشْرُونَ وَأَرْبَعَةٌ اتِّسَاعٌ</مقطع>

  <مقطع هوية='٤٧٧٩٦'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي أَرْبَعَةِ أَمْثَالِهِ فَيَكُونُ عِشْرِينَ</معادلة></مقطع>
  <مقطع هوية='٦٧٧٧٥'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي مِثْلِهِ كَانَ خَمْسَةً وَهُوَ جَذْرُ خَمْسَةٍ</مقطع>

  <مقطع هوية='٧٤٩٣٧'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي ثُلُثِهِ فَيَكُونُ عَشَرَةً</معادلة></مقطع>
  <مقطع هوية='٩٧٠٠٢'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي مِثْلِهِ كَانَ ثَلَاثِينَ فَتَقُولُ الْمَالُ جَذْرُ ثَلَاثِينَ</مقطع>

  <مقطع هوية='٩٢٨٧٨'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي أَرْبَعَةِ أَمْثَالِهِ فَيَعُودُ ثُلُثَ الْمَالِ الأَوَّلِ</معادلة></مقطع>
  <مقطع هوية='٢٩٦٠٢'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي اثْنَيْ عَشَرَ مِثْلَهُ عَادَ الْمَالُ</مقطع>
  <مقطع هوية='٥٨٥٦٨'>وَهُوَ نِصْفُ سُدُسٍ فِي ثُلُثٍ</مقطع>

  <مقطع هوية='٦٦٨٠٣'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي جَذْرِهِ
  فَيَعُودُ ثَلاثَةَ أَمْثَالِ الْمَالِ الأَوَّلِ</معادلة></مقطع>
  <مقطع هوية='١٨٦٨٦'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَ الْجَذْرَ فِي ثُلُثِ الْمَالِ عَادَ الْمَالُ</مقطع>
  <مقطع هوية='٢٢٠٢٣'>فَتَقُولُ هَذَا مَالٌ ثُلُثُهُ جَذْرُهُ وَهُوَ تِسْعَةٌ</مقطع>

  <مقطع هوية='٦٩٧١٦'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ أَرْبَعَةَ أَجْذَارِهِ فِي ثَلاثَةِ أَجْذَارِهِ فَيَعُودُ الْمَالَ وَزِيَادَةُ أَرْبَعَةٍ وَأَرْبَعِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٣٩٩٨١'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ أَرْبَعَةَ أَجْذَارٍ فِي ثَلاثَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٦٧٣٦٣'>فَيَكُونُ اثْنَيْ عَشَرَ مَالًا تَعْدِلُ مَالًا وَأَرْبَعَةً وَأَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٣٢٢٨١'>فَأَلْقِ مِنَ الِاثْنَيْ عَشَرَ الْمَالِ مَالًا فَيَبْقَى أَحَدُ عَشَرَ مَالًا</مقطع>
  <مقطع هوية='٣٩٤٤١'>تَعْدِلُ أَرْبَعَةً وَأَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٥٢٤٧٥'>فَاقْسِمْهَا عَلَيْهَا تَكُنْ أَرْبَعَةً وَهُوَ الْمَالُ</مقطع>

  <مقطع هوية='٠٦٨٣١'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ أَرْبَعَةَ أَجْذَارِهِ فِي خَمْسَةِ أَجْذَارِهِ فَيَعُودُ مِثْلَيْ الْمَالِ وَزِيَادَةَ سِتَّةَ وَثَلاثِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٥٨٧٥٩'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ تَضْرِبُ أَرْبَعَةَ أَجْذَارٍ فِي خَمْسَةِ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٧٣٢٠'>فَيَكُونُ عِشْرِينَ مَالًا تَعْدِلُ مَالَيْنِ وَسِتَّةَ وَثَلاثِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٤٧٤٥٣'>فَتُلْقِي مِنَ الْعِشْرِينَ الْمَالَ مَالَيْنِ بِمَالَيْنِ</مقطع>
  <مقطع هوية='٧٩٢٥٠'>فَتَبْقَى ثَمَانِيَةَ عَشَرَ مَالًا تَعْدِلُ سِتَّةَ وَثَلاثِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٠٣٥٤'>فَتَقْسِمُ سِتَّةَ وَثَلاثِينَ دِرْهَمًا عَلَى ثَمَانِيَةَ عَشَرَ</مقطع>
  <مقطع هوية='١٦٨٨٧'>فَيَكُونُ الْقَسْمُ أَثْنَيْنِ وَهُوَ الْمَالُ</مقطع>

  <مقطع هوية='١٦٦٠٩'>وَكَذٰلِكَ لَوْ قَالَ <معادلة>مَالٌ تَضْرِبُ جَذْرَهُ فِي أَرْبَعَةِ أَجْذَارِهِ فَيَعُودُ ثَلاثَةَ أَمْثَالِ الْمَالِ وَزِيَادَةَ خَمْسِينَ <صفحة رقم="٤٧"/>درهما</معادلة></مقطع>
  <!-- p047 -->
  <مقطع هوية='٧٨٦٧٣'>قِيَاسُهُ أَنْ تَضْرِبَ جَذْرًا فِي أَرْبَعَةِ أَجْدَارٍ</مقطع>
  <مقطع هوية='٥٢٥١٠'>فَيَكُونَ أَرْبَعَةَ أَمْوَالٍ تَعْدِلُ ثَلاثَةَ أَمْوَالٍ وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٨٥٢٨٨'>فَأَلْقِ ثَلاثَةَ أَمْوَالٍ مِنَ الأَرْبَعَةِ الْأَمْوَالِ</مقطع>
  <مقطع هوية='٢٤٠٩٥'>يَبْقَى مَالٌ وَاحِدٌ يَعْدِلُ خَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩١٠٠٣'>وَهُوَ جَذْرُ خَمْسِينَ مَضْرُوبٌ فِي أَرْبَعَةِ أَجْدَارِ خَمْسِينَ أَيْضًا</مقطع>
  <مقطع هوية='٢٥٧٠٨'>فَذٰلِكَ مَائَتَانِ يَكُونُ ثَلاثَةَ أَمْثَالِ الْمَالِ وَزِيَادَةُ خَمْسِينَ دِرْهَمًا</مقطع>

  <مقطع هوية='٣٩٥٢٨'>فَإِنْ قَالَ <معادلة>مالٌ تَزِيدُ عَلَيْهِ عِشْرِيْنَ دِرْهَمًا فَيَكُونُ مِثْلَ أَثْنَيْ عَشَرَ جَذْرِهِ</معادلة></مقطع>
  <مقطع هوية='١١١٩٥'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَقُولَ مَالٌ وَعَشْرُونَ دِرْهَمًا تَعْدِلُ أَثْنَيْ عَشَرَ جَذْرًا</مقطع>
  <مقطع هوية='٠٥٣١٩'>فَنَصِّفْ الْأَجْدَارَ وَاضْرِبْهَا فِي مِثْلِهَا تَكُنْ سِتَّةً وَثَلاَثِينَ</مقطع>
  <مقطع هوية='٧١٢٥٧'>فَانْقُصْ مِنْهَا الْعِشْرِينَ الدِّرْهَمَ وَخُذْ جَذْرَ مَا بَقِيَ</مقطع>
  <مقطع هوية='١٣١٩٨'>فَانْقُصْهُ مِنْ نِصْفِ الْأَجْدَارِ وَهُوَ سِتَّةٌ</مقطع>
  <مقطع هوية='٠٤٥٢٢'>فَمَا بَقِيَ فَهُوَ جَذْرُ الْمَالِ وَهُوَ دِرْهَمَانِ وَالْمَالُ أَرْبَعَةٌ</مقطع>

  <مقطع هوية='٠٨٤٢٠'>فَإِنْ قَالَ <معادلة>مَالٌ تَعْزِلُ ثُلُثَهُ وَثَلَاثَةُ دَرَاهِمَ
  وَتَضْرِبُ مَا بَقِيَ فِي مِثْلِهِ فَيَعُودُ الْمَالُ</معادلة></مقطع>
  <مقطع هوية='٩٤٧٣٣'><قياس>قِيَاسُهُ</قياس> أَنْكَ إِذَا أَلْقَيْتَ ثُلُثَهُ وَثَلَاثَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٧٨٧٠٤'>بَقِيَ ثُلُثَاهُ إِلَّا ثَلاثَةَ دَرَاهِمَ وَهُوَ جَذْرٌ</مقطع>
  <مقطع هوية='٩٣٧٣٨'>فَاضْرِبْ ثُلُثَيْ شَيْءٍ إِلَّا ثَلَاثَةَ دَرَاهِمَ فِي مِثْلِهِ</مقطع>
  <مقطع هوية='٠٠٤٣٠'>فَتَقُولُ ثُلُثَانِ فِي ثُلُثَيْنِ أَرْبَعَةَ أَتْسَاعِ مَالٍ</مقطع>
  <مقطع هوية='٩١١٢٤'>وَإِلَّا ثَلَاثَةَ دَرَاهِمَ فِي ثُلُثَيْ شَيْءٍ جَذْرَانِ</مقطع>
  <مقطع هوية='٩٤٣٦٧'>وَإِلَّا ثَلَاثَةَ دَرَاهِمَ فِي ثُلُثَيْ شَيْءٍ جَذْرَانِ</مقطع>
  <مقطع هوية='٦٠٢٩٩'>وَإِلَّا ثَلَاثَةَ دَرَاهِمَ فِي إِلَّا ثَلَاثَةَ دَرَاهِمَ تِسْعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٠٩٧٣٧'>فَيَصِيرُ مَعَكَ أَرْبَعَةُ اتِّسَاعِ مَالٍ وَتِسْعَةُ دَرَاهِمَ إِلَّا أَرْبَعةَ أَجْذَارٍ تَعْدِلُ جَذْرًا</مقطع>
  <مقطع هوية='٦٣٠٥٩'>فَرُدَّ الأَرْبَعَةَ الأَجْذَارِ عَلَى الْجَذْرِ فَيَكُونُ خَمْسَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٦٢٥٤٤'>تَعْدِلُ أَرْبَعَةَ اتِّسَاعٍ ( مَالٍ ) وَتِسْعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢١٩٧٧'>فَأَكْمِلْ مَالَكَ وَهُوَ أَنْ تَضْرِبَ الأَرْبَعَةَ الْأَتْسَاعَ فِي اثْنَيْنِ وَرُبْعٍ فَيَكُونُ مَالًا</مقطع>
  <مقطع هوية='٦٨٧٨٥'>وَاضْرِبْ تِسْعَةَ دَرَاهِمَ فِي اثْنَيْنِ وَرُبْعٍ يَكُونُ عِشْرِينَ وَرُبْعًا</مقطع>
  <!-- p048 -->
  <مقطع هوية='٦٣٧١٩'>ثُمَّ اضْرِبْ الْخَمْسَةَ الأَجْذَارَ <صفحة رقم="٤٨"/> فِي أَثْنَيْنِ وَرُبُعٍ</مقطع>
  <مقطع هوية='٨٥٢١٥'>فَيَكُونُ أَحَدَ عَشَرَ شَيْئًا وَرُبُعًا</مقطع>
  <مقطع هوية='٩٨٣٠٥'>فَيَصِيرُ مَعَكَ مَالٌ وَعِشْرُونَ دِرْهَمًا وَرُبُعٌ تَعْدِلُ أَحَدَ عَشَرَ جَذْرًا وَرُبُعًا</مقطع>
  <مقطع هوية='٤٨٨١٠'><ص مفتاح="قبل!قابِلْ">فَقَابِلْ بِذٰلِكَ</ص> كَنَحْوِ مَا وَصَفْتُ لَكَ فِي تَنْصِيفِ الْأَجْذَارِ إِنْ شَاءَ اللّٰهُ</مقطع>

  <مقطع هوية='٣٣٥٢١'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ ثُلُثَهُ فِي رُبُعِهِ فَيَعُودُ الْمَالُ</معادلة></مقطع>
  <مقطع هوية='١٦٩٨٦'><قياس>قِيَاسُهُ</قياس> أَنْ تَضْرِبَ ثُلُثَ شَيْءٍ فِي رُبْعِ شَيْءٍ فَيَكُونَ نِصْفَ سُدُسِ مَالٍ تَعْدِلُ شَيْئًا</مقطع>
  <مقطع هوية='١٤٤٧٢'>فَالْمَالُ يَعْدِلُ اثْنَيْ عَشَرَ شَيْئًا وَهُوَ جَذْرُ مِائَةٍ وَأَرْبَعَةٍ وَأَرْبَعِينَ</مقطع>

  <مقطع هوية='٧٤٣١٢'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ ثُلُثَهُ وَدِرْهَمًا فِي رُبْعِهِ وَدِرْهَمَيْنِ فَيَعُودُ الْمَالُ وَزِيَادَةُ ثَلاثَةَ عَشَرَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٤٧٨١١'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ ثُلُثَ شَيْءٍ فِي رُبْعِ شَيْءٍ فَيَكُونَ نِصْفَ سُدُسِ مَالٍ</مقطع>
  <مقطع هوية='٧٤٠٤٧'>وَتَضْرِبَ دِرْهَمَيْنِ فِي ثُلُثِ شَيْءٍ فَيَكُونَ ثُلُثَا جَذْرٍ </مقطع>
  <مقطع هوية='٨٣٥٠٣'>وَدِرْهَمًا فِي رُبْعِ شَيْءٍ فَيَكُونَ رُبُعَ جَذْرٍ</مقطع>
  <مقطع هوية='٧٩٨٥٣'>وَدِرْهَمَيْنِ فَدِرْهَمٌ بِدِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٠٤٢٧١'>فَذٰلِكَ نِصْفُ سُدُسِ مَالٍ وَدِرْهَمَانِ وَأَحَدَ عَشَرَ جُزْءً مِنِ اثْنَيْ عَشَرَ جُزْءً مِنْ جَذْرٍ تَعْدِلُ جَذْرًا وَثَلَاثَةَ عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٣٦٣٣١'>فَأَلْقِ دِرْهَمَيْنِ مِنْ ثَلاثَةَ عَشَرَ بِدِرْهَمَيْنِ فَيَبْقَى أَحَدَ عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٦٧٢٧٩'>وَأَلْقِ أَحَدَ عَشَرَ جُزْءً مِنْ جَذْرٍ</مقطع>
  <مقطع هوية='٢٩٢٨٤'>فَيَبْقَى نِصْفُ سُدُسِ جَذْرٍ وَأَحَدَ عَشَرَ دِرْهَمًا تَعْدِلُ نِصْفَ سُدُسِ مَالٍ</مقطع>
  <مقطع هوية='١٦١٧٥'>فَأَكْمِلْهُ وَذٰلِكَ أَنْ تَضْرِبَهُ فِي اِثْنَي عَشَرَ</مقطع>
  <مقطع هوية='٢٣٣٨٦'>وَتَضْرِبَ كُلَّ مَا مَعَكَ فِي اِثْنَي عَشَرَ</مقطع>
  <مقطع هوية='٩٤٢٦٣'>فَيَكُونُ مَالًا يَعْدِلُ مِائَةً وَاثْنَيْنِ وَثَلاثِينَ دِرْهَمًا وَجَذْرًا</مقطع>
  <مقطع هوية='٣٣٩٩٧'><مقابلة>فَقَابِلْ بِهِ</مقابلة> تُصِبْ إن شَاءَ اللَّهُ تَعَالَى كَمَا وَصَفْتُ لَكَ</مقطع>

  <مقطع هوية='٨٨٣٠٥'>فَإِنْ قَالَ <معادلة>دِرْهَمٌ وَنِصْفٌ
  مَقْسُومٌ عَلَى رَجُلٍ وَبَعْضِ رَجَالٍ
  فَأَصَابَ الرَّجُلُ مِثْلَيْ الْبَعْضِ</معادلة></مقطع>
  <!-- p049 -->
  <مقطع هوية='٢٣٦٠٠'><قياس>فقياسه</قياس> أن <صفحة رقم="٤٩"/> تَقُولُ الرَّجُلُ وَالْبَعْضُ هُوَ وَاحِدٌ وَشَيْءٌ</مقطع>
  <مقطع هوية='٢٦٤٨٧'>فَكَأَنَّهُ قَالَ دِرْهَمٌ وَنِصْفٌ بَيْنَ وَاحِدٍ وَشَيْءٍ
  فَأَصَابَ الْوَاحِدُ شَيْئَيْنِ</مقطع>
  <مقطع هوية='١١٧٨٠'>فَاضْرِبِ الشَّيْئَيْنِ فِي الْوَاحِدِ وَالشَّيْءِ</مقطع>
  <مقطع هوية='٦٠٤٤٣'>فَيَكُونُ مَالَيْنِ وَشَيْئَيْنِ تَعْدِلُ دِرْهَمًا وَنِصْفًا</مقطع>
  <مقطع هوية='٨٤٩٥١'>فَرُدَّهَا إِلَى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٩٩٥٨٠'>وَهُوَ أَنْ تَأْخُذَ مِنْ كُلِّ مَا مَعَكَ نَصِّفْهُ</مقطع>
  <مقطع هوية='١٥٥٤٩'>فَتَقُولُ مَالٌ وَشَيْءٌ تَعْدِلُ ثَلاثَةَ أَربَاعٍ دِرْهَمٍ</مقطع>
  <مقطع هوية='٦٢٨٩٢'><مقابلة>فَقَابِلْ بِهِ</مقابلة> عَلَى نَحْوِ مَا وَصَفْتُ لَكَ فِي صَدْرِ الْكِتَابِ</مقطع>

  <مقطع هوية='٢٣٩٠٠'>فَإِنْ قَالَ <معادلة>مَالٌ عَزَلْتَ ثُلُثَهُ وَرُبْعَهُ وَأَرْبَعَةَ دَرَاهِمَ وَضَرَبْتَ مَا بَقِيَ فِي مِثْلِهِ
  فَعَادَ الْمَالُ وَزِيَادَةٌ أَثْنَي عَشَرَ دَرْهَمًا</معادلة></مقطع>

  <مقطع هوية='٤٨٤٨٣'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ تَأْخُذُ شَيْئًا فَتَعْزِلُ ثُلُثَهُ وَرُبُعَهُ</مقطع>
  <مقطع هوية='٦٨١٩٢'>فَيَبْقَى خَمْسَةُ أَجْزَاءٍ مِنِ اثْنَيْ عَشَرَ جُزْءًا مِنْ شَيْءٍ</مقطع>
  <مقطع هوية='١٥٩٦٢'>فَتَعْزِلُ مِنْهَا أَرْبَعَةَ دَرَاهِمَ أَيْضًا</مقطع>
  <مقطع هوية='٩١٦٣١'>فَيَبْقَى خَمْسَةُ أَجْزَاءٍ مِنْ اثْنَيْ عَشَرَ مِنْ شَيْءٍ إِلَّا أَرْبَعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢١٢٦٠'>فَتَضْرِبُهَا فِي مِثْلِهَا فَتَكُونَ الأَجْزَاءُ الْخَمْسَةُ خَمْسَةً وَعِشْرِينَ حُزْءًا</مقطع>
  <مقطع هوية='٤٥٦٩٦'>وَتَضْرِبُ الِاثْنَيْ عَشَرَ فِي مِثْلِهَا فَتَكُونَ مِائَةً وَأَرْبَعَةً وَأَرْبَعِينَ</مقطع>
  <مقطع هوية='٤٥٤٧٠'>فَذٰلِكَ خَمْسَةٌ وَعِشْرُونَ مِنْ مِائَةٍ وَأَرْبَعَةٍ وَأَرْبَعِينَ مِنْ مَالٍ</مقطع>
  <مقطع هوية='٢٥٢١٤'>ثُمَّ تَضْرِبُ الأَرْبَعَةَ الدَّرَاهِمَ فِي الْخَمْسَةِ الأَجْزَاءِ مِنِ اثْنَيْ عَشَرَ مِنْ شَيْءٍ مَرَّتَيْنِ</مقطع>
  <مقطع هوية='٥٥٧٤٣'>فَيَكُونَ أَرْبَعِينَ جُزْءًا كُلُّ اثْنَيْ عَشَرَ مِنْهَا شَيْءٌ</مقطع>
  <مقطع هوية='١١٠٧١'>وَالْأَرْبَعَةُ الدَّرَاهِمِ فِي الأَرْبَعَةِ الدَّرَاهِمِ سِتَّةَ عَشَرَ دِرْهَمًا زَائِدَةً</مقطع>

  <مقطع هوية='٨٧٥٧١'>فَتَصِيرُ الْأَرْبَعُونَ الْجُزْءُ ثَلاثَةً أَجْذَارٍ وَثُلُثَ جَذْرٍ نَاقِصٍ</مقطع>
  <مقطع هوية='٧٥٠٣١'>فَتَحْصُلُ مَعَكَ خَمْسَةً وَعِشْرُونَ جُزْءًا مِنْ مِائَةٍ</مقطع>
  <مقطع هوية='٥٥٠٥٩'>وَأَرْبَعَةً وَأَرْبَعِينَ جُزْءًا مِنْ مَالٍ</مقطع>
  <مقطع هوية='٦٤٧٨٧'>وَسِتَّةَ عَشَرَ دِرْهَمًا إِلَّا ثَلاثَةَ أَجْذَارٍ وَثُلُثَ جَذْرٍ</مقطع>
  <مقطع هوية='٩٤٢٧٩'>تَعْدِلُ الْمَالَ الْأَوَّلَ وَهُوَ شَيْءٌ وَاثْنَي عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٩٣٢٠'><جبر مفتاح="جبر!اُجْبُرْ">فَاجْبُرْهُ</جبر> وَزِدِ الثَّلَاثَةَ الأَجْذَارِ وَالثُّلُثَ عَلَى الشَّيْءِ وَالِاثْنَي عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩٤١٠٧'>فَتَصِيرُ أَرْبَعَةَ أَجْذَارٍ وَثُلُثَ جَذْرٍ وَاثْنَي عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٢٤١٥٩'><مقابلة>فَقَابِلْ بِهِ</مقابلة> وَأَلْقِ اثْنَي عَشَرَ مِنْ سِتَّةِ عَشَرَ</مقطع>
  <مقطع هوية='٧٢٤٧٣'>يَبْقَى أَرْبَعَةُ دَرَاهِمَ وَخَمْسَةً وَعِشْرُونَ جُزْءًا مِنْ مِائَةٍ (وَأَرْبَعَةً)</مقطع>
  <مقطع هوية='١٧٧٦٤'>وَأَرْبَعِينَ مِنْ مَالٍ تَعْدِلُ أَرْبَعَةَ أَجْذَارٍ<صفحة رقم="٥٠"/> وثُلُثًا </مقطع>
  <!-- p050 -->
  <مقطع هوية='٣٧٣٩٨'>فَتَحْتَاجُ أَنْ تُكْمِلَ مَالَكَ</مقطع>
  <مقطع هوية='٥٧٥٧٠'>وَإِكْمَالُكَ إِيَّاهُ أَنْ تَضْرِبَ جَمِيعَ مَا مَعَكَ فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ أَجْزَاءِ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٢٩٩٩'>فَتَضْرِبُ خَمْسَةً وَعِشْرِينَ فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ خَمْسَةٍ وَعِشْرِينَ فَيَكُونُ مَالًا</مقطع>
  <مقطع هوية='٦٥٧٩٣'>وَتَضْرِبُ الْأَرْبَعَةَ الدِّرَاهِمَ فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٤٢٦٥'>فَيَكُونُ ثَلاثَةً وَعِشْرِينَ دِرْهَمًا جُزْءٌ مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٣٦٦٩٨'>وَتَضْرِبُ أَرْبَعَةَ أَجْذَارٍ وَثُلُثًا فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٠٢٢٣٦'>فَيَكُونُ أَرْبَعَةً وَعِشْرِينَ جَذْرًا وَأَرْبَعَةً وَعِشْرِينَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ مِنْ جَذْرٍ</مقطع>
  <مقطع هوية='٩٥٦٢٣'>فَنَصِّفْ الأَجْذَارَ فَيَكُونُ اثْنَيْ عَشَرَ جَذْرًا وَاثْنَيْ عَشَرَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ مِنْ جَذْرٍ</مقطع>
  <مقطع هوية='٢٠٤٥٨'>وَاضْرِبْهَا فِي مَثْلِهَا فَيَكُونُ مِائَةً وَخَمْسَةً وَخَمْسِينَ (دِرْهَمًا) وَأَرْبَعِمِائَةٍ وَتِسْعَةً وَسِتِّينَ جُزْءًا مِنْ سِتِّمَائَةٍ وَخَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧١٥٠٢'>فَأَلْقِ مِنْهَا (الدَّراهِمَ) الثَّلاثَةَ وَالْعِشْرِينَ
  وَالْجُزْءَ مِنَ الْخَمْسَةِ وَالْعِشْرِينَ الَّذِي كَانَ مَعَ الْمَالِ</مقطع>
  <مقطع هوية='٧٨٧٨٨'>فَيَبْقَى مِائَةٌ وَاثْنَانِ وَثَلاثُونَ وَأَرْبُعِمِائَةٍ وَأَرْبَعُونَ جُزْءًا مِنْ سِتِّمَائَةٍ وَخَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٠٧٩٢٣'>فَتَأْخُذُ جَذْرَ ذٰلِكَ وَهُوَ أَحَدَ عَشَرَ (دِرْهَمًا) وَثَلاثَةَ عَشَرَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٤٦٥٣٣'>فَتَزِيدُهُ عَلَى نِصْفِ الْأَجْذَارِ الَّتِي هِيَ اثْنَيْ عَشَرَ (دِرْهَمًا) وَاثْنَيْ عَشَرَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٨٩٤٧٨'>فَيَكُونُ ذٰلِكَ أَرْبَعَةً وَعِشْرِينَ وَهُوَ الْمَالُ الْمَطْلُوبُ الَّذِي تَعْزِلُ ثُلُثَهُ وَرُبُعَهُ وَأَرْبَعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٤٤٧١٧'>ثُمَّ تَضْرِبُ مَا بَقِيَ فِي مِثْلِهِ
  فَيَعُودُ الْمَالُ وَزِيَادَةُ اثْنَيْ عَشَرَ دِرْهَمًا</مقطع>
  <!-- p051 -->
  <مقطع هوية='٥١٨٠٤'>فَإِنْ قَالَ <صفحة رقم="٥٠"/>
  <معادلة>مَالَ ضَرَبْتَهُ فِي ثُلُثَيْهِ فَبَلَغَ خَمْسَةً</معادلة></مقطع>
  <مقطع هوية='٦٢٨٠٩'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ شَيْئًا فِي ثُلُثَيْ شَيْءٍ فَيَكُونَ ثُلُثَيْ مَالٍ تَعْدِلُ خَمْسَةً</مقطع>
  <مقطع هوية='٥١٦٨٨'>فَأَكْمِلْهُ بِمِثْلِ نِصْفِهِ وَزِدْ عَلَى الْخَمْسَةِ مِثْلَ نِصْفِهَا</مقطع>
  <مقطع هوية='١٧١٧٢'>فَيَصِيرُ مَعَكَ مَالٌ تَعْدِلُ سَبْعَةً وَنِصْفًا</مقطع>
  <مقطع هوية='٩٣٤٥٧'>فَخُذْ جَذْرَهَا وَهُوَ الشَّيْءُ الَّذِي تُرِيدُ أَنْ تَضْرِبَهُ
  فِي ثُلُثَيْهِ فَيَكُونَ خَمْسَةً</مقطع>

  <مقطع هوية='٢٠١٣٦'>فَإِنْ قَالَ <معادلة>مَالانِ بَيْنَهُمَا دِرْهَمَانِ
  قَسَمْتَ الْقَلِيلَ عَلَى الْكَثِيرِ فَأَصَابَ الْقِسْمَ نِصْفُ دِرْهَمٍ</معادلة></مقطع>
  <مقطع هوية='٤٨٣٣٦'><قياس>قِيَاسُهُ</قياس> أَنْ تَضْرِبَ شَيْئًا وَدِرْهَمَيْنِ فِي الْقِسْمِ وَهُوَ نِصْفٌ</مقطع>
  <مقطع هوية='٥٣١٢٧'>فَيَكُونُ نِصْفَ شَيْءٍ وَدِرْهَمًا تَعْدِلُ شَيْئًا</مقطع>
  <مقطع هوية='٦٨٥٨٦'>فَأَلْقِ نِصْفَ شَيْءٍ بِنِصْفِ شَيْءٍ يَبْقَى دِرْهَمٌ يَعْدِلُ نِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٩٨٣٠٧'>فَأَضْعِفْهُ فَيَكُونُ مَعَكَ شَيْءٌ يَعْدِلُ دِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٣٢٩٦١'>وَهُوَ أَحَدُ الْمَالَيْنِ وَالْمَالُ الْآخَرُ أَرْبَعَةٌ</مقطع>

  <مقطع هوية='١٥٠٧٣'>فَإِن قَالَ <معادلة>قَسَمْتَ دِرْهَمًا عَلَى رِجَالٍ
  فَأَصَابَهُمْ شَيْءٌ ثُمَّ زِدْتَ فِيهِمْ رَجُلًا ثُمَّ قَسَمْتَ عَلَيْهِمْ دِرْهَمًا
  فَأَصَابَهُمْ أَقَلُّ مِنَ الْقِسْمِ الْأَوَّلِ بِسُدُسِ دِرْهَمٍ</معادلة></مقطع>
  <مقطع هوية='٥١٣٤٨'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ عَدَدَ الرِّجَالِ الأَوَّلِينَ</مقطع>
  <مقطع هوية='٩١٩٠١'>وَهُمْ شَيْءٌ فِي النُّقْصَانِ الَّذِي بَيْنَهُمْ</مقطع>
  <مقطع هوية='٥٤٠٩٠'>ثُمَّ تَضْرِبُ مَا اجْتَمَعَ فِي عَدَدِ الرِّجَالِ الأَوَّلِينَ وَالْآخِرِينَ</مقطع>
  <مقطع هوية='٦٠٢٠٥'>ثُمَّ تَقْسِمُ مَا اجْتَمَعَ عَلَى مَا بَيْنَ الرِّجَالِ الأَوَّلِينَ وَالْآخِرِينَ</مقطع>
  <مقطع هوية='٨٥٩٥٦'>فَإنَّهُ يَخْرُجُ مَالُكَ الَّذِي قَسَمْتَهُ</مقطع>
  <مقطع هوية='٥٢٥٠٨'>فَاضْرِبْ عَدَدَ الرِّجَالِ الأوَّلِينَ وَهُمْ شَيْءٌ فِي السُّدُسِ الَّذِي بَيْنَهُمْ فَيَكُونُ سُدُسَ جَذْرٍ</مقطع>
  <مقطع هوية='٣٧٧٠٣'>ثُمَّ اضْرِبْ ذٰلِكَ فِي عَدَدِ الرِّجَالِ الأوَّلِينَ وَالآخِرِينَ</مقطع>
  <مقطع هوية='٦٦٩٩١'>وَهُوَ شَيْءٌ وَواحِدٌ يَكُونُ سُدُسَ مَالٍ وَسُدُسَ جَذْرٍ مَقْسُومٍ عَلَى دِرْهَمٍ تَعْدِلُ دِرْهَمًا</مقطع>
  <مقطع هوية='٥٩١٣٠'>فَكَمِّلِ الْمَالَ الَّذِي مَعَكَ</مقطع>
  <مقطع هوية='٥٢٤٤٧'>وَهُوَ أَنْ تُضْرِبَهُ فِي سِتَّةٍ فَيَكُونُ مَعَكَ مَالٌ وَجَذْرٌ</مقطع>
  <مقطع هوية='٤٣٠٣٥'>فَاضْرِبِ الدِّرْهَمَ فِي سِتَّةٍ فَيَكُونُ سِتَّةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٧٦٧٦٣'>فَيَكُونُ مَالًا وَجَذْرًا تَعْدِلُ سِتَّةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢١٩٤٥'>فَانْصِفْ الجَذْرَ وَاضْرِبْهُ فِي مِثْلِهِ فَيَكُونُ رُبُعًا</مقطع>
  <!-- p052 -->
  <مقطع هوية='٦١٢٨٩'>فَزِدْهُ عَلَى <صفحة رقم="٥٢"/>السِّتَّةِ وَخُذْ جَذْرَ مَا اجْتَمَعَ</مقطع>
  <مقطع هوية='١٩٠٣٧'>فَانْقُصْ مِنْهُ نِصْفَ الْجَذْرِ الَّذِي كُنتَ ضَرَبْتَهُ فِي مِثْلِهِ وَهُوَ نِصْفٌ</مقطع>
  <مقطع هوية='٥٣٢٥٩'>وَمَا بَقِيَ فَهُوَ عَدَدُ الرِّجَالِ الأوَّلِينَ وَهُمَا فِي هَذِهِ الْمَسْأَلَةِ رَجُلَانِ</مقطع>

  <مقطع هوية='٧٢٩٨١'>فَإِنْ قَالَ <معادلة>مَال ضَرَبْتَهُ فِي ثُلُثَيْهِ فَكَانَ خَمْسَةً</معادلة></مقطع>
  <مقطع هوية='٦٨٥٥١'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي مِثْلِهِ كَانَ سَبْعَةً وَنِصْفًا</مقطع>
  <مقطع هوية='٨٠١٣٥'>فَتَقُولُ هُوَ جَذْرُ سَبْعَةٍ وَنِصْفٍ فِي ثُلُثَيْ جَذْرِ سَبْعَةٍ وَنِصْفٍ</مقطع>
  <مقطع هوية='٨٤٩٤٨'>فَاضْرِبْ ثُلُثَيْنِ فِي ثُلُثَيْنِ فَيَكُونُ أَرْبَعَةً إِتِّسَاعً</مقطع>
  <مقطع هوية='٠٤٠٤١'>وَأَرْبَعَةُ أَتْسَاعٍ فِي سَبْعَةٍ وَنِصْفٍ يَكُونُ ثَلاثَةً وَثُلُثًا</مقطع>
  <مقطع هوية='٥٦٧٨٠'>فَجَذْرُ ثَلاثَةٍ وَثُلُثٍ هُوَ ثُلُثَا جَذْرِ سَبْعَةٍ وَنِصْفٍ</مقطع>

  <مقطع هوية='٠٦٣٢٠'>فَأَضْرِبْ ثَلاَثَةً وَثُلُثًا فِي سَبْعَةٍ وَنِصْفٍ فَيَكُونُ خَمْسَةً وَعِشْرِينَ فَجَذْرُهَا خَمْسَةٌ</مقطع>

  <مقطع هوية='٥٤٢٩٩'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي ثَلاثَةِ أَجْذَارِهِ فَيَكُونُ خَمْسَةً أَمْثَالَ الْمَالِ الأوَّلِ</معادلة></مقطع>
  <مقطع هوية='٥١٩٢٦'>فَكَأَنَّهُ قَالَ مَالٌ ضَرَبْتَهُ فِي جَذْرِهِ فَكَانَ مِثْلَ الْمَالِ الأوَّلِ وَثُلُثَيْهِ</مقطع>
  <مقطع هوية='١٢١٣٩'>فَجَذْرُ الْمَالِ دِرْهَمٌ وَثُلُثَانِ وَالْمَالُ دِرْهَمَانِ وَسَبْعَةٌ اتِّسَاعٌ</مقطع>

  <مقطع هوية='٩٦٢٩٦'>فَإِنْ قَالَ <معادلة>مَالٌ تُلْقِي ثُلُثَهُ ثُمَّ تَضْرِبُ الْبَاقِي فِي ثَلاثَةِ أَجْذَارِ الْمَالِ فَيَعُودُ الْمَالُ الْأَوَّلُ</معادلة></مقطع>
  <مقطع هوية='٨٨٢٧٧'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَ الْمَالَ الْأَوَّلَ كُلَّهُ</مقطع>
  <مقطع هوية='٠٤٥٤٧'>مِن قَبْلِ أَنْ تُلْقِي (ثُلُثَهُ) فِي ثَلاثَةِ أَجْذَارِهِ</مقطع>
  <مقطع هوية='٤٩٠٥٨'>كَانَ مَالًا وَنِصْفًا</مقطع>
  <مقطع هوية='٧١٣٥٣'>لِأَنَّ ثُلُثَيْهِ فِي ثَلاثَةِ أَجْذَارِهِ مَالٌ</مقطع>
  <مقطع هوية='٦٠٠٨٧'>فَهُوَ كُلُّهُ فِي ثَلاثَةِ أَجْذَارِهِ مَالٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٧٤٦٩١'>وَهُوَ كُلُّهُ فِي جَذْرٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٢٧٧٢٧'>نِصْفُ مَالٍ فَجَذْرُ الْمَالِ نِصْفٌ وَالْمَالُ رُبْعٌ</مقطع>
  <مقطع هوية='٦٤٤١٣'>فَثُلُثَا الْمَالِ سُدُسٌ وَثَلاثَةُ أَجْذَارِ الْمَالِ دِرْهَمٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='١٧٧٦٦'>فَمَتَى مَا ضَرَبْتَ سُدُسًا فِي دِرْهَمٍ وَنِصْفٍ خَرَجَ رُبْعًا وَهُوَ الْمَالُ</مقطع>

  <مقطع هوية='٩٨٧٧١'>فَإِن قَالَ <معادلة>مالٌ تَعْزِلُ أَرْبَعَةَ أَجْذَارِهِ
  ثُمَّ تَأْخُذُ ثُلُثَ مَا بَقِيَ فَيَكُونُ مِثْلَ الْأَرْبَعَةِ الأَجْذَارِ
  فَالْمَالُ مَائَتَانِ وَسِتَّةٌ وَخَمْسُونَ</معادلة></مقطع>
  <مقطع هوية='٠٨٣٥١'><قياس>فَقِيَاسُهُ</قياس> أَنْكَ تَعْلَمَ أَنَّ ثُلُثَ مَا بَقِيَ مِثْلُ الْأَرْبَعَةِ الأَجْذَارِ</مقطع>
  <مقطع هوية='٤٣٦٧١'>وَأَنَّ (مَا) بَقِيَ مِثْلَ اثْنَي عَشَرَ جَذْرِهِ</مقطع>
  <مقطع هوية='٩٤٠١١'>فَرَدَّ عَلَيْهَا الْأَرْبَعَةُ الأَجْذَارُ فَتَكُونُ سِتَّةَ عَشَرَ جَذْرًا وَهُوَ جَذْرُ الْمَالِ</مقطع>
  <!-- p053a -->
  <مقطع هوية='٥٠٦٦٧'>فَإِن قَالَ <معادلة>مَال عَزَلْتَ جَذْرَهُ وَزِدْتَ عَلَى جَذْرِهِ
  جَذْرَ <صفحة رقم="٥٣"/>مَا بَقِيَ فَكَانَ دِرْهَمَيْنِ</معادلة><صفحة رقم="٥٣"/></مقطع>

  <مقطع هوية='٠٦٦٤٩'>فَهَذَا جَذْرُ مَالٍ وَجَذْرُ مَالٍ إِلَّا جَذْرًا تَعْدِلُ دِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٤٣٩٣٣'>فَألْقِ مَنْهُ جَذْرَ مَالٍ وَألْقِ مِنَ الدِّرْهَمَيْنِ جَذْرَ مَالٍ</مقطع>
  <مقطع هوية='٠٥٦١٦'>فَيَكُونُ دِرْهَمَيْنِ إِلَّا جَذْرًا فِي مِثْلِهِ أَرْبَعَةُ دَرَاهِمَ وَمَالًا إِلَّا أَرْبَعَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٦٥٧١٨'>تَعْدِلُ مَالًا إِلَّا جَذْرًا</مقطع>
  <مقطع هوية='٩٨٥٤٥'><مقابلة مفتاح="قبل!قابِلْ">فَقَابِلْ بِهِ</مقابلة> فَيَكُونُ مَالًا وَأَرْبَعَةَ دَرَاهِمَ تَعْدِلُ مَالًا وَثَلاَثَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٤٤١٨١'>فَتُلْقِي مَالًا بِمَالٍ فَيَبْقَى ثَلاَثَةَ أَجْذَارٍ تَعْدِلُ أَرْبَعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢٨١١٨'>فَالْجَذْرُ يَعْدِلُ دِرْهَمًا وَثُلُثًا وَهُوَ جَذْرُ الْمَالِ</مقطع>
  <مقطع هوية='٨٥٠١٨'>وَالْمَالُ دِرْهَمٌ وَسَبْعَةُ أَتْسَاعِ دِرْهَمٍ</مقطع>

  <مقطع هوية='٤٥١٥٦'>فَإِنْ قَالَ <معادلة>مالٌ تَعْزِلُ ثَلاَثَةَ أَجْذَارِهِ ثُمَّ تَضْرِبُ مَا بَقِيَ فِي مِثْلِهِ فَيَعُودُ الْمَالُ</معادلة></مقطع>
  <مقطع هوية='٠٥٤٢٩'>فَقَدْ <ص مفتاح="علم!عَلِمْتَ">عَلِمْتَ</ص> أَنَّ الَّذِي بَقِيَ هُوَ جَذْرٌ أَيْضًا</مقطع>
  <مقطع هوية='٤٨٥٥١'>وَأَنَّ الْمَالَ أَرْبَعَةُ أَجْذَارٍ وَهُوَ سِتَّةَ عَشَرَ</مقطع>



</فصل>
