<ملف رقم="٩٢"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٤٠٢٤٠'>سَبْعًا خَمْسَةَ أَسْهُمٍ إِلَّا سُبْعِي سُدْسُ الْمَالِ</مقطع>
  <مقطع هوية='٢٥٢١٢'>فَيَكُونُ مَعَكَ سِتَّةَ أَسْهُمٍ وَثَلاثَةَ أَسْبَاعِ سَهْمٍ إِلَّا سُدُسَ مَالٍ وَسُبْعِي سُدُسَ مَالٍ</مقطع>
  <مقطع هوية='١١١٧٥'>فَتَزِيدُ عَلَى ذٰلِكَ ثُلُثَيِ الْمَالِ فَيَكُونُ مَعَكَ تِسْعَةَ عَشَرَ جُزْءًا مِنْ اثْنَيْنِ وَأَرْبَعِينَ جُزْءًا</مقطع>
  <مقطع هوية='٩٨٠٩١'>مِنْ مَالٍ وَسِتَّةَ أَسْهُمٍ وَثَلاثَةَ أَسْبَاعِ سَهْمٍ تَعْدِلُ ثَلاثَةَ عَشَرَ سَهْمًا</مقطع>
  <مقطع هوية='٦٥٠١١'>فَأَلْقِ مِنْهَا هَذِهِ السَُّهُمَ</مقطع>
  <مقطع هوية='٤١٧٤٢'>فَيَبْقَى تِسْعَةَ عَشَرَ جُزْءًا تَعْدِلُ سِتَّةَ أَسْهُمٍ وَأَرْبَعَةَ أَسْبَاعٍ سَهْمٍ</مقطع>
  <مقطع هوية='٥٨٥٩٨'>فَتَمِّمْ مَالَكَ وَهُوَ أَنْ تَزِيدَ عَلَيْهِ ضِعْفَهُ وَأَرْبَعَةَ أَجْزَاءَ مِنْ تِسْعَةَ عَشَرَ جُزْءًا</مقطع>
  <مقطع هوية='٦٩٨٠٩'>فَيَكُونُ مَعَكَ مَالٌ يَعْدِلُ أَرْبَعَةَ عَشَرَ سَهْمًا وَسَبْعِينَ جُزْءًا</مقطع>
  <مقطع هوية='٥٠٥٥٢'>مِنْ مِائَةٍ وَثَلاثَةٍ وَثَلاثِينَ جُزْءًا مِنْ سَهْمٍ</مقطع>
  <مقطع هوية='٢٩١٦٠'>فَاجْعَلِ السَّهْمَ مِائَةً وَثَلاثَةً وَثَلاثِينَ</مقطع>

  <مقطع هوية='١١٠١٤'>فَتَكُونُ سِهَامُ الْفَرِيضَةِ أَلْفًا وَتِسْعُ مِائَةٍ وَاثْنَيْنِ وَثَلاثِينَ سَهْمًا</مقطع>
  <مقطع هوية='٦٨٣٣٠'>وَالسَّهْمُ الْوَاحِدُ يُعَادِلُ مِائَةً وَثَلاثَةً وَثَلاثِينَ</مقطع>
  <مقطع هوية='٤٧٠٢٠'>وَالتَّكْمِلَةُ ثَلاثُمِائَةٍ وَواحِدٌ</مقطع>
  <مقطع هوية='٩١١٩٩'>وَإِلَّاَسْتِثْنَاءُ مِنَ الثُّلُثِ يَكُونُ ثَمَانِيَةً وَتِسْعِينَ</مقطع>
  <مقطع هوية='٤٥٢٨٥'>فَيَبْقَى الْوَصِيَّةُ مَائَتَانِ وَثَلاثَةٌ</مقطع>
  <مقطع هوية='٩٤٧٢٦'>وَيَبْقَى لِلْوَرَثَةِ أَلْفٌ وَسَبْعُمِائَةٍ وَتِسْعَةٌ وَعِشْرُونَ</مقطع>

  <فصل هوية='٣٨٢٣٣'>
    <عنوان>حِسَابُ الدَّوْرِ</عنوان>
  </فصل>

  <!-- TODO: implement <قسم> -->

  <مقطع هوية='٤٢٧١٨'>بَابٌ مِنهُ فِي التَّزْوِيجِ فِي الْمَرَضِ</مقطع>
  <مقطع هوية='٨٥٢٧٢'>رَجُلٌ تَزَوَّجَ امْرَأَةً فِي مَرَضِ مَوْتِهِ عَلَى مِائَةِ دِرْهَمٍ</مقطع>
  <مقطع هوية='٧٧٨٩٣'>وَلَا مَالَ لَهُ غَيْرُهَا</مقطع>
  <مقطع هوية='٣٨٤٩٦'>وَمَهْرُ مِثْلِهَا عَشَرَةُ دَرَاهِمَ</مقطع>
  <مقطع هوية='٥٧٢٧٠'>ثُمَّ مَاتَتِ الْمَرْأَةُ وَأَوْصَتْ بِثُلُثِ مَالِهَا</مقطع>
  <مقطع هوية='٣٧٤٦٩'>ثُمَّ مَاتَ الزَّوْجُ</مقطع>
  <مقطع هوية='٤٧٩٧٣'>فَقِيَاسُهُ أَنْ تُرْفَعَ مِنَ الْمِائَةِ مَا يَصِحُّ لَهَا مِنَ الْمَهْرِ وَهُوَ عَشَرَةُ دَرَاهِمَ</مقطع>
  <مقطع هوية='٩١٢٠٤'>وَتَبْقَى تِسْعُونَ دِرْهَمًا لَهَا مِنْهُ وَصِيَّةً</مقطع>
  <مقطع هوية='٠٦٨١٠'>فَتَجْعَلُ وَصِيَّتَهَا شَيْئًا مِّنْ ذٰلِكَ</مقطع>
  <مقطع هوية='٠٠٨٢٧'>فَيَبْقَى تِسْعُونَ دِرْهَمًا غَيْرَ شَيْءٍ</مقطع>
  <مقطع هوية='٩٥٨٥٦'>فَصَارَ فِي يَدِهَا عَشَرَةُ دَرَاهِمَ وَشَيْءٌ</مقطع>
  <مقطع هوية='٨٦٨٥٩'></مقطع>
  <مقطع هوية='١٨٢٢٨'>وَأَوْصَتْ بِثُلُثِ مَالِهَا وَهُوَ ثَلَاثَةُ دِرَاهِمَ وَثُلُثُ دِرْهَمٍ وَثُلُثُ شَيْءٍ</مقطع>
  <مقطع هوية='٨٧٦٧٠'>فَيَبْقَى سِتَّةُ دِرَاهِمَ وَثُلُثَانِ وَثُلُثَا شَيْءٍ</مقطع>
  <مقطع هوية='٣٢٩٥٥'>فَيَرْجِعُ إِلَى الزَّوْجِ مِنْ ذٰلِكَ مِيرَاثُهُ النِّصْفُ وَهُوَ ثَلَاثَةُ دِرَاهِمَ وَثُلثُ دِرْهَمٍ وَثُلثُ شَيْءٍ</مقطع>
  <مقطع هوية='٩٤٩١٦'>فَيَصِيرُ فِي أَيْدِي وَرَثَةِ الزَّوْجِ ثَلَاثَةً وَتِسْعِينَ دِرْهَمًا وَثُلثَ دِرْهَمٍ إِلَّا ثُلثَ شَيْءٍ</مقطع>
  <مقطع هوية='٤٦٣٦٣'>وَهُوَ مَثَلًا وَصِيَّةَ الْمَرْأَةِ</مقطع>
  <مقطع هوية='٨٩٤٩٦'>وَهِيَ شَيْءٌ لِأَنَّ الْمَرْأَةَ يَجُوزُ لَهَا بِالْوَصِيَّةِ ثُلُثُ جَمِيعِ مَا تَرَكَ الزَّوْجُ</مقطع>
  <مقطع هوية='٦٠٤٢٤'>مَثَلًا وَصِيَّتُهَا شَيْئَانِ فَاجْبِرِ الثَّلَاثَةَ وَالتِّسْعِينَ وَالثُّلْثَيْنِ وَثُلُثَي شَيْءٍ</مقطع>
  <مقطع هوية='٢٥٨٢٣'>وَزِدْهُ عَلَى الشَّيْئَيْنِ فَيَكُونَ ثَلَاثَةً وَتِسْعِينَ دِرْهَمًا وَثُلثًا</مقطع>
  <مقطع هوية='٥٥٨٩٢'>تَعْدِلُ شَيْئَيْنِ وَثُلثَي شَيْءٍ</مقطع>
  <مقطع هوية='٠١٠٠٤'>فَالشَّيْءُ الْواحِدُ مِنْ ذٰلِكَ هُوَ ثَلَاثَةٌ أَثْمَانِهُ</مقطع>
  <مقطع هوية='٥٢٤٢٤'>وَهُوَ يَعْدِلُ ثَلاَثَةَ أَثْمَانِ الثَّلَاثَةِ وَالتِّسْعِينَ</مقطع>
</ملف>
