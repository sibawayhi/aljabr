<ملف رقم="١٥"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <جزء هوية='١١٣٤٨'>
    <عنوان>كِتَابُ الْجَبْرِ</عنوان>
  </جزء>

  <فصل هوية='٩٧١٠٩'>
    <عنوان>[الْمُقَدِّمة]</عنوان>
  </فصل>

  <مقطع هوية='٤٤٦١٨'>هَذَا كِتَابٌ وَضَعَهُ مُحَمَّدٌ بْنُ مُوسَى الْخَوَارِزْمِيُّ افْتَتَحَهُ بِأَنْ قَالَ</مقطع>

  <مقطع هوية='٨٩٣٣١'>الْحَمْدُ لِلَّهِ عَلَى نِعَمِهِ بِمَا هُوَ أَهْلُهُ مِنْ مَحَامِدِهِ</مقطع>


  <مقطع هوية='٣٧٠١٠'>الَّتِي بِأَدَاءِ مَا افْتَرَضَ مِنْهَا عَلَى مَنْ يَعْبُدُهُ مِنْ خَلْقِهِ</مقطع>
  <مقطع هوية='٤٢٢٦٣'>يَقَعُ اسْمُ الشُّكْرِ وَيَسْتَوْجِبُ الْمَزِيدَ وَتُؤْمِنُ مِنَ الْغَيْرِ</مقطع>
  <مقطع هوية='٠٤٦٩١'>إِقْرَارًا بِرُبُوبِيَّتِهِ وَتَذَلُّلًا لِعِزَّتِهِ وَخُشُوعًا لِعَظَمَتِهِ</مقطع>
  <مقطع هوية='١٨٣٦٧'></مقطع>
  <مقطع هوية='٧١٥٠٤'>بَعَثَ مُحَمَّدًا صَلَّى اللَّهُ عَلَيْهِ وَعَلَى آلِهِ وَسَلَّمَ بِالنُّبُوَّةِ</مقطع>
  <مقطع هوية='٣٩٩٣٠'>عَلَى حِينِ فَتْرَةٍ مِنَ الرُّسُلِ</مقطع>
  <مقطع هوية='٨٧٨٢٢'>وَتَنَكُّرٍ مِنَ الْحَقِّ وَدُرُوسٍ مِنَ الْهُدَى</مقطع>
  <مقطع هوية='٩٩٩٣٤'>فَبَصَّرَ بِهِ مِنَ الْعَمَى وَاسْتَنْقَذَ بِهِ مِنَ الْهَلَكَةِ</مقطع>
  <مقطع هوية='٩٦٩١٢'>وَكَثُرَ بِهِ بَعْدَ الْقِلَّةِ وَأَلَّفَ بِهِ بَعْدَ الشَّتَاتِ</مقطع>

  <مقطع هوية='٢٥٨١٥'>تَبَارَكَ اللَّهُ رَبُّنَا وَتَعَالَى وَتَقَدَّسَتْ أَسْمَاؤُهُ وَلَا إِلٰهَ غَيْرُهُ</مقطع>
  <مقطع هوية='٩٠٧٦٩'>وَصَلَّى اللَّهُ عَلَى مُحَمَّدٍ النَّبِيِّ وَآلِهِ وَسَلَّمَ</مقطع>

  <رأس/>
  <مقطع هوية='٥٣٧٢٧'>وَلَم تَزَلِ العُلَمَاءُ فِي الأَزْمِنَةِ الخَالِيَةِ وَالأُمَمِ المَاضِيَةِ</مقطع>
  <مقطع هوية='٨٤٩٣٠'>يَكْتُبُونَ الكُتُبَ مِمَّا يُصَنِّفُونَ مِنْ صُنُوفِ العِلْمِ وَوُجُوهِ الحِكْمَةِ</مقطع>
  <مقطع هوية='١٧٧٥٧'>نَظَرًا لِمَنْ بَعْدَهُمْ وَاحْتِسَابًا لِلْأَجْرِ بِقَدْرِ الطَّاقَةِ</مقطع>
  <مقطع هوية='٠٤٧٧٦'>وَرَجَاءً أَن يُلَاحِقَهُم مِنْ أَجْرِ ذٰلِكَ ذَخْرَهُ وَذِكْرَهُ</مقطع>
  <مقطع هوية='٢٥٩٧١'>وَيَبْقَى لَهُم مِن لِسَانِ الصِّدْقِ مَا يَصْغُرُ فِي جَنْبِهِ</مقطع>
  <مقطع هوية='٦٥٠٧٨'>كَثِيرٌ مِمَّا كَانُوا يَتَكَلَّفُونَهُ مِنَ الْمَئُونَةِ</مقطع>
  <مقطع هوية='٩١٣١٥'>وَيَحْمِلُونَهُ عَلَى أَنفُسِهِم مِنَ الْمَشَقَّةِ فِي كَشْفِ أَسْرَارِ العِلْمِ وَغَامِضِهِ</مقطع>

  <رأس/>
  <مقطع هوية='٣١٨٤٩'>إِمَّا رَجُلٌ سَبَقَ إِلَى مَا لَمْ يَكُنْ مُسْتَخْرَجًا قَبْلَهُ فَوَرِثَهُ مَنْ بَعْدَهُ</مقطع>

  <مقطع هوية='٠٦٢٣٤'>وَإِمَّا رَجُلٌ شَرَحَ مَا أَبْقَى الأَوَّلُونَ مَا كَانَ مُسْتَغْلَقًا</مقطع>
  <مقطع هوية='٦٨٥٣٣'>فَأَوَضَحَ طَرِيقَهُ وَسَهَّلَ مَسْلَكَهُ وَقَرَّبَ مَأْخَذَهُ</مقطع>

  <مقطع هوية='٦٦٤٩٢'>وَإِمَّا رَجُلٌ وَجَدَ فِي بَعْضِ الْكُتُبِ خَلَلًا</مقطع>
  <مقطع هوية='٩٤٩٠٠'>فَلَمَّ شَعْثَهُ وَأَقَامَ أَدَدَهُ وَأَحْسَنَ الظَّنَّ بِصَاحِبِهِ</مقطع>
  <مقطع هوية='٤٩٠٨٦'>غَيْرَ رَادٍّ عَلَيْهِ وَلَا مُفْتَخِرٍ بِذٰلِكَ مِنْ فِعْلِ نَفْسِهِ</مقطع>

  <رأس/>
  <مقطع هوية='٧٩٧٠٣'>وَقَدْ شَجَّعَنِي</مقطع>
  <مقطع هوية='٩١٦٦٤'>مَا فَضَّلَ اللَّهُ بِهِ الْإِمَامَ الْمَأْمُونَ أَمِيرَ الْمُؤْمِنِينَ</مقطع>
  <مقطع هوية='٩٨٨٨٠'>مَعَ الْخِلَافَةِ الَّتِي حَازَ لَهُ إِرْثَهَا وَأَكْرَمَهُ بِلبَاسِهَا وَحَلَّاهُ بِزِينَتِهَا</مقطع>
  <مقطع هوية='٠٤٧٨٢'>مِنَ الرَّغْبَةِ فِي الْأَدَبِ وَتَقْرِيبِ أَهْلِهِ وَإدْنَائِهِمْ</مقطع>
  <مقطع هوية='٩٩٦٦٣'>وَبَسْطِ كَنَفِهِ لَهُمْ</مقطع>
  <مقطع هوية='٣٣٧٢٢'>وَمَعُونَتِهِ إِيَّاهُمْ عَلَى إِيضَاحِ مَا كَانَ مُسْتَبْهَمًا وَتَسْهِيلِ مَا كَانَ مُسْتَوْعِرًا</مقطع>
</ملف>
