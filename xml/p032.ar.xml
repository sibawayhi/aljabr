<ملف رقم="٣٢"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٦٩٢٢٠'>فَجَذْرُهَا هُوَ مَا يُصِيبُ <صفحة رقم="٣٢"/> الْواحِدَ
  وَهُوَ وَاحِدٌ وَنِصْفٌ</مقطع>

  <مقطع هوية='٠٨٧٥٥'>وَإِنْ أَرَدْتَ أَنْ <تعبير>تَقْسِمَ جَذْرَ أَرْبَعَةٍ عَلَى جَذْرِ تِسْعَةٍ</تعبير></مقطع>
  <مقطع هوية='٢٧١٦١'>فَإِنَّكَ تَقْسِمُ أَرْبَعَةً عَلَى تِسْعَةٍ فَيَكُونُ أَرْبَعَةَ أَتْسَاعِ وَاحِدٍ</مقطع>
  <مقطع هوية='٨٣٥٩٧'>فَجَذْرُهَا مَا يَصِيبُ الْواحِدَ وَهُوَ ثُلُثَا وَاحِدٍ</مقطع>

  <مقطع هوية='٦٣٧١١'>فَإِنْ أَرَدْتَ أَنْ <تعبير>تَقْسِمَ جَذْرَي تِسْعَةٍ عَلَى جَذْرِ أَرْبَعَةٍ أَوْ غَيْرِهَا مِنَ الْأَمْوَالِ</تعبير></مقطع>
  <مقطع هوية='٩٠٦٧٠'>فَأَضْعِفْ جَذْرَ التِّسْعَةِ عَلَى مَا أَرَيْتُكَ فِي عَمَلِ الْإِضْعَافِ فَمَا بَلَغَ</مقطع>
  <مقطع هوية='٧٠٢٤٠'>فَاقْسِمْهُ عَلَى أَرْبَعَةٍ أَوْ عَلَى مَا أَرَدْتَ أَنْ تَقْسِمَ عَلَيْهِ</مقطع>
  <مقطع هوية='١٦١٤٢'>وَاعْمَلْ بِهِ كَمَا عَمِلْتُ</مقطع>

  <مقطع هوية='٧٨٨٣٣'>وَكَذٰلِكَ إِنْ أَرَدْتَ ثَلاَثَةَ أَجْذَارِ تِسْعَةٍ أَوْ أَكْثَرَ</مقطع>
  <مقطع هوية='٢٠٩٩٢'>أَوْ نِصْفَ جَذْرِ تِسْعَةٍ أَوْ أَقَلَّ</مقطع>
  <مقطع هوية='٦٥٨٥٧'>أَوْ مَا كَانَ عَلَى هَذَا الْمِنْوَالِ</مقطع>
  <مقطع هوية='٩٧٣٣١'>فَاعْمَلْهُ تُصِبْ إِنْ شَاءَ اللَّهُ تَعَالَى</مقطع>

  <مقطع هوية='٧٠٤٠٦'>وَإِنْ أَرَدْتَ أَنْ <تعبير>تَضْرِبَ جَذْرَ تِسْعَةٍ فِي جَذْرِ أَرْبَعَةٍ</تعبير></مقطع>
  <مقطع هوية='٩١٤٣١'>فَاضْرِبْ تِسْعَةً فِي أَرْبَعَةٍ فَيَكُونُ سِتَّةً وَثَلاَثِينَ</مقطع>
  <مقطع هوية='٥٣٦٨٩'>فَخُذْ جَذْرَهَا وَهُوَ سِتَّةٌ فَهُوَ جَذْرُ تِسْعَةٍ مَضْرُوبٌ فِي جَذْرِ أَرْبَعَةٍ</مقطع>

  <مقطع هوية='٣٢٠٣١'>وَكَذٰلِكَ إِنْ أَرَدْتَ ثَلاثَةَ أَجْذَارِ تِسْعَةٍ أَوْ أَكْثَرَ</مقطع>
  <مقطع هوية='٣٤٣١٨'>أَوْ نِصْفَ جَذْرِ تِسْعَةٍ أَوْ أَقَلَّ</مقطع>
  <مقطع هوية='٠٤٥٩٩'>أَوْ مَا كَانَ عَلَى هَذَا الْمِنْوَالِ</مقطع>

  <مقطع هوية='٠٩٤٩٠'>وَكَذٰلِكَ لَوْ أَرَدْتَ أَنْ <تعبير>تَضْرِبَ جَذْرَ خَمْسَةٍ فِي جَذْرِ عَشَرَةٍ</تعبير></مقطع>
  <مقطع هوية='٧٠٣٩٨'>فَاضْرِبْ خَمْسَةً فِي عَشَرَةٍ فَجَذْرُ مَا بَلَغَ هُوَ الشَّيْءُ الَّذِي تَرِيدُهُ</مقطع>

  <مقطع هوية='١٨٢٩٦'>وَإِنْ أَرَدْتَ أَنْ <تعبير>تَضْرِبَ جَذْرَ ثُلُثٍ فِي جَذْرِ نِصْفٍ</تعبير></مقطع>
  <مقطع هوية='٥٦٧٧٣'>فَاضْرِبْ ثُلُثًا فِي نِصْفٍ فَيَكُونُ سُدُسًا</مقطع>
  <مقطع هوية='٦٠٩٣٠'>جَذْرُ السُّدُسِ هُوَ جَذْرُ الثُّلُثِ مَضْرُوبٌ فِي جَذْرِ النِّصْفِ</مقطع>

  <مقطع هوية='٢٩٥٦٥'>وَإِنْ أَرَدْتَ أَنْ <تعبير>تَضْرِبَ جَذْرَيْ تِسْعَةٍ فِي ثَلاثَةِ أَجْذَارِ أَرْبَعَةٍ</تعبير></مقطع>
  <مقطع هوية='٥٠٤٢٩'>فَاسْتَخْرِجْ جَذْرَيْ تِسْعَةٍ كَمَا وَصَفْتُ لَكَ حَتَّى تَعْلَمَ جَذْرَ أَيِّ مَالٍ هُوَ</مقطع>
  <مقطع هوية='٧٤٩٦١'>وَكَذٰلِكَ فَافْعَلْ بِثَلاثَةِ أَجْذَارِ الْأَرْبَعَةِ حَتَّى تَعْلَمَ جَذْرَ أَيِّ مَالٍ هُوَ</مقطع>
  <مقطع هوية='٣٥٨٥٠'>ثُمَّ اضْرِبْ الْمَالَيْنِ أَحَدَهُمَا فِي الْآخَرِ</مقطع>
  <مقطع هوية='٥١٥٢٤'>فَجَذْرُ مَا اجْتَمَعَ لَكَ هُوَ جَذْرَا تِسْعَةٍ فِي ثَلاثَةِ أَجْذَارِ أَرْبَعَةٍ</مقطع>

  <مقطع هوية='٨٨٨٨٣'>وَكَذٰلِكَ كُلَّمَا زَادَ مِنَ الْأَجْذَارِ أَوْ نَقَصَ</مقطع>
  <مقطع هوية='٣٥٢٧٤'>فَعَلَى هَذَا الْمِثَالِ فَاعْمَلْ بِهِ</مقطع>

  <مقطع هوية='٧١٨٢٤'>فَأَمَّا عَلَّةُ <تعبير>جَذْرِ مِائَتَيْنِ إِلَّا عَشَرَةً مَجْمُوعًا إِلَى عِشْرِينَ إِلَّا جَذْرَ مِائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٨٩٥١٢'>فَإِنَّ صُورَةَ ذٰلِكَ خَطُّ <خط>ا ٮ</خط> وَهُوَ جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٨٦٠١٧'>فَمِنْ <نقطة>ا</نقطة> إِلَى نُقْطَةِ <نقطة>ج</نقطة> هُوَ الْعَشَرَةُ</مقطع>
  <مقطع هوية='١٢٤٦٠'>وَالْبَاقِي جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='١٣٧٦٢'>هُوَ الْيَاقِي مِنْ خَطِّ <خط>ا ٮ</خط> وَهُوَ خَطُّ <خط>ج ٮ</خط></مقطع>
  <مقطع هوية='١٢٥٣٢'>ثُمَّ تَخْرُجُ مِنْ نُقْطَةِ <نقطة>ٮ</نقطة> خَطًّا إِلَى نُقْطَةِ <نقطة>ه</نقطة></مقطع>
  <مقطع هوية='٣٠٩١٣'>وَهُوَ خَطُّ الْعِشْرِينَ</مقطع>

</ملف>
