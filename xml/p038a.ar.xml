<ملف رقم="٣٨"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٢٩٠١٦'> وَاضْرِبْهَا فِي مِثْلِها<صفحة رقم="٣٨"/> فَتَكُونَ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٦٩١٧'>فَأَلْقِ مِنْهَا الْواحِدَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ فَيَبْقَى أَرْبَعَةً</مقطع>
  <مقطع هوية='٧٦٣١٨'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ فَإِنْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ الَّتِي هِيَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٢٨١٤٦'>فَيَبْقَى ثَلاثَةٌ وَهِيَ أَحَدُ الْقِسْمَيْنِ وَالْآخَرُ سَبْعَةٌ</مقطع>
  <مقطع هوية='٢٧٠١٣'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إلى أَحَدِ الْأَبْوَابِ الْسِّتَّةِ</مقطع>
  <مقطع هوية='٤٠٢٣٩'>وَهِيَ أَمْوَالٌ وَعَدَدٌ تَعْدِلُ جُذُورًا</مقطع>

  <مسألة هوية='٧٨٠٣٦' صفحة="٣٨">الْمَسْأَلةُ السَّادِسَةُ</مسألة>
  <مقطع هوية='٠٥١٤٩'>المَسْأَلَةُ السَّادِسَةُ</مقطع>
  <مقطع هوية='٢٠٦٧٢'>مَالٌ ضَرَبْتُ ثُلُثَهُ فِي رُبْعِهِ</مقطع>
  <مقطع هوية='٠٧٣٠١'>فَعَادَ الْمَالُ وَزِيَادَةُ أَرْبَعَةٍ وَعِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩٠٥٧٤'><قياس>فَقِيَاسُهَا</قياس></مقطع>
  <مقطع هوية='٧١٧٠٠'>أَنْ تَجْعَلَ مَالَكَ شَيْئًا</مقطع>
  <مقطع هوية='٠٧٢٥٢'>ثُمَّ تَضْرِبُ ثُلُثَ شَيْءٍ فِي رُبُعِ شَيْءٍ</مقطع>
  <مقطع هوية='٣٧٢٤٧'>فَيَكُونَ نِصْفُ سُدُسِ الْمَالِ تَعْدِلُ شَيْئًا وَأَرْبَعَةً وَعِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٨٦١٣٠'>ثُمَّ تَضْرِبُ نِصْفَ سُدُسِ الْمَالِ فِي اثْنَيْ عَشَرَ حَتَّى تُكْمِلَ مَالَكَ</مقطع>
  <مقطع هوية='٤٣١٣٨'>وَاضْرِبِ الشَّيْءَ فِي اثْنَيْ عَشَرَ يَكُنْ اثْنَيْ عَشَرَ شَيْئًا</مقطع>
  <مقطع هوية='١٥٠٠٨'>وَاضْرِبِ الْأَرْبَعَةَ وَالْعِشْرِينَ فِي اثْنَيْ عَشَرَ</مقطع>
  <مقطع هوية='٩٧٢٤٤'>فَيَصِيرُ مَعَكَ مَائَتَانِ وَثَمَانِيَةٌ وَثَمَانُونَ دِرْهَمًا وَاثْنَيْ عَشَرَ جَذْرًا تَعْدِلُ مَالًا</مقطع>
  <مقطع هوية='٠٧٣٧٢'>فَنَصِّفْ الْأَجْذَارِ تَكُونُ سِتَّةً</مقطع>
  <مقطع هوية='٣٧٠٩٢'>وَاضْرِبْهَا فِي مِثْلِهَا وَزِدْهَا عَلَى مِائَتَيْنِ وَثَمَانِيَةٍ وَثَمَانِينَ</مقطع>
  <مقطع هوية='٤٦٨٩٣'>فَيَكُونَ ثَلاثُمِائَةٍ وَأَرْبَعَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٩٣٦٨٠'>فَخُذْ جَذْرَهَا وَهُوَ ثَمَانِيَةَ عَشَرَ فَزِدْهَا عَلَى نِصْفِ الْأَجْذَارِ وَهِيَ سِتَّةٌ</مقطع>
  <مقطع هوية='٠٥١٣١'>فَيَكُونُ ذٰلِكَ أَرْبَعَةً وَعِشْرِينَ وَهُوَ الْمَالُ</مقطع>
  <مقطع هوية='٧٤٢٠٤'>فَقَدْ أَخْرَجْتَكَ هَذِهِ الْمُسْـأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٤٠٩٢٣'>وَهِيَ جُذُورٌ وَعَدَدٌ تَعْدِلُ أَمْوَالًا</مقطع>
</ملف>
