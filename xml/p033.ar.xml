<ملف رقم="٣٣"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٣٨٠٦٦'>وَهُوَ <صفحة رقم="٣٣"/> مَثَلًا خَطُّ [ا ب] الَّذِي هُوَ عَشَرَةٌ</مقطع>
  <مقطع هوية='٨٠٢٦٣'>فَمِن نُقْطَةِ [ٮ] إِلَى نُقْطَةِ [ه] مَثَلُ خَطِّ [ا ٮ]</مقطع>
  <مقطع هوية='٦٦٠١٠'>فَهُوَ جَذْرُ مِائَتَيْنِ أَيْضًا</مقطع>
  <مقطع هوية='٦٩٨٣٩'>وَالْبَاقِي مِنَ الْعِشْرِينَ هُوَ مِن نُقْطَةِ [ه] إِلَى نُقْطَةِ [د]</مقطع>
  <مقطع هوية='٥٤٩١٣'>فَلَمَّا أَرَدْنَا أَنْ نَجْمَعَ مَا بَقِيَ مِنْ جَذْرِ الْمِائَتَيْنِ بَعْدَ طَرْحِ الْعَشَرَةِ</مقطع>
  <مقطع هوية='٤٨٩٨٧'>وَهُوَ خَطُّ [ج ٮ] إِلَى خَطِّ [ه د] الَّذِي هُوَ عِشْرُونَ إِلَّا جَذْرَ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٦٤٥٥٤'>فَقَطَعْنَا مِنْ خَطِّ [ٮ ه] مِثْلَ خَطِّ [ج ٮ] وَهُوَ خَطُّ [ز ه]</مقطع>

  <مقطع هوية='٣٧٠٦٦'>وَقَدْ كَانَ تَبَيَّنَ لَنَا أَنَّ خَطَّ [ا ٮ] الَّذِي هُوَ جَذْرُ مِائَتَيْنِ مِثْلُ خَطِّ [ٮ ه]</مقطع>
  <مقطع هوية='٧٨٦٨٣'>وَأَنَّ خَطَّ [ا ج] الَّذِي هُوَ الْعَشَرَةُ مِثْلُ خَطِّ [ٮ ز]</مقطع>
  <مقطع هوية='٦٨٥٠٢'>وَالْبَاقِي مِنْ خَطِّ [ا ٮ] الَّذِي هُوَ [ح ٮ]</مقطع>
  <مقطع هوية='٥٢٠٩٢'>مِثْلُ الْبَاقِي مِنْ خَطِّ [ب ه] الَّذِي هُوَ [ز ه]</مقطع>
  <مقطع هوية='٢٨٣٠٦'>زِدْنَا عَلَى خَطِّ [ه د] خَطَّ [ز ه]</مقطع>

  <مقطع هوية='٩١٨٦٣'>تَبَيَّنَ لَنَا أَنَّهُ قَدْ نَقَصَ مِنْ خَطِّ [ٮ د] الَّذِي هُوَ عِشْرُونَ</مقطع>
  <مقطع هوية='٤٥٣١٩'>مِثْلُ خَطِّ [ا ج] الَّذِي هُوَ عَشَرَةٌ وَهُوَ خَطُّ [ٮ ز]</مقطع>
  <مقطع هوية='٩٧٨٨٩'>وَبَقِيَ لَنَا خَطُّ [ز د] وَهُوَ عَشَرَةٌ</مقطع>
  <مقطع هوية='٤٢١٦٤'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ وَهٰذِهِ صُورَتُهُ</مقطع>

  <رأس/>
  <مقطع هوية='٤٨٧٢٥'>وَأَمَّا عِلَّةُ جَذْرِ مِائَتَيْنِ إِلَّا عَشَرَةً مَنْقُوصًا مِنْ عِشْرِينَ إِلَّا جَذْرِ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٣٣٢٩١'>فَإنَّ صُورَةَ ذٰلِكَ خَطُّ [ا ب] وَهُوَ جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٩٢١٤٠'>وَمِنَ [ا] إِلَى نُقْطَةِ [ج] هِيَ الْعَشَرَةُ الْمَعْلُومَةُ</مقطع>
  <مقطع هوية='٩٨٦٩٩'>وَنُخْرِجُ مِنْ نُقْطَةِ [ٮ] خَطًّا إِلَى نُقْطَةِ [د] وَنَجْعَلُهُ الْعِشْرِينَ</مقطع>
  <مقطع هوية='٧٣٥٩٢'>وَنَجْعَلُ مِنْ [ٮ] إِلَى نُقْطَةِ [ه] مِثْلَ خَطِّ جَذْرِ مِائَتَيْنِ وَهُوَ مِثْلُ خَطِّ [ا ٮ]</مقطع>

  <مقطع هوية='١٤٤٠٤'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ خَطَّ [ج ٮ] هُوَ مَا بَقِيَ مِنْ جَذْرِ مِائَتَيْنِ بَعْدَ الْإِلْقَاءِ الْعَشَرَةِ</مقطع>
  <مقطع هوية='٢٦٥١٦'>وَخَطُّ [د ه] هُوَ مَا بَقِيَ مِنَ الْعِشْرِينَ بَعْدَ الْإِلْقَاءِ جَذْرَ الْمِائَتَيْنِ</مقطع>
  <مقطع هوية='٦٦٥٩٧'>فَأَرَدْنَا أَنْ نَنْقُصَ خَطَّ [ج ٮ] مِنْ خَطِّ [ه د]</مقطع>
  <مقطع هوية='٦٤٥٢٨'>فَأَخْرَجْنَا مِنْ نُقْطَةِ [ٮ] خَطًّا إِلَى نُقْطَةِ [ز]</مقطع>
  <مقطع هوية='٨٧٨١٨'>وَهُوَ مِثْلُ خَطِّ [ا ج] الَّذِي هُوَ الْعَشَرَةُ</مقطع>
  <مقطع هوية='٧٩٣٣٠'>فَصَارَ جَمِيعُ خَطِّ [ز د] مِثْلَ خَطِّ [ز ٮ] وَخَطِّ [ٮ د]</مقطع>
  <مقطع هوية='٩١٧٦٦'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ ذٰلِكَ كُلَّهُ ثَلاَثُونَ</مقطع>
  <مقطع هوية='٦٠٥٦٥'>وَقَطَعْنَا مِنْ خَطِّ [ه د] مِثْلَ خَطِّ [ج ٮ] وَهُوَ خَطُّ [ه ح]</مقطع>
  <مقطع هوية='٨٤١٢٤'>فَتَبَيَّنَ لَنَا أَنَّ خَطَّ [ح د] هُوَ مَا بَقِيَ مِنْ خَطِّ [ز د] الَّذِي <صفحة رقم="٣٤"/> هُوَ ثَلاثُونَ</مقطع>

</ملف>

