<فصل هوية='٧٥١٢٧'

  xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <عنوان>[المُعادَلاتُ ذاتُ الْحَدَّيْنِ]</عنوان>
  <!-- <عنوان>[اقْتِرانُ الضُّروب]</عنوان> -->

  <مقطع هوية='٩٩٩٨٤'>وَوَجَدْتُ‏ هٰذِهِ الضُّرُوبَ الثَّلَاثةَ الَّتِي هِي الْجُذُوْرُ والْأَمْوالُ وَالْعَدَدُ تَقْتَرِنُ</مقطع>
  <مقطع هوية='٩٤٣٣٥'>فَيَكُونُ مِنْهَا ثَلَاثةُ أَجْناسٍ مُقْتَرِنَةٍ</مقطع>
  <مقطع هوية='٦٤٨٢٥'>وَهِيَ أَمْوالٌ وَجُذُورٌ تَعْدِلُ عَدَدًا</مقطع>
  <مقطع هوية='٥٣١٩١'>وَأَمْوالٌ وَعَدَدٌ تَعْدِلُ جُذُورًا</مقطع>
  <مقطع هوية='٨١٨٤٢'>وَجُذُورٌ وَعَدَدٌ تَعْدِلُ أَمْوالًا</مقطع>

  <قسم هوية='٣٢٧٨١'>
    <عنوان>[أموال + جذور = عدد]</عنوان>
  </قسم>
  <مقطع هوية='٠١٢٣٦'>فَأَمَّا الْأَمْوالُ والْجُذُورُ الَّتِي تَعْدِلُ الْعَدَدَ</مقطع>
  <مقطع هوية='١٨٩٣١'>فَمِثْلُ قَوْلِكَ <معادلة>مالٌ وَعَشَرَةُ أَجْذارِهِ يَعْدِلُ تِسْعَةً وَثَلَاثِيْنَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٣٨٨٧٦'>وَمَعْناهُ <قبس>أَيُّ مالٍ اذَا زِدْت عَلَيْهِ مِثْلَ عَشَرَةِ أَجْذارِهِ بَلَغَ ذَلِكَ كُلُّهُ تِسْعَةً وَئَلَاثِيْنَ</قبس></مقطع>
  <!-- p019 -->
  <مقطع هوية='٢٧٧٥٣'><قياس>فَبَابُهُ</قياس> أَنْ تُنْصِفَ الْأَجْذَارَ وَهَى فِي <صفحة رقم="١٩"/>
  هَذِهِ الْمَسْئَلةِ خَمْسَةٌ</مقطع>
  <مقطع هوية='٠٧٦٦٦'>فَتَضْرِبَهَا فِي مِثْلِهَا فَتَكُونَ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٨٧٤٥٨'>فَتَزِيدَهَا عَلَى التِّسْعَةِ وَالثَّلَاثِينَ فَتَكُونَ أَرْبَعَةً وَسِتِّينَ</مقطع>
  <مقطع هوية='٥٣٢٨٧'>فَتَأْخُذَ جَذْرَهَا وَهُوَ ثَمَانِيَةٌ</مقطع>
  <مقطع هوية='٣٨٧٨٨'>فَتَنْقُصُ مِنْهُ نِصْفَ الْأَجْذَارِ وَهُوَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٥٣٤٩٥'>فَيَبْقَى ثَلَاثَةً وَهُوَ جَذْرُ الْمَالِ الَّذِى تُرِيدُ وَالْمَالُ تِسْعَةٌ</مقطع>
  <مقطع هوية='٥٩٧٢٧'>وَكَذَلِكَ لَوْ ذَكَرَ مَالَيْنِ أَوْ ثَلَاثَةً أَوْ أَقَلَّ أَوْ أَكْثَرَ</مقطع>
  <مقطع هوية='٢٠٩٦٣'>فَارْدُدْهُ إلَى مَالٍ وَاحِدٍ وَارْدُدْ مَا كَانَ مَعَهُ مِنْ الْأَجْذَارِ وَالْعَدَدِ إلَى مِثْلِ مَا رَدَدْتَ إلَيْهِ الْمَالَ</مقطع>
  <مقطع هوية='٢٥٧٩٦'>وَهُوَ نَحْوُ قَوْلِكَ <معادلة>مَالانِ وَعَشَرَةُ أَجْذَارٍ تَعْدِلُ ثَمَانِيَةً وَأَرْبَعِينَ دِرْهَمًا</معادلة>
  </مقطع>
  <مقطع هوية='٨٣٧٤٨'>وَمَعْنَاهُ <قبس>أَيُّ مَالَيْنِ إِذَا جُمِعَا وَزِيدَ عَلَيْهِمَا مِثْلُ عَشَرَةِ أَجْذَارِ أَحَدِهِمَا بَلَغَ ذَلِكَ ثَمَانِيَةً وَأَرْبَعِينَ دِرْهَمًا ؟</قبس></مقطع>
  <مقطع هوية='٤١٤٥٠'>فَيَنْبَغِي أَنْ تَرُدَّ الْمَالَيْنَ إِلَى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٨٠٧٤٨'>وَقَدْ عَلِمْتَ أَنَّ مَالًا مِنْ مَالَيْنِ نِصْفُهُمَا</مقطع>
  <مقطع هوية='٣٩١٨٥'>فَارْدَدْ كُلَّ شَىْءٍ فِي الْمَسْئَلَةِ إلَى نِصْفِهِ</مقطع>
  <مقطع هوية='١٩٨٥٨'>فَكَأنَهُ قَالَ <معادلة>مَالٌ وَخَمْسَةُ أَجْذَارٍ يَعْدِلُ أَرْبَعَةً وَعِشْرِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٦٣٤٠٨'>وَمَعْنَاهُ <قبس>أَيُّ مَالٍ إذَا زِدْتَ عَلَيْهِ خَمْسَةَ أَجْذَارِهِ بَلَغَ ذَلِكَ أَرْبَعَةً وَعِشْرِينَ ؟</قبس></مقطع>
  <مقطع هوية='٧٠٢٧٩'>فَنَصِّفِ الْأَجْذَارَ فَتَكُونَ اثْنَيْنِ وَنِصْفًا</مقطع>
  <مقطع هوية='٩٩٨٢٦'>فَاضْرِبْهَا فِي مِثْلِهَا فَتَكُونَ سِتَّةً وَرُبْعًا</مقطع>
  <مقطع هوية='٢٥١٨١'>فَزِدْهَا عَلَى الْأَرْبَعَةِ وَالْعِشْرِينَ فَتَكُونَ ثَلَاثِينَ دِرْهَمًا وَرُبْعًا</مقطع>
  <مقطع هوية='٩٤٠٨٦'>فَخُذْ جَذْرَهَا وَهُوَ خَمْسَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='١٥٦٦٣'>فَانْقُصْ مِنْهَا نِصْفَ الْأَجْذَارِ وَهُوَ اثْنَانِ وَنِصْفٌ</مقطع>
  <مقطع هوية='٥٤٨٩٥'>يَبْقَى ثَلاثَةٌ وَهُوَ جَذْرُ الْمَالِ وَالْمَالُ تِسْعَةٌ</مقطع>
  <مقطع هوية='٤١٠١٩'>وَكَذَلِكَ لَوْ قَالَ <معادلة>نِصْفُ مَالٍ وَخَمْسَةُ أَجْذَارِهِ يَعْدِلُ ثَمَانِيَةً وَعِشْرِينَ دِرْهَمًا</معادلة>
  </مقطع>
  <مقطع هوية='١٩٨٦٥'>فَمَعْنَى ذَلِكَ <قبس>أَيُّ مَالٍ إذَا زِدْتَ عَلَى نِصْفِهِ مِثْلَ خَمْسَةِ أَجْذَارِهِ بَلَغَ ذَلِكَ ثَمَانِيَةً وَعِشْرِينَ دِرْهَمًا ؟</قبس></مقطع>
  <مقطع هوية='٦٧١٣٧'>فَتُرِيدُ أَنْ <ص مفتاح="كمل">تُكْمِلَ</ص> مَالَكَ حَتَّى يَبْلُغَ مَالًا تَامًّا وَهُوَ أَنْ تُضْعِفَهُ</مقطع>
  <مقطع هوية='٧٥٥٤٩'>فَأَضْعِفْهُ وَأَضْعِفْ كُلَّمَا مَعَكَ مِمَّا يُعَادِلُهُ</مقطع>
  <مقطع هوية='٣٥٧٤٣'>فَيَكُونَ <قبس>مَالًا وَعَشَرَةَ أَجْذَارٍ يَعْدِلُ سِتَّةً وَخَمْسِينَ دِرْهَمًا</قبس></مقطع>
  <!-- p020 -->
  <مقطع هوية='٤٨٣٣٣'>فَنَصِّفْ الْأَجْذَارَ فَتَكُونَ <صفحة رقم="٢٠"/>خَمْسَةً</مقطع>
  <مقطع هوية='٧٢٢٣٨'>فَاضْرِبْهَا فِي مِثْلِهَا فَتَكُونَ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٦٥٩٠١'>فَزِدَهَا عَلَى السِّتَّةِ وَالْخَمْسِينَ فَتَكُونَ أَحَدًا وَثَمَانِينَ</مقطع>
  <مقطع هوية='٨٣١٣٥'>فَخُذْ جَذْرَهَا وَهُوَ تِسْعَةٌ</مقطع>
  <مقطع هوية='١٠٩٣٨'>فَانْقُصْ مِنْهَا نِصْفَ الْأَجْذَارِ وَهُوَ خَمْسَةُ</مقطع>
  <مقطع هوية='٢٥٤٨٤'>فَيَبْقَى أَرْبَعَةٌ وَهُوَ جَذْرُ الْمَالِ الَّذِى أَرَدْتُ وَالْمَالُ سِتَّةُ عَشَرَ وَنِصْفُهُ ثَمَانِيَةٌ</مقطع>

  <مقطع هوية='٣١٨٥٣'>وَكَذَلِكَ فَافْعَلْ بِجَمِيعِ مَا جَاءَكَ مِنَ الِامْوَالِ وَالْجَذُورِ وَمَا عَادَلَهَا مِنْ الْعَدَدِ تُصِبْ إِنْ شَاءَ اللَّهُ</مقطع>

  <قسم هوية='١٤٢٩٠'>
    <عنوان>[أموال+عدد=جذور]</عنوان>
  </قسم>
  <مقطع هوية='٨٨١٧٩'>وَأَمَّا الْأَمْوَالُ وَالْعَدَدُ الَّتِي تَعْدِلُ الْجُذُورَ</مقطع>
  <مقطع هوية='١٤٥٤٩'>فَنَحْوُ قَوْلِك <معادلة>مَالٌ وَأَحَدٌ وَعِشْرُونَ مِنْ الْعَدَدِ يَعْدِلُ عَشَرَةَ أَجْذَارِهِ</معادلة>
  </مقطع>
  <مقطع هوية='٠٢٤٦٨'>وَمَعْنَاهُ <قبس>أَيُّ مَالٍ إذَا زِدْتْ عَلَيْهِ وَاحِدًا وَعِشْرِينَ دِرْهَمًا كَانَ مَا اجْتَمَعَ مِثْلَ عَشَرَةِ أَجْذَارِ ذَلِكَ الْمَالِ ؟</قبس></مقطع>
  <مقطع هوية='٨٦٥٦٣'><قياس>فَبَابُهُ</قياس> أَنْ تُنَصِّفَ الْأَجْذَارَ فَتَكُونَ خَمْسَةً</مقطع>
  <مقطع هوية='٠٨٩٧٩'>فَاضْرِبْهَا فِي مِثْلِهَا فَتَكُونَ خَمْسَةً وَعِشْرِيْنَ</مقطع>
  <مقطع هوية='١٤٥٢٤'>فَانْقُصْ مِنْهَا الْوَاحِدَ وَالْعِشْرِينَ الَّتِي ذُكِرَ أَنَّهَا مَعَ الْمَالِ فَيَبْقَى أَرْبَعَةٌ</مقطع>
  <مقطع هوية='٩٥٩٦٥'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ</مقطع>
  <مقطع هوية='٤٩٤٢٩'>فَانْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ وَهُوَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٧٨٨٥٩'>فَيَبْقَى ثَلَاثَةٌ وَهُوَ جَذْرُ الْمَالِ الَّذِي تُرِيدُهُ وَالْمَالُ تِسْعَةٌ</مقطع>

  <رأس/>
  <مقطع هوية='١٩٥٢٤'>وَإِنْ شِئْتَ فَزِدْ الْجَذْرَ عَلَى نِصْفِ الْأَجْذَارِ فَتَكُونَ سَبْعَةً</مقطع>
  <مقطع هوية='١٢١٩٨'>وَهُوَ جَذْرُ الْمَالِ الَّذِى تُرِيدُهُ وَالْمَالُ تِسْعَةٌ وَأَرْبَعُونَ</مقطع>
  <مقطع هوية='١١٠٢٤'>فَاذَا وَرَدَتْ عَلَيْكَ مَسْئَلَةٌ تُخْرِجُكَ إِلَى هَذَا الْبَابِ فَامْتَحِنْ صَوَابَهَا بِالزِّيَادَةِ</مقطع>
  <مقطع هوية='٠٩٦٤٦'>فَإِنْ لَمْ تَكُنْ فَهِيَ بِالنُّقْصَانِ لَا مَحَالَةَ</مقطع>
  <مقطع هوية='٣٤٩٦٦'>وَهَذَا الْبَابُ يَعْمَلُ بِالزِّيَادَةِ وَالنُّقْصَانِ جَمِيعًا</مقطع>
  <مقطع هوية='٩١٠٠٣'>وَلَيْسَ ذَلِكَ فِي غَيْرِهِ مِنْ الأَبْوَابِ الثَّلَاثَةِ الَّتِى يُحْتَاجُ فِيْهَا إِلَى تَنْصِيفِ الْأَجْذَارِ</مقطع>

  <رأس/>
  <مقطع هوية='٦٢٥٤١'><ص مفتاح="علم!اعْلَمْ">وَاعْلَمْ</ص> أَنَّكَ إِذَا نَصَّفْتَ الْأَجْذَارَ فِي هَذَا الْبَابِ</مقطع>
  <!-- p021a -->
  <مقطع هوية='٩٤١٣٤'>وَضَرَبْتَهَا فِي <صفحة رقم="٢١"/>مِثْلِهَا</مقطع>
  <مقطع هوية='٥٤٢٥٣'>فَكَانَ مَبْلَغُ ذَلِكَ أَقَلَّ مِنَ الدَّراهِمِ الَّتِي مَعَ الْمَالِ</مقطع>
  <مقطع هوية='٨٥٢٤٢'>فَالْمَسْئَلَةُ مُسْتَحِيلَةٌ</مقطع>
  <مقطع هوية='٧٨٩٥٠'>وَإِنْ كَانَ مِثْلَ الدَّرَاهِمِ بِعَيْنِهَا</مقطع>
  <مقطع هوية='٤٧٥٢٨'>فَجَذْرُ الْمَالِ مِثْلُ نِصْفِ الِاجْذَارِ سَوَاءً لا زِيَادَةً وَلَا نُقْصَانَ</مقطع>
  <مقطع هوية='٩٦٩٧٨'>وَكُلُّ مَا أَتَاكَ مِنْ مَالَيْنِ أَوْ أَكْثَرَ أَوْ أَقَلَّ فَارْدُدْهُ الْى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٩٤٥٩٩'>كَنَحْوِ مَا بَيَّنْتُ لَكَ فِي الْبَابِ الِاوْلِ</مقطع>

  <قسم هوية='٨٧٣٦٨'>
    <عنوان>[جذور+عدد=أموال]</عنوان>
  </قسم>
  <مقطع هوية='٩٨٨٣٧'>وَأَمَّا الْجُذُورُ وَالْعَدَدُ الَّتِي تَعْدِلُ الْأَمْوَالَ</مقطع>
  <مقطع هوية='٣٩٢٣١'>فَنَحْوُ قَوْلِكَ <معادلة>ثَلاثَةُ أَجْذَارٍ وَأَرْبَعَةٌ مِنْ الْعَدَدِ تَعْدِلُ مَالًا</معادلة></مقطع>
  <مقطع هوية='٠٥٦٣٦'><قياس>فَبَابُهُ</قياس> أَنْ تُنَصِّفَ الْأَجْذَارَ فَتَكُونَ وَاحِدًا وَنِصْفًا</مقطع>
  <مقطع هوية='٤٦٠٥٩'>فَاضْرِبْهَا فِي مِثْلِهَا فَتَكُونَ اثْنَيْنِ وَرُبْعًا</مقطع>
  <مقطع هوية='٥٩٤٣٢'>فَزِدْهَا عَلَى الْأَرْبَعَةِ فَتَكُونَ سِتَّةً وَرُبْعًا</مقطع>
  <مقطع هوية='٠٤٦٣٢'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٥٢٥٧'>فَزِدْهُ عَلَى نِصْفِ االْأَجْذَارِ وَهُوَ وَاحِدٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٢٠٧٠'>فَتَكُونَ أَرْبَعَةً وَهُوَ جَذْرُ الْمَالِ وَالْمَالُ سِتَّةُ عَشَرَ</مقطع>
  <مقطع هوية='٦٠٤٣٤'>وَكُلُّ مَا كَانَ‎ أَكْثَرَ مِنْ مَالٍ أَوْ أَقَلَّ فَأَرْدَدْهُ إلَى مَالٍ وَاحِدٍ</مقطع>

</فصل>
