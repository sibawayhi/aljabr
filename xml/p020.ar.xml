<ملف رقم="٢٠"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٤٨٣٣٣'>فَنِصْفُ الْأَجْذَارِ تَكُونُ <صفحة رقم="٢٠"/>خَمْسَةٌ</مقطع>
  <مقطع هوية='٧٢٢٣٨'>فَاضْرِبْهَا فِي مِثْلِهَا تَكُونُ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٦٥٩٠١'>فَزِدَهَا عَلَى الْسِّتَّةِ وَالْخَمْسِينَ تَكُونُ أَحَدًا وَثَمَانِينَ</مقطع>
  <مقطع هوية='٨٣١٣٥'>فَخُذْ جَذْرَهَا وَهُوَ تِسْعَةٌ فَانْقُصْ مِنْهَا نِصْفَ الْأَجْذَارِ وَهُوَ خَمْسَةُ</مقطع>
  <مقطع هوية='٢٥٤٨٤'>فَيَبْقَى أَرْبَعَةٌ وَهُوَ جَذْرُ الْمَالِ الَّذِى أَرَدْتُ وَالْمَالُ سِتَّةُ عَشَرَ وَنِصْفُهُ ثَمَانِيَةٌ</مقطع>
  <مقطع هوية='٣١٨٥٣'>وَكَذَلِكَ فَافْعَلْ بِجَمِيعِ مَا جَاءَكَ مِنَ الِامْوَالِ وَالْجَذُورِ وَمَا عَادَلَهَا مِنْ الْعَدَدِ تُصِبْ إِنْ شَاءَ الْلَّهُ</مقطع>

  <قسم هوية='١٤٢٩٠'>
    <عنوان>[أموال+عدد=جذور]</عنوان>
  </قسم>
  <مقطع هوية='٨٨١٧٩'>وَأَمَّا الْأَمْوَالُ وَالْعَدَدُ الَّتِي تَعْدِلُ الْجُذُورَ</مقطع>
  <مقطع هوية='١٤٥٤٩'>فَنَحْوُ قَوْلِك <معادلة>مَالٌ وَأَحَدٌ وَعِشْرُونَ مِنْ الْعَدَدِ يَعْدِلُ عَشَرَةَ أَجْذَارِهِ</معادلة>
  </مقطع>
  <مقطع هوية='٠٢٤٦٨'>وَمَعْنَاهُ <قبس>أَيُّ مَالٍ إذَا زِدْتْ عَلَيْهِ وَاحِدًا وَعِشْرِينَ دِرْهَمًا كَانَ مَا اجْتَمَعَ مِثْلَ عَشَرَةِ أَجْذَارِ ذَلِكَ الْمَالِ</قبس></مقطع>
  <مقطع هوية='٨٦٥٦٣'><قياس>فَبَابُهُ</قياس> أَنْ تُنَصِّفَ الْأَجْذَارَ فَتَكُونَ خَمْسَةً</مقطع>
  <مقطع هوية='٠٨٩٧٩'>فَاضْرِبْهَا فِي مِثْلِهَا تَكُونَ خَمْسَةً وَعِشْرِيْنَ</مقطع>
  <مقطع هوية='١٤٥٢٤'>فَانْقُصْ مِنْهَا الْوَاحِدَ وَالْعِشْرِينَ الَّتِي ذُكِرَ أَنَّهَا مَعَ الْمَالِ فَيَبْقَى أَرْبَعَةٌ</مقطع>
  <مقطع هوية='٩٥٩٦٥'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ</مقطع>
  <مقطع هوية='٤٩٤٢٩'>فَانْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ وَهُوَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٧٨٨٥٩'>فَيَبْقَى ثَلَاثَةٌ وَهُوَ جَذْرُ الْمَالِ الَّذِي تُرِيدُهُ وَالْمَالُ تِسْعَةٌ</مقطع>
  <مقطع هوية='١٩٥٢٤'>وَإِنْ شِئْتَ فَزِدْ الْجَذْرَ عَلَى نِصْفِ الْأَجْذَارِ فَتَكُونَ سَبْعَةً</مقطع>
  <مقطع هوية='١٢١٩٨'>وَهُوَ جَذْرُ الْمَالِ الَّذِى تُرِيدُهُ وَالْمَالُ تِسْعَةٌ وَأَرْبَعُونَ</مقطع>
  <مقطع هوية='١١٠٢٤'>فَاذَا وَرَدَتْ عَلَيْكَ مَسْئَلَةٌ تُخْرِجُكَ إِلَى هَذَا الْبَابِ فَامْتَحِنْ صَوَابَهَا بِالزِّيَادَةِ</مقطع>
  <مقطع هوية='٠٩٦٤٦'>فَإِنْ لَمْ تَكُنْ فَهِيَ بِالنُّقْصَانِ لَا مَحَالَةَ</مقطع>
  <مقطع هوية='٣٤٩٦٦'>وَهَذَا الْبَابُ يَعْمَلُ بِالزِّيَادَةِ وَالنُّقْصَانِ جَمِيعًا</مقطع>
  <مقطع هوية='٩١٠٠٣'>وَلَيْسَ ذَلِكَ فِي غَيْرِهِ مِنْ الْأَبْوَابِ الْثَّلَاثَةِ الَّتِى يُحْتَاجُ فِيْهَا إِلَى تَنْصِيفِ الْأَجْذَارِ</مقطع>

  <رأس/>
  <مقطع هوية='٦٢٥٤١'>وَاعْلَمْ أَنَّكَ إِذَا نَصَّفْتَ الْأَجْذَارَ فِي هَذَا الْبَابِ</مقطع>

</ملف>
