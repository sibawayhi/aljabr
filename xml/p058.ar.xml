<ملف رقم="٥٨"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٣٥١٩٩'><صفحة رقم="٥٨"/> فَصَارَ سَطْحُ [اٮجد] أَرْبَعَةَ سُطُوحٍ مُتَسَاوِيَةِ الأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٠٩٢٠٩'>وَالمِسَاحَةُ وَهِيَ سَطْحُ [ا ك] وَسَطْحُ [ج ك] وَسَطْحُ [ٮ ك] وَسَطْحُ [د ك]</مقطع>
  <مقطع هوية='٢٦٧٦٣'>ثُمَّ نُخْرِجُ مِن نُقْطَةِ [ه] إِلَى نُقْطَةِ [ط] خَطًّا يَقْطَعُ سَطْحَ [ا ك] نِصْفَيْنِ</مقطع>
  <مقطع هوية='٣٧٤٣١'>فَحَدَثَ مِنَ السَّطْحِ مُثَلَّثَانِ وَهُمَا مُثَلَّثَا [ا ط ه] وَ [ه ك ك]</مقطع>
  <مقطع هوية='٤٢٧٢٠'>فَقَدْ تَبَيَّنَ لَنَا أَنَّ [ا ط] نِصْفُ [ا ب]</مقطع>
  <مقطع هوية='٦٢٤٩٤'>وَ [ا ه] مِثْلُهُ وَهُوَ نِصْفُ [ا ج]</مقطع>
  <مقطع هوية='٢١٢٥٣'>وَوَتْرُهُمَا خَطُّ [ط ه] عَلَى زَاوِيَةٍ قَائِمَةٍ</مقطع>
  <مقطع هوية='٠٩٣٥٢'>وَكَذٰلِكَ نُخْرِجُ خُطُوطًا مِن [ط] إِلَى [ز] وَمِن [ز] إِلَى [ح] وَمِن [ح] إِلَى [ه]</مقطع>
  <مقطع هوية='٩١٧٦٩'>فَيَحْدُثُ مِنْ جَمِيعِ الْمُرَبَّعَةِ ثَمَانِي مُثَلَّثَاتٍ مُتَسَاوِيَاتٍ</مقطع>
  <مقطع هوية='٨٧٥٠٥'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ أَرْبَعَةً مِنْهَا نِصْفُ السَّطْحِ الْأَعْظَمِ الَّذِي هُوَ [ا د]</مقطع>
  <مقطع هوية='١٣٩٢٩'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ ضِلَعَ [ا ط] فِي نَفْسِهِ تَكْسِيرُ مُثَلَّثَيْنِ</مقطع>
  <مقطع هوية='١١٠٤٤'>وَ [ا ه] تَكْسِيرُ مُثَلَّثَيْنِ مِثْلَهُمَا</مقطع>
  <مقطع هوية='٩٤٧٩٤'>فَيَكُونُ جَمِيعُ ذٰلِكَ تَكْسِيرَ أَرْبَعَ مُثَلَّثَاتٍ</مقطع>
  <مقطع هوية='٠٣٦٠٨'>وَضِلَعُ [ه ط] فِي نَفْسِهِ أَيْضًا تَكْسِيرُ أَرْبَعَ مُثَلَّثَاتٍ أُخَرَ</مقطع>
  <مقطع هوية='١٢٣٩٠'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ [ا ط] فِي نَفْسِهِ وَ[ا ه] فِي نَفْسِهِ مَجْمُوعَيْنِ</مقطع>
  <مقطع هوية='٠٨٥٦١'>مِثْلَ الَّذِي يَكُونُ مِنْ ضَرْبِ [ط ه] فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٠٨٧٤٤'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ وَهَذِهِ صُورَتُهُ</مقطع>
  <صورة هوية='٧٤٦٥٧' ملف="../figures/fig058"/>
</ملف>
