<ملف رقم="٩٤"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='١٣٠٢٩'>الزَّوْجُ مِائَةُ دِرْهَمٍ وَعَشَرَةُ دِرَاهِمَ</مقطع>
  <مقطع هوية='١١٤٠٦'>مِنْ ذٰلِكَ وَصِيَّةُ الْمَرْأَةِ شَيْءٌ</مقطع>
  <مقطع هوية='٧٠٠٧٣'>فَيَبْقَى مِائَةُ دِرْهَمٍ وَعَشَرَةُ دِرَاهِمَ غَيْرُ شَيْءٍ</مقطع>
  <مقطع هوية='٠٧٨٩٤'>وَيَصِيرُ فِي أَيْدِي وَرَثَةِ الْمَرْأَةِ عِشْرُونَ دِرْهَمًا وَشَيْءٌ</مقطع>
  <مقطع هوية='٧٨٢٦٧'>وَأَوْصَتْ مِنْ ذٰلِكَ بِثُلُثِهِ وَهُوَ سِتَّةُ دِرَاهِمَ وَثُلْثَانِ وَشَيْءٌ</مقطع>
  <مقطع هوية='١١١٠٩'>وَيَرْجِعُ إِلَى وَرَثَةِ الزَّوْجِ مِنْ ذٰلِكَ بِالْمِيرَاثِ نِصْفَ مَا بَقِيَ وَهُوَ سِتَّةُ دِرَاهِمَ وَثُلْثَانِ وَشَيْءٌ</مقطع>
  <مقطع هوية='٨٥٧٥٩'>فَيَصِيرُ فِي أَيْدِي وَرَثَةِ الزَّوْجِ مِائَةُ دِرْهَمٍ وَسِتَّةَ عَشَرَ دِرْهَمًا وَثُلْثَانِ غَيْرُ شَيْءٍ وَثُلُثِي شَيْءٍ</مقطع>

  <مقطع هوية='٦٠١١٤'>تَعْدِلُ مِثْلَيِ الْوَصِيَّتَيْنِ وَذٰلِكَ أَرْبَعَةُ أَشْيَاءَ</مقطع>
  <مقطع هوية='٨٥٠٩٦'>فَاجْبُرْ ذٰلِكَ فَيَكُونُ مِائَةً وَسِتَّةَ عَشَرَ دِرْهَمًا وَثُلُثِيَ دِرْهَمٍ</مقطع>
  <مقطع هوية='٣٢٠٩٥'>تَعْدِلُ خَمْسَةَ أَشْيَاءَ وَثُلُثِيَ شَيْءٍ</مقطع>
  <مقطع هوية='٧٣٧٥١'>فَالشَّيْءُ الْواحِدُ يُعَادِلُ عِشْرِينَ دِرْهَمًا وَعَشَرَةَ أَجْزَاءِ مِنْ سَبْعَةَ عَش</مقطع>

  <قسم هوية='٥٦١٣٦'>
    <عنوان>بَابُ الْعِتْقِ فِي الْمَرَضِ</عنوان>
  </قسم>

  <مقطع هوية='٢٢٣٧٨'>إِذَا أَعْتَقَ الرَّجُلُ عَبْدَيْنِ لَهُ فِي مَرَضِهِ</مقطع>
  <مقطع هوية='٨٠٠٣٩'>وَتَرَكَ السَّيِّدُ ابْنًا وَابْنَةً</مقطع>
  <مقطع هوية='٩٣٩٦٤'>ثُمَّ مَاتَ أَحَدُ الْعَبْدَيْنِ وَتَرَكَ مَالًا أَكْثَرَ مِنْ قِيمَتِهِ وَتَرَكَ ابْنَةً</مقطع>
  <مقطع هوية='٥٠٠٧٤'>فَاجْعَلْ ثُلُثَ قِيمَتِهِ وَمَا سَعَى فِيهِ الْعَبْدُ الْآخَرُ</مقطع>
  <مقطع هوية='٥٥٧٩١'>وَمِيرَاثُ السَّيِّدِ مِنْهُ بَيْنَ الْابْنِ وَالْبِنْتِ</مقطع>
  <مقطع هوية='٩١٥٠٦'>لِلذَّكَرِ مِثْلُ حَظِّ الْأُنْثَيَيْنِ إِذَا كَانَ الْعَبْدُ مَاتَ قَبْلَ السَّيِّدِ</مقطع>
  <مقطع هوية='٧٤٥٠٣'>فَإِنْ كَانَ الْعَبْدُ مَاتَ بَعْدَ السَّيِّدِ</مقطع>
  <مقطع هوية='٠٥٧٥٩'>جَعَلْتُ ثُلُثَيْ قِيمَتِهِ وَمَا سَعَى فِيهِ الْعَبْدُ الْآخَرُ بَيْنَ الْابْنِ وَالْبِنْتِ</مقطع>
  <مقطع هوية='٥٢٤٢٥'>لِلذَّكَرِ مِثْلُ حَظِّ الْأُنْثَيَيْنِ وَمَا بَقِيَ مِنْ بَعْدِ ذٰلِكَ فَهُوَ لِلذَّكَرِ دُونَ الْأُنْثَى</مقطع>
  <مقطع هوية='٦٣٠٩٧'>لَأَنَّ النِّصْفَ مِنْ مِيرَاثِ الْعَبْدِ لِابْنَةِ الْعَبْدِ</مقطع>
  <مقطع هوية='٦١٤٢١'>وَالنِّصْفُ بِالْوَلَاءِ لِابْنِ السَّيِّدِ وَلِابْنَةِ شَيْءٍ</مقطع>

  <مقطع هوية='٩٦٩٦١'>وَكَذٰلِكَ لَوْ أَعْتَقَ رَجُلٌ عَبْدًا لَهُ فِي مَرَضِ مَوْتِهِ وَلَا مَالَ لَهُ غَيْرُهُ</مقطع>
  <مقطع هوية='١٣٦٥٦'>ثُمَّ مَاتَ الْعَبْدُ قَبْلَ السَّيِّدِ</مقطع>

  <مقطع هوية='٦٧٦٢٩'>فَإِنْ أَعْتَقَ الرَّجُلُ عَبْدًا فِي مَرَضِهِ وَلَا مَالَ لَهُ غَيْرُهُ</مقطع>
  <مقطع هوية='١٧٥٧٢'>فَإِنَّ الْعَبْدَ يَسْعَى فِي ثُلُثَي قِيمَتِهِ</مقطع>
  <مقطع هوية='٤٢٢١٧'>فَإِن كَانَ السَّيِّدُ قَدْ تَعَجَّلَ مِنْهُ ثُلُثَي قِيمَتِهِ</مقطع>
  <مقطع هوية='٧٩٧٣٧'>فَاسْتَهْلَكَ الْسَّيِّدُ ثُمَّ مَاتَ السَّيِّدُ</مقطع>
  <مقطع هوية='٢٨٩٠٠'>فَإِنَّ الْعَبْدَ يَسْعَى فِي ثُلُثَي مَا بَقِيَ</مقطع>
  <مقطع هوية='٥٠٦٩٦'>فَإِنْ كَانَ قَدِ اسْتَوْفَى مِنْهُ قِيمَتَهُ كُلَّهَا</مقطع>
  <مقطع هوية='٥٧٦٧٤'>فَاسْتَهْلَكَها فَلَا سَبِيلَ عَلَى الْعَبْدِ لِأَنَّهُ قَدْ أَدَّى جَمِيعَ قِيمَتِهِ</مقطع>
  <مقطع هوية='٤٨١٩١'>فَإِنْ أَعْتَقَ عَبْدًا لَهُ فِي مَرَضِ مَوْتِهِ ثَلَاثُمِائَةَ دِرْهَمٍ</مقطع>
  <مقطع هوية='٥٦٢٤٩'>وَلَا مَالَ لَهُ غَيْرُهُ ثُمَّ مَاتَ الْعَبْدُ</مقطع>
  <مقطع هوية='٣٩٠٩١'>وَتَرَكَ ثَلَاثُمِائَةَ دِرْهَمٍ وَتَرَكَ بِنْتًا</مقطع>
  <مقطع هوية='٠٧١٤٢'>فَقيَاسُهُ أَنْ تَجْعَلَ وَصِيَّةَ الْعَبْدِ شَيْئًا</مقطع>
  <مقطع هوية='٨٣١٨٧'>وَيَسْعَى فِيمَا بَقِيَ مِنْ قِيمَتِهِ وَهُوَ ثَلَاثُمِائَةٌ غَيْرَ شَيْءٍ</مقطع>
  <مقطع هوية='٣٣٢٣٦'>فَصَارَ فِي يَدِ الْمَوْلَى السِّعايةُ وَهِيَ ثَلَاثُمِائَةٌ غَيْرَ شَيْءٍ</مقطع>
</ملف>
