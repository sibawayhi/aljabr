<صفحة رقم="٢٨"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٧٩٠٨٨'>وَالْوَاحِدُ <folio nbr="٢٨"/> النَّاقِصُ فِي الْعَشَرَةِ عَشَرَةٌ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٦٧٣٣٩'>وَالْوَاحِدُ النَّاقِصُ أَيْضًا فِي الْعَشَرَةِ عَشَرَةٌ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٦٩١٨٢'>فَذٰلِكَ ثَمَانُونَ</مقطع>
  <مقطع هوية='٥٨٣٦٠'>وَالْوَاحِدُ النَّاقِصُ فِي الْوَاحِدِ النَّاقِصِ وَاحِدٌ زَائِدٌ</مقطع>
  <مقطع هوية='٩٦٨٠٨'>فَذٰلِكَ أَحَدٌ وَثَمَانُونَ</مقطع>

  <رأس/>
  <مقطع هوية='١٦٠٢٩'>وَإِذَا كَانَتْ <تعبير>عَشَرَةٌ وَاثْنَانِ فِي عَشَرَةٍ إِلَّا وَاحِدًا</تعبير></مقطع>
  <مقطع هوية='٩٨٩٩٤'>فَالعَشَرَةُ فِي العَشَرَةِ مِائَةٌ</مقطع>
  <مقطع هوية='٨١٨١٣'>وَالْوَاحِدُ النَّاقِصُ فِي العَشَرَةِ عَشَرَةٌ نَاقِصَةٌ</مقطع>
  <مقطع هوية='١٨١٢٠'>وَالِاثْنَانِ الزَّائِدَانِ فِي العَشَرَةِ عِشْرُونَ زَائِدَةٌ</مقطع>
  <مقطع هوية='٩٢٩٧٥'>فَذٰلِكَ مِائَةٌ وَعَشَرَةٌ</مقطع>
  <مقطع هوية='٥٨٠٢٠'>وَالِاثْنَانِ الزَّائِدَانِ فِي الْوَاحِدِ الْمَنْقُوصِ اثْنَانِ نَاقِصَانِ</مقطع>
  <مقطع هوية='٧٨٤٠٨'>فَذٰلِكَ كُلُّهُ مِائَةٌ وَثَمَانِيَةٌ</مقطع>

  <رأس/>
  <مقطع هوية='٨٩٢٥٥'>وَإِنَّمَا بَيَّنْتُ ذٰلِكَ لِتَسْتَدِلَّ بِهِ عَلَى ضَرْبِ الْأَشْيَاءَ بَعْضِهَا فِي بَعْضٍ</مقطع>
  <مقطع هوية='١٩٠٥٧'>إِذَا كَانَ مَعَهَا عَدَدٌ أَوْ اسْتُثْنِيَتْ مِنْ عَدَدٍ أَوْ اسْتُثْنِيَ مِنْهَا عَدَدٌ</مقطع>

  <رأس/>
  <مقطع هوية='٦٩٩١٤'>فَإِذَا قِيْلَ لَكَ <تعبير>عَشَرَةٌ إِلَّا شَيْئًا وَمَعْنَى الشَّيْءِ الْجَذْرُ فِي عَشَرَةٍ</تعبير></مقطع>
  <مقطع هوية='١٦٩٠٤'>فَاضْرِبْ عَشَرَةً فِي عَشَرَةٍ يَكُونُ مِائَةً</مقطع>
  <مقطع هوية='٢٤١٥٠'>وَإِلَّا شَيْئًا فِي عَشَرَةٍ يَكُونُ عَشَرَةَ أَجْذَارٍ نَاقِصَةً</مقطع>
  <مقطع هوية='٨٣٨١٥'>فَيَعْدِلُ مِائَةً إِلَّا عَشَرَةَ أَشْيَاءَ</مقطع>

  <رأس/>
  <مقطع هوية='١٩٤٤٩'>فَإِنْ قَالَ <تعبير>عَشَرَةً وَشَيْءً فِي عَشَرَةٍ</تعبير></مقطع>
  <مقطع هوية='٦٢٩٠٣'>فَاضْرِبْ عَشَرَةً فِي عَشَرَةٍ يَكُونُ مِائَةً</مقطع>
  <مقطع هوية='٢٣٧٥٧'>وَشَيْئًا فِي عَشَرَةٍ بِعَشَرَةٍ أَشْيَاءَ زَائِدَةً</مقطع>
  <مقطع هوية='٠٤٢١٦'>يَكُونُ مِائَةً وَعَشَرَةَ أَشْيَاءَ</مقطع>

  <رأس/>
  <مقطع هوية='٥٨٩٨٧'>وَإِنْ قَالَ <تعبير>عَشَرَةٌ وَشَيْءٌ فِي مِثْلِهَا</تعبير></مقطع>
  <مقطع هوية='٦٢٥٦٦'>قُلْتَ عَشَرَةٌ فِي عَشَرَةٍ مِائَةٌ</مقطع>
  <مقطع هوية='٢٣٩٨٩'>وَعَشَرَةٌ فِي شَيْءٍ بِعَشَرَةِ أَشْيَاءَ</مقطع>
  <مقطع هوية='٦٢٦٧١'>وَعَشَرَةٌ فِي شَيْءٍ بِعَشَرَةِ أَشْيَاءَ أَيْضًا</مقطع>
  <مقطع هوية='٧٨١٢٩'>وَشَيْءٌ فِي شَيْءٍ مَالٌ زَائِدٌ</مقطع>
  <مقطع هوية='٣٢٦٨٤'>فَيَكُونُ ذَلِكَ مِائَةَ دِرْهَمٍ وَعِشْرِينَ شَيْئًا وَمَالًا زَائِدًا</مقطع>

  <رأس/>
  <مقطع هوية='٨٥٥٩١'>وَإِنْ قَالَ <تعبير>عَشَرَةٌ إِلَّا شَيْئًا فِي عَشَرَةٍ إِلَّا شَيْئًا</تعبير></مقطع>
  <مقطع هوية='٥٢٢٤١'>قُلْتَ عَشَرَةٌ فِي عَشَرَةٍ بِمِائَةٍ</مقطع>
  <مقطع هوية='٧٧٣١٠'>وَإِلَّا شَيْئًا فِي عَشَرَةٍ عَشَرَةَ أَشْيَاءَ نَاقِصَةً</مقطع>
  <مقطع هوية='٢٠٢٦٩'>وَإِلَّا شَيْئًا فِي عَشَرَةٍ عَشَرَةَ أَشْيَاءَ نَاقِصَةً</مقطع>
  <مقطع هوية='١٦٦٧٤'>وَإِلَّا شَيْئًا فِي إِلَّا شَيْثًا مَالٌ زَائِدٌ</مقطع>
  <مقطع هوية='٦٦٣١٦'>فَيَكُونُ ذٰلِكَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
</صفحة>
<!-- وَكَذَلِكَ <folio nbr="٢٩"/> -->
