<ملف رقم="٦٣"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

<مقطع هوية='٧١٥٣٩'><مقابلة>فَقَابِلْ بِهِمَا</مقابلة> <صفحة رقم="٦٣"/> وَهُوَ أَنْ تُلْقِي مَالًا بِمَالٍ لِأنَّ الْمَالَيْنِ نَاقِصَانِ</مقطع>
<مقطع هوية='١٩٢٤٩'>فَيَبْقَى تِسْعَةٌ وَعِشْرُونَ وَثَمَانِيَةٌ وَعِشْرُونَ شَيْئًا تَعْدِلُ مِائَةً وَتِسْعَةً وَسِتِّينَ</مقطع>
<مقطع هوية='٨٦٤٧٥'>فَأَلْقِ تِسْعَةً وَعِشْرِينَ مِنْ مِائَةٍ وَتِسْعَةٍ وَسِتِّينَ</مقطع>
<مقطع هوية='٢٨٥١٦'>فَيَبْقَى مِائَةٌ وَأَرْبَعُونَ تَعْدِلُ ثَمَانِيَةً وَعِشْرِينَ شَيْئًا</مقطع>
<مقطع هوية='٦٩٩٥٨'>فَالْشَّيْءُ الْوَاحِدُ خَمْسَةٌ وَهُوَ مَسْقَطُ الْحَجَرِ مِمَّا يَلِي الثَّلَاثَةَ عَشَرَ</مقطع>
<مقطع هوية='٤٨٥٥٤'>وَتَمَامُ الْقَاعِدَةِ مَا عَلَى الضِّلْعِ الْآخَرِ فَهُوَ تِسْعَةٌ</مقطع>
<مقطع هوية='٧٤٧٢٠'>فَإِذَا أَرَدْتَ أَنْ تَعْرِفَ الْعَمُودَ</مقطع>
<مقطع هوية='٩٣٥٩٦'>فَاضْرِبْ هَذِهِ الْخَمْسَةَ فِي مِثْلِهَا</مقطع>
<مقطع هوية='٣٩٩٢٥'>وَانْقُصْهَا مِنَ الضِّلَعِ الَّذِي يَلِيهَا مَضْرُوبًا فِي مَثْلِهِ وَهُوَ ثَلاثَةَ عَشَرَ</مقطع>
<مقطع هوية='٥٠٤٠٥'>فَيَبْقَى مِائَةً وَأَرْبَعَةً وَأَرْبَعُونَ</مقطع>
<مقطع هوية='٧٥٣٦٩'>فَجَذْرُ ذٰلِكَ هُوَ الْعُمُودُ وَهُوَ اثْنَا عَشَرَ</مقطع>
<مقطع هوية='٢٩٢٩٥'>وَالْعُمُودُ أَبَدًا يَقَعُ عَلَى الْقَاعِدَةِ عَلَى زَاوِيَتَيْنِ قَائِمَتَيْنِ</مقطع>
<مقطع هوية='٣٢٣٣٩'>وَلِذٰلِكَ سُمِّيَ عُمُودًا لِأَنَّهُ مُسْتَوٍ</مقطع>
<مقطع هوية='٤٦٦٣٧'>فَاضْرِبْ الْعُمُودَ فِي نِصْفِ الْقَاعِدَةِ وَهُوَ سَبْعَةٌ</مقطع>
<مقطع هوية='٢٢٠٦٤'>فَيَكُونُ أَرْبَعَةً وَثَمَانِينَ وَذٰلِكَ تَكْسِيرُهَا وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٨٩١٧٤' عرض="0.5" ملف="../figures/fig063"/>

<مقطع هوية='١٣٥٠٥'>وَالْجِنْسُ الثَّالِثُ <شدة>الْمُنْفَرِجَةُ</شدة></مقطع>
<مقطع هوية='٦٥٥٤٩'>وَهِيَ الَّتِي لَهَا زَاوِيَةٌ مُنفَرِجَةٌ وَهِيَ مُثَلَّثَةٌ مِنْ كُلِّ جَانِبٍ عَدَدٌ مُخْتَلِفٌ</مقطع>
<مقطع هوية='١٨٤١٥'>وَهِيَ مِنْ جَانِبٍ سِتَّةٌ وَمِنْ جَانِبٍ خَمْسَةٌ وَمِنْ جَانِبٍ تِسْعَةٌ</مقطع>
<مقطع هوية='٩٨٨٩٥'>فَمَعْرِفَةُ تَكْسِيرِ هَذِهِ مِنْ قَبْلِ عَمُودِهَا وَمَسْقَطِ حَجَرِهَا</مقطع>
<مقطع هوية='٨١٣٧٨'>وَلَا يَقَعُ مَسْقَطُ هَذِهِ الْمُثَلَّثَةِ فِي جَوْفِهَا إِلَّا عَلَى الضِّلَعِ الأَطْوَلِ فَاجْعَلْهُ قَاعِدَةً</مقطع>
<مقطع هوية='٤٩٧٨٢'>وَلَوْ جَعَلْتَ أَحَدَ الضِّلَعينِ الأَقْصَرَيْنِ قَاعِدَةً لَوَقَعَ مَسْقَطُ حَجَرِهَا خَارِجَهَا</مقطع>
<مقطع هوية='١١٤٠٤'>وَعِلْمُ مَسْقَطِ حَجَرِهَا وَعَمُودِهَا عَلَى مِثَالِ مَا عَمَلْتُ لَكَ فِي الْحَادَّةِ</مقطع>
<مقطع هوية='٣٦٧٦٠'>وَعَلَى ذٰلِكَ الْقِيَاسِ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٢٧٣٠٥' عرض="0.8" ملف="../figures/fig064a"/>

  <قسم هوية='٤١٥١٠'>
    <عنوان>[الْمُدَوَّراتُ]</عنوان>
  </قسم>
<مقطع هوية='٣٤٥٨١'>وَأَمَّا <شدة>لِلْمُدَوَّرَاتِ</شدة> الَّتِي فَرَغْنَا مِنْ صِفَتِهَا وَتَكْسِيرِهَا فِي <صفحة رقم="٦٤"/> صَدْرِ الْكِتَابِ</مقطع>
</ملف>
