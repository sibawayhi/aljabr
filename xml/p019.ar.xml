<ملف رقم="١٩"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٢٧٧٥٣'><قياس>فَبَابُهُ</قياس> أَنْ تُنْصِفَ الْأَجْذَارَ وَهَى فِي <صفحة رقم="١٩"/>
  هَذِهِ الْمَسْئَلةِ خَمْسَةٌ</مقطع>
  <مقطع هوية='٠٧٦٦٦'>فَتَضْرِبَهَا فِي مِثْلِهَا فَتَكُونَ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٨٧٤٥٨'>فَتَزِيدَهَا عَلَى التِّسْعَةِ وَالثَّلَاثِينَ فَتَكُونَ أَرْبَعَةً وَسِتِّينَ</مقطع>
  <مقطع هوية='٥٣٢٨٧'>فَتَأْخُذَ جَذْرَهَا وَهُوَ ثَمَانِيَةٌ</مقطع>
  <مقطع هوية='٣٨٧٨٨'>فَتَنْقُصُ مِنْهُ نِصْفَ الْأَجْذَارِ وَهُوَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٥٣٤٩٥'>فَيَبْقَى ثَلَاثَةً وَهُوَ جَذْرُ الْمَالِ الَّذِى تُرِيدُ وَالْمَالُ تِسْعَةٌ</مقطع>
  <مقطع هوية='٥٩٧٢٧'>وَكَذَلِكَ لَوْ ذَكَرَ مَالَيْنِ أَوْ ثَلَاثَةً أَوْ أَقَلَّ أَوْ أَكْثَرَ</مقطع>
  <مقطع هوية='٢٠٩٦٣'>فَارْدُدْهُ إلَى مَالٍ وَاحِدٍ وَارْدُدْ مَا كَانَ مَعَهُ مِنْ الْأَجْذَارِ وَالْعَدَدِ إلَى مِثْلِ مَا رَدَدْتَ إلَيْهِ الْمَالَ</مقطع>
  <مقطع هوية='٢٥٧٩٦'>وَهُوَ نَحْوُ قَوْلِكَ <معادلة>مَالانِ وَعَشَرَةُ أَجْذَارٍ تَعْدِلُ ثَمَانِيَةً وَأَرْبَعِينَ دِرْهَمًا</معادلة>
  </مقطع>
  <مقطع هوية='٨٣٧٤٨'>وَمَعْنَاهُ <قبس>أَيُّ مَالَيْنِ إِذَا جُمِعَا وَزِيدَ عَلَيْهِمَا مِثْلُ عَشَرَةِ أَجْذَارِ أَحَدِهِمَا بَلَغَ ذَلِكَ ثَمَانِيَةً وَأَرْبَعِينَ دِرْهَمًا ؟</قبس></مقطع>
  <مقطع هوية='٤١٤٥٠'>فَيَنْبَغِي أَنْ تَرُدَّ الْمَالَيْنَ إِلَى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٨٠٧٤٨'>وَقَدْ عَلِمْتَ أَنَّ مَالًا مِنْ مَالَيْنِ نِصْفُهُمَا</مقطع>
  <مقطع هوية='٣٩١٨٥'>فَارْدَدْ كُلَّ شَىْءٍ فِي الْمَسْئَلَةِ إلَى نِصْفِهِ</مقطع>
  <مقطع هوية='١٩٨٥٨'>فَكَأنَهُ قَالَ <معادلة>مَالٌ وَخَمْسَةُ أَجْذَارٍ يَعْدِلُ أَرْبَعَةً وَعِشْرِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٦٣٤٠٨'>وَمَعْنَاهُ <قبس>أَيُّ مَالٍ إذَا زِدْتَ عَلَيْهِ خَمْسَةَ أَجْذَارِهِ بَلَغَ ذَلِكَ أَرْبَعَةً وَعِشْرِينَ ؟</قبس></مقطع>
  <مقطع هوية='٧٠٢٧٩'>فَنَصِّفِ الْأَجْذَارَ فَتَكُونَ اثْنَيْنِ وَنِصْفًا</مقطع>
  <مقطع هوية='٩٩٨٢٦'>فَاضْرِبْهَا فِي مِثْلِهَا فَتَكُونَ سِتَّةً وَرُبْعًا</مقطع>
  <مقطع هوية='٢٥١٨١'>فَزِدْهَا عَلَى الْأَرْبَعَةِ وَالْعِشْرِينَ فَتَكُونَ ثَلَاثِينَ دِرْهَمًا وَرُبْعًا</مقطع>
  <مقطع هوية='٩٤٠٨٦'>فَخُذْ جَذْرَهَا وَهُوَ خَمْسَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='١٥٦٦٣'>فَانْقُصْ مِنْهَا نِصْفَ الْأَجْذَارِ وَهُوَ اثْنَانِ وَنِصْفٌ</مقطع>
  <مقطع هوية='٥٤٨٩٥'>يَبْقَى ثَلاثَةٌ وَهُوَ جَذْرُ الْمَالِ وَالْمَالُ تِسْعَةٌ</مقطع>
  <مقطع هوية='٤١٠١٩'>وَكَذَلِكَ لَوْ قَالَ <معادلة>نِصْفُ مَالٍ وَخَمْسَةُ أَجْذَارِهِ يَعْدِلُ ثَمَانِيَةً وَعِشْرِينَ دِرْهَمًا</معادلة>
  </مقطع>
  <مقطع هوية='١٩٨٦٥'>فَمَعْنَى ذَلِكَ <قبس>أَيُّ مَالٍ إذَا زِدْتَ عَلَى نِصْفِهِ مِثْلَ خَمْسَةِ أَجْذَارِهِ بَلَغَ ذَلِكَ ثَمَانِيَةً وَعِشْرِينَ دِرْهَمًا ؟</قبس></مقطع>
  <مقطع هوية='٦٧١٣٧'>فَتُرِيدُ أَنْ تُكْمِلَ مَالَكَ حَتَّى يَبْلُغَ مَالًا تَامًّا وَهُوَ أَنْ تُضْعِفَهُ</مقطع>
  <مقطع هوية='٧٥٥٤٩'>فَأَضْعِفْهُ وَأَضْعِفْ كُلَّمَا مَعَكَ مِمَّا يُعَادِلُهُ</مقطع>
  <مقطع هوية='٣٥٧٤٣'>فَيَكُونَ <قبس>مَالًا وَعَشَرَةَ أَجْذَارٍ يَعْدِلُ سِتَّةً وَخَمْسِينَ دِرْهَمًا</قبس></مقطع>

</ملف>
