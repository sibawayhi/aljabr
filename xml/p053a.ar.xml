<ملف رقم="٥٣"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٥٠٦٦٧'>فَإِن قَالَ <معادلة>مَال عَزَلْتَ جَذْرَهُ وَزِدْتَ عَلَى جَذْرِهِ
  جَذْرَ <صفحة رقم="٥٣"/>مَا بَقِيَ فَكَانَ دِرْهَمَيْنِ</معادلة><صفحة رقم="٥٣"/></مقطع>

  <مقطع هوية='٠٦٦٤٩'>فَهَذَا جَذْرُ مَالٍ وَجَذْرُ مَالٍ إِلَّا جَذْرًا تَعْدِلُ دِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٤٣٩٣٣'>فَألْقِ مَنْهُ جَذْرَ مَالٍ وَألْقِ مِنَ الدِّرْهَمَيْنِ جَذْرَ مَالٍ</مقطع>
  <مقطع هوية='٠٥٦١٦'>فَيَكُونُ دِرْهَمَيْنِ إِلَّا جَذْرًا فِي مِثْلِهِ أَرْبَعَةُ دَرَاهِمَ وَمَالًا إِلَّا أَرْبَعَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٦٥٧١٨'>تَعْدِلُ مَالًا إِلَّا جَذْرًا</مقطع>
  <مقطع هوية='٩٨٥٤٥'><مقابلة مفتاح="قبل!قابِلْ">فَقَابِلْ بِهِ</مقابلة> فَيَكُونُ مَالًا وَأَرْبَعَةَ دَرَاهِمَ تَعْدِلُ مَالًا وَثَلاَثَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٤٤١٨١'>فَتُلْقِي مَالًا بِمَالٍ فَيَبْقَى ثَلاَثَةَ أَجْذَارٍ تَعْدِلُ أَرْبَعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢٨١١٨'>فَالْجَذْرُ يَعْدِلُ دِرْهَمًا وَثُلُثًا وَهُوَ جَذْرُ الْمَالِ</مقطع>
  <مقطع هوية='٨٥٠١٨'>وَالْمَالُ دِرْهَمٌ وَسَبْعَةُ أَتْسَاعِ دِرْهَمٍ</مقطع>

  <مقطع هوية='٤٥١٥٦'>فَإِنْ قَالَ تَعْزِلُ ثَلاَثَةَ أَجْذَارِهِ ثُمَّ تَضْرِبُ مَا بَقِيَ فِي مِثْلِهِ فَيَعُودُ الْمَالُ</مقطع>
  <مقطع هوية='٠٥٤٢٩'>فَقَدْ عَلِمْتَ أَنَّ الَّذِي بَقِيَ هُوَ جَذْرٌ أَيْضًا</مقطع>
  <مقطع هوية='٤٨٥٥١'>وَأَنَّ الْمَالَ أَرْبَعَةُ أَجْذَارٍ وَهُوَ سِتَّةَ عَشَرَ</مقطع>

</ملف>
