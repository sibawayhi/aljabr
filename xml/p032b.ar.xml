<?xml version="1.0" encoding="utf-8"?>

<ملف رقم="٣٢"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <فصل هوية='٤٦٨١٨'>
    <عنوان>[صُوَرُ الْجَمْعِ والنُّقْصانِ]</عنوان>
  </فصل>

  <مقطع هوية='٧١٨٢٤'>فَأَمَّا عَلَّةُ <تعبير>جَذْرِ مِائَتَيْنِ إِلَّا عَشَرَةً مَجْمُوعًا إِلَى عِشْرِينَ إِلَّا جَذْرَ مِائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٨٩٥١٢'>فَإِنَّ صُورَةَ ذٰلِكَ خَطُّ <خط>اٮ</خط> وَهُوَ جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٨٦٠١٧'>فَمِنْ <نقطة>ا</نقطة> إِلَى نُقْطَةِ <نقطة><جيم/></نقطة> هُوَ الْعَشَرَةُ</مقطع>
  <مقطع هوية='١٢٤٦٠'>وَالْبَاقِي جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='١٣٧٦٢'>هُوَ الْيَاقِي مِنْ خَطِّ <خط>اٮ</خط> وَهُوَ خَطُّ <خط><جيم/> ٮ</خط></مقطع>
  <مقطع هوية='١٢٥٣٢'>ثُمَّ تُخْرِجُ مِنْ نُقْطَةِ <نقطة>ٮ</نقطة> خَطًّا إِلَى نُقْطَةِ <نقطة><ه/></نقطة></مقطع>
  <مقطع هوية='٣٠٩١٣'>وَهُوَ خَطُّ الْعِشْرِينَ</مقطع>

</ملف>
