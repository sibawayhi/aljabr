<ملف رقم="٣٩"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٣٧٠١٦'>فَقَدْ <ص مفتاح="علم!عَلِمْتَ">عَلِمْتَ</ص> أَنَّ أَحَدَ الْقِسْمَيْنِ <صفحة رقم="٣٩"/> مِنَ الْعَشَرَةِ شَيْءٌ وَالْآخَرُ عَشَرَةٌ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٠٧٦٧١'>فَاضْرِبْ شَيْئًا فِي عَشَرَةٍ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٦١٢٥١'>فَيَكُونُ عَشَرَةَ أَشْيَاءَ إِلَّا مَالًا تَعْدِلُ أَحَدًا وَعِشْرِينَ</مقطع>
  <مقطع هوية='٨٠٥٨٤'><جبر>فَاجْبُرْ</جبر> الْعَشَرَةَ الْأَشْيَاءِ بِالْمَالِ وَزِدْهُ عَلَى الْواحِدِ وَالْعِشْرِينَ</مقطع>
  <مقطع هوية='٠٧٣٧٠'>فَيَكُونُ عَشَرَةَ أَشْيَاءَ تَعْدِلُ أَحَدًا وَعِشْرِينَ دِرْهَمًا وَمَالًا</مقطع>
  <مقطع هوية='٥٩١٦٢'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> نِصْفَ الأَجْذَارِ فَبَقِيَ خَمْسَةً</مقطع>
  <مقطع هوية='٣٦٦٧٧'>فَاصْرِبْهَا فِي مِثْلِهَا تَكُنْ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٢٤٣٦٠'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> مِنْهَا الْواحِدَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ فَيَبْقَى أَرْبَعَةً</مقطع>
  <مقطع هوية='٥٣٢٦٢'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ فَانْقُصْهُ مِنْ نِصْفِ الأَجْذَارِ وَهِيَ خَمْسَةٌ</مقطع>
  <مقطع هوية='١٢٩٨٢'>فَيَبْقَى ثَلاثَةٌ وَذٰلِكَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='١٤٥٧٣'>وَإِنْ شِئْتَ زِدْتَ جَذْرَ الْأَرْبَعَةِ عَلَى نِصْفِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٠١٧٦٩'>فَتَكُونُ سَبْعَةً وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='٦٠١٦١'>وَهَذِهِ الْمَسْأَلَةُ الَّتِي تَعْمَلُ بِالزِّيَادَةِ وَالنُّقْصَانِ</مقطع>

  <مقطع هوية='٤٥٢١٤'>وَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ فَضَرَبْتَ كُلَّ قِسْمٍ فِي نَفْسِهِ ثُمَّ أَلْقَيْتَ الأَقَلَّ مِنَ الأَكْثَرِ فَبَقِيَ أَرْبَعُونَ</معادلة></مقطع>
  <مقطع هوية='٧١٢٢٧'><قياس>قِيَاسُهُ</قياس> أَنْ تَضْرِبَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا فَتَكُونَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٢٨٤١'>وَتَضْرِبَ شَيْئًا فِي شَيْءٍ فَيَكُونَ مَالًا</مقطع>
  <مقطع هوية='٤٢٣٤٣'>فَانْقُصْهُ مِنَ المِائَةِ وَالْمَالِ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٠٦٥٧'>تَبْقَى مِائَةً إِلَّا عِشْرِينَ شَيْئًا تُعَدِّلُ أَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٠٢٠٥١'><جبر مفتاح="جبر!اُجْبُرْ">فَاجْبُرِ</جبر> المِائَةَ بِالْعِشْرِينَ الشَّيْءِ وَزِدْهَا عَلَى الأَرْبَعِينَ</مقطع>
  <مقطع هوية='٨٧٧٦٨'>فَيَكُونَ مِائَةً تَعْدِلُ عِشْرِينَ شَيْئًا وَأَرْبَعِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٨٧٧٤١'><ص مفتاح="لقي!أَلْقِ">فَأَلْقِ</ص> الْأَرْبَعِينَ مِنَ المِائَةِ فَيَبْقَى سِتُّونَ دِرْهَمًا تَعْدِلُ عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٠٥٥٨٣'>فَالشَّيْءُ الْواحِدُ يَعْدِلُ ثَلاَثَةً وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٢٨٠٢٧'>وَإِن قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  فَضَرَبْتَ كُلَّ قِسْمٍ فِي نَفْسِهِ وَجَمَعْتَهُمَا
  وَزِدْتَ عَلَيْهِمَا فَضْلَ مَا بَيْنَ الْقِسْمَيْنِ مِن قَبْلِ أَنْ تَضْرِبَهُمَا
  فَبَلَغَ ذٰلِكَ أَرْبَعَةً وَخَمْسِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='١٦٥٧٢'><قياس>فَإِنَّ قِيَاسَهُ</قياس></مقطع>
  <مقطع هوية='٥٠٤٠٨'>أَنْ تَضْرِبَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٧٨٧٣٧'>فَتَكُونَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٤٥٢١٧'>وَتَضْرِبَ الشَّيءَ الْبَاقِي مِنَ الْعَشَرَةِ فِي مِثْلِهِ <صفحة رقم="٤٠"/>فَيَكُونَ مَالًا</مقطع>
</ملف>
