  <فصل هوية='٤٦٨١٨'

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

    <عنوان>[صُوَرُ الْجَمْعِ والنُّقْصانِ]</عنوان>

  <مقطع هوية='٧١٨٢٤'>فَأَمَّا عَلَّةُ <تعبير>جَذْرِ مِائَتَيْنِ إِلَّا عَشَرَةً مَجْمُوعًا إِلَى عِشْرِينَ إِلَّا جَذْرَ مِائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٨٩٥١٢'>فَإِنَّ صُورَةَ ذٰلِكَ خَطُّ <خط>اٮ</خط> وَهُوَ جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٨٦٠١٧'>فَمِنْ <نقطة>ا</نقطة> إِلَى نُقْطَةِ <نقطة><جيم/></نقطة> هُوَ الْعَشَرَةُ</مقطع>
  <مقطع هوية='١٢٤٦٠'>وَالْبَاقِي جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='١٣٧٦٢'>هُوَ الْيَاقِي مِنْ خَطِّ <خط>اٮ</خط> وَهُوَ خَطُّ <خط><جيم/> ٮ</خط></مقطع>
  <مقطع هوية='١٢٥٣٢'>ثُمَّ تُخْرِجُ مِنْ نُقْطَةِ <نقطة>ٮ</نقطة> خَطًّا إِلَى نُقْطَةِ <نقطة><ه/></نقطة></مقطع>
  <مقطع هوية='٣٠٩١٣'>وَهُوَ خَطُّ الْعِشْرِينَ</مقطع>
  <!-- p033 -->
  <مقطع هوية='٣٨٠٦٦'>وَهُوَ <صفحة رقم="٣٣"/> مِثْلَا خَطِّ <خط>اب</خط> الَّذِي هُوَ عَشَرَةٌ</مقطع>
  <مقطع هوية='٨٠٢٦٣'>فَمِن نُقْطَةِ <نقطة>ٮ</نقطة>
  إِلَى نُقْطَةِ <نقطة><ه/></نقطة> مِثْلُ خَطِّ <خط>اٮ</خط></مقطع>
  <مقطع هوية='٦٦٠١٠'>فَهُوَ جَذْرُ مِائَتَيْنِ أَيْضًا</مقطع>
  <مقطع هوية='٦٩٨٣٩'>وَالْبَاقِي مِنَ الْعِشْرِينَ هُوَ مِن نُقْطَةِ <نقطة><ه/></نقطة> إِلَى نُقْطَةِ <نقطة>د</نقطة></مقطع>
  <مقطع هوية='٥٤٩١٣'>فَلَمَّا أَرَدْنَا أَنْ نَجْمَعَ مَا بَقِيَ مِنْ جَذْرِ الْمِائَتَيْنِ بَعْدَ طَرْحِ الْعَشَرَةِ وَهُوَ خَطُّ <خط><جيم/> ٮ</خط></مقطع>
  <مقطع هوية='٤٨٩٨٧'>إِلَى خَطِّ <خط><ه/> د</خط> الَّذِي هُوَ عِشْرُونَ إِلَّا جَذْرَ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٦٤٥٥٤'>فَقَطَعْنَا مِنْ خَطِّ <خط>ٮ <ه/></خط>
  مِثْلَ خَطِّ <خط><جيم/> ٮ</خط> وَهُوَ خَطُّ <خط>ز <ه/></خط></مقطع>

  <مقطع هوية='٣٧٠٦٦'>وَقَدْ كَانَ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>اٮ</خط>
  الَّذِي هُوَ جَذْرُ مِائَتَيْنِ مِثْلُ خَطِّ <خط>ٮ <ه/></خط></مقطع>
  <مقطع هوية='٧٨٦٨٣'>وَأَنَّ خَطَّ <خط>ا<جيم/></خط> الَّذِي هُوَ الْعَشَرَةُ
  مِثْلُ خَطِّ <خط>ٮ ز</خط></مقطع>
  <مقطع هوية='٦٨٥٠٢'>وَالْبَاقِي مِنْ خَطِّ <خط>اٮ</خط>
  الَّذِي هُوَ <خط><جيم/> ٮ</خط></مقطع>
  <مقطع هوية='٥٢٠٩٢'>مِثْلُ الْبَاقِي مِنْ خَطِّ <خط>ب <ه/></خط>
  الَّذِي هُوَ <خط>ز <ه/></خط></مقطع>
  <مقطع هوية='٢٨٣٠٦'>زِدْنَا عَلَى خَطِّ <خط><ه/> د</خط> خَطَّ <خط>ز <ه/></خط></مقطع>

  <مقطع هوية='٩١٨٦٣'>تَبَيَّنَ لَنَا أَنَّهُ قَدْ نَقَصَ مِنْ خَطِّ <خط>ٮ د</خط>
  الَّذِي هُوَ عِشْرُونَ</مقطع>
  <مقطع هوية='٤٥٣١٩'>مِثْلُ خَطِّ <خط>ا<جيم/></خط> الَّذِي هُوَ عَشَرَةٌ
  وَهُوَ خَطُّ <خط>ٮ ز</خط></مقطع>
  <مقطع هوية='٩٧٨٨٩'>وَبَقِيَ لَنَا خَطُّ [ز د] وَهُوَ عَشَرَةٌ</مقطع>
  <مقطع هوية='٤٢١٦٤'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ وَهٰذِهِ صُورَتُهُ</مقطع>
  <صورة هوية='٨٧٢١٠' ملف="../figures/fig033"
        tex="
             \left(١٠ -
             \جذر{}{٢٠٠}\right)
             +
             \left(\جذر{}{٢٠٠}
             - ٢٠\right)"
        pdf="
             (٢٠ - √(٢٠٠)) +
             (√(٢٠٠) - ١٠)"
        />

  <رأس/>
  <مقطع هوية='٤٨٧٢٥'>وَأَمَّا عِلَّةُ <تعبير صفحة="٣٣">جَذْرِ مِائَتَيْنِ إِلَّا عَشَرَةً مَنْقُوصًا مِنْ عِشْرِينَ إِلَّا جَذْرَ مِائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٣٣٢٩١'>فَإنَّ صُورَةَ ذٰلِكَ خَطُّ <خط>اب</خط> وَهُوَ جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٩٢١٤٠'>وَمِنَ <نقطة>ا</نقطة> إِلَى نُقْطَةِ <نقطة><جيم/></نقطة> هِيَ الْعَشَرَةُ الْمَعْلُومَةُ</مقطع>
  <مقطع هوية='٩٨٦٩٩'>وَنُخْرِجُ مِنْ نُقْطَةِ <نقطة>ٮ</نقطة> خَطًّا
  إِلَى نُقْطَةِ <نقطة>د</نقطة> وَنَجْعَلُهُ الْعِشْرِينَ</مقطع>
  <مقطع هوية='٧٣٥٩٢'>وَنَجْعَلُ مِنْ <نقطة>ٮ</نقطة>
  إِلَى نُقْطَةِ <نقطة><ه/></نقطة> مِثْلَ خَطِّ جَذْرِ مِائَتَيْنِ
  وَهُوَ مِثْلُ خَطِّ <خط>اٮ</خط></مقطع>

  <مقطع هوية='١٤٤٠٤'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط><جيم/> ٮ</خط>
  هُوَ مَا بَقِيَ مِنْ جَذْرِ مِائَتَيْنِ بَعْدَ إِلْقَاءِ الْعَشَرَةِ</مقطع>
  <مقطع هوية='٢٦٥١٦'>وَخَطُّ <خط>د <ه/></خط>
  هُوَ مَا بَقِيَ مِنَ الْعِشْرِينَ بَعْدَ إِلْقَاءِ جَذْرَ الْمِائَتَيْنِ</مقطع>
  <مقطع هوية='٦٦٥٩٧'>فَأَرَدْنَا أَنْ نَنْقُصَ خَطَّ <خط><جيم/> ٮ</خط>
  مِنْ خَطِّ <خط><ه/> د</خط></مقطع>
  <مقطع هوية='٦٤٥٢٨'>فَأَخْرَجْنَا مِنْ نُقْطَةِ <نقطة>ٮ</نقطة>
  خَطًّا إِلَى نُقْطَةِ <نقطة>ز</نقطة></مقطع>
  <مقطع هوية='٨٧٨١٨'>وَهُوَ مِثْلُ خَطِّ <خط>ا<جيم/></خط> الَّذِي هُوَ الْعَشَرَةُ</مقطع>
  <مقطع هوية='٧٩٣٣٠'>فَصَارَ جَمِيعُ خَطِّ <خط>ز د</خط>
  مِثْلَ خَطِّ <خط>ز ٮ</خط> وَخَطِّ <خط>ٮ د</خط></مقطع>
  <مقطع هوية='٩١٧٦٦'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ ذٰلِكَ كُلَّهُ ثَلاَثُونَ</مقطع>
  <مقطع هوية='٦٠٥٦٥'>وَقَطَعْنَا مِنْ خَطِّ <خط><ه/> د</خط>
  مِثْلَ خَطِّ <خط><جيم/> ٮ</خط> وَهُوَ خَطُّ <خط><ه/> ح</خط></مقطع>
  <مقطع هوية='٨٤١٢٤'>فَتَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>ح د</خط>
  هُوَ مَا بَقِيَ مِنْ خَطِّ <خط>ز د</خط> الَّذِي <صفحة رقم="٣٤"/> هُوَ ثَلاثُونَ</مقطع>
  <!-- p034a -->
  <مقطع هوية='٩٨٣٣٥'>وَتَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>ٮ <ه/></خط> جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٢٦٦٩١'>وَخَطُّ <خط>ز ٮ</خط> وَ<خط>ٮ <جيم/></خط> جَذْرُ الْمَأْتَيْنِ أَيْضًا</مقطع>
  <مقطع هوية='٠٦٤٦٩'>فَلَمَّا صَارَ خَطُّ <خط><ه/> ح</خط> مِثْلَ خَطِّ <خط><جيم/> ٮ</خط></مقطع>
  <مقطع هوية='٢٦٠٢١'>تَبَيَّنَ لَنَا أَنَّ الَّذِي نَقَصَ مِنْ خَطِّ <خط>ز د</خط></مقطع>
  <مقطع هوية='٣٢٠٧٥'>الَّذِي هُوَ ثَلاثُونَ</مقطع>
  <مقطع هوية='٦٩٠٢٥'>جَذْرَا مِائَتَيْنِ</مقطع>
  <مقطع هوية='٩٨٠٥٧'>وَجَذْرَا مِائَتَيْنِ هُوَ جَذْرُ ثَمَانِي مِائَةٍ</مقطع>
  <مقطع هوية='٤٩٥١٦'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ وَهَذِهِ صُورَتُهُ</مقطع>
  <صورة هوية='١٦٠١٩' ملف="../figures/fig034"
        tex="
             \left(١٠ -
             \جذر{}{٢٠٠}\right)
             -
             \left(\جذر{}{٢٠٠}
             - ٢٠\right)"
        pdf="
             (٢٠ - √(٢٠٠)) -
             (√(٢٠٠) - ١٠)"
             />

  <رأس/>
  <مقطع هوية='٩٢٠٢٨'>وَأَمَّا <تعبير صفحة="٣٤">مَائَةٌ وَمَالٌ إِلَّا عِشْرِينَ جَذْرًا مَجْمُوعٌ إِلَيْهِ خَمْسُونَ وَعَشَرَةُ أَجْذَارٍ إِلَّا مَالَيْنِ</تعبير></مقطع>
  <مقطع هوية='٦١٠٣٧'>فَلَمْ تَسْتَقِمْ لَهُ صُورَةٌ لِأَنَّهُ مِنْ ثَلاثَةِ أَجْنَاسٍ مُخْتَلِفَةٍ</مقطع>
  <مقطع هوية='٢٢٣٢١'>أَمْوَالٌ وَجُذُورٌ وَعَدَدٌ</مقطع>
  <مقطع هوية='٩٢٤٤٧'>وَلَيْسَ مَعَهَا مَا يُعَادِلُهَا فَتُصَوَّرُ</مقطع>
  <مقطع هوية='٦٧٩٦٤'>وَقَدْ يُمْكِنُنا لَهَا صُورَةٌ لَا تُحَسُّ</مقطع>

  <مقطع هوية='٧١٢٨٢'>فَأَمَّا اضْطِرَارُهَا بِاللَّفْظِ فَبَيِّنٌ</مقطع>
  <مقطع هوية='٤١٣٥٧'>وَذٰلِكَ أَنَّكَ قَدْ عَلِمْتَ أَنَّ مَعَكَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ جَذْرًا</مقطع>
  <مقطع هوية='٣٩٥١٤'>فَلَمَّا زِدْتَ عَلَيْهَا خَمْسِينَ وَعَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٥٢٩٩'>صَارَتْ مِائَةً وَخَمْسِينَ وَمَالًا إِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٥٣١٠٩'>لِأَنَّ هَذِهِ الْعَشَرَةَ الأَجْذَارِ الْمَزِيدَةَ
  <جبر مفتاح="جبر!جَبَرَتْ">جَبَرَتْ</جبر> مِنَ الْعِشْرِينَ الْجَذْرِ النَّاقِصَةِ عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٧٣٥٠٥'>فَبَقِيَتْ مِائَةٌ وَخَمْسُونَ وَمَالٌ إِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٠٣١٤'>وَقَدْ كَانَ مَعَ الْمِائَةِ مَالٌ</مقطع>
  <مقطع هوية='٣٤٥٥٣'>فَلَمَّا نَقَصْتَ مِنَ الْمِائَةِ وَالْمَالِ
  الْمَالَيْنِ <ص مفتاح="ثني!مُسْتَثْنَيْنِ">الْمُسْتَثْنَيَيْنِ مِنَ</ص> الْخَمْسِينَ</مقطع>
  <مقطع هوية='٦١٣٧٤'>ذَهَبَ مَالٌ بِمَالٍ وَبَقِيَ عَلَيْكَ مَالٌ</مقطع>
  <مقطع هوية='٥٩٣٤٨'>فَصَارَتْ مِائَةً وَخَمْسِينَ إِلَّا مَالًا وَإِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٩٠٤٢١'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ</مقطع>

  </فصل>
