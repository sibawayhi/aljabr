<ملف رقم="٥٥"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٥٦٨٦٣'>فَإنَّ السَّطْحَ كُلَّهُ وَاحِدٌ</مقطع>
  <مقطع هوية='٤٦٤٠٧'>فَإنْ كَانَ مِنْ كُلِّ جانِبٍ اثْنَانِ وَهُوَ مُتَسَاوِ الأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٠٦٨٥٣'>فَالسَّطْحُ كُلُّهُ أَرْبَعَةُ أَمْثَالِ السَّطْحِ
  الَّذِي هُوَ ذِرَاعٌ فِي ذِرَاعٍ</مقطع>

  <مقطع هوية='١٣٧٥١'>وَكَذَلكَ ثَلاثَةٌ فِي ثَلاثَةٍ وَمَا زَادَ عَلَى ذَلكَ أَوْ نَقَصَ</مقطع>
  <مقطع هوية='٩٠٠٧٥'>وَكَذَلكَ نِصْفٌ فِي نِصْفٍ رُبْعٌ وَغَيْرُ ذَلكَ مِنَ الْكُسُورِ فَعَلَى هذا</مقطع>

  <مقطع هوية='٥٨٩٥٩'>وَكُلُّ سَطْحٍ مُرَبَّعٍ يَكُونُ مِنْ كُلِّ جانِبٍ نِصْفُ ذِرَاعٍ</مقطع>
  <مقطع هوية='٩٨٠٤٢'>فَهُوَ مِثْلُ رُبْعِ السَّطْحِ الَّذِي هُوَ مِنْ كُلِّ جانِبٍ ذِرَاعٌ</مقطع>

  <مقطع هوية='٠٥٧١٤'>وَكَذٰلِكَ ثُلُثٌ فِي ثُلُثٍ وَرُبُعٌ فِي رُبُعٍ وَخُمْسٌ فِي خُمْسٍ</مقطع>
  <مقطع هوية='١٩٠٥٩'>وَثُلُثَانِ فِي نِصْفٍ أَوْ أَقَلَّ مِنْ ذَلكَ أَوْ أَكْثَرَ فَعَلَى حِسَابِهِ</مقطع>

  <مقطع هوية='٧٧٣٩٦'>وَكُلُّ سَطْحٍ مُرَبَّعٍ مُتَسَاوِي الْأَضْلَاعِ</مقطع>
  <مقطع هوية='٧١٧٦٩'>فَإِنَّ أَحَدَ أَضْلَاعِهِ فِي وَاحِدٍ جَذْرُهُ</مقطع>
  <مقطع هوية='٦٥٩٩٣'>وَفِي اثْنَيْنِ جَذْرَاهُ</مقطع>
  <مقطع هوية='٣٧٦٢٧'>صَغُرَ هَذَا السَّطْحُ أَوْ كَبُرَ</مقطع>

  <!-- <قسم هوية='٦٢٤١٦'> -->
  <!--   <عنوان>[الْمُثَلَّثُ]</عنوان> -->
  <!-- </قسم> -->
  <مقطع هوية='١٧٢٩٥'>وَكُلُّ <شدة>مُثَلَّثٍ مُتَسَاوِي الْأَضْلَاعِ</شدة></مقطع>
  <مقطع هوية='٨٠٦٦١'>فَإِنَّ ضَرَبْتَ عَمُودَهُ وَنِصْفَ الْقَاعِدَةِ الَّتِي يَقَعُ عَلَيْهَا الْعَمُودُ</مقطع>
  <مقطع هوية='٨٥٩٣٨'>هُوَ تَكْسِيرُ ذَلكَ الْمُثَلَّثِ</مقطع>

  <!-- <قسم هوية='٤٤٤٤١'> -->
  <!--   <عنوان>[الْمُعَيَّن]</عنوان> -->
  <!-- </قسم> -->
  <مقطع هوية='٩٠٠٣٨'>وَكُلُّ <شدة>مَعَيَّنَةٍ مُتَسَاوِيَةِ الأَضْلاعِ</شدة></مقطع>
  <مقطع هوية='٤١٠٤٣'>فَإِنَّ ضَرْبَكَ أَحَدَ القُطْرَيْنِ فِي نِصْفِ الآخَرِ هُوَ تَكْسِيرُهَا</مقطع>

  <قسم هوية='٤٢٧٢٩'>
    <عنوان>[الْمُدَوَّرَةُ]</عنوان>
  </قسم>
  <مقطع هوية='٧٥٧٤٩'>وَكُلُّ <شدة>مُدَوَّرَةٍ</شدة> فَإِنَّ ضَرْبَكَ القُطْرَ فِي ثَلاثَةٍ وَسُبُعٍ</مقطع>
</ملف>
