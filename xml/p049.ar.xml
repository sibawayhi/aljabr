<ملف رقم="٤٩"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٢٣٦٠٠'><قياس>فقياسه</قياس> أن <صفحة رقم="٤٩"/> تَقُولُ الرَّجُلُ وَالْبَعْضُ هُوَ وَاحِدٌ وَشَيْءٌ</مقطع>
  <مقطع هوية='٢٦٤٨٧'>فَكَأَنَّهُ قَالَ دِرْهَمٌ وَنِصْفٌ بَيْنَ وَاحِدٍ وَشَيْءٍ
  فَأَصَابَ الْوَاحِدُ شَيْئَيْنِ</مقطع>
  <مقطع هوية='١١٧٨٠'>فَاضْرِبِ الشَّيْئَيْنِ فِي الْوَاحِدِ وَالشَّيْءِ</مقطع>
  <مقطع هوية='٦٠٤٤٣'>فَيَكُونُ مَالَيْنِ وَشَيْئَيْنِ تَعْدِلُ دِرْهَمًا وَنِصْفًا</مقطع>
  <مقطع هوية='٨٤٩٥١'>فَرُدَّهَا إِلَى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٩٩٥٨٠'>وَهُوَ أَنْ تَأْخُذَ مِنْ كُلِّ مَا مَعَكَ نَصِّفْهُ</مقطع>
  <مقطع هوية='١٥٥٤٩'>فَتَقُولُ مَالٌ وَشَيْءٌ تَعْدِلُ ثَلاثَةَ أَربَاعٍ دِرْهَمٍ</مقطع>
  <مقطع هوية='٦٢٨٩٢'>فَقَابَلْ بِهِ عَلَى نَحْوِ مَا وَصَفْتُ لَكَ فِي صَدْرِ الْكِتَابِ</مقطع>

  <مقطع هوية='٢٣٩٠٠'>فَإِنْ قَالَ <معادلة>مَالٌ عَزَلْتَ ثُلُثَهُ وَرُبْعَهُ وَأَرْبَعَةَ دَرَاهِمَ وَضَرَبْتَ مَا بَقِيَ فِي مِثْلِهِ
  فَعَادَ الْمَالُ وَزِيَادَةٌ أَثْنَي عَشَرَ دَرْهَمًا</معادلة></مقطع>

  <مقطع هوية='٤٨٤٨٣'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ تَأْخُذُ شَيْئًا فَتَعْزِلُ ثُلُثَهُ وَرُبُعَهُ</مقطع>
  <مقطع هوية='٦٨١٩٢'>فَيَبْقَى خَمْسَةُ أَجْزَاءٍ مِنِ اثْنَيْ عَشَرَ جُزْءًا مِنْ شَيْءٍ</مقطع>
  <مقطع هوية='١٥٩٦٢'>فَتَعْزِلُ مِنْهَا أَرْبَعَةَ دَرَاهِمَ أَيْضًا</مقطع>
  <مقطع هوية='٩١٦٣١'>فَيَبْقَى خَمْسَةُ أَجْزَاءٍ مِنْ اثْنَيْ عَشَرَ مِنْ شَيْءٍ إِلَّا أَرْبَعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢١٢٦٠'>فَتَضْرِبُهَا فِي مِثْلِهَا فَتَكُونَ الأَجْزَاءُ الْخَمْسَةُ خَمْسَةً وَعِشْرِينَ حُزْءًا</مقطع>
  <مقطع هوية='٤٥٦٩٦'>وَتَضْرِبُ الِاثْنَيْ عَشَرَ فِي مِثْلِهَا فَتَكُونَ مِائَةً وَأَرْبَعَةً وَأَرْبَعِينَ</مقطع>
  <مقطع هوية='٤٥٤٧٠'>فَذٰلِكَ خَمْسَةٌ وَعِشْرُونَ مِنْ مِائَةٍ وَأَرْبَعَةٍ وَأَرْبَعِينَ مِنْ مَالٍ</مقطع>
  <مقطع هوية='٢٥٢١٤'>ثُمَّ تَضْرِبُ الأَرْبَعَةَ الدَّرَاهِمَ فِي الْخَمْسَةِ الأَجْزَاءِ مِنِ اثْنَيْ عَشَرَ مِنْ شَيْءٍ مَرَّتَيْنِ</مقطع>
  <مقطع هوية='٥٥٧٤٣'>فَيَكُونَ أَرْبَعِينَ جُزْءًا كُلُّ اثْنَيْ عَشَرَ مِنْهَا شَيْءٌ</مقطع>
  <مقطع هوية='١١٠٧١'>وَالْأَرْبَعَةُ الدَّرَاهِمِ فِي الأَرْبَعَةِ الدَّرَاهِمِ سِتَّةَ عَشَرَ دِرْهَمًا زَائِدَةً</مقطع>

  <مقطع هوية='٨٧٥٧١'>فَتَصِيرُ الْأَرْبَعُونَ الْجُزْءُ ثَلاثَةً أَجْذَارٍ وَثُلُثَ جَذْرٍ نَاقِصٍ</مقطع>
  <مقطع هوية='٧٥٠٣١'>فَتَحْصُلُ مَعَكَ خَمْسَةً وَعِشْرُونَ جُزْءًا مِنْ مِائَةٍ</مقطع>
  <مقطع هوية='٥٥٠٥٩'>وَأَرْبَعَةً وَأَرْبَعِينَ جُزْءًا مِنْ مَالٍ</مقطع>
  <مقطع هوية='٦٤٧٨٧'>وَسِتَّةَ عَشَرَ دِرْهَمًا إِلَّا ثَلاثَةَ أَجْذَارٍ وَثُلُثَ جَذْرٍ</مقطع>
  <مقطع هوية='٩٤٢٧٩'>تَعْدِلُ الْمَالَ الْأَوَّلَ وَهُوَ شَيْءٌ وَاثْنَي عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٩٣٢٠'>فَاجْبُرْهُ وَزِدِ الثَّلَاثَةَ الأَجْذَارِ وَالثُّلُثَ عَلَى الشَّيْءِ وَالِاثْنَي عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩٤١٠٧'>فَتَصِيرُ أَرْبَعَةَ أَجْذَارٍ وَثُلُثَ جَذْرٍ وَاثْنَي عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٢٤١٥٩'>فَقَابِلْ بِهِ وَأَلْقِ اثْنَي عَشَرَ مِنْ سِتَّةِ عَشَرَ</مقطع>
  <مقطع هوية='٧٢٤٧٣'>يَبْقَى أَرْبَعَةُ دَرَاهِمَ وَخَمْسَةً وَعِشْرُونَ جُزْءًا مِنْ مِائَةٍ (وَأَرْبَعَةً)</مقطع>
  <مقطع هوية='١٧٧٦٤'>وَأَرْبَعِينَ مِنْ مَالٍ تَعْدِلُ أَرْبَعَةَ أَجْذَارٍ<صفحة رقم="٥٠"/> وثُلُثًا </مقطع>
</ملف>
