<ملف رقم="٥١"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٥١٨٠٤'>فَإِنْ قَالَ <صفحة رقم="٥٠"/>
  <معادلة>مَالَ ضَرَبْتَهُ فِي ثُلُثَيْهِ فَبَلَغَ خَمْسَةً</معادلة></مقطع>
  <مقطع هوية='٦٢٨٠٩'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ شَيْئًا فِي ثُلُثَيْ شَيْءٍ فَيَكُونَ ثُلُثَيْ مَالٍ تَعْدِلُ خَمْسَةً</مقطع>
  <مقطع هوية='٥١٦٨٨'>فَأَكْمِلْهُ بِمِثْلِ نِصْفِهِ وَزِدْ عَلَى الْخَمْسَةِ مِثْلَ نِصْفِهَا</مقطع>
  <مقطع هوية='١٧١٧٢'>فَيَصِيرُ مَعَكَ مَالٌ تَعْدِلُ سَبْعَةً وَنِصْفًا</مقطع>
  <مقطع هوية='٩٣٤٥٧'>فَخُذْ جَذْرَهَا وَهُوَ الشَّيْءُ الَّذِي تُرِيدُ أَنْ تَضْرِبَهُ
  فِي ثُلُثَيْهِ فَيَكُونَ خَمْسَةً</مقطع>

  <مقطع هوية='٢٠١٣٦'>فَإِنْ قَالَ <معادلة>مَالانِ بَيْنَهُمَا دِرْهَمَانِ
  قَسَمْتَ الْقَلِيلَ عَلَى الْكَثِيرِ فَأَصَابَ الْقِسْمَ نِصْفُ دِرْهَمٍ</معادلة></مقطع>
  <مقطع هوية='٤٨٣٣٦'><قياس>قِيَاسُهُ</قياس> أَنْ تَضْرِبَ شَيْئًا وَدِرْهَمَيْنِ فِي الْقِسْمِ وَهُوَ نِصْفٌ</مقطع>
  <مقطع هوية='٥٣١٢٧'>فَيَكُونُ نِصْفَ شَيْءٍ وَدِرْهَمًا تَعْدِلُ شَيْئًا</مقطع>
  <مقطع هوية='٦٨٥٨٦'>فَأَلْقِ نِصْفَ شَيْءٍ بِنِصْفِ شَيْءٍ يَبْقَى دِرْهَمٌ يَعْدِلُ نِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٩٨٣٠٧'>فَأَضْعِفْهُ فَيَكُونُ مَعَكَ شَيْءٌ يَعْدِلُ دِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٣٢٩٦١'>وَهُوَ أَحَدُ الْمَالَيْنِ وَالْمَالُ الْآخَرُ أَرْبَعَةٌ</مقطع>

  <مقطع هوية='١٥٠٧٣'>فَإِن قَالَ <معادلة>قَسَمْتَ دِرْهَمًا عَلَى رِجَالٍ
  فَأَصَابَهُمْ شَيْءٌ ثُمَّ زِدْتَ فِيهِمْ رَجُلًا ثُمَّ قَسَمْتَ عَلَيْهِمْ دِرْهَمًا
  فَأَصَابَهُمْ أَقَلُّ مِنَ الْقِسْمِ الْأَوَّلِ بِسُدُسِ دِرْهَمٍ</معادلة></مقطع>
  <مقطع هوية='٥١٣٤٨'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ عَدَدَ الرِّجَالِ الأَوَّلِينَ</مقطع>
  <مقطع هوية='٩١٩٠١'>وَهُمْ شَيْءٌ فِي النُّقْصَانِ الَّذِي بَيْنَهُمْ</مقطع>
  <مقطع هوية='٥٤٠٩٠'>ثُمَّ تَضْرِبُ مَا اجْتَمَعَ فِي عَدَدِ الرِّجَالِ الأَوَّلِينَ وَالْآخِرِينَ</مقطع>
  <مقطع هوية='٦٠٢٠٥'>ثُمَّ تَقْسِمُ مَا اجْتَمَعَ عَلَى مَا بَيْنَ الرِّجَالِ الأَوَّلِينَ وَالْآخِرِينَ</مقطع>
  <مقطع هوية='٨٥٩٥٦'>فَإنَّهُ يَخْرُجُ مَالُكَ الَّذِي قَسَمْتَهُ</مقطع>
  <مقطع هوية='٥٢٥٠٨'>فَاضْرِبْ عَدَدَ الرِّجَالِ الأوَّلِينَ وَهُمْ شَيْءٌ فِي السُّدُسِ الَّذِي بَيْنَهُمْ فَيَكُونُ سُدُسَ جَذْرٍ</مقطع>
  <مقطع هوية='٣٧٧٠٣'>ثُمَّ اضْرِبْ ذٰلِكَ فِي عَدَدِ الرِّجَالِ الأوَّلِينَ وَالآخِرِينَ</مقطع>
  <مقطع هوية='٦٦٩٩١'>وَهُوَ شَيْءٌ وَواحِدٌ يَكُونُ سُدُسَ مَالٍ وَسُدُسَ جَذْرٍ مَقْسُومٍ عَلَى دِرْهَمٍ تَعْدِلُ دِرْهَمًا</مقطع>
  <مقطع هوية='٥٩١٣٠'>فَكَمِّلِ الْمَالَ الَّذِي مَعَكَ</مقطع>
  <مقطع هوية='٥٢٤٤٧'>وَهُوَ أَنْ تُضْرِبَهُ فِي سِتَّةٍ فَيَكُونُ مَعَكَ مَالٌ وَجَذْرٌ</مقطع>
  <مقطع هوية='٤٣٠٣٥'>فَاضْرِبِ الدِّرْهَمَ فِي سِتَّةٍ فَيَكُونُ سِتَّةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٧٦٧٦٣'>فَيَكُونُ مَالًا وَجَذْرًا تَعْدِلُ سِتَّةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢١٩٤٥'>فَانْصِفْ الجَذْرَ وَاضْرِبْهُ فِي مِثْلِهِ فَيَكُونُ رُبُعًا</مقطع>
</ملف>
