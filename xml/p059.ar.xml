<ملف رقم="٥٩"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <قسم هوية='٣٢٢٧٣'>
    <عنوان>[الْمُرَبَّعاتُ]</عنوان>
  </قسم>
  <مقطع هوية='١١٨١٤'><صفحة رقم="٥٩"/> أَعْلَمُ أَنْ الْمُرَبَّعَاتِ خَمْسَةٌ أَجْنَاسٌ</مقطع>
  <مقطع هوية='٨٠٤٨٩'><شدة>فَمِنْهَا</شدة> مُسْتَوِيَةُ الْأَضْلَاعِ قَائِمَةُ الزَّوَايَا</مقطع>
  <مقطع هوية='١٣٠٩٩'><شدة>وَالثَّانِيَةُ</شدة> قَائِمَةُ الزَّوَايَا مُخْتَلِفَةُ الْأَضْلَاعِ طُولُهَا أَكْثَرُ مِنْ عَرْضِهَا</مقطع>
  <مقطع هوية='٦٥٨٤٩'><شدة>وَالثَّالِثَةُ</شدة> تُسَمَّى الْمُعَيَّنَةَ وَهِيَ الَّتِي اسْتَوَتْ أَضْلَاعُهَا وَاخْتَلَفَتْ زَوَايَاهَا</مقطع>
  <مقطع هوية='١٩١٤٤'><شدة>وَالرَّابِعَةُ</شدة> الْمُشَبَّهَةُ بِالْمُعَيَّنَةِ وَهِيَ الَّتِي طُولُهَا وَعَرْضُهَا مُخْتَلِفَانِ وَزَوَايَاهَا مُخْتَلِفَةٌ</مقطع>
  <مقطع هوية='٦٩٦٢٨'>غَيْرَ أَنَّ الطُّولَيْنِ مُتَسَاوِيَانِ وَالْعَرْضَيْنِ مُتَسَاوِيَيْنِ أَيْضًا</مقطع>
  <مقطع هوية='٠٦١٢٦'><شدة>وَالْخَامِسَةُ</شدة> الْمُخْتَلِفَةُ الْأَضْلَاعِ وَالزَّوَايَا</مقطع>

  <رأس/>
  <مقطع هوية='٠٧١٩٠'>فَمَا كَانَ مِنَ <شدة>الْمُرَبَّعَاتِ مُسْتَوِيَةَ</شدة> الْأَضْلَاعِ قَائِمَةَ الزَّوَايَا</مقطع>
  <مقطع هوية='٣٦٥٢٦'>أَوْ مُخْتَلِفَةَ الْأَضْلَاعِ قَائِمَةَ الزَّوَايَا</مقطع>
  <مقطع هوية='٧٣٠٧٣'>فَإِنَّ تَكْسِيرَهَا أَنْ تَضْرِبَ الطُّولَ فِي الْعَرْضِ فَمَا بَلَغَ فَهُوَ التَّكْسِيرُ</مقطع>

  <مقطع هوية='٩٤٦٤١'>وَمِثَالُ ذٰلِكَ أَرْضٌ مُرَبَّعَةٌ مِنْ كُلِّ جَانِبٍ خَمْسَةُ أَذْرُعٍ</مقطع>
  <مقطع هوية='٢٥٩٦٨'>تَكْسِيرُهَا خَمْسَةٌ وَعِشْرُونَ ذِرَاعًا وَهَذِهِ صُورَتُهَا</مقطع>

  <رأس/>
  <مقطع هوية='٤٢٤٢٤'>وَالثَّانِيَةُ أَرْضٌ مُرَبَّعَةٌ طُولُهَا ثَمَانِيَةُ أَذْرُعٍ ثَمَانِيَةُ أَذْرُعٍ وَالْعَرْضَانِ سِتَّةٌ سِتَّةٌ</مقطع>
  <مقطع هوية='٤٨٢٢٣'>فَتَكْسِيرُهَا أَنْ تَضْرِبَ سِتَّةً فِي ثَمَانِيَةٍ فَيَكُونُ ثَمَانِيَةً وَأَرْبَعِينَ ذِرَاعًا</مقطع>
  <مقطع هوية='٣٤٤٧٠'>وَذٰلِكَ تَكْسِيرُهَا وَهَذِهِ صُورَتُهَا</مقطع>

  <رأس/>
  <مقطع هوية='٨٠٤٠٥'>وَأَمَّا <شدة>الْمُعَيَّنَةُ الْمُسْتَوِيَةُ</شدة> الْأَضْلَاعِ الَّتِي كُلُّ جَانِبٍ مِنْهَا <صفحة رقم="٦٠"/> خَمْسَةُ أَذْرُعٍ</مقطع>
</ملف>
