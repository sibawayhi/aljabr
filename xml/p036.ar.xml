<ملف رقم="٣٦"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٩٧٢٠٨'>فَارْدُدْهُ إِلَى مَالٍ وَاحِدٍ <صفحة رقم="٣٦"/> وَهُوَ تِسْعَةُ أَجْزَاءِ مِنْ خَمْسَةٍ وَعِشْرِينَ جُزْئًا</مقطع>
  <مقطع هوية='٥٣٢٢٥'>وَهُوَ خُمْسٌ وَأَرْبَعَةُ أَخْمَاسِ الْخُمْسِ</مقطع>
  <مقطع هوية='٣٤٢٥٤'>فَخُذْ خُمْسَ الْمِائَةِ وَأَرْبَعَةَ أَخْمَاسِ خُمْسِهَا وَهُوَ سِتَّةٌ وَثَلاَثُونَ تَعْدِلُ مَالًا</مقطع>
  <مقطع هوية='٠٢٣٣٦'>فَخُذْ جَذْرَهَا سِتَّةٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='٥٥٥٠٧'>وَالْآخَرُ أَرْبَعَةٌ لَا مَحَالَةَ</مقطع>
  <مقطع هوية='٣١٣٤٧'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٧٠١١٨'>وَهِيَ أَمْوَالٌ تُعَادِلُ عَدَدًا</مقطع>

  <مسألة هوية='٤٥٨٥٦'>الْمَسْأَلةُ الثَّالِثَةُ</مسألة>
  <مقطع هوية='٧٤٧٣١'>وَالْمَسْأَلَةُ الثَّالِثَةُ</مقطع>
  <مقطع هوية='٢٧٢٨٩'>عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ</مقطع>
  <مقطع هوية='٧٣٣٠٧'>ثُمَّ قَسَمْتُ أَحَدَهَمَا عَلَى الْآخَرِ</مقطع>
  <مقطع هوية='٣١٠٣٣'>فَخَرَجَ الْقِسْمُ أَرْبَعَةً</مقطع>
  <مقطع هوية='٠٧٢٩٨'><قياس>فَقِيَاسُ ذٰلِكَ</قياس></مقطع>
  <مقطع هوية='٧٩٩٣٢'>أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةَ إِلَّا شَيْءً</مقطع>
  <مقطع هوية='٣٧١٨٥'>ثُمَّ تَقْسِمُ عَشَرَةً إِلَّا شَيْءً عَلَى شَيْءٍ لِيَكُونَ أَرْبَعَةً</مقطع>
  <مقطع هوية='٣٥٢٦٩'>وَقَدْ عَلِمْتَ أَنَّكَ مَتَى مَا ضَرَبْتَ
  مَا خَرَجَ لَكَ مِنَ الْقِسْمِ فِي الْمَقْسُومِ عَلَيْهِ</مقطع>
  <مقطع هوية='٨٥١٧٦'>عَادَ الْمَالُ الَّذِي قَسَمْتَهُ</مقطع>
  <مقطع هوية='٠٦٩٩١'>وَالْقِسْمُ فِي هَذِهِ الْمَسْأَلَةِ أَرْبَعَةٌ وَالْمَقْسُومُ عَلَيْهِ شَيْءٌ</مقطع>
  <مقطع هوية='٦٢٢٧٥'>فَاضْرِبْ أَرْبَعَةً فِي شَيْءٍ</مقطع>
  <مقطع هوية='٢٩١٥٦'>فَيَكُونَ أَرْبَعَةَ أَشْيَاءَ تَعْدِلُ الْمَالَ الَّذِي قَسَمْتَهُ وَهُوَ عَشَرَةٌ إلّا شَيْئًا</مقطع>
  <مقطع هوية='٦٦٩٤١'><جبر>فَاجْبُرِ</جبر> الْعَشَرَةَ بِالشَّيْءِ وَزِدْهُ عَلَى الْأَرْبَعَةِ الْأَشْيَاءِ</مقطع>
  <مقطع هوية='٤٥٢٧٢'>فَيَكُونَ خَمْسَةَ أَشْيَاءَ تَعْدِلُ عَشَرَةً</مقطع>
  <مقطع هوية='٣٦٣٧٩'>فَالشَّيْءُ الْوَاحِدُ اثْنَانِ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='١٢٤٦٩'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٧٣٩٩٧'>وَهِيَ جُذُورٌ تَعْدِلُ عَدَدًا</مقطع>

  <مسألة هوية='٩٠٣١٥'>الْمَسْأَلةُ الرَّابِعَةُ</مسألة>
  <مقطع هوية='٣٠٧٦٠'>وَالمَسْأَلَةُ الرَّابِعَةُ</مقطع>
  <مقطع هوية='٢٦٣٤٤'>مَالٌ ضَرَبْتُ ثُلُثَهُ وَدِرْهَمًا فِي رُبْعِهِ وَدِرْهَمٍ فَكَانَ عِشْرِينَ</مقطع>
  <مقطع هوية='٧١٦٨٦'><قياس>قِيَاسُهُ</قياس></مقطع>
  <مقطع هوية='١٣٩٧٦'>أَنْ تَضْرِبَ ثُلُثَ شَيْءٍ فِي رُبْعِ شَيْءٍ فَيَكُونَ نِصْفَ سُدُسِ مَالٍ</مقطع>
  <مقطع هوية='١٣١٧٣'>وَتَضْرِبَ دِرْهَمًا فِي ثُلُثِ شَيْءٍ فَيَكُونُ ثُلُثَ شَيْءٍ</مقطع>
  <مقطع هوية='٣٢٩٤٧'>وَدِرْهَمًا فِي رُبْعِ شَيْءٍ بِرُبْعِ شَيْءٍ</مقطع>
  <مقطع هوية='٨٨٩٧٨'>وَدِرْهَمًا فِي دِرْهَمٍ بِدِرْهَمٍ</مقطع>
  <مقطع هوية='٣٣٥٤٦'>فَذٰلِكَ كُلُّهُ نِصْفُ سُدُسِ مَالٍ وَثُلُثُ شَيْءٍ
  <صفحة رقم="٣٧"/>وَرُبْعُ شَيْءٍ وَدِرْهَمٌ</مقطع>
</ملف>
