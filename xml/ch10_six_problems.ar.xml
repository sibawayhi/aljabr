  <فصل هوية='٨٢٧٦٦'

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

    <عنوان>بَابُ الْمَسَائِلِ السِّتِّ</عنوان>

  <مقطع هوية='١٠٧٤٧'>وَقَدْ قَدَّمْنَا قَبْلُ أَبْوَابَ الْحِسَابِ</مقطع>
  <مقطع هوية='٣٦٨٩٠'>وَوُجُوهُهَا سِتُّ مَسَائِلَ</مقطع>
  <مقطع هوية='٤٠٧١١'>جَعَلْتُهَا أَمْثِلَةً لِلِسِّتَةِ الْأَبْوَابِ الْمُتَقَدِّمَةِ فِي صَدْرِ كِتَابِي هٰذَا</مقطع>
  <مقطع هوية='٣٢٠١١'>لَا بُدَّ أَنَّ مِنْهَا ثَلاثَةً لَا تُنْصِفُ فِيهَا الْأَجْذَارَ</مقطع>
  <مقطع هوية='٣٥٤٥٨'>وَذَكَرْتُ أَنَّ حِسَابَ الْجَبْرِ وَالْمُقَابَلَةِ</مقطع>
  <مقطع هوية='٢٨٩٨٥'>لَا بُدَّ أَنْ يُخْرِجَكَ إِلَى بَابٍ مِنْهَا</مقطع>
  <مقطع هوية='٦١٥٢٢'>ثُمَّ أَتْبَعْتُ ذٰلِكَ مِنَ الْمَسَائِلِ بِمَا يُقَرِّبُ مِنَ الْفَهْمِ</مقطع>
  <مقطع هوية='٦٢٤٥٥'>وَتُخَفُّ فِيهِ الْمُؤْنَةُ وَتُسَهَّلُ بِهِ الدَّلَالَةُ إِنْ شَاءَ اللَّهُ تَعَالَى</مقطع>

  <مسألة هوية='٠٢٤٢٢' صفحة="٣٤">الْمَسْأَلةُ الْأُولى</مسألة>
  <مقطع هوية='١٧٣١٨'>فَالْأُوْلَى مِنَ السِّتِّ نَحْوُ قَوْلِكَ</مقطع>
  <مقطع هوية='٨٩٨٥٤'>عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ</مقطع>
  <مقطع هوية='١٦٧٣١'>فَضَرَبْتُ أَحَدَ الْقِسْمَيْنِ فِي الْآخَرِ</مقطع>
  <مقطع هوية='٥١٤٢٤'>ثُمَّ ضَرَبْتُ أَحَدَهُمَا فِي نَفْسِهِ</مقطع>
  <مقطع هوية='١٧٦١٥'>فَصَارَ الْمَضْرُوبُ فِي نَفْسِهِ مِثْلَ أَحَدِ الْقِسْمَيْنِ فِي الْآخَرِ أَرْبَعَ <صفحة رقم="٣٥"/> مَارَّاتٍ</مقطع>
  <!-- p035 -->
  <مقطع هوية='٠٤٨٣٢'><قياس>فَقِيَاسُهَا</قياس> أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةَ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٢٨٤٨٠'>فَتَضْرِبُ شَيْئًا فِي عَشَرَةٍ إِلَّا شَيْئًا فَكُونَ عَشَرَةَ أَشْيَاءَ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٩٨٢٢٦'>ثُمَّ تَضْرِبُهُ فِي أَرْبَعَةٍ لِقَوْلِكَ <قبس>أَرْبَعَ مَرَّاتٍ</قبس></مقطع>
  <مقطع هوية='٤٢٧٦٧'>فَيَكُونَ أَرْبَعَةَ أَمْثَالِ الْمَضْرُوبِ مِنْ أَحَدِ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='١٨٢٦٤'>وَالْآخَرُ فَيَكُونَ ذٰلِكَ أَرْبَعِينَ شَيْئًا إِلَّا أَرْبَعَةَ أَمْوَالٍ</مقطع>
  <مقطع هوية='٥١٦٩٩'>ثُمَّ تَضْرِبُ شَيْئًا فِي شَيْءٍ وَهُوَ أَحَدُ الْقِسْمَيْنِ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٤٣٥٣٣'>فَيَكُونَ مَالًا يَعْدِلُ أَرْبَعِينَ شَيْئًا إِلَّا أَرْبَعَةَ أَمْوَالٍ</مقطع>
  <مقطع هوية='٩١٤٤٩'><جبر>فَاجْبُرْهَا</جبر> بِالْأَرْبَعَةِ الْأَمْوَالِ وَزِدْهَا عَلَى الْمَالِ</مقطع>
  <مقطع هوية='٤١٥٧٦'>فَيَكُونَ أَرْبَعِينَ شَيْئًا تَعْدِلُ خَمْسَةَ أَمْوَالٍ</مقطع>
  <مقطع هوية='٠٧٨٧٨'>فَالْمَالُ الْواحِدُ يَعْدِلُ ثَمَانِيَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٢٦٥١٤'>وَهُوَ أَرْبَعَةٌ وَسِتُّونَ جَذْرُهَا ثَمَانِيَةٌ</مقطع>
  <مقطع هوية='٢٥٩٥٨'>وَهُوَ أَحَدُ الْقِسْمَيْنِ الْمَضْرُوبِ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٦٣٥٦٠'>وَالْبَاقِي مِنَ الْعَشَرَةِ اثْنَاُنِ وَهُوَ الْقِسْمُ الآخَرُ</مقطع>
  <مقطع هوية='٠٢١٣١'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٨٥٧٨٠'>وَهِيَ أَمْوَالٌ تَعْدِلُ جُذُورًا</مقطع>
  <مقطع هوية='٦٧٠٤٦'>فَاعْلَمْ ذٰلِكَ</مقطع>

  <مسألة هوية='٢٢٣٧٢'>الْمَسْأَلةُ الثَّانِيَةُ</مسألة>
  <مقطع هوية='٤٨٣٩٩'>وَالمَسْألَةُ الثَّانِيَةُ</مقطع>
  <مقطع هوية='٩٨٠٣٣'>عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ</مقطع>
  <مقطع هوية='٣٣٩٦٤'>فَضَرَبْتُ كُلَّ قِسْمٍ فِي نَفْسِهِ</مقطع>
  <مقطع هوية='٢٠٥٤٦'>ثُمَّ ضَرَبْتُ الْعَشَرَةَ فِي نَفْسِهَا</مقطع>
  <مقطع هوية='٠٨٩٥٧'>فَكانَ مَا اجْتَمَعَ مِنْ ضَرْبِ الْعَشَرَةِ فِي نَفْسِهَا</مقطع>
  <مقطع هوية='٤٩٧٧٨'>مِثْلَ أَحَدِ الْقِسْمَيْنِ مَضْرُوبًا فِي نَفْسِهِ مَرَّتَيْنِ وَسَبْعَةَ أَتْسَاعِ مَرَّةٍ</مقطع>
  <مقطع هوية='٤٥٦٥١'>أَوْ مِثْلَ الآخَرِ مَضْرُوبًا فِي نَفْسِهِ سِتَّ مَرَّاتٍ وَرُبُعَ مَرَّةٍ</مقطع>

  <مقطع هوية='٣٨٧٠٦'><قياس>فَقِيَاسُ ذٰلِكَ</قياس></مقطع>
  <مقطع هوية='٥٠٧٥٧'>أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةً إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٢٣٣٧٩'>فَتَضْرِبُ الشَّيْءَ فِي نَفْسِهِ فَيَكُونَ مَالًا</مقطع>
  <مقطع هوية='٣٧٢٨٨'>ثُمَّ فِي اثْنَيْنِ وَسَبْعَةَ أَتْسَاعٍ</مقطع>
  <مقطع هوية='٦٠٩٦٣'>فَيَكُونَ مَالَيْنِ وَسَبْعَةَ أَتْسَاعِ مَالٍ</مقطع>
  <مقطع هوية='١١٧٣٧'>ثُمَّ تَضْرِبُ الْعَشَرَةَ فِي مِثْلِهَا
  فَتَكُونَ مِائَةً تَعْدِلُ مَالَيْنِ وَسَبْعَةَ أَتْسَاعِ مَالٍ</مقطع>
  <!-- p036 -->
  <مقطع هوية='٩٧٢٠٨'>فَارْدُدْهُ إِلَى مَالٍ وَاحِدٍ <صفحة رقم="٣٦"/> وَهُوَ تِسْعَةُ أَجْزَاءِ مِنْ خَمْسَةٍ وَعِشْرِينَ جُزْئًا</مقطع>
  <مقطع هوية='٥٣٢٢٥'>وَهُوَ خُمْسٌ وَأَرْبَعَةُ أَخْمَاسِ الْخُمْسِ</مقطع>
  <مقطع هوية='٣٤٢٥٤'>فَخُذْ خُمْسَ الْمِائَةِ وَأَرْبَعَةَ أَخْمَاسِ خُمْسِهَا وَهُوَ سِتَّةٌ وَثَلاَثُونَ تَعْدِلُ مَالًا</مقطع>
  <مقطع هوية='٠٢٣٣٦'>فَخُذْ جَذْرَهَا سِتَّةٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='٥٥٥٠٧'>وَالْآخَرُ أَرْبَعَةٌ لَا مَحَالَةَ</مقطع>
  <مقطع هوية='٣١٣٤٧'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٧٠١١٨'>وَهِيَ أَمْوَالٌ تُعَادِلُ عَدَدًا</مقطع>

  <مسألة هوية='٤٥٨٥٦'>الْمَسْأَلةُ الثَّالِثَةُ</مسألة>
  <مقطع هوية='٧٤٧٣١'>وَالْمَسْأَلَةُ الثَّالِثَةُ</مقطع>
  <مقطع هوية='٢٧٢٨٩'>عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ</مقطع>
  <مقطع هوية='٧٣٣٠٧'>ثُمَّ قَسَمْتُ أَحَدَهَمَا عَلَى الْآخَرِ</مقطع>
  <مقطع هوية='٣١٠٣٣'>فَخَرَجَ الْقِسْمُ أَرْبَعَةً</مقطع>
  <مقطع هوية='٠٧٢٩٨'><قياس>فَقِيَاسُ ذٰلِكَ</قياس></مقطع>
  <مقطع هوية='٧٩٩٣٢'>أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةَ إِلَّا شَيْءً</مقطع>
  <مقطع هوية='٣٧١٨٥'>ثُمَّ تَقْسِمُ عَشَرَةً إِلَّا شَيْءً عَلَى شَيْءٍ لِيَكُونَ أَرْبَعَةً</مقطع>
  <مقطع هوية='٣٥٢٦٩'>وَقَدْ عَلِمْتَ أَنَّكَ مَتَى مَا ضَرَبْتَ
  مَا خَرَجَ لَكَ مِنَ الْقِسْمِ فِي الْمَقْسُومِ عَلَيْهِ</مقطع>
  <مقطع هوية='٨٥١٧٦'>عَادَ الْمَالُ الَّذِي قَسَمْتَهُ</مقطع>
  <مقطع هوية='٠٦٩٩١'>وَالْقِسْمُ فِي هَذِهِ الْمَسْأَلَةِ أَرْبَعَةٌ وَالْمَقْسُومُ عَلَيْهِ شَيْءٌ</مقطع>
  <مقطع هوية='٦٢٢٧٥'>فَاضْرِبْ أَرْبَعَةً فِي شَيْءٍ</مقطع>
  <مقطع هوية='٢٩١٥٦'>فَيَكُونَ أَرْبَعَةَ أَشْيَاءَ تَعْدِلُ الْمَالَ الَّذِي قَسَمْتَهُ وَهُوَ عَشَرَةٌ إلّا شَيْئًا</مقطع>
  <مقطع هوية='٦٦٩٤١'><جبر>فَاجْبُرِ</جبر> الْعَشَرَةَ بِالشَّيْءِ وَزِدْهُ عَلَى الْأَرْبَعَةِ الْأَشْيَاءِ</مقطع>
  <مقطع هوية='٤٥٢٧٢'>فَيَكُونَ خَمْسَةَ أَشْيَاءَ تَعْدِلُ عَشَرَةً</مقطع>
  <مقطع هوية='٣٦٣٧٩'>فَالشَّيْءُ الْوَاحِدُ اثْنَانِ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>
  <مقطع هوية='١٢٤٦٩'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٧٣٩٩٧'>وَهِيَ جُذُورٌ تَعْدِلُ عَدَدًا</مقطع>

  <مسألة هوية='٩٠٣١٥'>الْمَسْأَلةُ الرَّابِعَةُ</مسألة>
  <مقطع هوية='٣٠٧٦٠'>وَالمَسْأَلَةُ الرَّابِعَةُ</مقطع>
  <مقطع هوية='٢٦٣٤٤'>مَالٌ ضَرَبْتُ ثُلُثَهُ وَدِرْهَمًا فِي رُبْعِهِ وَدِرْهَمٍ فَكَانَ عِشْرِينَ</مقطع>
  <مقطع هوية='٧١٦٨٦'><قياس>قِيَاسُهُ</قياس></مقطع>
  <مقطع هوية='١٣٩٧٦'>أَنْ تَضْرِبَ ثُلُثَ شَيْءٍ فِي رُبْعِ شَيْءٍ فَيَكُونَ نِصْفَ سُدُسِ مَالٍ</مقطع>
  <مقطع هوية='١٣١٧٣'>وَتَضْرِبَ دِرْهَمًا فِي ثُلُثِ شَيْءٍ فَيَكُونُ ثُلُثَ شَيْءٍ</مقطع>
  <مقطع هوية='٣٢٩٤٧'>وَدِرْهَمًا فِي رُبْعِ شَيْءٍ بِرُبْعِ شَيْءٍ</مقطع>
  <مقطع هوية='٨٨٩٧٨'>وَدِرْهَمًا فِي دِرْهَمٍ بِدِرْهَمٍ</مقطع>
  <مقطع هوية='٣٣٥٤٦'>فَذٰلِكَ كُلُّهُ نِصْفُ سُدُسِ مَالٍ وَثُلُثُ شَيْءٍ
  <صفحة رقم="٣٧"/>وَرُبْعُ شَيْءٍ وَدِرْهَمٌ</مقطع>
  <!-- p037 -->
  <مقطع هوية='٣١١٩٤'>تَعْدِلُ عِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٥٠٥٦'>فأَلْقِ مِنَ الْعِشْرِينَ دِرْهَمًا بِدِرْهَمٍ</مقطع>
  <مقطع هوية='٣٢٤٩٠'>فَتَبْقَى تِسْعَةَ عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٤١٠٦٦'>تَعْدِلُ نِصْفَ سُدُسِ مَالٍ وَثُلُثَ شَيْءٍ وَرُبْعَ شَيْءٍ</مقطع>
  <مقطع هوية='١٦٢٨٣'>فَأَكْمِلْ مَالَكَ وَإِكَمالُهُ أَنْ تَضْرِبَ كُلَّ مَا مَعَكَ فِي اثْنَيْ عَشَرَ</مقطع>
  <مقطع هوية='٦٩٨١٠'>فَيَصِيرَ مَعَكَ مَالٌ وَسَبْعَةُ أَجْذَارٍ</مقطع>
  <مقطع هوية='٥٥٠٢٧'>تَعْدِلُ مِائَتَيْنِ وَثَمَانِيَةٍ وَعِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٠٤٩٤'>فَنَصِّفْ الْأَجْذَارَ وَاضْرِبْهَا فِي مِثْلِهَا
  تَكُنْ اثْنَيْ عَشَرَ وَرُبْعًا</مقطع>
  <مقطع هوية='١١٩٧٣'>فَارْدُدْهَا عَلَى الْأَعْدَادِ وَهِيَ مَائَتَانِ وَثَمَانِيَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='١٠٩٥٣'>فَيَكُونَ مِائَتَيْنِ وَأَرْبَعِينَ وَرُبْعًا</مقطع>
  <مقطع هوية='٥٤٥٦٥'>فَخُذْ جَذْرَهَا خَمْسَةَ عَشَرَ وَنِصْفًا</مقطع>
  <مقطع هوية='٧٤٩٤٣'>فَانْقُصْ مِنهُ نِصْفَ الْأَجْذَارِ وَهُوَ ثَلَاثَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٩٩٤٣'>يَبْقَى اثْنَي عَشَرَ وَهُوَ الْمَالُ</مقطع>
  <مقطع هوية='١٩٧٣٩'>فَقَدْ أَخْرَجْتَكَ هَذِهِ المَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٠٩٥٧٦'>وَهِيَ أَمْوَالٌ وَجُذُورٌ تَعْدِلُ عَدَدًا</مقطع>

  <مسألة هوية='٧٨٤٦٥'>الْمَسْأَلةُ الْخَامِسَةُ</مسألة>
  <مقطع هوية='٤٨٢٩٦'>وَالمَسْأَلَةُ الْخَامِسَةُ</مقطع>
  <مقطع هوية='١٠٩٥٩'>عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ</مقطع>
  <مقطع هوية='٣٦٤٩١'>ثُمَّ ضَرَبْتُ كُلَّ قِسْمٍ فِي نَفْسِهِ وَجَمَعْتُهُمْ فَكَانَا ثَمَانِيَةً وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩٩١٣٣'><قياس>قِيَاسُهُ</قياس></مقطع>
  <مقطع هوية='١٠٤٨٣'>أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةً إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٨١٦٤٦'>فَاضْرِبْ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٨١٤٠٤'>فَيَكُونَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٤٦٢٧٧'>ثُمَّ تَضْرِبُ شَيْئًا فِي شَيْءٍ فَيَكُونَ مَالًا</مقطع>
  <مقطع هوية='٦١١٧٣'>ثُمَّ تَجْمَعُهُمَا فَيَكُونَ ذٰلِكَ مِائَةً وَمَالَيْنِ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٩٥٨٩٤'>تَعْدِلُ ثَمَانِيَةً وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٠٣٠٨٢'><جبر>فَاجْبُرِ</جبر> الْمِائَةَ وَالْمَالَيْنِ بِالْعِشْرِينَ الشَّيْءِ النَّاقِصَةِ</مقطع>
  <مقطع هوية='٨٧١٩٧'>وَزِدْهَا عَلَى الثَّمَانِيَةِ وَالْخَمْسِينَ</مقطع>
  <مقطع هوية='٤٥٢٧٤'>فَيَكُونَ مِائَةً وَمَالَيْنِ تَعْدِلُ ثَمَانِيَةً وَخَمْسِينَ دِرْهَمًا وَعِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٢٠١٩٦'>فَارْدُدْ ذٰلِكَ إِلَى مَالٍ وَاحِدٍ</مقطع>

  <مقطع هوية='٠٩٢٠٤'>وَهُوَ أَنْ تَأْخُذَ نِصْفَ مَا مَعَكَ فَيَكُونُ خَمْسِينَ دِرْهَمًا وَمَالًا</مقطع>
  <مقطع هوية='٨٣٢٣٤'>تَعْدِلُ تِسْعَةً وَعِشْرِينَ دِرْهَمًا وَعَشَرَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٠١٩٤٠'><مقابلة>فَقَابِلْ بِهِ</مقابلة> وَذٰلِكَ أَنَّكَ تُلْقِي مِنَ الْخَمْسِينَ تِسْعَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٥٧٠٣'>فَيَبْقَى أَحَدٌ وَعِشْرُونَ وَمَالٌ تَعْدِلُ عَشَرَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٦٤٣٩٥'>فَنَصِّفْ الْأَجْذَارَ يَكُونُ خَمْسَةً</مقطع>
  <!-- p038a -->
  <مقطع هوية='٢٩٠١٦'> وَاضْرِبْهَا فِي مِثْلِها<صفحة رقم="٣٨"/> فَتَكُونَ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٦٩١٧'>فَأَلْقِ مِنْهَا الْواحِدَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ فَيَبْقَى أَرْبَعَةً</مقطع>
  <مقطع هوية='٧٦٣١٨'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ فَإِنْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ الَّتِي هِيَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٢٨١٤٦'>فَيَبْقَى ثَلاثَةٌ وَهِيَ أَحَدُ الْقِسْمَيْنِ وَالْآخَرُ سَبْعَةٌ</مقطع>
  <مقطع هوية='٢٧٠١٣'>فَقَدْ أَخْرَجَتْكَ هَذِهِ الْمَسْأَلَةُ إلى أَحَدِ الْأَبْوَابِ الْسِّتَّةِ</مقطع>
  <مقطع هوية='٤٠٢٣٩'>وَهِيَ أَمْوَالٌ وَعَدَدٌ تَعْدِلُ جُذُورًا</مقطع>

  <مسألة هوية='٧٨٠٣٦' صفحة="٣٨">الْمَسْأَلةُ السَّادِسَةُ</مسألة>
  <مقطع هوية='٠٥١٤٩'>المَسْأَلَةُ السَّادِسَةُ</مقطع>
  <مقطع هوية='٢٠٦٧٢'>مَالٌ ضَرَبْتُ ثُلُثَهُ فِي رُبْعِهِ</مقطع>
  <مقطع هوية='٠٧٣٠١'>فَعَادَ الْمَالُ وَزِيَادَةُ أَرْبَعَةٍ وَعِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩٠٥٧٤'><قياس>فَقِيَاسُهَا</قياس></مقطع>
  <مقطع هوية='٧١٧٠٠'>أَنْ تَجْعَلَ مَالَكَ شَيْئًا</مقطع>
  <مقطع هوية='٠٧٢٥٢'>ثُمَّ تَضْرِبُ ثُلُثَ شَيْءٍ فِي رُبُعِ شَيْءٍ</مقطع>
  <مقطع هوية='٣٧٢٤٧'>فَيَكُونَ نِصْفُ سُدُسِ الْمَالِ تَعْدِلُ شَيْئًا وَأَرْبَعَةً وَعِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٨٦١٣٠'>ثُمَّ تَضْرِبُ نِصْفَ سُدُسِ الْمَالِ فِي اثْنَيْ عَشَرَ حَتَّى تُكْمِلَ مَالَكَ</مقطع>
  <مقطع هوية='٤٣١٣٨'>وَاضْرِبِ الشَّيْءَ فِي اثْنَيْ عَشَرَ يَكُنْ اثْنَيْ عَشَرَ شَيْئًا</مقطع>
  <مقطع هوية='١٥٠٠٨'>وَاضْرِبِ الْأَرْبَعَةَ وَالْعِشْرِينَ فِي اثْنَيْ عَشَرَ</مقطع>
  <مقطع هوية='٩٧٢٤٤'>فَيَصِيرُ مَعَكَ مَائَتَانِ وَثَمَانِيَةٌ وَثَمَانُونَ دِرْهَمًا وَاثْنَيْ عَشَرَ جَذْرًا تَعْدِلُ مَالًا</مقطع>
  <مقطع هوية='٠٧٣٧٢'>فَنَصِّفْ الْأَجْذَارِ تَكُونُ سِتَّةً</مقطع>
  <مقطع هوية='٣٧٠٩٢'>وَاضْرِبْهَا فِي مِثْلِهَا وَزِدْهَا عَلَى مِائَتَيْنِ وَثَمَانِيَةٍ وَثَمَانِينَ</مقطع>
  <مقطع هوية='٤٦٨٩٣'>فَيَكُونَ ثَلاثُمِائَةٍ وَأَرْبَعَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٩٣٦٨٠'>فَخُذْ جَذْرَهَا وَهُوَ ثَمَانِيَةَ عَشَرَ فَزِدْهَا عَلَى نِصْفِ الْأَجْذَارِ وَهِيَ سِتَّةٌ</مقطع>
  <مقطع هوية='٠٥١٣١'>فَيَكُونُ ذٰلِكَ أَرْبَعَةً وَعِشْرِينَ وَهُوَ الْمَالُ</مقطع>
  <مقطع هوية='٧٤٢٠٤'>فَقَدْ أَخْرَجْتَكَ هَذِهِ الْمُسْـأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٤٠٩٢٣'>وَهِيَ جُذُورٌ وَعَدَدٌ تَعْدِلُ أَمْوَالًا</مقطع>

  </فصل>
