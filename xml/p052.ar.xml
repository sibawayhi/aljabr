<ملف رقم="٥١"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٦١٢٨٩'>فَزِدْهُ عَلَى <صفحة رقم="٥٢"/>السِّتَّةِ وَخُذْ جَذْرَ مَا اجْتَمَعَ</مقطع>
  <مقطع هوية='١٩٠٣٧'>فَانْقُصْ مِنْهُ نِصْفَ الْجَذْرِ الَّذِي كُنتَ ضَرَبْتَهُ فِي مِثْلِهِ وَهُوَ نِصْفٌ</مقطع>
  <مقطع هوية='٥٣٢٥٩'>وَمَا بَقِيَ فَهُوَ عَدَدُ الرِّجَالِ الأوَّلِينَ وَهُمَا فِي هَذِهِ الْمَسْأَلَةِ رَجُلَانِ</مقطع>

  <مقطع هوية='٧٢٩٨١'>فَإِنْ قَالَ <معادلة>مَال ضَرَبْتَهُ فِي ثُلُثَيْهِ فَكَانَ خَمْسَةً</معادلة></مقطع>
  <مقطع هوية='٦٨٥٥١'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَهُ فِي مِثْلِهِ كَانَ سَبْعَةً وَنِصْفًا</مقطع>
  <مقطع هوية='٨٠١٣٥'>فَتَقُولُ هُوَ جَذْرُ سَبْعَةٍ وَنِصْفٍ فِي ثُلُثَيْ جَذْرِ سَبْعَةٍ وَنِصْفٍ</مقطع>
  <مقطع هوية='٨٤٩٤٨'>فَاضْرِبْ ثُلُثَيْنِ فِي ثُلُثَيْنِ فَيَكُونُ أَرْبَعَةً إِتِّسَاعً</مقطع>
  <مقطع هوية='٠٤٠٤١'>وَأَرْبَعَةُ أَتْسَاعٍ فِي سَبْعَةٍ وَنِصْفٍ يَكُونُ ثَلاثَةً وَثُلُثًا</مقطع>
  <مقطع هوية='٥٦٧٨٠'>فَجَذْرُ ثَلاثَةٍ وَثُلُثٍ هُوَ ثُلُثَا جَذْرِ سَبْعَةٍ وَنِصْفٍ</مقطع>

  <مقطع هوية='٠٦٣٢٠'>فَأَضْرِبْ ثَلاَثَةً وَثُلُثًا فِي سَبْعَةٍ وَنِصْفٍ فَيَكُونُ خَمْسَةً وَعِشْرِينَ فَجَذْرُهَا خَمْسَةٌ</مقطع>

  <مقطع هوية='٥٤٢٩٩'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُهُ فِي ثَلاثَةِ أَجْذَارِهِ فَيَكُونُ خَمْسَةً أَمْثَالَ الْمَالِ الأوَّلِ</معادلة></مقطع>
  <مقطع هوية='٥١٩٢٦'>فَكَأَنَّهُ قَالَ مَالٌ ضَرَبْتَهُ فِي جَذْرِهِ فَكَانَ مِثْلَ الْمَالِ الأوَّلِ وَثُلُثَيْهِ</مقطع>
  <مقطع هوية='١٢١٣٩'>فَجَذْرُ الْمَالِ دِرْهَمٌ وَثُلُثَانِ وَالْمَالُ دِرْهَمَانِ وَسَبْعَةٌ اتِّسَاعٌ</مقطع>

  <مقطع هوية='٩٦٢٩٦'>فَإِنْ قَالَ <معادلة>مَالٌ تُلْقِي ثُلُثَهُ ثُمَّ تَضْرِبُ الْبَاقِي فِي ثَلاثَةِ أَجْذَارِ الْمَالِ فَيَعُودُ الْمَالُ الْأَوَّلُ</معادلة></مقطع>
  <مقطع هوية='٨٨٢٧٧'><قياس>فَقِيَاسُهُ</قياس> أَنَّكَ إِذَا ضَرَبْتَ الْمَالَ الْأَوَّلَ كُلَّهُ</مقطع>
  <مقطع هوية='٠٤٥٤٧'>مِن قَبْلِ أَنْ تُلْقِي (ثُلُثَهُ) فِي ثَلاثَةِ أَجْذَارِهِ</مقطع>
  <مقطع هوية='٤٩٠٥٨'>كَانَ مَالًا وَنِصْفًا</مقطع>
  <مقطع هوية='٧١٣٥٣'>لِأَنَّ ثُلُثَيْهِ فِي ثَلاثَةِ أَجْذَارِهِ مَالٌ</مقطع>
  <مقطع هوية='٦٠٠٨٧'>فَهُوَ كُلُّهُ فِي ثَلاثَةِ أَجْذَارِهِ مَالٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٧٤٦٩١'>وَهُوَ كُلُّهُ فِي جَذْرٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٢٧٧٢٧'>نِصْفُ مَالٍ فَجَذْرُ الْمَالِ نِصْفٌ وَالْمَالُ رُبْعٌ</مقطع>
  <مقطع هوية='٦٤٤١٣'>فَثُلُثَا الْمَالِ سُدُسٌ وَثَلاثَةُ أَجْذَارِ الْمَالِ دِرْهَمٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='١٧٧٦٦'>فَمَتَى مَا ضَرَبْتَ سُدُسًا فِي دِرْهَمٍ وَنِصْفٍ خَرَجَ رُبْعًا وَهُوَ الْمَالُ</مقطع>

  <مقطع هوية='٩٨٧٧١'>فَإِن قَالَ <معادلة>مالٌ تَعْزِلُ أَرْبَعَةَ أَجْذَارِهِ
  ثُمَّ تَأْخُذُ ثُلُثَ مَا بَقِيَ فَيَكُونُ مِثْلَ الْأَرْبَعَةِ الأَجْذَارِ
  فَالْمَالُ مَائَتَانِ وَسِتَّةٌ وَخَمْسُونَ</معادلة></مقطع>
  <مقطع هوية='٠٨٣٥١'><قياس>فَقِيَاسُهُ</قياس> أَنْكَ تَعْلَمَ أَنَّ ثُلُثَ مَا بَقِيَ مِثْلُ الْأَرْبَعَةِ الأَجْذَارِ</مقطع>
  <مقطع هوية='٤٣٦٧١'>وَأَنَّ (مَا) بَقِيَ مِثْلَ اثْنَي عَشَرَ جَذْرِهِ</مقطع>
  <مقطع هوية='٩٤٠١١'>فَرَدَّ عَلَيْهَا الْأَرْبَعَةُ الأَجْذَارُ فَتَكُونُ سِتَّةَ عَشَرَ جَذْرًا وَهُوَ جَذْرُ الْمَالِ</مقطع>

</ملف>
