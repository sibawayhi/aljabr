<ملف رقم="٤٧"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٧٨٦٧٣'>قِيَاسُهُ أَنْ تَضْرِبَ جَذْرًا فِي أَرْبَعَةِ أَجْدَارٍ</مقطع>
  <مقطع هوية='٥٢٥١٠'>فَيَكُونَ أَرْبَعَةَ أَمْوَالٍ تَعْدِلُ ثَلاثَةَ أَمْوَالٍ وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٨٥٢٨٨'>فَأَلْقِ ثَلاثَةَ أَمْوَالٍ مِنَ الأَرْبَعَةِ الْأَمْوَالِ</مقطع>
  <مقطع هوية='٢٤٠٩٥'>يَبْقَى مَالٌ وَاحِدٌ يَعْدِلُ خَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩١٠٠٣'>وَهُوَ جَذْرُ خَمْسِينَ مَضْرُوبٌ فِي أَرْبَعَةِ أَجْدَارِ خَمْسِينَ أَيْضًا</مقطع>
  <مقطع هوية='٢٥٧٠٨'>فَذٰلِكَ مَائَتَانِ يَكُونُ ثَلاثَةَ أَمْثَالِ الْمَالِ وَزِيَادَةُ خَمْسِينَ دِرْهَمًا</مقطع>

  <مقطع هوية='٣٩٥٢٨'>فَإِنْ قَالَ <معادلة>مالٌ تَزِيدُ عَلَيْهِ عِشْرِيْنَ دِرْهَمًا فَيَكُونُ مِثْلَ أَثْنَيْ عَشَرَ جَذْرِهِ</معادلة></مقطع>
  <مقطع هوية='١١١٩٥'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَقُولَ مَالٌ وَعَشْرُونَ دِرْهَمًا تَعْدِلُ أَثْنَيْ عَشَرَ جَذْرًا</مقطع>
  <مقطع هوية='٠٥٣١٩'>فَنَصِّفْ الْأَجْدَارَ وَاضْرِبْهَا فِي مِثْلِهَا تَكُنْ سِتَّةً وَثَلاَثِينَ</مقطع>
  <مقطع هوية='٧١٢٥٧'>فَانْقُصْ مِنْهَا الْعِشْرِينَ الدِّرْهَمَ وَخُذْ جَذْرَ مَا بَقِيَ</مقطع>
  <مقطع هوية='١٣١٩٨'>فَانْقُصْهُ مِنْ نِصْفِ الْأَجْدَارِ وَهُوَ سِتَّةٌ</مقطع>
  <مقطع هوية='٠٤٥٢٢'>فَمَا بَقِيَ فَهُوَ جَذْرُ الْمَالِ وَهُوَ دِرْهَمَانِ وَالْمَالُ أَرْبَعَةٌ</مقطع>

  <مقطع هوية='٠٨٤٢٠'>فَإِنْ قَالَ <معادلة>مَالٌ تَعْزِلُ ثُلُثَهُ وَثَلَاثَةُ دَرَاهِمَ
  وَتَضْرِبُ مَا بَقِيَ فِي مِثْلِهِ فَيَعُودُ الْمَالُ</معادلة></مقطع>
  <مقطع هوية='٩٤٧٣٣'><قياس>قِيَاسُهُ</قياس> أَنْكَ إِذَا أَلْقَيْتَ ثُلُثَهُ وَثَلَاثَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٧٨٧٠٤'>بَقِيَ ثُلُثَاهُ إِلَّا ثَلاثَةَ دَرَاهِمَ وَهُوَ جَذْرٌ</مقطع>
  <مقطع هوية='٩٣٧٣٨'>فَاضْرِبْ ثُلُثَيْ شَيْءٍ إِلَّا ثَلَاثَةَ دَرَاهِمَ فِي مِثْلِهِ</مقطع>
  <مقطع هوية='٠٠٤٣٠'>فَتَقُولُ ثُلُثَانِ فِي ثُلُثَيْنِ أَرْبَعَةَ أَتْسَاعِ مَالٍ</مقطع>
  <مقطع هوية='٩١١٢٤'>وَإِلَّا ثَلَاثَةَ دَرَاهِمَ فِي ثُلُثَيْ شَيْءٍ جَذْرَانِ</مقطع>
  <مقطع هوية='٩٤٣٦٧'>وَإِلَّا ثَلَاثَةَ دَرَاهِمَ فِي ثُلُثَيْ شَيْءٍ جَذْرَانِ</مقطع>
  <مقطع هوية='٦٠٢٩٩'>وَإِلَّا ثَلَاثَةَ دَرَاهِمَ فِي إِلَّا ثَلَاثَةَ دَرَاهِمَ تِسْعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٠٩٧٣٧'>فَيَصِيرُ مَعَكَ أَرْبَعَةُ اتِّسَاعِ مَالٍ وَتِسْعَةُ دَرَاهِمَ إِلَّا أَرْبَعةَ أَجْذَارٍ تَعْدِلُ جَذْرًا</مقطع>
  <مقطع هوية='٦٣٠٥٩'>فَرُدَّ الأَرْبَعَةَ الأَجْذَارِ عَلَى الْجَذْرِ فَيَكُونُ خَمْسَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٦٢٥٤٤'>تَعْدِلُ أَرْبَعَةَ اتِّسَاعٍ ( مَالٍ ) وَتِسْعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢١٩٧٧'>فَأَكْمِلْ مَالَكَ وَهُوَ أَنْ تَضْرِبَ الأَرْبَعَةَ الْأَتْسَاعَ فِي اثْنَيْنِ وَرُبْعٍ فَيَكُونُ مَالًا</مقطع>
  <مقطع هوية='٦٨٧٨٥'>وَاضْرِبْ تِسْعَةَ دَرَاهِمَ فِي اثْنَيْنِ وَرُبْعٍ يَكُونُ عِشْرِينَ وَرُبْعًا</مقطع>
</ملف>
