  <مقطع هوية='٥١٢٨٣'>وَذَلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ</مقطع>

  <رأس/>
  <مقطع هوية='١٨١٣٥'>وَأَمَّا <معادلة>ثَلَاثَةُ أَجْذَارٍ وَأَرْبَعَةٌ مِنْ الْعَدَدِ تَعْدِلُ مَالًا</معادلة></مقطع>
  <مقطع هوية='٥٧٠٠٨'>فَإِنَّا نَجْعَلُ الْمَالَ سَطْحًا مُرَبَّعًا مَجْهُولَ الْأَضْلَاعِ مُتَسَاوِيَ الْأَضْلَاعِ وَالزَّوَايَا وَهُوَ سَطْحٌ <سطح>اد</سطح></مقطع>
  <!-- فَهَذَا السَّطْحُ -->
  <!-- p026 -->
  <مقطع هوية='١٤٠٨٦'>فَهَذَا السَّطْحُ <صفحة رقم="٢٦"/> كُلُّهُ يَجْمَعُ الثَّلَاثَةَ الْأَجْذَارَ وَالْأَرْبَعَةَ الَّتِي ذَكَرْنَاهَا</مقطع>
  <مقطع هوية='١٧٦٢٤'>وَكُلُّ سَطْحٍ مُرَبَّعٍ فَإِنَّ أَحَدَ أَضْلَاعِهِ فِي وَاحِدٍ جَذْرُهُ</مقطع>
  <مقطع هوية='٣٣٠٨٩'>فَقَطَعْنَا مِنْ سَطْحِ <سطح>اد</سطح> سَطْحَ <سطح><ه/> د</سطح></مقطع>
  <مقطع هوية='٩٦٨٠١'>فَجَعَلْنَا أَحَدَ أَضْلَاعِهِ الَّذِي هُوَ <ضلع><ه/> <جيم/></ضلع> ثَلَاثَةً الَّتِي هِيَ عَدَدُ الْأَجْذَارِ وَهِيَ مِثْلُ <ضلع>زد</ضلع></مقطع>
  <مقطع هوية='٧٤٢٥٩'>فَتَبَيَّنَ لَنَا أَنَّ سَطْحَ <سطح><ه/> ٮ</سطح>
  هُوَ الْأَرْبَعَةُ الْمَزِيدَةُ عَلَى الْأَجْذَارِ</مقطع>
  <مقطع هوية='٦٧٦٣٦'>فَقَطَعْنَا ضِلْعَ <ضلع><ه/> <جيم/></ضلع> الَّذِي هُوَ ثَلَاثَةُ أَجْذَارٍ نِصْفَيْنِ عَلَى نُقْطَةٍ <نقطة>ح</نقطة></مقطع>
  <مقطع هوية='٨٤٠٦١'>ثُمَّ جَعَلْنَا مِنْهُ سَطْحًا مُرَبَّعًا وَهُوَ سَطْحُ <سطح><ه/> ط</سطح></مقطع>
  <مقطع هوية='٦٦٠٨٨'>وَهُوَ مَا كَانَ مِنْ ضَرْبِ نِصْفِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٩١٠٩٣'>الَّتِي هُوَ وَاحِدٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٥٧٤٩'>فِي مِثْلِهِ وَهُوَ اثْنَانِ وَرُبْعٌ</مقطع>
  <مقطع هوية='٣٥٣٦٩'>ثُمّ زِدْنَا فِي خَطّ <خط>ح ط</خط> مِثْلَ خَطّ <خط>ا <ه/></خط></مقطع>
  <مقطع هوية='٧٠٤٧٨'>وَهُوَ خَطّ <خط>ط ل</خط></مقطع>
  <مقطع هوية='٧٤١٠٦'>فَصَارَ خَطُّ <خط>ح ل</خط> مِثْلَ خَطِّ <خط>ا ح</خط></مقطع>
  <مقطع هوية='١٠٦٠٣'>وَخَطُّ <خط><كا/> ن</خط> مِثْلَ خَطِّ <خط>ط ل</خط></مقطع>
  <مقطع هوية='٤٥٠٧١'>وَحَدَثَ سَطْحٌ مُرَبَّعٌ مُتَسَاوِي الْأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٩١٣٠٩'>وَهُوَ سَطْحُ <سطح>ح م</سطح></مقطع>
  <مقطع هوية='٣٥٦٧٠'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>اح</خط>
  مِثْلُ خَطِّ <خط>م ل</خط></مقطع>
  <مقطع هوية='٣٩٣٠٦'>وَخَطَّ <خط>اح</خط> مِثْلُ خَطّ <خط>ح ل</خط></مقطع>
  <مقطع هوية='٢٣٣٨٤'>فَبَقِيَ خَطُّ <خط>ح <جيم/></خط> مِثْلُ خَطِّ <خط>ن ز</خط></مقطع>
  <مقطع هوية='٨١٤٥٨'>وَخَطُّ <خط>م ن</خط> مِثْلُ خَطِّ <خط>ط ل</خط></مقطع>
  <مقطع هوية='١٦٥٢٢'>فَيَفْضُلُ مِنْ سَطْحِ <سطح><ه/> ٮ</سطح>
