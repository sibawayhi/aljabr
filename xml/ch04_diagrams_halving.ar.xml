<فصل هوية='٧٦١٣٩'

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">


  <عنوان>[صُوَرُ تَنْصِيْفِ الْأَجْذارِ]</عنوان>

  <مقطع هوية='٧٠٩٣٦'>فَهَذِهِ السِّتَّةُ الضُّرُوبُ الَّتِي ذَكَرْتُهَا فِي صَدْرِ كِتَابِي هَذَا</مقطع>
  <مقطع هوية='٢٦٣٤٨'>وَقَدْ أَتَيْتُ عَلَى تَفْسِيرِهَا وَأَخْبَرْتُ أَنَّ مِنْهَا ثَلٰثَةُ ضُرُوْبٍ لَا تُنَصِّفُ فِيْهَا الْأَجْذَارَ</مقطع>
  <مقطع هوية='٧٣١٦٨'>وَقَدْ يَيَّنْتُ قِيَاسَهَا وَاضْطِرَارَهَا</مقطع>

  <مقطع هوية='٨٦٢٢٢'>فَأَمَّا مَا تَحْتَاجُ فِيْهِ إِلَى تَنْصِيْفِ الْأَجْذَارِ فِي الثَّلَاثَةِ الْأَبْوَابِ الْبَاقِيَةِ</مقطع>
  <مقطع هوية='١٨٨٠٢'>فَقَدْ وَصَفَتُهُ بِأَبْوَابٍ صَحِيْحَةٍ</مقطع>
  <مقطع هوية='٩١٨٨٠'>وَصَيَّرْتُ لِكُلِّ بَابٍ مِنْهَا صُوْرَةً يُسْتَدَلُّ مِنْهَا عَلَى الْعِلَّةِ فِي التَّنْصِيْفِ</مقطع>

  <رأس/>
  <مقطع هوية='٦٨٩٧٧'>فَأَمَّا عِلَّةُ <معادلة>مَالٍ وَعَشَرَةُ أَجْذَارٍ تَعْدِلُ تِسْعَةً وَثَلَاثِيْنَ دِرْهَمًا</معادلة>
  </مقطع>
  <!-- p022 -->
  <مقطع هوية='٧١٣٢٦'>فَصُوْرَةُ ذَلِكَ سَطْحٌ <صفحة رقم="٢٢"/> مُرَبَّعٌ مَجْهُولُ الْأَضْلَاعِ</مقطع>
  <مقطع هوية='٧٧٦٧٧'>وَهُوَ الْمَالُ الَّذِى تُرِيدُ أَنْ تَعْرِفَهُ وَتَعْرِفَ جَذْرَهُ وَهُوَ سَطْحُ <سطح>اٮ</سطح></مقطع>
  <مقطع هوية='٢٠٩٧٧'>وَكُلُّ ضِلْعٍ مِنْ أَضْلَاعِهِ فَهُوَ جَذْرُهُ</مقطع>
  <مقطع هوية='٢٧٢١٢'>وَكُلُّ ضِلْعٍ مِنْ أَضْلَاعِهِ إذَا ضَرَبْتَهُ فِي عَدَدٍ مِنْ الْأَعْدَادِ</مقطع>
  <مقطع هوية='٢٠٢٩٧'>فَمَا بَلَغَتْ الْأَعْدَادُ فَهِيَ أَعْدَادُ جُذُورٍ</مقطع>
  <مقطع هوية='٤٩٣١٧'>كُلُّ جَذْرٍ مِثْلُ جَذْرِ ذَلِكَ السَّطْحِ</مقطع>
  <مقطع هوية='٣٩٩٤٧'>فَلَمَّا قِيلَ <قبس>إنَّ مَعَ الْمَالِ عَشَرَةُ أَجْذَارِهِ</قبس></مقطع>
  <مقطع هوية='٦٣٣٧٤'>أخَذْنَا رُبْعَ الْعَشَرَةِ وَهُوَ اثْنَانِ وَنِصْفٌ</مقطع>
  <مقطع هوية='٧٢٠٢٨'>وَصَيَّرْنَا كُلَّ رُبْعٍ مِنْهَا مع ضِلْعٍ مِنْ أَضْلاعِ السَّطْحِ</مقطع>
  <مقطع هوية='١٢٨٨٢'>فَصَارَ مَعَ السَّطْحِ الْأَوَّلِ الذِّي هُوَ سَطْحُ <سطح>اٮ</سطح> أَرْبَعَةُ سُطُوحٍ مُتَسَاوِيَةٍ</مقطع>
  <مقطع هوية='٦٨٩٨٤'>طُوْلُ كُلِّ سَطْحٍ مِنْهَا مِثْلُ جَذْرِ سَطْحِ <سطح>اٮ</سطح>
  وَعَرْضُهُ اثْنَانِ وَنِصْفٌ</مقطع>
  <مقطع هوية='٢٢٩٦٦'>وَهِي سُطُوْحٌ <سطح>ح</سطح> <سطح>ط</سطح>
  <سطح><كا/></سطح> <سطح><جيم/></سطح></مقطع>
  <مقطع هوية='٨٠٩٦٢'>فَحَدَثَ سَطْحٌ مُتَسَاوِي الْأَضْلاَعِ مَجْهُولٌ أَيْضًا</مقطع>
  <مقطع هوية='٦٠٩٩٥'>نَاقِصٌ فِى زَوَايَاهُ الأَرْبَعِ</مقطع>
  <مقطع هوية='١١٤٢٩'>فِى كُلِّ زَاوِيَةٍ مِنَ النُّقْصَانِ اثْنَانِ وَنِصْفٌ فِي اثْنَيْنِ وَنِصْفٌ</مقطع>
  <مقطع هوية='٧٠١٠٨'>فَصَارَ الَّذِى يُحْتَاجُ إِلَيْهِ مِنْ الزِّيَادَةِ حَتَّى يَتَرَبَّعَ السَّطْحُ</مقطع>
  <مقطع هوية='٢٦٨٢٩'>اثْنَانِ وَنِصْفٌ فِي مِثْلِهِ أَرْبَعَ مَرَّاتٍ</مقطع>
  <مقطع هوية='٤٣٤٠٠'>وَمَبْلَغُ ذَلِكَ جَمِيعُهُ خَمْسَةٌ وَعِشْرُونَ</مقطع>

  <مقطع هوية='١٩٤٥٤'>وَقَدْ عَلِمْنَا أَنَّ السَّطْحَ الأَوَّلَ الَّذِى هُوَ سَطْحُ الْمَالِ</مقطع>
  <مقطع هوية='٠٢٨٠٨'>وَالْأَرْبَعَةُ السُّطُوحُ الَّتِى حَوْلَهُ وَهِىَ عَشَرَةُ أَجْذَارٍ</مقطع>
  <مقطع هوية='٧٨٣٨٨'>هِىَ تِسْعَةٌ وَثَلَاثُونَ مِنْ الْعَدَدِ</مقطع>
  <مقطع هوية='٤٦٣١٨'>فَإِذَا زِدْنَا عَلَيْهَا الْخَمْسَةَ وَالْعِشْرِينَ</مقطع>
  <مقطع هوية='٥٠٢٠٨'>الَّتِي هي الْمُرَبَّعَاتُ الْأَرْبَعُ الَّتِي هِيَ على زَوايا سَطْحِ <سطح>اٮ</سطح></مقطع>
  <مقطع هوية='٨٠٨٤٤'>تَمَّ تَرْبِيعُ السَّطْحِ الْأَعْظَمِ وَهُوَ سَطْحُ
  <سطح>د <ه/></سطح></مقطع>
  <مقطع هوية='٥٢٣٠٥'>وَقَدْ عَلِمْنَا أَنَّ ذَلِكَ كُلَّهُ أَرْبَعَةٌ وَسِتُّونَ</مقطع>
  <مقطع هوية='٣٥٣٤٧'>وَأَحَدُ أَضْلَاعِهِ جَذْرُهُ وَهُوَ ثَمَانِيَةٌ</مقطع>
  <مقطع هوية='٧٩٠١٤'>فَاذَا نَقَصْنَا مِنَ الثَّمانِيَةِ مِثْلَ رُبْعِ الْعَشَرَةِ مَرَّتَيْنِ</مقطع>
  <مقطع هوية='٤٨٧٠٥'>مِنْ طَرَفَيْ ضِلْعِ السَّطْحِ الأَعْظَمِ الَّذِى هُوَ
  سَطْحُ <سطح>د <ه/></سطح></مقطع>
  <مقطع هوية='٣٣٨٣٧'>وَهُوَ خَمْسَةٌ</مقطع>
  <!-- p023 -->
  <مقطع هوية='٧٢٦٧٥'>بَقِيَ مِنْ <صفحة رقم="٢٣"/> ضِلْعِهِ ثَلَاثَةٌ وَهُوَ جَذْرُ ذَلِكَ الْمَالِ</مقطع>

  <رأس/>
  <مقطع هوية='٢٣١٦٦'>وَإِنَّمَا نَصَّفْنَا الْعَشَرَةَ الْأَجْذَارَ وَضَرَبْنَاهَا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٥٠٣٠٨'>وَزِدْنَاهَا عَلَى الْعَدَدِ الَّذِى هُوَ تِسْعَةٌ وَثَلَاثُونَ</مقطع>
  <مقطع هوية='٥٧٨٨٧'>لِيَتِمَّ لَنَا بِنَاءُ السَّطْحِ الْأَعْظَمِ بِمَا نَقَصَ مِنْ زَوَايَاهُ الْأَرْبَعُ</مقطع>
  <مقطع هوية='٩٩٢٥٦'>لِأَنَّ كُلَّ عَدَدٍ يُضْرَبُ رُبْعُهُ فِي مِثْلِهِ ثُمَّ فِي أَرْبَعَةٍ</مقطع>
  <مقطع هوية='٧٠٣٣٢'>يَكُونُ مِثْلَ ضَرْبِ نِصْفِهِ فِي مِثْلِهِ</مقطع>
  <مقطع هوية='١١٥٩٧'>فَاسْتَغْنَيْنَا بِضَرْبِ نِصْفِ الْأَجْذَارِ فِي مِثْلِهَا عَنْ الرُّبْعُ فِي مِثْلِهِ ثُمَّ في أَرْبَعَةٍ</مقطع>
  <مقطع هوية='١٠٠٩١'>وَهَذِهِ صُورَتُهُ</مقطع>
  <صورة هوية='٩١٢٢٤' عرض="1.0" ملف="../figures/fig022"
        tex="٣٩ = \os{س}{}١٠ + \os{س}{٢}"
        pdf="س² + ١٠س = ٣٩"
        />

  <رأس/>
  <مقطع هوية='٤٥٧٩٩'>وَلَهُ أَيْضًا صُورَةٌ أُخْرَى تُؤَدِّي الَى هَذَا</مقطع>
  <مقطع هوية='٨٨٥١٢'>وَهَى سَطْحُ <سطح>اٮ</سطح> وَهُوَ الْمَالُ</مقطع>
  <مقطع هوية='٠٣٣٣٦'>فَأَرَدْنَا أَنْ نَزِيْدَ عَلَيْهِ مِثْلَ عَشَرَةِ أَجْذَارِهِ</مقطع>
  <مقطع هوية='٥٣١٤٧'>فَنَصَّفْنَا الْعَشَرَةَ فَصَارَتْ خَمْسَةً</مقطع>
  <مقطع هوية='٩٣١١٤'>فَصَيَّرْنَاهَا سَطْحَيْنِ عَلَى جَنْبَتَيْ سَطْحِ <سطح>اٮ</سطح> وَهُمَا سَطْحا <سطح><جيم/> د</سطح></مقطع>
  <مقطع هوية='٣٣٣١٧'>فَصَارَ طُولُ كُلِّ سَطْحٍ مِنْهُمَا خَمْسَةَ أَذْرُعٍ</مقطع>
  <مقطع هوية='٣٨٥٣٣'>وَهُوَ نِصْفُ الْعَشَرَةِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٧٦١٨٠'>وَعَرْضُهُ مِثْلُ ضِلْعِ سَطْحِ <سطح>اٮ</سطح></مقطع>
  <مقطع هوية='٥٧٣٤٠'>فَبَقِيَتْ لَنَا مُرَبَّعَةٌ مِنْ زَوَايَا سَطْحِ <سطح>اٮ</سطح></مقطع>
  <مقطع هوية='٠٨٦٩١'>وَهِىَ خَمْسَةٌ فِي خَمْسَةٍ وَهِى نِصْفُ الْعَشَرَةِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٧٥٨٨٦'>الَّتِى زِدْنَاهَا عَلَى جَنْبَتَيْ السَّطْحِ الْأَوَّلِ</مقطع>
  <مقطع هوية='٢٢٧٤٩'>فَعَلِمْنَا أَنَّ السَّطْحَ االْأَوَّلَ هُوَ الْمَالُ</مقطع>
  <مقطع هوية='٩٥٦٦١'>وَأَنَّ السَّطْحَيْنِ اللَّذَيْنِ عَلَى جَنْبَتَيْهِ هُمَا عَشَرَةُ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٩٥٩٦'>فَذَلِكَ كُلُّهُ تِسْعَةٌ وَثَلَاثُونَ</مقطع>
  <مقطع هوية='٠٨٩٥٤'>وَبَقِيَ الَى تَمَامِ السَّطْحِ الْأَعْظَمِ مُرَبَّعَةُ خَمْسَةٍ فِي خَمْسَةٍ فَذَلِكَ خَمْسَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٥٤٦٢٣'>فَزِدْنَاهَا عَلَى تِسْعَةٍ وَثَلَاثِينَ</مقطع>
  <مقطع هوية='٩٦٨٥٤'>لِيَتِمَّ لَنَا السَّطْحُ الِاعْظَمُ الّّذي هُوَ سطح <سطح>ز<ه/></سطح></مقطع>
  <مقطع هوية='٨٣٤٣٦'>فَبَلَغَ ذَلِكَ كُلُّهُ أَرْبَعَةً وَسِتِّينَ</مقطع>
  <مقطع هوية='٤٠٨٤٠'>فَأَخَذْنَا جَذْرَهَا وَهُوَ ثَمَانِيَةٌ وَهُوَ أَحَدُ أَضْلَاعِ السَّطْحِ الْأَعْظَمُ</مقطع>
  <مقطع هوية='٩٦١٨٣'>فَاذَا نَقَصْنَا مِنْهُ مِثْلَ مَا زِدْنَا عَلَيْهِ وَهُوَ خَمْسَةٌ بَقِيَ ثَلاثَةٌ</مقطع>
  <مقطع هوية='٦٣٠٤٨'>وَهُوَ ضِلْعُ سَطْحِ <سطح>اٮ</سطح> الَّذِى هُوَ الْمَالُ</مقطع>
  <مقطع هوية='٨٧٨٧٩'>وَهُوَ جَذْرُهُ وَالْمَالُ تِسْعَةٌ</مقطع>
  <مقطع هوية='٩٦٤٣٨'>وَهَذِهِ صُورَتُهُ</مقطع>

  <صورة هوية='٠٩٨١١' عرض="1.0" ملف="../figures/fig023"
        tex="٣٩ = \os{س}{}١٠ + \os{س}{٢}"
        pdf="س² + ١٠س = ٣٩"
        />

  <رأس/>
  <مقطع هوية='٢٥٠٩٥'>وَأَمَّا <معادلة>مَالٌ وَأَحَدٌ وَعِشْرُوْنَ دِرْهَمًا تَعْدِلُ عَشَرَةَ أَجْذَاْرِهِ</معادلة></مقطع>
  <!-- p024 -->
  <مقطع هوية='٤٢٧٥٨'>فَإِنَّا نَجْعَلُ الْمَالَ سَطْحًا <صفحة رقم="٢٤"/> مُرَبَّعًا مَجْهُوْلَ الْأَضْلَاعِ</مقطع>

  <مقطع هوية='٤٢٤٩٥'>وَهُوَ سَطْحٌ <سطح>اد</سطح></مقطع>
  <مقطع هوية='٢٧٦٩٥'>ثُمَّ نَضُمُّ إِلَيْهِ سَطْحًا مُتَوَازِيَ الْأَضْلَاعِ</مقطع>
  <مقطع هوية='٥٢٨٥١'>عَرْضُهُ مِثْلُ أَحَدِ أَضْلَاعِ سَطْحِ <سطح>اد</سطح></مقطع>
  <مقطع هوية='٧٨٢٢٩'>وَهُوَ ضِلْعُ <ضلع><ه/> ن</ضلع> وَالسَّطْحُ <سطح><ه/> ٮ</سطح></مقطع>
  <مقطع هوية='٩٣٠٢٢'>فَصَارَ طُولَ السَّطْحَيْنِ جَمِيعًا ضِلْعُ <سطح><جيم/> <ه/></سطح></مقطع>
  <مقطع هوية='١٣٦٩٠'>وَقَدْ عَلِمْنَا أَنَّ طُولَهُ عَشَرَةٌ مِنْ الْعَدَدِ</مقطع>
  <مقطع هوية='٦٩٨٩٨'>لِأَنَّ كُلَّ سَطْحٍ مُرَبَّعٍ مُتَسَاوِيِ الْأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٨٠٦٨٩'>فَإِنَّ أَحَدَ أَضْلَاعِهِ مَضْرُوبًا فِي وَاحِدٍ جَذْرُ ذَلِكَ السَّطْحِ</مقطع>
  <مقطع هوية='٤٦٠١٣'>وَفِي اثْنَيْنِ جَذْرَاهُ</مقطع>
  <مقطع هوية='٧٣٦٥٢'>فَلَمَّا قَالَ <قبس>مَالٌ وَأَحَدٌ وَعِشْرُونَ تَعْدِلُ عَشَرَةَ أَجْذَارِهِ</قبس></مقطع>
  <مقطع هوية='٤٢٣٤٠'>عَلِمْنَا أَنَّ طُولَ ضِلْعِ <ضلع><ه/> <جيم/></ضلع> عَشَرَةِ أَعْدَادٍ</مقطع>
  <مقطع هوية='٣٣١٠٦'>لِأَنَّ ضِلْعَ <ضلع><جيم/> د</ضلع> جَذَرُ الْمَالِ</مقطع>
  <مقطع هوية='٤١١٧٨'>فَقَسَمْنَا ضِلْعَ <ضلع><جيم/> <ه/></ضلع> نِصْفَيْنِ عَلَى نُقْطَةٍ <نقطة>ح</نقطة></مقطع>
  <مقطع هوية='٣٦٥٤٧'>فَيَتَبَيَّنُ لَنَا أَنَّ خَطَّ <خط><ه/> ح</خط>
  مِثْلَ خَطِّ <خط>ح <جيم/></خط></مقطع>
  <مقطع هوية='٨٠٧٦٧'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>ح ط</خط>
  مِثْلُ خَطّ <خط><جيم/> د</خط></مقطع>
  <مقطع هوية='٨٧٢١٩'>فَزِدْنَا عَلَى خَطّ <خط>ح ط</خط> عَلَى اسْتِقَامَتِهِ
  مِثْلَ فَضْلِ <خط><جيم/> ح</خط> عَلَى <خط>ح ط</خط> لِيَتَرَبَّعَ السَّطْحُ</مقطع>
  <مقطع هوية='٦٨٥٦٥'>فَصَارَ خَطُّ <خط>ط <كا/></خط> مِثْلَ خَطِّ <خط><كا/> م</خط></مقطع>
  <مقطع هوية='٠٢٩٧٣'>وَحَدَثَ سَطْحٌ مُرَبَّعٌ مُتَسَاوِي الْأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٧٦٦٤٩'>وَهُوَ سَطْحُ <خط>م ط</خط></مقطع>
  <مقطع هوية='٥٠٣٨٤'>وَقَدْ كَانَ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>ط <كا/></خط> خَمْسَةٌ</مقطع>
  <مقطع هوية='٤٧٢٥٦'>وَأَضْلَاعُهُ مِثْلُهُ فَسَطْحُهُ اذًا خَمْسَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٠٢٣٧٦'>وَهُوَ مَا اجْتَمَعَ مِنْ ضَرْبِ نِصْفُ الْأَجْذَارِ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٧٤٩٣٩'>وَهُوَ خَمْسَةٌ فِي خَمْسَةٍ يَكُونُ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٣٧١٧٥'>وَقَدْ كَانَ تَبَيَّنَ لَنَا أَنَّ سَطْحَ <سطح><ه/> ٮ</سطح></مقطع>
  <مقطع هوية='٣٧٩١٣'>هُوَ الْوَاحِدُ وَالْعِشْرُونَ الَّتِى زِيدَتْ عَلَى الْمَالِ</مقطع>
  <مقطع هوية='٢٤٨٨١'>فَقَطَعْنَا مِنْ سَطْحِ <سطح><ه/> ٮ</سطح> بِخَطِّ
  <خط>ط <كا/></خط></مقطع>
  <مقطع هوية='٣٨٩٥٦'>كَالَّذِى هُوَ احْدُ أَضْلَاعِ سَطْحِ <سطح>م ط</سطح></مقطع>
  <مقطع هوية='١٤٢٠٧'>بَقِيَ سَطْحُ <سطح>ط ا</سطح></مقطع>
  <مقطع هوية='٢٣٧٧٤'>وَأَخَذْنَا مِنْ خَطِّ <خط><كا/> م</خط> خَطَّ <خط><كا/> ل</خط>
  وَهُوَ مِثْلُ خَطِّ <خط>ح <كا/></خط></مقطع>
  <مقطع هوية='٣٠٩٩٤'>فَتَبَيَّنَ لَنَا أَنْ خَطَّ <خط>ط ح</خط> مِثْلُ خَطِّ <خط>م ل</خط></مقطع>
  <مقطع هوية='٠٣١٦٧'>وَفَضَلَ مِنْ خَطِّ <خط>م <كا/></خط> خَطُّ <خط>ل <كا/></خط>
  وَهُوَ مِثْلُ خَطِّ <خط><كا/> ح</خط></مقطع>
  <مقطع هوية='٥٩٤٦٦'>فَصَارَ سَطْحُ <سطح>م ز</سطح>
  مِثْلَ سَطْحِ <سطح>ط ا</سطح></مقطع>
  <مقطع هوية='٦٨٦٠٥'>فَيَتَبَيَّنُ لَنَا أَنَّ سَطْحَ <سطح><ه/> ط</سطح>
  مَزِيدًا عَلَيْهِ سَطْحَ <سطح>م ز</سطح></مقطع>
  <مقطع هوية='٦٢٩٥٣'>مِثْلُ سَطْحِ <سطح><ه/> ٮ</سطح> وَهُوَ وَاحِدٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٠٨٤٢٢'>وَقَدْ كَانَ سَطْحُ <سطح>م ط</سطح> خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٩٩٩٠٢'>فَلَمَّا نَقَصْنَا مِنْ سَطْحِ <سطح>م ط</سطح></مقطع>
  <مقطع هوية='٦١٢٦٥'>سَطْحَ <سطح><ه/> ط</سطح> وَسَطْحَ <سطح>م ز</سطح> اللَّذَيْنِ هُمَا وَاحِدٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٩٣٩٣٣'>بَقِيَ لَنَا سَطْحٌ صَغِيرٌ وَهُوَ سَطْحُ <سطح>ز<كا/></سطح></مقطع>
  <مقطع هوية='٥٤٦١٣'>وَهُوَ فَضْلُ مَا بَيْنَ خَمْسَةٍ وَعِشْرِينَ وَوَاحِدٍ وَعِشْرِينَ وَهُوَ أَرْبَعَةٌ</مقطع>
  <مقطع هوية='٨٣٤٠٢'>وَجَذْرُهَا خَطُّ <خط>زح</خط>
  وَهُوَ مِثْلُ خَطِّ <خط>ح ا</خط> وَهُوَ اثْنَانِ</مقطع>
  <مقطع هوية='٩٧٠٤٦'>فَإِنْ نَقَصْتَهُمَا مِنْ خَطِّ <خط>ح <جيم/></خط>
  الَّذِى هُوَ نِصْفُ الْأَجْذَارِ بَقِيَ خَطُّ <خط>ا<جيم/></خط></مقطع>
  <!-- p025 -->
  <مقطع هوية='٨٢٩٧٥'>وَهُوَ <صفحة رقم="٢٥"/> ثَلَاثَةٌ وَهُوَ جَذْرُ الْمَالِ الْأَوَّلِ</مقطع>
  <مقطع هوية='٦٤٥٢٢'>فَإِنْ زِدْتَهُ عَلَى خَطِّ <خط><جيم/> ح</خط> الَّذِي هُوَ نِصْفُ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٦١٩٢٠'>بَلَغَ ذَلِكَ سَبْعَةً وَهُوَ خَطُّ <خط>ز<جيم/></خط></مقطع>
  <مقطع هوية='٦٧٩٣٧'>وَيَكُونُ جَذْرُ مَالٍ أَكْثَرَ مِنْ هَذَا الْمَالِ</مقطع>
  <مقطع هوية='٠٨٢١٥'>إذَا زِدْتْ عَلَيْهِ وَاحِدًا وَعِشْرِينَ صَارَ ذَلِكَ مِثْلَ عَشَرَةِ أَجْذَارِهِ</مقطع>
  <مقطع هوية='٥٩٢٣١'>وَهَذِهِ صُورَتُهُ</مقطع>

