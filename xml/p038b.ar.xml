<?xml version="1.0" encoding="utf-8"?>

<ملف رقم="٣٨"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <فصل هوية='٧٢٨٢٩' صفحة="٣٨">
    <عنوان>بَابُ الْمَسَاءِلِ الْمُخْتَلِفَةِ</عنوان>
  </فصل>

  <مقطع هوية='٥٠٨٠٦'>فَإِنْ سَأَلَ سَائِلٌ فَقالَ</مقطع>
  <مقطع هوية='١٣٥٤٩'><معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ ثُمَّ ضَرَبْتَ أَحَدَهُمَا فِي الْآخَرِ فَكَانَ وَاحِدًا وَعِشْرِينَ دِرْهَمًا</معادلة></مقطع>
</ملف>
