      رقم="٢٦">

  <مقطع هوية='١٤٠٨٦'>فَهَذَا السَّطْحُ <folio nbr="٢٦"/> كُلُّهُ يَجْمَعُ الثَّلَاثَةَ الْأَجْذَارَ وَالْأَرْبَعَةَ الَّتِي ذَكَرْنَاهَا</مقطع>

  <صورة هوية='٩٧٣٧٨' عرض="1.3" ملف="../figures/fig026"/>

  <مقطع هوية='١٧٦٢٤'>وَكُلُّ سَطْحٍ مُرَبَّعٍ فَإِنَّ أَحَدَ أَضْلَاعِهِ فِي وَاحِدٍ جَذْرُهُ
  فَقَطَعْنَا مِنْ سَطْحِ <سطح>ا د</سطح> سَطْحَ <سطح>ه د</سطح></مقطع>
  <مقطع هوية='٩٦٨٠١'>فَجَعَلْنَا أَحَدَ أَضْلَاعِهِ الَّذِي هُوَ <ضلع>ه ج</ضلع>
  ثَلَاثَةً الَّتِي هِيَ عَدَدُ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٥٩٠٧٤'>وَهِيَ مِثْلُ <ضلع>ز د</ضلع></مقطع>
  <مقطع هوية='٧٤٢٥٩'>فَتَبَيَّنَ لَنَا أَنَّ سَطْحَ <سطح>ه ٮ</سطح>
  هُوَ الْأَرْبَعَةُ الْمَزِيدَةُ عَلَى الْأَجْذَارِ</مقطع>
  <مقطع هوية='٦٧٦٣٦'>فَقَطَعْنَا ضِلْعَ <ضلع>ه ج</ضلع> الَّذِي هُوَ ثَلَاثَةُ أَجْذَارٍ نِصْفَيْنِ عَلَى نُقْطَةٍ <نقطة>ح</نقطة></مقطع>
  <مقطع هوية='٨٤٠٦١'>ثُمَّ جَعَلْنَا مِنْهُ سَطْحًا مُرَبَّعًا
  وَهُوَ سَطْحُ <سطح>ه ط</سطح></مقطع>
  <مقطع هوية='٦٦٠٨٨'>وَهُوَ مَا كَانَ مِنْ ضَرْبِ نِصْفِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٩١٠٩٣'>الَّتِي هُوَ وَاحِدٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٥٧٤٩'>فِي مِثْلِهِ وَهُوَ اثْنَانِ وَرُبْعٌ</مقطع>
  <مقطع هوية='٣٥٣٦٩'>ثُمّ زِدْنَا فِي خَطّ <خط></خط> مِثْلَ خَطّ []</مقطع>
  <مقطع هوية='٧٠٤٧٨'>وَهُوَ خَطّ <خط></خط></مقطع>
  <مقطع هوية='٧٤١٠٦'>فَصَارَ خَطُّ <خط></خط> مِثْلَ خَطِّ <خط></خط></مقطع>
  <مقطع هوية='١٠٦٠٣'>وَخَطُّ <خط></خط> مِثْلَ خَطِّ <خط></خط></مقطع>
  <مقطع هوية='٤٥٠٧١'>وَحَدَثَ سَطْحٌ مُرْبَعٌ مُتَسَاوِيُ الْأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٩١٣٠٩'>وَهُوَ سَطْحُ <سطح></سطح></مقطع>
  <مقطع هوية='٣٥٦٧٠'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط></خط>
  مِثْلُ خَطِّ <خط></خط></مقطع>
  <مقطع هوية='٣٩٣٠٦'>وَخَطَّ <خط></خط> مِثْلُ خَطّ <خط></خط></مقطع>
  <مقطع هوية='٢٣٣٨٤'>فَبَقِيَ خَطُّ <خط></خط> مِثْلُ خَطِّ <خط></خط></مقطع>
  <مقطع هوية='٨١٤٥٨'>وَخَطُّ <خط></خط> مِثْلُ خَطِّ <خط></خط></مقطع>
  <مقطع هوية='١٦٥٢٢'>فَيَفْضُلُ مِنْ سَطْحِ <سطح></سطح>
  مِثْلُ سَطْحِ <سطح></سطح></مقطع>
  <مقطع هوية='١٩٣٢٨'>وَقَدْ عَلِمْنَا أَنَّ سَطْحَ <سطح></سطح> هُوَ الْأَرْبَعَةُ الزَّائِدَةُ عَلَى الثَّلَاثَةِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٨١٠٧٢'>فَصَارَ سَطْحُ <سطح></سطح> وَسَطْحُ <سطح></سطح>
  مِثْلُ سَطْحِ <سطح></سطح> الَّذِي هُوَ الْأَرْبَعَةُ الْعَدَدُ</مقطع>
  <مقطع هوية='٥٤٨٥٨'>فَتَبَيَّنَ لَنَا أَنَّ سَطْحَ <سطح></سطح> هُوَ نِصْفُ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٦٧٠٧١'>الَّذِي هُوَ وَاحِدٌ وَنِصْفٌ فِي مِثْلِهِ</مقطع>
  <مقطع هوية='٧٣٨١٣'>وَهُوَ اثْنَانِ وَرُبُعٌ وَزِيَادَةُ الْأَرْبَعَةِ
  الَّتِي هِيَ سَطْحُ <سطح></سطح> وَسَطْحُ <سطح></سطح></مقطع>
  <مقطع هوية='٦٩٥٣٨'>وَقَدْ بَقِيَ لَنَا مِنْ ضِلْعِ الْمُرَبَّعَةِ الْأَوَّلَه
  الَّتِي هِيَ سَطْحُ <سطح></سطح></مقطع>
  <مقطع هوية='٨٨٩٨٥'>وَهُوَ الْمَالُ كُلُّهُ نِصْفُ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٣٠٤٨٠'>وَهُوَ وَاحِدٌ وَنِصْفٌ هُوَ خَطُّ <خط></خط></مقطع>
  <مقطع هوية='٧٥٣٤٣'>فَاذَا زِدْنَاهُ عَلَى خَطٍّ <خط></خط>
  الَّذِي هُوَ جَذْرُ سَطْحِ <سطح></سطح> اثْنَانِ <folio nbr="٢٧"/>  وَنِصْفٌ</مقطع>

</صفحة>
