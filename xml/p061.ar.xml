<ملف رقم="٦١"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٤١٢١٢'>وَأَمَّا <شدة>الْمُنْفَرِجَةُ</شدة> فَهِيَ <صفحة رقم="٦١"/> كُلُّ مُثَلَّثَةٍ إِذَا ضَرَبْتَ ضِلَعَيْهَا الأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٥٤٨٨٥'>كُلَّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ وَجَمَعْتَهُمَا</مقطع>
  <مقطع هوية='٠٨٢٥٦'>كَانَا أَقَلَّ مِنَ الضِّلَعِ الأَطْوَلِ مَضْرُوبًا فِي نَفْسِهِ</مقطع>

  <مقطع هوية='٦٦٥٣٥'>فَأَمَّا <شدة>القَائِمَةُ الزَّوَايَا</شدة>
  فَهِيَ الَّتِي لَهَا عَمُودَانِ وَقُطْرٌ</مقطع>
  <مقطع هوية='٠٨٥٠١'> وَهِيَ نِصْفُ مُرَبَّعَةٍ تَكْسِيرُهَا أَنْ تَضْرِبَ أَحَدَ الضِّلَعَيْنِ الْمُحِيطَيْنِ بِالزَّاوِيَةِ القَائِمَةِ فِي نِصْفِ الآخَرِ</مقطع>
  <مقطع هوية='٩٢٨٨٥'>فَمَا بَلَغَ ذٰلِكَ فَهُوَ تَكْسِيرُهَا</مقطع>

  <مقطع هوية='٢٦٥١١'>وَمِثَالُ ذٰلِكَ مُثَلَّثَةٌ قَائِمَةُ الزَّاوِيَةِ</مقطع>
  <مقطع هوية='٠٥٦٠٤'>ضِلَعٌ مِنْهَا سِتَّةُ أَذْرُعٍ وَضِلَعٌ مِنْهَا ثَمَانِيَةُ أَذْرُعٍ وَالْقُطْرُ عَشَرَةٌ</مقطع>
  <مقطع هوية='٢١٧٣٩'>فَحِسَابُ ذٰلِكَ أَنْ تَضْرِبَ سِتَّةً فِي أَرْبَعَةٍ</مقطع>
  <مقطع هوية='٣٤٧٤٦'>فَيَكُونُ أَرْبَعَةً وَعِشْرِينَ ذِرَاعًا وَهُوَ تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٦٤٢٢٣'>وَإِنْ أَحْبَبْتَ أَنْ تَحْسُبَهَا بِالْعَمُودِ</مقطع>
  <مقطع هوية='٥٠٣٣٦'>فَإِنَّ عَمُودَهَا لَا يَقَعُ إِلَّا عَلَى الضِّلَعِ الْأَطْوَلِ</مقطع>
  <مقطع هوية='٧٩٧٠٦'>لِأَنَّ الضِّلَعَيْنِ الْقَصِيرَيْنِ عَمُودَانِ</مقطع>
  <مقطع هوية='٠٥٧١٦'>فَإِنْ أَرَدْتَ ذٰلِكَ فَاضْرِبْ عَمُودَهَا فِي نِصْفِ الْقَاعِدَةِ</مقطع>
  <مقطع هوية='١١٨٠٩'>فَمَا كَانَ فَهُوَ تَكْسِيرُهَا وَهَذِهِ صُورَتُهَا</مقطع>

  <مقطع هوية='٢٢٣٢٠'>وَأَمَّا الْجِنْسُ الثَّانِي <شدة>فَالْمُثَلَّثَةُ الْمُتَسَاوِيَةُ الْأَضْلَاعِ حَادَّةُ الزَّوَايَا</شدة></مقطع>

  <مقطع هوية='١٠١٣٥'>مِنْ كُلِّ جَانِبٍ عَشَرَةُ أَذْرُعٍ</مقطع>
  <مقطع هوية='١٥٤٥٨'>فَإِنَّ تَكْسِيرَهَا يُعْرَفُ مِنْ قَبْلِ عَمُودِهَا وَمَسْقَطِ حَجَرِهَا</مقطع>
  <مقطع هوية='١٧٥٩٨'>وَاعْلَمْ أَنَّ كُلَّ ضِلْعَيْنِ مُسْتَوِيَيْنِ مِنْ مُثَلَّثَةٍ</مقطع>
  <مقطع هوية='١٢٦٥٠'>يَخْرُجُ بَيْنَهُمَا عَمُودٌ عَلَى قَاعِدَةٍ</مقطع>
  <مقطع هوية='٥٦٣٢٣'>فَإِنَّ مَسْقَطَ حَجَرِ الْعَمُودِ يَقَعُ عَلَى زَاوِيَةٍ قَائِمَةٍ</مقطع>
  <مقطع هوية='٣٥٦٠٤'>وَيَقَعُ عَلَى نِصْفِ الْقَاعِدَةِ سَوَاءً إِذَا اسْتَوَى الضِّلْعَانِ</مقطع>
  <مقطع هوية='١٢٧٥٣'>فَإِنِ اخْتَلَفَا خَالَفَ مَسْقَطُ الْحَجَرِ عَنْ نِصْفِ الْقَاعِدَةِ</مقطع>
  <مقطع هوية='٥٠٤٤٠'>وَلَكِنْ قَدْ عَلِمْنَا أَنَّ مَسْقَطَ حَجَرِ هَذِهِ الْمُثَلَّثَةِ عَلَى أَيِّ أَضْلَاعِهَا جَعَلْتَهُ</مقطع>
  <مقطع هوية='٧١٠٦٢'>لَا يَقَعُ إِلَّا عَلَى نَصْفِهِ فَذٰلِكَ خَمْسَةُ أَذْرُعٍ</مقطع>

  <مقطع هوية='٨٣٧٠٤'>فَمَعْرِفَةُ الْعَمُودِ أَنْ تَضْرِبَ الْخَمْسَةَ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٢٣٧٠٧'>وَتَضْرِبَ أَحَدَ الضِّلَعَيْنِ فِي مِثْلِه</مقطع>
  <مقطع هوية='١٥٢٥٥'>وَهُوَ عَشَرَةٌ فَيَكُونُ مِائَةً فَتَنْقُصُ مِنْهَا مَبْلَغَ الْخَمْسَةِ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٦٢٤٨٠'>وَهُوَ خَمْسَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٠٧٠٨٩'>فَيَبْقَى خَمْسَةٌ وَسَبْعُونَ فَخُذْ جَذْرَ ذٰلِكَ فَهُوَ الْعَمُودُ</مقطع>
  <مقطع هوية='٩٦٢١٠'>وَقَدْ صَارَ ضِلَعًا عَلَى مُثَلَّثَتَيْنِ قَائِمَتَيْنِ</مقطع>
  <مقطع هوية='٣٩١٠٥'>فَإِنْ أَرَدْتَ التَّكْسِيرَ فَاضْرِبْ جَذْرَ الْخَمْسَةِ وَالسَّبْعِينَ فِي نِصْفِ الْقَاعِدَةِ وَهُوَ خَمْسَةٌ</مقطع>
</ملف>
