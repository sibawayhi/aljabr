<صفحة رقم="١٨"
xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='١٨.١'><folio nbr="١٨"/>
وَأَمَّا الْأَمْوَاْلُ الَّتِي تَعْدِلُ الْعَدَدَ</مقطع>
  <مقطع هوية='١٨.٢'>فَمِثْلُ قَوْلِك <معادلة>مَاْلٌ يَعْدِلُ تِسْعَةً</معادلة></مقطع>
  <مقطع هوية='٠٥٨٣٢'>فَهُوَ الْمَاْلُ وَجَذْرُهُ ثَلَاثَةٌ</مقطع>
  <مقطع هوية='٨٨٧٠٩'>وَكَقَوْلِك <معادلة>خَمْسَةُ أَمْوَاْلٍ تَعْدِلُ ثَمَاْنِينَ</معادلة></مقطع>
  <مقطع هوية='٦٩١٤٥'>فَاْلْمَاْلُ الْوَاْحِدُ خُمْسُ الثَّمَاْنِينَ وَهُوَ سِتَّةُ عَشَرَ</مقطع>
  <مقطع هوية='٣٦٢٠٨'>وَكَقَوْلِك <معادلة>نِصْفُ مَاْلٍ يَعْدِلُ ثَمَاْنِيَةَ عَشَرَ</معادلة></مقطع>
  <مقطع هوية='٣٣٧٥٢'>فَاْلْمَاْلُ يَعْدِلُ سِتَّةً وَثَلَاثِينَ وَجَذْرُهُ سِتَّةٌ</مقطع>
  <مقطع هوية='٥٥٤٩١'>وَكَذَلِكَ جَمِيعُ الْأَمْوَاْلِ زَاْئِدُهَا وَنَاْقِصُهَا
  تُرَدُّ إلَى مَاْلٍ وَاْحِدٍ</مقطع>
  <مقطع هوية='١١٥١٧'>وَإِنْ كَاْنَتْ أَقَلَّ مِنْ مَاْلِ زَيْدَ عَلَيْهَا حَتَّى تَكَمَّلَ مَاْلًا تَامًًّا</مقطع>
  <مقطع هوية='١١٦٦٨'>وَكَذَلِكَ يُفْعَلُ بِمَا عَاْدَلَهَا مِنْ الْأَعْدَاْدِ</مقطع>

  <رأس/>
  <مقطع هوية='٩١٩٢٦'>وَأَمَّا الْجُذُوْرُ الَّتِي تَعْدِلُ عَدَدًا</مقطع>
  <مقطع هوية='١٩٣٨٠'>فَكَقَوْلِك <معادلة>جَذْرٌ يَعْدِلُ ثَلَاثَةً مِنْ الْعَدَدِ</معادلة></مقطع>
  <مقطع هوية='٥٢٣٥٧'>فَاْلْجَذْرُ ثَلَاثَةٌ وَاْلْمَاْلُ الَّذِى يَكُونُ مِنْهُ تِسْعَةٌ</مقطع>
  <مقطع هوية='٣٤٢٧٧'>وَكَقَوْلِك <معادلة>أَرْبَعَةُ أَجْذَاْرٍ تَعْدِلُ عِشْرِينَ</معادلة> </مقطع>
  <مقطع هوية='٠٨٢٢٣'>فَاْلْجَذْرُ الْوَاْحِدُ يَعْدِلُ خَمْسَةً وَاْلْمَاْلُ الَّذِى يَكُونُ مِنْهُ خَمْسَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٥٠٩١٤'>وَكَقَوْلِك <معادلة>نِصْفُ جَذْرٍ يَعْدِلُ عَشَرَةً</معادلة></مقطع>
  <مقطع هوية='٧٥١٨٩'>فَاْلْجَذْرُ يَعْدِلُ عِشْرِينَ وَاْلْمَاْلُ الَّذِى يَكُونُ مِنْهُ أَرْبَعَمِائَةٌ</مقطع>
  <مقطع هوية='٩٩٩٨٤'>وَوَجَدْتُ‏ هَذِهِ الْضُّرُوبَ الثَّلَاثَةَ الَّتِى هِى الْجُذُوْرُ وَاْلْأَمْوَاْلُ وَالْعَدَدُ تَقْتَرْنُ</مقطع>
  <مقطع هوية='٩٤٣٣٥'>فَيَكُونَ مِنْهَا ثَلَاثَةَ أَجْنَاْسٍ مُقْتَرِنَةٍ</مقطع>
  <مقطع هوية='٦٤٨٢٥'>وَهَى أَمْوَاْلٌ وَجُذُورٌ تَعَدُّلُ عَدَدًا</مقطع>
  <مقطع هوية='٥٣١٩١'>وَأَمْوَاْلٌ وَعَدَدٌ تَعْدِلُ جُذُوْرًا</مقطع>
  <مقطع هوية='٨١٨٤٢'>وَجُذُوْرٌ وَعَدَدٌ تَعْدِلُ أَمْوَاْلًا</مقطع>

  <رأس/>
  <مقطع هوية='٠١٢٣٦'>فَأَمَّا الْأَمْوَاْلُ وَاْلْجَذُورُ الَّتِي تَعْدِلُ الْعَدَدَ</مقطع>
  <مقطع هوية='١٨٩٣١'>فَمِثْلُ قَوْلِك <معادلة>مَاْلٌ وَعَشَرَةُ أَجْذَاْرِهِ يَعْدِلُ تِسْعَةً وَثَلَاثِينَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٣٨٨٧٦'>وَمَعْنَاْهُ أَيُّ مَاْلٍ اذَا زِدْت عَلَيْهِ مِثْلَ عَشَرَةِ أَجْذَاْرِهِ بَلَغَ ذَلِكَ كُلُّهُ تِسْعَةً وَئَلَاثِينَ</مقطع>

</صفحة>
