<ملف رقم="٤٨"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٦٣٧١٩'>ثُمَّ اضْرِبْ الْخَمْسَةَ الأَجْذَارَ <صفحة رقم="٤٨"/> فِي أَثْنَيْنِ وَرُبُعٍ</مقطع>
  <مقطع هوية='٨٥٢١٥'>فَيَكُونُ أَحَدَ عَشَرَ شَيْئًا وَرُبُعًا</مقطع>
  <مقطع هوية='٩٨٣٠٥'>فَيَصِيرُ مَعَكَ مَالٌ وَعِشْرُونَ دِرْهَمًا وَرُبُعٌ تَعْدِلُ أَحَدَ عَشَرَ جَذْرًا وَرُبُعًا</مقطع>
  <مقطع هوية='٤٨٨١٠'><ص مفتاح="قبل!قابِلْ">فَقَابِلْ بِذٰلِكَ</ص> كَنَحْوِ مَا وَصَفْتُ لَكَ فِي تَنْصِيفِ الْأَجْذَارِ إِنْ شَاءَ اللّٰهُ</مقطع>

  <مقطع هوية='٣٣٥٢١'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ ثُلُثَهُ فِي رُبُعِهِ فَيَعُودُ الْمَالُ</معادلة></مقطع>
  <مقطع هوية='١٦٩٨٦'><قياس>قِيَاسُهُ</قياس> أَنْ تَضْرِبَ ثُلُثَ شَيْءٍ فِي رُبْعِ شَيْءٍ فَيَكُونَ نِصْفَ سُدُسِ مَالٍ تَعْدِلُ شَيْئًا</مقطع>
  <مقطع هوية='١٤٤٧٢'>فَالْمَالُ يَعْدِلُ اثْنَيْ عَشَرَ شَيْئًا وَهُوَ جَذْرُ مِائَةٍ وَأَرْبَعَةٍ وَأَرْبَعِينَ</مقطع>

  <مقطع هوية='٧٤٣١٢'>فَإِنْ قَالَ <معادلة>مَالٌ تَضْرِبُ ثُلُثَهُ وَدِرْهَمًا فِي رُبْعِهِ وَدِرْهَمَيْنِ فَيَعُودُ الْمَالُ وَزِيَادَةُ ثَلاثَةَ عَشَرَ دِرْهَمًا</معادلة></مقطع>
  <مقطع هوية='٤٧٨١١'><قياس>فَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ ثُلُثَ شَيْءٍ فِي رُبْعِ شَيْءٍ فَيَكُونَ نِصْفَ سُدُسِ مَالٍ</مقطع>
  <مقطع هوية='٧٤٠٤٧'>وَتَضْرِبَ دِرْهَمَيْنِ فِي ثُلُثِ شَيْءٍ فَيَكُونَ ثُلُثَا جَذْرٍ </مقطع>
  <مقطع هوية='٨٣٥٠٣'>وَدِرْهَمًا فِي رُبْعِ شَيْءٍ فَيَكُونَ رُبُعَ جَذْرٍ</مقطع>
  <مقطع هوية='٧٩٨٥٣'>وَدِرْهَمَيْنِ فَدِرْهَمٌ بِدِرْهَمَيْنِ</مقطع>
  <مقطع هوية='٠٤٢٧١'>فَذٰلِكَ نِصْفُ سُدُسِ مَالٍ وَدِرْهَمَانِ وَأَحَدَ عَشَرَ جُزْءً مِنِ اثْنَيْ عَشَرَ جُزْءً مِنْ جَذْرٍ تَعْدِلُ جَذْرًا وَثَلَاثَةَ عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٣٦٣٣١'>فَأَلْقِ دِرْهَمَيْنِ مِنْ ثَلاثَةَ عَشَرَ بِدِرْهَمَيْنِ فَيَبْقَى أَحَدَ عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٦٧٢٧٩'>وَأَلْقِ أَحَدَ عَشَرَ جُزْءً مِنْ جَذْرٍ</مقطع>
  <مقطع هوية='٢٩٢٨٤'>فَيَبْقَى نِصْفُ سُدُسِ جَذْرٍ وَأَحَدَ عَشَرَ دِرْهَمًا تَعْدِلُ نِصْفَ سُدُسِ مَالٍ</مقطع>
  <مقطع هوية='١٦١٧٥'>فَأَكْمِلْهُ وَذٰلِكَ أَنْ تَضْرِبَهُ فِي اِثْنَي عَشَرَ</مقطع>
  <مقطع هوية='٢٣٣٨٦'>وَتَضْرِبَ كُلَّ مَا مَعَكَ فِي اِثْنَي عَشَرَ</مقطع>
  <مقطع هوية='٩٤٢٦٣'>فَيَكُونُ مَالًا يَعْدِلُ مِائَةً وَاثْنَيْنِ وَثَلاثِينَ دِرْهَمًا وَجَذْرًا</مقطع>
  <مقطع هوية='٣٣٩٩٧'><مقابلة>فَقَابِلْ بِهِ</مقابلة> تُصِبْ إن شَاءَ اللَّهُ تَعَالَى كَمَا وَصَفْتُ لَكَ</مقطع>

  <مقطع هوية='٨٨٣٠٥'>فَإِنْ قَالَ <معادلة>دِرْهَمٌ وَنِصْفٌ مَقْسُومٌ عَلَى رَجُلٍ وَبَعْضِ رَجُلٍ فَأَصَابَ الرَّجُلُ مِثْلَيْ الْبَعْضِ</معادلة></مقطع>

</ملف>
