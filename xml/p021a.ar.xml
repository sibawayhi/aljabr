<ملف رقم="٢١"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">


  <مقطع هوية='٩٤١٣٤'>وَضَرَبْتَهَا فِي <صفحة رقم="٢١"/>مِثْلِهَا</مقطع>
  <مقطع هوية='٥٤٢٥٣'>فَكَانَ مَبْلَغُ ذَلِكَ أَقَلَّ مِنَ الدَّراهِمِ الَّتِي مَعَ الْمَالِ</مقطع>
  <مقطع هوية='٨٥٢٤٢'>فَالْمَسْئَلَةُ مُسْتَحِيلَةٌ</مقطع>
  <مقطع هوية='٧٨٩٥٠'>وَإِنْ كَانَ مِثْلَ الدَّرَاهِمِ بِعَيْنِهَا</مقطع>
  <مقطع هوية='٤٧٥٢٨'>فَجَذْرُ الْمَالِ مِثْلُ نِصْفِ الِاجْذَارِ سَوَاءً لا زِيَادَةً وَلَا نُقْصَانَ</مقطع>
  <مقطع هوية='٩٦٩٧٨'>وَكُلُّ مَا أَتَاكَ مِنْ مَالَيْنِ أَوْ أَكْثَرَ أَوْ أَقَلَّ فَارْدُدْهُ الْى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية='٩٤٥٩٩'>كَنَحْوِ مَا بَيَّنْتُ لَكَ فِي الْبَابِ الِاوْلِ</مقطع>

  <قسم هوية='٨٧٣٦٨'>
    <عنوان>[جذور+عدد=أموال]</عنوان>
  </قسم>
  <مقطع هوية='٩٨٨٣٧'>وَأَمَّا الْجُذُورُ وَالْعَدَدُ الَّتِي تَعْدِلُ الْأَمْوَالَ</مقطع>
  <مقطع هوية='٣٩٢٣١'>فَنَحْوُ قَوْلِكَ <معادلة>ثَلاثَةُ أَجْذَارٍ وَأَرْبَعَةٌ مِنْ الْعَدَدِ تَعْدِلُ مَالًا</معادلة></مقطع>
  <مقطع هوية='٠٥٦٣٦'><قياس>فَبَابُهُ</قياس> أَنْ تُنَصِّفَ الْأَجْذَارَ فَتَكُونَ وَاحِدًا وَنِصْفًا</مقطع>
  <مقطع هوية='٤٦٠٥٩'>فَاضْرِبْهَا فِي مِثْلِهَا فَتَكُونَ اثْنَيْنِ وَرُبْعًا</مقطع>
  <مقطع هوية='٥٩٤٣٢'>فَزِدْهَا عَلَى الْأَرْبَعَةِ فَتَكُونَ سِتَّةً وَرُبْعًا</مقطع>
  <مقطع هوية='٠٤٦٣٢'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَانِ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٥٢٥٧'>فَزِدْهُ عَلَى نِصْفِ االْأَجْذَارِ وَهُوَ وَاحِدٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٢٠٧٠'>فَتَكُونَ أَرْبَعَةً وَهُوَ جَذْرُ الْمَالِ وَالْمَالُ سِتَّةُ عَشَرَ</مقطع>
  <مقطع هوية='٦٠٤٣٤'>وَكُلُّ مَا كَانَ‎ أَكْثَرَ مِنْ مَالٍ أَوْ أَقَلَّ فَأَرْدَدْهُ إلَى مَالٍ وَاحِدٍ</مقطع>

</ملف>
