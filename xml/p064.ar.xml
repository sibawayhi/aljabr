<ملف رقم="٦٤"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='١٤٣٢٥'>فِيهَا مُدَوَّرَةٌ قُطرُهَا سَبْعَةُ أَذْرُعٍ وَيُحِيطُ بِهَا اثْنَانِ وَعِشْرُونَ أَذْرُعًا</مقطع>
  <مقطع هوية='٧٦٥٧٢'>فَإِنَّ تَكْسِيرَهَا أَنْ تَضْرِبَ نِصْفَ الْقُطْرِ وَهُوَ ثَلاثَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٢٠٢٠٣'>فِي نِصْفِ الدَّوْرِ الَّذِي يُحِيطُ بِهَا وَهُوَ أَحَدَ عَشَرَ</مقطع>
  <مقطع هوية='٣٦٥٦٥'>فَيَكُونُ ثَمَانِيَةً وَثَلاثِينَ وَنِصْفًا وَهُوَ تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٩٢٨٩٨'>فَإِنْ أَحْبَبْتَ فَاضْرِبْ الْقُطْرَ وَهُوَ سَبْعَةٌ فِي مِثْلِهِ فَيَكُونُ تِسْعَةً وَأَرْبَعِينَ</مقطع>
  <مقطع هوية='٩٠١٥٩'>فَانْقُصْ مِنْهَا سُبُعَهَا وَنِصْفَ سُبُعَهَا وَهُوَ عَشَرَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٤٢٦٠٨'>فَيَبْقَى ثَمَانِيَةٌ وَثَلاثُونَ وَنِصْفٌ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٩٨٤٥٠' عرض="0.5" ملف="../figures/fig064b"/>

  <قسم هوية='٢٠٨٧٤'>
    <عنوان>[الْمَخْروطاتُ]</عنوان>
  </قسم>
  <مقطع هوية='٢٩٣٤٦'>فَإِنْ قَالَ عَمُودٌ مَخْرُوطٌ أَسْفَلُهُ أَرْبَعَةُ أَذْرُعٍ فِي أَرْبَعَةِ أَذْرُعٍ</مقطع>
  <مقطع هوية='٣٩١٧٥'>وَارْتِفَاعُهُ عَشَرَةُ أَذْرُعٍ وَرَأْسُهُ ذِرَاعَانِ فِي ذِرَاعَيْنِ</مقطع>
  <مقطع هوية='١٤١٣٤'>وَقَدْ كُنَّا بَيَّنَّا أَنَّ كُلَّ مَخْرُوطٍ مُحَدَّدِ الرَّأْسِ</مقطع>
  <مقطع هوية='١٥١٥٣'>فَإِنَّ ثُلُثَ تَكْسِيرِ أَسْفَلِهِ مَضْرُوبًا فِي عَمُودِهِ هُوَ تَكْسِيرُهُ</مقطع>
  <مقطع هوية='٧٩٩٣٨'>فَلَمَّا صَارَ هَذَا غَيْرَ مُحَدَّدٍ أَرَدْنَا أَنْ نَعْلَمَ</مقطع>
  <مقطع هوية='١٨٧٢٤'>كَمْ يَرْتَفِعُ حَتَّى يَفْنَى رَأْسُهُ فَيَكُونَ لَا رَأْسَ لَهُ</مقطع>
  <مقطع هوية='٧٢١٠٥'>فَعَلِمْنَا أَنَّ هَذِهِ الْعَشَرَةَ</مقطع>
  <مقطع هوية='٤٢٣١٠'>مِنَ الطُّولِ كُلِّهَا كَقَدْرِ الْإِثْنَيْنِ مِنَ الْأَرْبَعَةِ</مقطع>
  <مقطع هوية='٥٨٥٨٩'>فَالْإِثْنَانِ نِصْفُ الْأَرْبَعَةِ فَإِذَا كَانَ ذٰلِكَ كَذٰلِكَ فَالْعَشَرَةُ نِصْفُ الطُّولِ</مقطع>
</ملف>
