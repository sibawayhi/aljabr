<ملف رقم="٣٤"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٩٨٣٣٥'>وَتَبَيَّنَ لَنَا أَنَّ خَطَّ [ٮ ج] جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٢٦٦٩١'>وَخَطُّ [ز ٮ] وَ[ٮ ح] جَذْرُ الْمَأْتَيْنِ أَيْضًا</مقطع>
  <مقطع هوية='٠٦٤٦٩'>فَلَمَّا صَارَ خَطُّ [ه ح] مِثْلَ خَطِّ [ج ٮ] تَبَيَّنَ لَنَا أَنَّ الَّذِي نَقَصَ مِنْ خَطِّ [ز د]</مقطع>
  <مقطع هوية='٣٢٠٧٥'>الَّذِي هُوَ ثَلاثُونَ</مقطع>
  <مقطع هوية='٦٩٠٢٥'>جَذْرَا مِائَتَيْنِ</مقطع>
  <مقطع هوية='٩٨٠٥٧'>وَجَذْرَا مِائَتَيْنِ هُوَ جَذْرُ ثَمَانِي مِائَةٍ</مقطع>
  <مقطع هوية='٤٩٥١٦'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ وَهَذِهِ صُورَتُهُ</مقطع>

  <مقطع هوية='٩٢٠٢٨'>وَأَمَّا مَائَةٌ وَمَالٌ إِلَّا عِشْرِينَ جَذْرًا</مقطع>
  <مقطع هوية='٧٨١٣٧'>مَجْمُوعٌ إِلَيْهِ خَمْسُونَ وَعَشَرَةُ أَجْذَارٍ إِلَّا مَالَيْنِ</مقطع>
  <مقطع هوية='٦١٠٣٧'>فَلَمْ تَسْتَقِمْ لَهُ صُورَةٌ لِأَنَّهُ مِنْ ثَلاثَةِ أَجْنَاسٍ مُخْتَلِفَةٍ</مقطع>
  <مقطع هوية='٢٢٣٢١'>أَمْوَالٌ وَجُذُورٌ وَعَدَدٌ</مقطع>
  <مقطع هوية='٩٢٤٤٧'>وَلَيْسَ مَعَهَا مَا يُعَادِلُهَا فَتُصَوَّرُ</مقطع>
  <مقطع هوية='٦٧٩٦٤'>وَقَدْ تَمَكَّنَّا لَهَا صُورَةً لَا تَحْسُنُ</مقطع>
  <مقطع هوية='٥٧٦٩٢'></مقطع>
  <مقطع هوية='٧١٢٨٢'>فَأَمَّا اضْطِرَارُهَا بِاللَّفْظِ فَبَيِّنٌ</مقطع>
  <مقطع هوية='٤١٣٥٧'>وَذٰلِكَ أَنَّكَ قَدْ عَلِمْتَ أَنَّ مَعَكَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ جَذْرًا</مقطع>
  <مقطع هوية='٣٩٥١٤'>فَلَمَّا زِدْتَ عَلَيْهَا خَمْسِينَ وَعَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٥٢٩٩'>صَارَتْ مِائَةً وَخَمْسِينَ وَمَالًا إِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٥٣١٠٩'>لِأَنَّ هَذِهِ الْعَشَرَةَ الأَجْذَارِ الْمَزِيدَةَ جَبَرَتْ مِنَ الْعِشْرِينَ الْجَذْرِ النَّاقِصَةِ عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٧٣٥٠٥'>فَبَقِيَتْ مِائَةٌ وَخَمْسُونَ وَمَالٌ إِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٠٣١٤'>وَقَدْ كَانَ مَعَ الْمِائَةِ مَالٌ</مقطع>
  <مقطع هوية='٣٤٥٥٣'>فَلَمَّا نَقَصْتَ مِنَ الْمِائَةِ وَالْمَالِ الْمَالَيْنِ الْمُسْتَثْنَيَيْنِ مِنَ الْخَمْسِينَ</مقطع>
  <مقطع هوية='٦١٣٧٤'>ذَهَبَ مَالٌ بِمَالٍ وَبَقِيَ عَلَيْكَ مَالٌ</مقطع>
  <مقطع هوية='٥٩٣٤٨'>فَصَارَتْ مِائَةً وَخَمْسِينَ إِلَّا مَالًا وَإِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٩٠٤٢١'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ</مقطع>

  <فصل هوية='٨٢٧٦٦'>
    <عنوان>بَابُ الْمَسَائِلِ السِّتِّ</عنوان>
  </فصل>

  <مقطع هوية='١٠٧٤٧'>وَقَدْ قَدَّمْنَا قَبْلَ أَبْوَابِ الْحِسَابِ وَوُجُوهِهَا سِتَّ مَسَائِلَ</مقطع>
  <مقطع هوية='٤٠٧١١'>جَعَلْتُهَا أَمْثِلَةً لِلِسِّتَةِ الْأَبْوَابِ الْمُتَقَدِّمَةِ فِي صَدْرِ كِتَابِي هٰذَا</مقطع>
  <مقطع هوية='٣٢٠١١'>لَا بُدَّ أَنَّ مِنْهَا ثَلاثَةً لَا تُنْصِفُ فِيهَا الْأَجْذَارَ</مقطع>
  <مقطع هوية='٣٥٤٥٨'>وَذَكَرْتُ أَنَّ حِسَابَ الْجَبْرِ وَالْمُقَابَلَةِ لَا بُدَّ أَنْ يُخْرِجَكَ إِلَى بَابٍ مِنْهَا</مقطع>
  <مقطع هوية='٦١٥٢٢'>ثُمَّ أَتْبَعْتُ ذٰلِكَ مِنَ الْمَسَائِلِ بِمَا يُقَرِّبُ مِنَ الْفَهْمِ</مقطع>
  <مقطع هوية='٦٢٤٥٥'>وَتُخِفُّ فِيهِ الْمُؤْنَةَ وَتُسَهِّلُ فِي الدَّلَالَةِ إِنْ شَاءَ اللَّهُ تَعَالَى</مقطع>

  <مسألة هوية='٠٢٤٢٢'>الْمَسْأَلةُ الْأُولى</مسألة>
  <مقطع هوية='١٧٣١٨'>فَالْأُوْلَى مِنَ السِّتِّ نَحْوُ قَوْلِكَ عَشَرَةٌ قَسَمْتُهَا قِسْمَيْنِ</مقطع>
  <مقطع هوية='١٦٧٣١'>فَضَرَبْتُ أَحَدَ الْقِسْمَيْنِ فِي الْآخَرِ</مقطع>
  <مقطع هوية='٥١٤٢٤'>ثُمَّ ضَرَبْتُ أَحَدَهُمَا فِي نَفْسِهِ</مقطع>
  <مقطع هوية='١٧٦١٥'>فَصَارَ الْمَضْرُوبُ فِي نَفْسِهِ مِثْلَ أَحَدِ الْقِسْمَيْنِ فِي الْآخَرِ أَرْبَعَ <صفحة رقم="٣٥"/> مَارَّاتٍ</مقطع>

</ملف>
