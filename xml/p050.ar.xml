<ملف رقم="٥٠"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٣٧٣٩٨'>فَتَحْتَاجُ أَنْ تُكْمِلَ مَالَكَ</مقطع>
  <مقطع هوية='٥٧٥٧٠'>وَإِكْمَالُكَ إِيَّاهُ أَنْ تَضْرِبَ جَمِيعَ مَا مَعَكَ فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ أَجْزَاءِ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٩٠١٥٠'>فَتَضْرِبُ خَمْسَةً وَعِشْرِينَ فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ خَمْسَةٍ وَعِشْرِينَ فَيَكُونُ مَالًا</مقطع>
  <مقطع هوية='٦٥٧٩٣'>وَتَضْرِبُ الْأَرْبَعَةَ الدِّرَاهِمَ فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٤٢٦٥'>فَيَكُونُ ثَلاثَةً وَعِشْرِينَ دِرْهَمًا جُزْءٌ مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٣٦٦٩٨'>وَتَضْرِبُ أَرْبَعَةَ أَجْذَارٍ وَثُلُثًا فِي خَمْسَةٍ وَتِسْعَةَ عَشَرَ جُزْءً مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٠٢٢٣٦'>فَيَكُونُ أَرْبَعَةً وَعِشْرِينَ جَذْرًا وَأَرْبَعَةً وَعِشْرِينَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ مِنْ جَذْرٍ</مقطع>
  <مقطع هوية='٩٥٦٢٣'>فَنَصِّفْ الأَجْذَارَ فَيَكُونُ اثْنَيْ عَشَرَ جَذْرًا وَاثْنَيْ عَشَرَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ مِنْ جَذْرٍ</مقطع>
  <مقطع هوية='٢٠٤٥٨'>وَاضْرِبْهَا فِي مَثْلِهَا فَيَكُونُ مِائَةً وَخَمْسَةً وَخَمْسِينَ (دِرْهَمًا) وَأَرْبَعِمِائَةٍ وَتِسْعَةً وَسِتِّينَ جُزْءًا مِنْ سِتِّمَائَةٍ وَخَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧١٥٠٢'>فَأَلْقِ مِنْهَا (الدَّراهِمَ) الثَّلاثَةَ وَالْعِشْرِينَ
  وَالْجُزْءَ مِنَ الْخَمْسَةِ وَالْعِشْرِينَ الَّذِي كَانَ مَعَ الْمَالِ</مقطع>
  <مقطع هوية='٧٨٧٨٨'>فَيَبْقَى مِائَةٌ وَاثْنَانِ وَثَلاثُونَ وَأَرْبُعِمِائَةٍ وَأَرْبَعُونَ جُزْءًا مِنْ سِتِّمَائَةٍ وَخَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٠٧٩٢٣'>فَتَأْخُذُ جَذْرَ ذٰلِكَ وَهُوَ أَحَدَ عَشَرَ (دِرْهَمًا) وَثَلاثَةَ عَشَرَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٤٦٥٣٣'>فَتَزِيدُهُ عَلَى نِصْفِ الْأَجْذَارِ الَّتِي هِيَ اثْنَيْ عَشَرَ (دِرْهَمًا) وَاثْنَيْ عَشَرَ جُزْءًا مِنْ خَمْسَةٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٨٩٤٧٨'>فَيَكُونُ ذٰلِكَ أَرْبَعَةً وَعِشْرِينَ وَهُوَ الْمَالُ الْمَطْلُوبُ الَّذِي تَعْزِلُ ثُلُثَهُ وَرُبُعَهُ وَأَرْبَعَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٤٤٧١٧'>ثُمَّ تَضْرِبُ مَا بَقِيَ فِي مِثْلِهِ
  فَيَعُودُ الْمَالُ وَزِيَادَةُ اثْنَيْ عَشَرَ دِرْهَمًا</مقطع>

</ملف>
