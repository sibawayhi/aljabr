<ملف رقم="٦٧"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <جزء هوية='٤٣١٣٩'>
    <عنوان>كِتَابُ الْوَصَايَا</عنوان>
  </جزء>

  <فصل هوية='٦٣٩٥٠'>
    <عنوان>بَابٌ مِنْ ذٰلِكَ فِي الْعَيْنِ وَالدَّيْنِ</عنوان>
  </فصل>

  <مقطع هوية='٧٤٠٤٩'>رَجُلٌ مَاتَ وَتَرَكَ ابْنَيْنِ وَأَوْصَى بِثُلُثِ مَالِهِ لِرَجُلٍ أَجْنَبِيٍّ</مقطع>
  <مقطع هوية='٠٨٩١٤'>وَتَرَكَ عَشَرَةَ دَرَاهِمَ عَيْنًا وَعَشَرَةَ دَرَاهِمَ دَيْنًا عَلَى أَحَدِ الِابْنَيْنِ</مقطع>
  <مقطع هوية='٥٠٨٢٦'>قِيَاسُهُ أَنْ تَجْعَلَ الْمُسْتَخْرَجَ مِنَ الدَّيْنِ شَيْئًا فَتَزِيدَهُ عَلَى الْعَيْنِ</مقطع>
  <مقطع هوية='٨٤٦٠٩'>وَهُوَ عَشَرَةُ دَرَاهِمَ فَيَكُونُ عَشَرَةً وَشَيْئًا</مقطع>
  <مقطع هوية='٨٨٤٩٢'>ثُمَّ تَعْزِلُ ثُلُثَهُ لِأَنَّهُ أَوْصَى بِثُلُثِ مَالِهِ وَهُوَ ثَلاَثَةُ دَرَاهِمَ وَثُلُثٌ وَثُلُثُ شَيْءٍ</مقطع>
  <مقطع هوية='٠٧٠١٧'>فَيَبْقَى سِتَّةُ دَرَاهِمَ وَثُلُثَا شَيْءٍ</مقطع>
  <مقطع هوية='٥٣١١٦'>فَتَقْسِمُهُ بَيْنَ الِابْنَيْنِ فَيُصِيبُ كُلُّ ابْنٍ ثَلاَثَةَ دَرَاهِمَ وَثُلُثَ دِرْهَمٍ وَثُلُثَ شَيْءٍ</مقطع>
  <مقطع هوية='٦٩١٦٤'>فَهُوَ يَعْدِلُ الشَّيْءَ الْمُسْتَخْرَجَ</مقطع>

  <مقطع هوية='٥١٠٣٨'>فَقَابِلْ بِهِ فَتُلْقِي ثُلُثًا مِنْ شَيْءٍ بِثُلُثِ شَيْءٍ</مقطع>
  <مقطع هوية='٩١٥١٧'>فَيَبْقَى ثُلُثَا شَيْءٍ تُعَادِلُ ثَلاثَةَ دَرَاهِمَ وَثُلُثًا</مقطع>
  <مقطع هوية='٥٦٤٩٤'>فَتَحْتَاجُ أَنْ تُكْمِلَ الشَّيْءَ الَّذِي اسْتُخْرِجَ مِنَ الدَّيْنِ</مقطع>
  <مقطع هوية='٢٤٤٣٨'>فَإِنْ تَرَكَ ابْنَيْنِ</مقطع>
  <مقطع هوية='١١٩٤٥'>وَتَرَكَ عَشَرَةَ دَرَاهِمَ عَيْنًا وَعَشَرَةَ دَرَاهِمَ دَيْنًا عَلَى أَحَدِ الِابْنَيْنِ</مقطع>
  <مقطع هوية='٨٩٨٥١'>وَأَوْصَى لِرَجُلٍ بِخُمُسِ مَالِهِ وَدِرْهَمٍ</مقطع>
  <مقطع هوية='١١٢٥٧'>فَقِيَاسُهُ أَنْ تَجْعَلَ مَا يُسْتَخْرَجُ مِنَ الدَّيْنِ شَيْئًا</مقطع>
  <مقطع هوية='٥٠٠٠٦'>فَتَزِيدَهُ عَلَى الْعَيْنِ فَتَكُونَ شَيْئًا وَعَشَرَةَ دَرَاهِمَ</مقطع>
  <مقطع هوية='٢٩٤٥٠'>فَتَعْزِلُ خُمُسًا لِأَنَّهُ أَوْصَى بِخُمُسِ مَالِهِ وَهُوَ دَرْهَمَانِ وَخُمُسُ شَيْءٍ</مقطع>
  <مقطع هوية='٥٨٥١٢'>فَيَبْقَى ثَمَانِيَةَ دَرَاهِمَ</مقطع>
</ملف>
