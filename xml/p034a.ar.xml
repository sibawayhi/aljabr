<ملف رقم="٣٤"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٩٨٣٣٥'>وَتَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>ٮ <ه/></خط> جَذْرُ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٢٦٦٩١'>وَخَطُّ <خط>ز ٮ</خط> وَ<خط>ٮ <جيم/></خط> جَذْرُ الْمَأْتَيْنِ أَيْضًا</مقطع>
  <مقطع هوية='٠٦٤٦٩'>فَلَمَّا صَارَ خَطُّ <خط><ه/> ح</خط> مِثْلَ خَطِّ <خط><جيم/> ٮ</خط></مقطع>
  <مقطع هوية='٢٦٠٢١'>تَبَيَّنَ لَنَا أَنَّ الَّذِي نَقَصَ مِنْ خَطِّ <خط>ز د</خط></مقطع>
  <مقطع هوية='٣٢٠٧٥'>الَّذِي هُوَ ثَلاثُونَ</مقطع>
  <مقطع هوية='٦٩٠٢٥'>جَذْرَا مِائَتَيْنِ</مقطع>
  <مقطع هوية='٩٨٠٥٧'>وَجَذْرَا مِائَتَيْنِ هُوَ جَذْرُ ثَمَانِي مِائَةٍ</مقطع>
  <مقطع هوية='٤٩٥١٦'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ وَهَذِهِ صُورَتُهُ</مقطع>
  <صورة هوية='١٦٠١٩' ملف="../figures/fig034"
        tex="
             \left(١٠ -
             \جذر{}{٢٠٠}\right)
             -
             \left(\جذر{}{٢٠٠}
             - ٢٠\right)"
        pdf="
             (٢٠ - √(٢٠٠)) -
             (√(٢٠٠) - ١٠)"
             />

  <رأس/>
  <مقطع هوية='٩٢٠٢٨'>وَأَمَّا <تعبير صفحة="٣٤">مَائَةٌ وَمَالٌ إِلَّا عِشْرِينَ جَذْرًا مَجْمُوعٌ إِلَيْهِ خَمْسُونَ وَعَشَرَةُ أَجْذَارٍ إِلَّا مَالَيْنِ</تعبير></مقطع>
  <مقطع هوية='٦١٠٣٧'>فَلَمْ تَسْتَقِمْ لَهُ صُورَةٌ لِأَنَّهُ مِنْ ثَلاثَةِ أَجْنَاسٍ مُخْتَلِفَةٍ</مقطع>
  <مقطع هوية='٢٢٣٢١'>أَمْوَالٌ وَجُذُورٌ وَعَدَدٌ</مقطع>
  <مقطع هوية='٩٢٤٤٧'>وَلَيْسَ مَعَهَا مَا يُعَادِلُهَا فَتُصَوَّرُ</مقطع>
  <مقطع هوية='٦٧٩٦٤'>وَقَدْ يُمْكِنُنا لَهَا صُورَةٌ لَا تُحَسُّ</مقطع>

  <مقطع هوية='٧١٢٨٢'>فَأَمَّا اضْطِرَارُهَا بِاللَّفْظِ فَبَيِّنٌ</مقطع>
  <مقطع هوية='٤١٣٥٧'>وَذٰلِكَ أَنَّكَ قَدْ عَلِمْتَ أَنَّ مَعَكَ مِائَةً وَمَالًا إِلَّا عِشْرِينَ جَذْرًا</مقطع>
  <مقطع هوية='٣٩٥١٤'>فَلَمَّا زِدْتَ عَلَيْهَا خَمْسِينَ وَعَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٥٢٩٩'>صَارَتْ مِائَةً وَخَمْسِينَ وَمَالًا إِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٥٣١٠٩'>لِأَنَّ هَذِهِ الْعَشَرَةَ الأَجْذَارِ الْمَزِيدَةَ <جبر>جَبَرَتْ</جبر> مِنَ الْعِشْرِينَ الْجَذْرِ النَّاقِصَةِ عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٧٣٥٠٥'>فَبَقِيَتْ مِائَةٌ وَخَمْسُونَ وَمَالٌ إِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٠٣١٤'>وَقَدْ كَانَ مَعَ الْمِائَةِ مَالٌ</مقطع>
  <مقطع هوية='٣٤٥٥٣'>فَلَمَّا نَقَصْتَ مِنَ الْمِائَةِ وَالْمَالِ الْمَالَيْنِ الْمُسْتَثْنَيَيْنِ مِنَ الْخَمْسِينَ</مقطع>
  <مقطع هوية='٦١٣٧٤'>ذَهَبَ مَالٌ بِمَالٍ وَبَقِيَ عَلَيْكَ مَالٌ</مقطع>
  <مقطع هوية='٥٩٣٤٨'>فَصَارَتْ مِائَةً وَخَمْسِينَ إِلَّا مَالًا وَإِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٩٠٤٢١'>وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ</مقطع>

</ملف>
