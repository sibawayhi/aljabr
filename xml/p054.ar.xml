<ملف رقم="٥٤"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٨٦٣٦٥'><فإن>وَمِثَالُ ذٰلِكَ فِي وَجْهٍ <صفحة رقم="٥٤"/>مِنْهُ</فإن><صفحة رقم="٥٤"/></مقطع>
  <مقطع هوية='٧٤٤٢٨'>إِذَا قِيْلَ لَكَ <حرف>عَشَرَةٌ بِسِتَّةٍ كَمْ لَكَ بِأَرْبَعَةٍ</حرف></مقطع>
  <مقطع هوية='٣٢١٢٥'>فَقَوْلُهُ <حرف>عَشَرَةٌ</حرف> هُوَ الْعَدَدُ الْمُسَعَّرُ</مقطع>
  <مقطع هوية='٩٤٩٥٠'>وَقَوْلُهُ <حرف>بِسِتَّةٍ</حرف> هُوَ السِّعْرُ</مقطع>
  <مقطع هوية='٧٩٣٥٨'>وَقَوْلُهُ <حرف>كَمْ لَكَ</حرف> هُوَ الْعَدَدُ الْمَجْهُولُ الْمُثَمَّنُ</مقطع>
  <مقطع هوية='٩٠١٦٥'>وَقَوْلُهُ <حرف>بِأَرْبَعَةٍ</حرف> هُوَ الْعَدَدُ الَّذِي هُوَ الثَّمَنُ</مقطع>
  <مقطع هوية='٨١٩٨٧'>فَالْعَدَدُ الْمُسَعَّرُ الَّذِي هُوَ الْعَشَرَةُ مُمَايِنٌ لِلْعَدَدِ الَّذِي هُوَ الثَّمَنُ وَهُوَ الْأَرْبَعَةُ</مقطع>
  <مقطع هوية='١٤٥٠٨'>فَاضْرِبْ الْعَشَرَةَ فِي الْأَرْبَعَةِ وَهُمَا الْمُتَبَايِنَانِ الظَّاهِرَانِ</مقطع>
  <مقطع هوية='٥٥٥٤٧'>فَيَكُونُ أَرْبَعِينَ فَاقْسِمْهَا عَلَى الْعَدَدِ الْآخَرِ الظَّاهِرِ الَّذِي هُوَ السِّعْرُ وَهُوَ سِتَّةٌ</مقطع>
  <مقطع هوية='٥٨٤٧٨'>فَيَكُونُ سِتَّةً وَثُلُثَيْنَ وَهُوَ الْعَدَدُ الْمَجْهُولُ الَّذِي هُوَ فِي قَوْلِ الْقَائِلِ <حرف>كَمْ</حرف></مقطع>
  <مقطع هوية='٤٩٤٦٣'>وَهُوَ الثَّمَنُ وَمُبايِنُهُ السِّتَّةُ الَّذِي هُوَ السِّعْرُ</مقطع>

  <مقطع هوية='١٨٨٥٤'><فإن>وَالْوَجْهُ الثَّانِي</فإن> قَوْلُ الْقَائِلِ <حرف>عَشَرَةٌ بِثَمَانِيَةٍ كَمْ ثَمَنُ أَرْبَعَةٍ</حرف></مقطع>
  <مقطع هوية='٢٦٠٧٤'>وَرُبَّمَا قَالَ <حرف>أَرْبَعَةٌ مِنْهَا كَمْ ثَمَنُهَا</حرف></مقطع>
  <مقطع هوية='٨١٨١٢'>فَالعَشَرَةُ هِيَ الْعَدَدُ الْمُسَعَّرُ</مقطع>
  <مقطع هوية='٥٦٦٥٣'>وَهُوَ مُبَايِنٌ لِلْعَدَدِ الَّذِي هُوَ الثَّمَنُ الْمَجْهُولُ الَّذِي فِي قَوْلِهِ <حرف>كَمْ</حرف></مقطع>
  <مقطع هوية='٠٣٦٢٧'>وَالثَّمَانِيَةُ هِيَ الْعَدَدُ الَّذِي هُوَ السِّعْرُ</مقطع>
  <مقطع هوية='٧٨٩٨٢'>وَهُوَ مُبَايِنٌ لِلْعَدَدِ الظَّاهِرِ الَّذِي هُوَ الثَّمَنُ وَهُوَ أَرْبَعَةٌ</مقطع>
  <مقطع هوية='٩٧٨٣٨'>فَاضْرِبِ الْعَدَدَيْنِ الظَّاهِرَيْنِ الْمُتَبَايِنِينَ أَحَدُهُمَا فِي الْآخَرِ</مقطع>
  <مقطع هوية='٨٦٧٦٢'>وَهُوَ أَرْبَعَةٌ فِي ثَمَانِيَةٍ فَيَكُونُ اثْنَانِ وَثَلاثِينَ</مقطع>
  <مقطع هوية='٦١٦٥٤'>وَاقْسِمْهُ عَلَى الْعَدَدِ الْآخَرِ الظَّاهِرِ الَّذِي هُوَ السِّعْرُ وَهُوَ عَشَرَةٌ</مقطع>
  <مقطع هوية='٨٧٧٦٢'>فَيَكُونُ ثَلَاثَةً وَخُمُسًا وَهُوَ الْعَدَدُ الَّذِي هُوَ الْمُثَمَّنُ</مقطع>
  <مقطع هوية='٤٠٣١٢'>وَهُوَ مُبَايِنٌ لِلْعَشَرَةِ الَّتِي عَلَيْهَا قَسَمْتَ</مقطع>

  <مقطع هوية='٩١٩٠٥'>وَهَكَذَا جَمِيعُ مُعَامَلاتِ النَّاسِ وَقِيَاسُهَا إِنْ شَاءَ اللهُ تَعَالَى</مقطع>

  <مقطع هوية='٢٦١٥٣'><فإن>فَإِنْ سَأَلَ سَائِلٌ فَقَالَ</فإن> <حرف>أَجِيرٌ أَجْرَتَهُ فِي الشَّهْرِ عَشَرَةَ دَرَاهِمَ</حرف></مقطع>
  <مقطع هوية='١٣٩٤٤'>عَمَلَ سِتَّةَ أَيَّامٍ كَمْ نَصِيبُهُ</مقطع>
  <مقطع هوية='٠١٩٠٣'>فَقَدْ عَلِمْتَ أَنَّ السِّتَّةَ الأَيَّامِ هِيَ خُمُسُ الشَّهْرِ</مقطع>
  <مقطع هوية='٢٨٤٧٥'>وَأَنَّ الَّذِي يَصِيبُهُ مِنَ الدَّرَاهِمِ بِقَدْرِ مَا عَمَلَ مِنَ الشَّهْرِ</مقطع>
  <مقطع هوية='٨٠٥٨٢'><قياس>وَقِيَاسُ ذٰلِكَ</قياس> أَنَّ قَوْلَهُ <حرف>شَهْرٌ</حرف> وَهُوَ ثَلَاثُونَ يَوْمًا وَهُوَ الْمُسَعَّرُ</مقطع>
  <مقطع هوية='٨٠٨٦١'>وَقَوْلُهُ <حرف>عَشَرَةَ دَرَاهِمَ</حرف> هُوَ السِّعْرُ</مقطع>
  <مقطع هوية='٦٦٤٠٠'>وَقَوْلُهُ <حرف>سِتَّةَ أَيَّامٍ</حرف> هُوَ الْمُثَمَّنُ</مقطع>
  <مقطع هوية='٢٧٠٩٨'>وَقَوْلُهُ <حرف>كَمْ يَصِيبُهُ</حرف> هُوَ الثَّمَنُ</مقطع>

  <مقطع هوية='٧٥٥٥٩'>فَاضْرِبْ السِّعْرَ الَّذِي هُوَ عَشَرَةَ فِي الْمُثَمَّنِ الَّذِي هُوَ مَبَايِنُهُ وَهُوَ سِتَّةٌ فَيَكُونُ سِتِّينَ</مقطع>
  <مقطع هوية='٢١١٢٠'>فَاقْسِمْهُ عَلَى الْعَدَدِ الظَّاهِرِ وَهُوَ الْمُسَعَّرُ</مقطع>
  <مقطع هوية='٥٢٧٩٣'>فَيَكُونُ ذٰلِكَ دِرْهَمَيْنِ وَهُوَ الثَّمَنُ</مقطع>
  <مقطع هوية='٠١٥٨١'>وَهَذَا مَا يَتَعَامَلُ النَّاسُ بِهِ بَيْنَهُمْ مِنَ الصَّرْفِ وَالْكَيْلِ وَالْوَزْنِ</مقطع>

  <فصل هوية='٨٦٥١١'>
    <عنوان>بَابُ الْمِسَاحَةِ</عنوان>
  </فصل>
  <مقطع هوية='٠٥٧٤٣'>اعْلَمْ أَنَّ مَعْنَى وَاحِدٍ فِي وَاحِدٍ إِنَّمَا هِيَ مِسَاحَةٌ</مقطع>
  <مقطع هوية='٣٦٧٤٨'>وَمَعْنَاهُ ذِرَاعٌ فِي ذِرَاعٍ</مقطع>
  <مقطع هوية='٤٦٤٣٤'>فَكُلُّ سَطْحٍ مُتَسَاوِي الأَضْلَاعِ وَالزَّوَايَا يَكُونُ مِنْ كُلِّ جَانِبِهِ</مقطع>
</ملف>
