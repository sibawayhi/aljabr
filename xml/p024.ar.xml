<صفحة xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi"
      رقم="٢٤">

  <مقطع هوية='٤٢٧٥٨'>فَإِنَّا نَجْعَلُ الْمَالَ سَطْحًا <folio nbr="٢٤"/> مُرَبَّعًا مَجْهُوْلَ الْأَضْلَاعِ</مقطع>

  <مقطع هوية='٤٢٤٩٥'>وَهُوَ سَطْحٌ <سطح>ا د</سطح></مقطع>
  <مقطع هوية='٢٧٦٩٥'>ثُمَّ نَضُمُّ إِلَيْهِ سَطْحًا مُتَوَازِيَ الْأَضْلَاعِ عَرْضُهُ مِثْلُ أَحَدِ أَضْلَاعِ سَطْحِ <سطح>ا د</سطح></مقطع>
  <مقطع هوية='٧٨٢٢٩'>وَهُوَ ضِلْعُ <ضلع>ه ن</ضلع> وَالسَّطْحُ <سطح>ه ٮ</سطح></مقطع>
  <مقطع هوية='٩٣٠٢٢'>فَصَارَ طُولَ السَّطْحَيْنِ جَمِيعًا ضِلْعُ <سطح>حـ ه</سطح></مقطع>
  <مقطع هوية='١٣٦٩٠'>وَقَدْ عَلِمْنَا أَنَّ طُولَهُ عَشَرَةٌ مِنْ الْعَدَدِ لِأَنَّ كُلَّ سَطْحٍ مُرَبَّعٍ مُتَسَاوِيِ الْأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٨٠٦٨٩'>فَإِنَّ أَحَدَ أَضْلَاعِهِ مَضْرُوبًا فِي وَاحِدِ جَذْرِ ذَلِكَ السَّطْحِ</مقطع>
  <مقطع هوية='٤٦٠١٣'>وَفِي اثْنَيْنِ جَذْرَاهُ</مقطع>
  <مقطع هوية='٧٣٦٥٢'>فَلَمَّا قَالَ مَالٌ وَاحِدٌ وَعِشْرُونَ تَعْدِلُ عَشَرَةَ أَجْذَارِهِ</مقطع>
  <مقطع هوية='٤٢٣٤٠'>عَلِمْنَا أَنَّ طُولَ ضِلْعٍ <ضلع>ه حـ</ضلع> عَشَرَةِ أَعْدَادٍ</مقطع>
  <مقطع هوية='٣٣١٠٦'>لِأَنَّ ضِلْعَ <ضلع>حـ د</ضلع> جَذَرُ الْمَالِ</مقطع>
  <مقطع هوية='٤١١٧٨'>فَقَسَمْنَا ضِلْعَ <ضلع>حـ ه</ضلع> نِصْفَيْنِ عَلَى نُقْطَةٍ <نقطة>حـ</نقطة></مقطع>
  <مقطع هوية='٣٦٥٤٧'>فَيَتَبَيَّنُ لَنَا أَنَّ خَطَّ <خط>ه ع</خط>
  مِثْلَ خَطِّ <خط>ع حـ</خط></مقطع>
  <مقطع هوية='٨٠٧٦٧'>وَقَدْ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>ع ط</خط>
  مِثْلُ خَطّ <خط>حـ د</خط></مقطع>
  <مقطع هوية='٨٧٢١٩'>فَزِدْنَا عَلَى خَطّ <خط>ع ط</خط> عَلَى اسْتِقَامَتِهِ
  مِثْلَ فَضْلِ <خط>حـ ع</خط> عَلَى <خط>حـ ط</خط> لِيَتَرَبَّعَ السَّطْحُ</مقطع>
  <مقطع هوية='٦٨٥٦٥'>فَصَارَ خَطُّ <خط>ط ك</خط> مِثْلَ خَطِّ <خط>ك م</خط> وَحَدَثَ سَطْحٌ مُرَبَّعٌ مُتَسَاوِي الْأَضْلَاعِ وَالزَّوَايَا</مقطع>
  <مقطع هوية='٧٦٦٤٩'>وَهُوَ سَطْحُ <خط>م ط</خط>
  وَقَدْ كَانَ تَبَيَّنَ لَنَا أَنَّ خَطَّ <خط>ط ك</خط> خَمْسَةٌ</مقطع>
  <مقطع هوية='٤٧٢٥٦'>وَأَضْلَاعُهُ مِثْلُهُ فَسَطْحُهُ اذًا خَمْسَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٠٢٣٧٦'>وَهُوَ مَا اجْتَمَعَ مِنْ ضَرْبِ نِصْفُ الْأَجْذَارِ فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٧٤٩٣٩'>وَهُوَ خَمْسَةٌ فِي خَمْسَةٍ يَكُونُ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٣٧١٧٥'>وَقَدْ كَانَ تَبَيَّنَ لَنَا أَنَّ سَطْحَ <سطح>H B</سطح> هُوَ الْوَاحِدُ وَالْعِشْرُونَ الَّتِى زِيدَتْ عَلَى الْمَالِ</مقطع>
  <مقطع هوية='٢٤٨٨١'>فَقَطَعْنَا مِنْ سَطْحِ <سطح>حـ ٮ</سطح>
  بِخَطِّ <خط>ط ك</خط> كَالَّذِى هُوَ احْدُ أَضْلَاعِ سَطْحِ <سطح>م ط</سطح></مقطع>
  <مقطع هوية='١٤٢٠٧'>بَقِيَ سَطْحُ <سطح>ط ا</سطح></مقطع>
  <مقطع هوية='٢٣٧٧٤'>وَأَخَذْنَا مِنْ خَطِّ <خط>ك م</خط> خَطَّ <خط>ك ل</خط>
  وَهُوَ مِثْلُ خَطِّ <خط>ع ك</خط></مقطع>
  <مقطع هوية='٣٠٩٩٤'>فَتَبَيَّنَ لَنَا أَنْ خَطَّ <خط>ط ع</خط>
  مِثْلُ خَطِّ <خط>م ل</خط></مقطع>
  <مقطع هوية='٠٣١٦٧'>وَفَضْلٌ مِنْ خَطِّ <خط>م ك</خط> خَطِّ <خط>ل ك</خط>
  وَهُوَ مِثْلُ خَطِّ <خط>ك ع</خط></مقطع>
  <مقطع هوية='٥٩٤٦٦'>فَصَارَ سَطْحُ <سطح>م ز</سطح>
  مِثْلَ سَطْحِ <سطح>ط ا</سطح></مقطع>
  <مقطع هوية='٦٨٦٠٥'>فَيَتَبَيَّنُ لَنَا أَنَّ سَطْحَ <سطح>ه ط</سطح>
  مَزِيدًا عَلَيْهِ سَطْحَ <سطح>م ز</سطح> مِثْلُ سَطْحِ <سطح>ه ٮ</سطح></مقطع>
  <مقطع هوية='٦٢٩٥٣'>وَهُوَ وَاحِدٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٠٨٤٢٢'>وَقَدْ كَانَ سَطْحَ <سطح>م ط</سطح> خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٩٩٩٠٢'>فَلَمَّا نَقَصْنَا مِنْ سَطْحِ <سطح>م ط</سطح>
  سَطْحَ <سطح>ه ط</سطح> وَسَطْحَ <سطح>م ز</سطح> اللَّذَيْنِ هُمَا وَاحِدٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٩٣٩٣٣'>بَقِيَ لَنَا سَطْحٌ صَغِيرٌ وَهُوَ سَطْحُ <سطح>ز ك</سطح> وَهُوَ فَضْلُ مَا بَيْنَ خَمْسَةٍ وَعِشْرِينَ وَوَاحِدٍ وَعِشْرِينَ</مقطع>
  <مقطع هوية='٨٣٤٠٢'>وَهُوَ أَرْبَعَةٌ وَجَذْرُهَا خَطُّ <خط>ز ع</خط>
  وَهُوَ مِثْلُ خَطِّ <خط>ع ا</خط> وَهُوَ اثْنَانِ</مقطع>
  <مقطع هوية='٩٧٠٤٦'>فَإِنْ نَقَصْتَهُمَا مِنْ خَطِّ <خط>ع حـ</خط>الَّذِى هُوَ نِصْفُ الْأَجْذَارِ بَقِيَ خَطٌّ <خط>ا حـ</خط></مقطع>

</صفحة>
