<ملف رقم="٣٠"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='١٦٧١١'>فَيَكُونُ جَمِيعُ ذَلِكَ خَمْسَةَ دَرَاهِمَ إِلَّا تِسْعَةً وَأَرْبَعِينَ جَذْرًا <صفحة رقم="٣٠"/> ( شَيْئًا) وَثَلاثَةَ أَرْبَاعِ جَذْرٍ</مقطع>
  <مقطع هوية='١٩٥٦٢'>ثُمَّ تَضْرِبُ خَمْسَةَ أَجْذَارٍ نَاقِصَةً فِي نِصْفِ جَذْرٍ زَائِدٍ</مقطع>
  <مقطع هوية='٩٧٤٧٧'>فَيَكُونُ مَالَيْنِ وَنِصْفًا نَاقِصًا</مقطع>
  <مقطع هوية='٩٣٣٨٩'>فَذٰلِكَ خَمْسَةُ دَرَاهِمَ إِلَّا مَالَيْنِ وَنِصْفًا وَإِلَّا تِسْعَةً وَأَرْبَعِينَ جَذْرًا وَثَلاثَةَ أَرْبَاعِ جَذْرٍ</مقطع>

  <رأس/>
  <مقطع هوية='٨٠٨٨٩'>فَإِنْ قَالَ <قبس>عَشَرَةٌ وَشَيْءٌ فِي شَيْءٍ إِلَّا عَشَرَةً</قبس></مقطع>
  <مقطع هوية='٦٠٧٨٧'>فَكَأَنَّهُ قَالَ <تعبير>شَيْءٌ وَعَشَرَةٌ فِي شَيْءٍ إِلَّا عَشَرَةً</تعبير></مقطع>
  <مقطع هوية='٨٨٣١٨'>فَتَقُولُ شَيْءٌ فِي شَيْءٍ مَالٌ زَائِدٌ</مقطع>
  <مقطع هوية='٩٩٨١٩'>وَعَشَرَةٌ فِي شَيْءٍ عَشَرَةُ أَشْيَاءَ زَائِدَةٌ</مقطع>
  <مقطع هوية='٩٨٢٣٥'>وَإِلَّا عَشَرَةً فِي شَيْءٍ عَشَرَةُ أَشْيَاءَ نَاقِصَةٌ</مقطع>
  <مقطع هوية='٥١٨٩٠'>فَذَهَبَتِ الزِّيَادَةُ بِالنُّقْصَانِ وَبَقِيَ الْمَالُ</مقطع>
  <مقطع هوية='٨٥٨٨٨'>وَإِلَّا عَشَرَةً فِي عَشَرَةٍ مِائَةٌ مَنْقُوصَةٌ مِنَ الْمَالِ</مقطع>
  <مقطع هوية='٢٧٤٧٧'>فَجَمِيعُ ذٰلِكَ مَالٌ إِلَّا مِائَةَ دِرْهَمٍ</مقطع>

  <رأس/>
  <مقطع هوية='٩٧٤٣٣'>وَكُلُّ مَا كَانَ مِنَ الضِّرْبِ زَائِدًا وَنَاقِصًا مَثَلُ الْأَشْيَاءِ فِي زِيَادَةِ شَيْءٍ</مقطع>
  <مقطع هوية='٩٨٣٧١'>فَالضَّرْبُ الْأَخِيرُ نَاقِصٌ أَبَدًا</مقطع>
  <مقطع هوية='٢٦٨٥٠'>فَاعْلَمْ ذٰلِكَ وَبِاللهِ التَّوْفِيقُ</مقطع>

  <فصل هوية='٠٣٠٤٢'>
    <عنوان>بَابُ الْجَمْعِ وَالنُّقْصَانِ</عنوان>
  </فصل>
  <مقطع هوية='٠٠٩٥٦'>اِعْلَمْ أَنَّ <تعبير>جَذْرَ مِائَتَيْنِ إِلَّا عَشَرَةً مَجْمُوعٌ إِلَى عِشْرِينَ إِلَّا جَذْرَ مَائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٠٨٢١٨'>فَإِنَّهُ عَشَرَةٌ سَوِيًّا</مقطع>

  <مقطع هوية='٤٩٦١١'>وَ<تعبير>جَذْرُ مِائَتَيْنِ إِلَّا عَشَرَةً مَنْقُوصٌ مِنْ عِشْرِينَ إِلَّا جَذْرَ مِائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٠٥٤٤٧'>فَهُوَ ثَلاَثُونَ إِلَّا جَذْرَيْ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٨٥٧٦٧'>وَجَذْرَا مِائَتَيْنِ هُوَ جَذْرُ ثَمَانِي مِائَةٍ</مقطع>

  <مقطع هوية='٦٢٥٩٤'>وَ<تعبير>مِائَةٌ وَمَالٌ إِلَّا عِشْرِينَ جَذْرًا مَجْمُوعٌ إِلَيْهِ خَمْسُونَ وَعَشَرَةُ أَجْذَارٍ إِلَّا مَالَيْنِ</تعبير></مقطع>
  <مقطع هوية='٧٠٢٣١'>فَهُوَ مَائَةٌ (وَمَالٌ) وَخَمْسُونَ إِلَّا مَالًا وَإِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>

  <مقطع هوية='٠٢٢٤٨'>وَ<تعبير>مِائَةٌ وَمَالٌ إِلَّا عِشْرِينَ جَذْرًا مَنْقُوصٌ مِنهُ خَمْسُونَ وَعَشَرَةُ أَجْذَارٍ إِلَّا مَالَيْنِ</تعبير></مقطع>
  <مقطع هوية='٦٠٧٦٣'>فَهُوَ خَمْسُونَ دِرْهَمًا وَثَلاَثَةُ أَمْوَالٍ إِلَّا ثَلاَثِينَ جَذْرًا</مقطع>

  <رأس/>
  <مقطع هوية='٣٦٧٥٩'>وَأَنَا مُبَيِّنٌ لَكَ عِلَّةَ ذٰلِكَ فِي صُورَةٍ تُؤَدِّي إِلَى الطَّلَبِ إن شَاءَ اللهُ تَعَالَى</مقطع>

  <فصل هوية='٦٧١٦٦'>
    <عنوان>[إضْعافُ الْجُذورِ]</عنوان>
  </فصل>

  <قسم هوية='٨٠٠٨٤'>
    <عنوان>[مَبادِء]</عنوان>
  </قسم>
    <مقطع هوية='٧٥٠٨٢'>وَاعْلَمْ أَنَّ كُلَّ جَذْرِ مَالٍ مَعْلُومٍ أَوْ أَصَمَّ
    تُرِيدُ أَنْ تُضْعِفَهُ</مقطع>
  <مقطع هوية='٥٧٩٠٣'>وَمَعْنَى إِضْعَافِكَ إِيَّاهُ أَنْ تَضْرِبَهُ فِي اثْنَيْنِ</مقطع>

</ملف>
