<ملف رقم="٣٧"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٣١١٩٤'><صفحة رقم="٣٨"/> وَرُبْعُ شَيْءٍ وَدِرْهَمٌ تَعْدِلُ عِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٥٠٥٦'>فَالْقَ مِنَ الْعِشْرِينَ دِرْهَمًا بِدِرْهَمٍ فَتَبْقَى تِسْعَةَ عَشَرَ دِرْهَمًا</مقطع>
  <مقطع هوية='٤١٠٦٦'>تَعْدِلُ نِصْفَ سُدُسِ مَالٍ وَثُلُثَ شَيْءٍ وَرُبْعَ شَيْءٍ</مقطع>
  <مقطع هوية='١٦٢٨٣'>فَكَمِّلْ مَالَكَ وَأَكَالَهُ أَنْ تَضْرِبَ كُلَّ مَا مَعَكَ فِي اثْنَيْ عَشَرَ</مقطع>
  <مقطع هوية='٦٩٨١٠'>فَيَصِيرُ مَعَكَ مَالٌ وَسَبْعَةُ أَجْذَارٍ</مقطع>
  <مقطع هوية='٥٥٠٢٧'>تَعْدِلُ مِائَتَيْنِ وَثَمَانِيَةٍ وَعِشْرِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='١٠٤٩٤'>فَنِصْفُ الْأَجْذَارِ وَاضْرِبْهَا فِي مِثْلِهَا تَكُنْ اثْنَيْ عَشَرَ وَرُبْعًا</مقطع>
  <مقطع هوية='١١٩٧٣'>فَارْدُدْهَا عَلَى الْأَعْدَادِ وَهِيَ مَائَتَانِ وَثَمَانِيَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='١٠٩٥٣'>فَيَكُونُ مِائَتَيْنِ وَأَرْبَعِينَ وَرُبْعًا</مقطع>
  <مقطع هوية='٥٤٥٦٥'>فَخُذْ جَذْرَهَا خَمْسَةَ عَشَرَ وَنِصْفًا</مقطع>
  <مقطع هوية='٧٤٩٤٣'>فَانْقُصْ مِنهُ نِصْفَ الْأَجْذَارِ وَهُوَ ثَلَاثَةٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٠٩٩٤٣'>يَبْقَى اثْنَي عَشَرَ وَهُوَ الْمَالُ</مقطع>
  <مقطع هوية='١٩٧٣٩'>فَقَدْ أَخْرَجْتَكَ هَذِهِ المَسْأَلَةُ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ</مقطع>
  <مقطع هوية='٠٩٥٧٦'>وَهِيَ أَمْوَالٌ وَجُذُورٌ تَعْدِلُ عَدَدًا</مقطع>

  <مسألة هوية='٧٨٤٦٥'>الْمَسْأَلةُ الْخَامِسَةُ</مسألة>
  <مقطع هوية='٤٨٢٩٦'>وَالمَسْأَلَةُ الْخَامِسَةُ عَشَرَةَ قَسَمْتُهَا قِسْمَيْنِ</مقطع>
  <مقطع هوية='٣٦٤٩١'>ثُمَّ ضَرَبْتَ كُلَّ قِسْمٍ فِي نَفْسِهِ وَجَمَعْتَهُمْ فَكَانَا ثَمَانِيَةً وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٩٩١٣٣'>قِيَاسُهُ أَنْ تَجْعَلَ أَحَدَ الْقِسْمَيْنِ شَيْئًا وَالْآخَرَ عَشَرَةً إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٨١٦٤٦'>فَاضْرِبْ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٨١٤٠٤'>فَيَكُونُ مِائَةً وَمَالًا إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٤٦٢٧٧'>ثُمَّ تَضْرِبُ شَيْئًا فِي شَيْءٍ فَيَكُونُ مَالًا</مقطع>
  <مقطع هوية='٦١١٧٣'>ثُمَّ تَجْمَعُهُمَا فَيَكُونُ ذٰلِكَ مِائَةً وَمَالَيْنِ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٩٥٨٩٤'>تَعْدِلُ ثَمَانِيَةً وَخَمْسِينَ دِرْهَمًا</مقطع>
  <مقطع هوية='٠٣٠٨٢'>فَاجْبُرِ الْمِائَةَ وَالْمَالَيْنِ بِالْعِشْرِينَ الشَّيْءِ النَّاقِصَةِ</مقطع>
  <مقطع هوية='٨٧١٩٧'>وَازِدْهَا عَلَى الثَّمَانِيَةِ وَالْخَمْسِينَ</مقطع>
  <مقطع هوية='٤٥٢٧٤'>فَيَكُونُ مِائَةً وَمَالَيْنِ تَعْدِلُ ثَمَانِيَةً وَخَمْسِينَ دِرْهَمًا وَعِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٢٠١٩٦'>فَارْدُدْ ذٰلِكَ إِلَى مَالٍ وَاحِدٍ</مقطع>

  <مقطع هوية='٠٩٢٠٤'>وَهُوَ أَنْ تَأْخُذَ نِصْفَ مَا مَعَكَ فَيَكُونُ خَمْسِينَ دِرْهَمًا وَمَالًا</مقطع>
  <مقطع هوية='٨٣٢٣٤'>تَعْدِلُ تِسْعَةً وَعِشْرِينَ دِرْهَمًا وَعَشَرَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٠١٩٤٠'>فَقَابِلْ بِهِ وَذٰلِكَ أَنَّكَ تَلْقَى مِنَ الْخَمْسِينَ تِسْعَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٧٥٧٠٣'>فَيَبْقَى أَحَدٌ وَعِشْرُونَ وَمَالٌ تَعْدِلُ عَشَرَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٦٤٣٩٥'>فَنِصْفُ الْأَجْذَارِ يَكُونُ خَمْسَةً وَاضْرِبْهَا فِي مَثْلَبًا</مقطع>
</ملف>
