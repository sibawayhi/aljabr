<ملف رقم="٦٠"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٤٣٣٩٥'>وَأَحَدُ قُطْرَيْهَا ثَمانِيَةٌ وَالْآخَرُ سِتَّةُ أَذْرُعٍ</مقطع>

  <مقطع هوية='٧٣٥٢٧'>فَاعْلَمْ أَنَّ تَكْسِيرَهَا أَنْ تَعْرِفَ الْقُطْرَيْنِ أَوْ أَحَدَهُمَا</مقطع>
  <مقطع هوية='٥٤٩٥٢'>فَإِنْ عَرَفْتَ الْقُطْرَيْنِ جَمِيعًا</مقطع>
  <مقطع هوية='٢٦٩٧١'>فَإِنَّ الَّذِي يَكُونُ مِنْ ضَرْبِ أَحَدِهُمَا فِي نِصْفِ الْآخَرِ هُوَ تَكْسِيرُهَا</مقطع>
  <مقطع هوية='٥٠٢٩٦'>وَذٰلِكَ أَنْ تَضْرِبَ ثَمَانِيَةَ فِي ثَلاثَةٍ أَوْ أَرْبَعَةَ فِي سِتَّةٍ</مقطع>
  <مقطع هوية='٧٥٢٤١'>فَيَكُونُ أَرْبَعَةً وَعِشْرِينَ ذِرَاعًا وَهُوَ تَكْسِيرُهَا</مقطع>

  <مقطع هوية='١٨٦١٩'>فَإِنْ عَرَفْتَ قُطْرًا وَاحِدًا فَقَدْ عَلِمْتَ أَنَّهَا مُثَلَّثَتانِ</مقطع>
  <مقطع هوية='٩٣٢٦٦'>كُلُّ وَاحِدَةٍ مِنْهُمَا ضِلَعاهَا خَمْسَةُ أَذْرُعٍ</مقطع>
  <مقطع هوية='٣١٦٧٢'>وَالضِّلَعُ الثَّالِثُ هُوَ قُطْرُهَا</مقطع>
  <مقطع هوية='٣١٩٢١'>فَاحْسُبْهَا عَلَى حِسَابِ الْمُثَلَّثَاتِ وَهَذِهِ صُورَتُهَا</مقطع>
  <صورة هوية='٠٨٨٤٢' عرض="0.6" ملف="../figures/fig060a"/>

  <مقطع هوية='٢٢٤١١'>وَأَمَّا <شدة>المُشَبَّهَةُ بِالْمُعَيَّنَةِ</شدة> فَعَلَى مِثالِ الْمُعَيَّنَةِ</مقطع>

  <مقطع هوية='٦٥٥٥٩'>وَأَمَّا <شدة>سَائِرُ الْمُرَبَّعَاتِ</شدة></مقطع>
  <مقطع هوية='٦٣٨٧١'>فَإِنَّمَا يُعْرَفُ تَكْسِيرُهَا مِن قَبْلِ الْقُطْرِ فَيَخْرُجُ إِلَى حِسَابِ الْمُثَلَّثَاتِ</مقطع>
  <مقطع هوية='٠٧٠٨٤'>فَاعْلَمْ ذٰلِكَ وَهَذِهِ صُورَةُ الْمُشَبَّهَةِ بِالْمُعَيَّنَةِ</مقطع>
  <صورة هوية='٤١٨٨٧' عرض="1.0" ملف="../figures/fig060b"/>

  <قسم هوية='٣٢٢٧'>
    <عنوان>[الْمُثَلَّثاتُ]</عنوان>
  </قسم>
  <مقطع هوية='١٠٤٥٥'>وَأَمَّا الْمُثَلَّثَاتُ فَهِيَ ثَلاثَةُ أَجْنَاسٍ الْقَائِمَةُ وَالْحَادَّةُ وَالْمُنْفَرِجَةُ</مقطع>

  <مقطع هوية='٦٠٤٧٥'>فَأَمَّا <شدة>الْقَائِمَةُ</شدة>
  إِذَا ضَرَبْتَ ضِلَعَيْهَا الْأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٧٩٩٠٧'>كُلَّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ وَجَمَعْتَهُمَا</مقطع>
  <مقطع هوية='٤٨٢٥٦'>كَانَ ذٰلِكَ مِثَالَ ضِلَعِهَا الْأَطْوَلِ مَضْرُوبًا فِي نَفْسِهِ</مقطع>

  <مقطع هوية='٦٧٣٩٨'>وَأَمَّا <شدة>الْحَادَّةُ</شدة> فَكُلُّ مُثَلَّثَةٍ
  إِذَا ضَرَبْتَ ضِلَعَيْهَا الْأَقْصَرَيْنِ</مقطع>
  <مقطع هوية='٥٩٠٣٩'>كُلَّ وَاحِدٍ مِنْهُمَا فِي نَفْسِهِ ثُمَّ جَمَعْتَهُمَا</مقطع>
  <مقطع هوية='٥٧٩٠٥'>كَانَا أَكْثَرَ مِنَ الضِّلَعِ الْأَطْوَلِ مَضْرُوبًا فِي نَفْسِهِ</مقطع>

</ملف>
