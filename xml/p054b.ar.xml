<?xml version="1.0" encoding="utf-8"?>

<ملف رقم="٥٤"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <فصل هوية='٨٦٥١١'>
    <عنوان>بَابُ الْمِسَاحَةِ</عنوان>
  </فصل>
  <مقطع هوية='٠٥٧٤٣'>اعْلَمْ أَنَّ مَعْنَى وَاحِدٍ فِي وَاحِدٍ إِنَّمَا هِيَ مِسَاحَةٌ</مقطع>
  <مقطع هوية='٣٦٧٤٨'>وَمَعْنَاهُ ذِرَاعٌ فِي ذِرَاعٍ</مقطع>

  <قسم هوية='١٥٣٩٣'>
    <عنوان>[السَّطْحُ الْمُتَسَاوِي الأَضْلَاعِ]</عنوان>
  </قسم>
  <مقطع هوية='٤٦٤٣٤'>فَكُلُّ <شدة>سَطْحٍ مُتَسَاوِي الأَضْلَاعِ وَالزَّوَايَا</شدة>
  يَكُونُ مِنْ كُلِّ جَانِبِهِ <صفحة رقم="٥٥"/> وَاحِدٌ</مقطع>
</ملف>
