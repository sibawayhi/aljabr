    <عنوان>
       <مقطع هوية="١">كتابُ الْجَبْرِ والْمُقابَلةِ</مقطع>
   </عنوان>
    <folio nbr="16"/>
    <مقطع هوية="٢">أَلَّفْتُ مِنْ كِتَابِ الْجَبْرِ وَالْمُقَابَلَةِ كِتَابًا مُخْتَصَرًا حَاصِرًا لِلَطِيفِ الْحِسَابِ وَجَلِيلِهِ لِمَا يَلْزَمُ النَّاسُ مِنْ الْحَاجَةِ إلَيْهِ</مقطع>
    <مقطع هوية="٣">فِي مَوَارِيثِهِمْ وَوَصَايَاهُمْ</مقطع>
    <مقطع هوية="٤">وَفِي مُقَاسَمَتِهِمْ وَأَحْكَامِهِمْ وَتِجَارَاتِهِمْ</مقطع>
    <مقطع هوية="٥">وَفِي جَمِيعِ مَا يَتَعَامَلُونَ بِهِ بَيْنَهُمْ مِنْ مِسَاحَةِ الْأَرَضِينَ وَكَرَى الْأَنْهَارِ وَالْهِنْدَسَةِ وَغَيْرِ ذَلِكَ مِنْ وَُجُوهِهِ وَفَنُونِهِ</مقطع>
    <مقطع هوية="٦">مُقَدَّمًا لِحُسْنِ النِّيَّةِ فِيهِ وَرَاجِيًا لِأَنْ يَنْزِلَهُ أَهْلُ االْأَدَبِ بِفَضْلِ مَا اسْتَوْدَعُوا مِنْ نِعْمِ اللَّهِ تَعَالَى</مقطع>
    <مقطع هوية="٧">وَجَلِيلُ آلَائِهِ وَجَمِيلِ بَلَائِهِ عِنْدَهُمْ مَنْزِلَتُهُ</مقطع>
    <مقطع هوية="٨">وَبِاَللَّهِ تَوْفِيقِي فِي هَذَا وَفِي غَيْرِهِ عَلَيْهِ تَوَكَّلْتُ وَهُوَ رَبُّ الْعَرْشِ الْعَظِيمِ</مقطع>
    <مقطع هوية="٩">وَصَلَّى اللَّهُ عَلَى جَمِيعِ الِانْبِيَاءِ وَالْمُرْسَلِينَ</مقطع>
    <!-- start -->
    <رأس هو="١">الْعَدَدُ</رأس>
    <باب>
       <مقطع هوية="١٠">وَإِنِّي لَمَّا نَظَرْتُ فِيمَا يَحْتَاجُ الْيهِ النَّاسُ مِنْ الْحِسَابِ</مقطع>
       <مقطع هوية="١١">وَجَدْتُ جَمِيعَ ذَلِكَ عَدَدًا</مقطع>
       <مقطع هوية="١٢">وَوَجَدْتُ جَمِيعَ الْأَعْدَادِ إنَّمَا تَرَكَّبَتْ مِنْ الْوَاحِدِ</مقطع>
       <مقطع هوية="١٣">وَالْوَاحِدُ دَاخِلٌ فِي جَمِيعِ الْأَعْدَادِ</مقطع>
       <مقطع هوية="١٤">وَوَجَدْتُ جَمِيعَ مَا يُلْفَظُ بِهِ مِنْ الْأَعْدَادِ مَا جَاوَزَ الْوَاحِدَ إلَى الْعَشَرَةِ يَخْرُجُ مَخْرَجَ الْوَاحِدِ</مقطع>
       <مقطع هوية="١٥">ثُمَّ تُثَنَّى الْعَشَرَةُ وَتُثَلُّثُ كَمَا فُعِلَ بِالْوَاحِدِ فَتَكُونُ مِنْهَا الْعِشْرُونَ وَالثَّلَاثُونَ الَى تَمَامِ الْمِائَةِ</مقطع>
       <مقطع هوية="١٦">ثُمَّ تُثَنَّى الْمِائَةُ وَتُثَلَّثُ كَمَا فُعِلَ بِالْوَاحِدِ وَبِالْعَشَرَةِ إلَى الْأَلْفِ</مقطع>
       <مقطع هوية="١٧">ثُمَّ كَذَلِكَ تَرَدَّدَ الْأَلْفُ عِنْدَ كُلِّ عَقْدٍ إلَى غَايَةِ الْمُدْرَكِ مِنْ الْعَدَدِ</مقطع>
       <مقطع هوية="١٨">وَوَجَدْتُ الْأَعْدَادَ الَّتِى يُحْتَاجُ إِلَيْهَا فِي حِسَابِ الْجَبْرِ وَالْمُقَابَلَةِ عَلَى ثَلَاثَةِ ضُرُوبٍ</مقطع>
       <مقطع هوية="١٩">وَهِى جُذُورٌ وَأَمْوَالٌ وَعَدَدٌ مُفْرَدٍ <folio nbr="١٧"/>لَا يُنْسَبُ إلَى جَذْرٍ وَلَا إلَى مَالٍ</مقطع>
       <مقطع هوية="٢٠">فَالْجَذْرُ مِنْهَا كُلُّ شَيْءٍ مَضْرُوبٍ فِي نَفْسِهِ مِنَ الْوَاحِدِ وَمَا فَوْقَهُ مِنَ الْأَعْدَادِ وَمَا دُونَهُ مِنَ الْكُسُورِ</مقطع>
       <مقطع هوية="٢١">وَالْمَالُ كُلُّ مَا اجْتَمَعَ مِنَ الْجَذْرِ الْمَضْرُوبِ فِي نَفْسِهِ</مقطع>
       <مقطع هوية="٢٢">وَالْعَدَدُ الْمُفْرَدُ كُلُّ مَلْفُوظٍ بِهِ مِنَ الْعَدَدِ بِلَا نِسْبَةٍ إلَى جَذْرٍ وَلَا إلَى مَالٍ</مقطع>
       <مقطع هوية="٢٣">فَمِنْ هَذِهِ الضُّرُوبِ الثَّلَاثَةِ مَا يَعْدِلُ بَعْضُهَا بَعْضًا</مقطع>
       <مقطع هوية="٢٤">وَهُوَ كَقَوْلِك <قبس>أَمْوَالٌ تَعْدِلُ جُذُوْرًا</قبس> وَ<قبس>أَمْوَالٌ تَعْدِلُ عَدَدًا</قبس> وَ<قبس>جُذُورٌ تَعْدِلُ عَدَدًا</قبس>
      </مقطع>

      <رأس/>
      <مقطع هوية="٢٥"><folio nbr="١٨" rosen="٤"/>فَأَمَّا الْأَمْوَالُ الَّتِي تَعْدِلُ الْجُذُوْرَ</مقطع>
       <مقطع هوية="٢٦">فَمِثْلُ قَوْلِكَ <معادلة>مَالٌ يَعْدِلُ خَمْسَةَ أَجْذَارِهِ</معادلة>
      </مقطع>
       <مقطع هوية="٢٧">فَجَذْرُ الْمَالِ خَمْسَةٌ</مقطع>
       <مقطع هوية="٢٨">وَالْمَالُ خَمْسَةٌ وَعِشْرُونَ وَهُوَ مِثْلُ خَمْسَةِ أَجْذَارِهِ</مقطع>
       <مقطع هوية="٢٩">وَكَقَوْلِكَ <معادلة>ثُلْثُ مَالٍ يَعْدِلُ أَرْبَعَةَ أَجْذَارٍ</معادلة></مقطع>
       <مقطع هوية="٣٠">فَالْمَالُ كُلُّهُ يَعْدِلُ اثْنَيْ عَشَرَ جَذْرًا</مقطع>
       <مقطع هوية="٣١">وَهُوَ مِائَةٌ وَأَرْبَعَةٌ وَأَرْبَعُونَ</مقطع>
       <مقطع هوية="٣٢">وَجَذْرُهُ اثْنَيْ عَشَرَ</مقطع>

       <مقطع هوية="٣٣">وَمِثْلُ قَوْلِكَ <معادلة>خَمْسَةُ أَمْوَالٍ تَعْدِلُ عَشَرَةَ أَجْذَارٍ</معادلة></مقطع>
       <مقطع هوية="٣٤">فَالْمَالُ الْوَاحِدُ يَعْدِلُ جَذْرَيْنِ وَجَذْرُ الْمَالِ اثْنَانِ وَالْمَالُ أَرْبَعَةٌ</مقطع>
       <مقطع هوية="٣٥">وَكَذَلِكَ مَا كَثُرَ مِنْ الْأَمْوَالِ أَوْ قَلَّ يُرَدُّ إلَى مَالٍ وَاحِدٍ</مقطع>
       <مقطع هوية="٣٦">وَكَذَلِكَ يُفْعَلُ بِمَا عَادَلَهَا مِنْ الْأَجْذَارِ</مقطع>
       <مقطع هوية='٣٧'>يُرَدُّ إلَى مِثْلِ مَا يُرَدُّ إلَيْهَا الْمَالُ</مقطع>

