<ملف رقم="٣٠"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <فصل هوية='٠٣٠٤٢'>
    <عنوان>بَابُ الْجَمْعِ وَالنُّقْصَانِ</عنوان>
  </فصل>
  <مقطع هوية='٠٠٩٥٦'>اِعْلَمْ أَنَّ <تعبير>جَذْرَ مِائَتَيْنِ إِلَّا عَشَرَةً مَجْمُوعٌ إِلَى عِشْرِينَ إِلَّا جَذْرَ مَائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٠٨٢١٨'>فَإِنَّهُ عَشَرَةٌ سَوِيًّا</مقطع>

  <مقطع هوية='٤٩٦١١'>وَ<تعبير>جَذْرُ مِائَتَيْنِ إِلَّا عَشَرَةً مَنْقُوصٌ مِنْ عِشْرِينَ إِلَّا جَذْرَ مِائَتَيْنِ</تعبير></مقطع>
  <مقطع هوية='٠٥٤٤٧'>فَهُوَ ثَلاَثُونَ إِلَّا جَذْرَيْ مِائَتَيْنِ</مقطع>
  <مقطع هوية='٨٥٧٦٧'>وَجَذْرَا مِائَتَيْنِ هُوَ جَذْرُ ثَمَانِي مِائَةٍ</مقطع>

  <مقطع هوية='٦٢٥٩٤'>وَ<تعبير>مِائَةٌ وَمَالٌ إِلَّا عِشْرِينَ جَذْرًا مَجْمُوعٌ إِلَيْهِ خَمْسُونَ وَعَشَرَةُ أَجْذَارٍ إِلَّا مَالَيْنِ</تعبير></مقطع>
  <مقطع هوية='٧٠٢٣١'>فَهُوَ مَائَةٌ وَخَمْسُونَ إِلَّا مَالًا وَإِلَّا عَشَرَةَ أَجْذَارٍ</مقطع>

  <مقطع هوية='٠٢٢٤٨'>وَ<تعبير>مِائَةٌ وَمَالٌ إِلَّا عِشْرِينَ جَذْرًا مَنْقُوصٌ مِنهُ خَمْسُونَ وَعَشَرَةُ أَجْذَارٍ إِلَّا مَالَيْنِ</تعبير></مقطع>
  <مقطع هوية='٦٠٧٦٣'>فَهُوَ خَمْسُونَ دِرْهَمًا وَثَلاَثَةُ أَمْوَالٍ إِلَّا ثَلاَثِينَ جَذْرًا</مقطع>

  <رأس/>
  <مقطع هوية='٣٦٧٥٩'>وَأَنَا مُبَيِّنٌ لَكَ عِلَّةَ ذٰلِكَ فِي صُورَةٍ تُؤَدِّي إِلَى الطَّلَبِ إن شَاءَ اللهُ تَعَالَى</مقطع>

  <فصل هوية='٦٧١٦٦'>
    <عنوان>[إضْعافُ الْجُذورِ]</عنوان>
  </فصل>

  <قسم هوية='٨٠٠٨٤'>
    <عنوان>[مَبادِء]</عنوان>
  </قسم>
    <مقطع هوية='٧٥٠٨٢'><ص مفتاح="علم!اعْلَمْ">وَاعْلَمْ</ص> أَنَّ كُلَّ جَذْرِ مَالٍ مَعْلُومٍ أَوْ أَصَمَّ
    تُرِيدُ أَنْ تُضْعِفَهُ</مقطع>
  <مقطع هوية='٥٧٩٠٣'>وَمَعْنَى إِضْعَافِكَ إِيَّاهُ أَنْ تَضْرِبَهُ فِي اثْنَيْنِ</مقطع>

</ملف>
