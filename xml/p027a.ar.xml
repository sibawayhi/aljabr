<ملف رقم="٢٧"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٢٧٢٧٧'>وَزِدْنَا عَلَيْهِ خَطُّ <خط>ح <جيم/></خط>
  الَّذِي هُوَ نِصْفُ الثَّلَاثَةِ الأَجْذَارِ وَهُوَ وَاحِدٌ وَنِصْفٌ</مقطع>
  <مقطع هوية='٦١٢٨٦'>فَبَلَغَ ذٰلِكَ كُلُّهُ أَرْبَعَةً وَهُوَ خَطُّ <خط>ا<جيم/></خط></مقطع>
  <مقطع هوية='٦٥٦٣٨'>وَهُوَ جُذْرُ الْمَالِ الَّذِي هُوَ سَطْحُ <سطح>اد</سطح></مقطع>
  <مقطع هوية='٦٤٩٠٢'>وَهٰذِهِ صُورَتُهُ وَذٰلِكَ مَا أَرَدْنَا أَنْ نُبَيِّنَ</مقطع>
  <صورة هوية='٩٧٣٧٨' عرض="1.0" ملف="../figures/fig026"
        tex="\os{س}{٢} = ٤ + \os{س}{}٤"
        pdf="٣س + ٤ = س²"
        />

  <رأس/>
    <مقطع هوية='٧٨٥٨٧'>وَوَجَدْنَا كُلَّ مَا يُعْمَلُ بِهِ مِنْ حِسَابِ الْجَبْرِ وَالْمُقَابَلَةِ</مقطع>
  <مقطع هوية='٦٩٤٢١'>لَا بُدَّ أَنْ يُخْرِجَكَ إِلَى أَحَدِ الْأَبْوَابِ السِّتَّةِ
  الَّتِي وَصَفْتُ فِي كِتَابِي هٰذَا</مقطع>
  <مقطع هوية='٧٣٠٠٥'>وَقَدْ أَتَيْتُ عَلَى تَفْسِيرِهَا فَاعْرِفْ ذَلِكَ</مقطع>

</ملف>
