<صفحة رقم="٢١"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">


       <مقطع هوية='٩٤١٣٤'>وَضَرَبْتَهَا فِي <folio nbr="٢١"/>مِثْلِهَا</مقطع>
       <مقطع هوية='٥٤٢٥٣'>فَكَاْنَ مَبْلَغُ ذَلِكَ أَقَلَّ مِنْ الْدَّراْهِمِ الَّتِي مَعَ الْمَاْلِ</مقطع>
       <مقطع هوية='٨٥٢٤٢'>فَاْلْمَسْئَلَةُ مُسْتَحِيلَةٌ</مقطع>
       <مقطع هوية='٧٨٩٥٠'>وَإِنْ كَاْنَ مِثْلَ الدَّرَاْهِمِ بِعَيْنِهَا</مقطع>
       <مقطع هوية='٤٧٥٢٨'>فَجَذْرُ الْمَاْلِ مِثْلُ نِصْفِ الِاجْذَاْرِ سَوَاْءً لا زِيَاْدَةً وَلَا نُقْصَاْنَ</مقطع>
       <مقطع هوية='٩٦٩٧٨'>وَكُلُّ مَا أَتَاْكَ مِنْ مَاْلَيْنِ أَوْ أَكْثَرَ أَوْ أَقَلَّ فَاْرْدَدْهُ الْى مَاْلٍ وَاْحِدٍ</مقطع>
       <مقطع هوية='٩٤٥٩٩'>كَنَحْوِ مَا بَيَّنْتُ لَكَ فِي الْبَاْبِ الِاوْلِ</مقطع>

       <رأس/>
       <مقطع هوية='٩٨٨٣٧'>وَأَمَّا الْجُذُورُ وَاْلْعَدَدُ الَّتِي تَعْدِلُ الْأَمْوَاْلَ</مقطع>
       <مقطع هوية='٣٩٢٣١'>فَنَحْوُ قَوْلِكَ <معادلة>ثَلٰثَةُ أَجْذَاْرٍ وَأَرْبَعَةٌ مِنْ الْعَدَدِ تَعْدِلُ مَاْلًا</معادلة></مقطع>
       <مقطع هوية='٠٥٦٣٦'>فَبَاْبُهُ أَنْ تُنَصِّفَ الْأَجْذَاْرَ فَتَكُونَ وَاْحِدًا وَنِصْفًا</مقطع>
       <مقطع هوية='٣٧١٧٥'>فَاضْرِبْهَا فِي مِثْلِهَا فَتَكُونَ اثْنَيْنِ وَرُبْعًا</مقطع>
       <مقطع هوية='٥٩٤٣٢'>فَزِدْهَا عَلَى الْأَرْبَعَةِ فَتَكُونَ سِتَّةً وَرُبْعًا</مقطع>
       <مقطع هوية='٠٤٦٣٢'>فَخُذْ جَذْرَهَا وَهُوَ اثْنَاْنِ وَنِصْفٌ</مقطع>
       <مقطع هوية='٠٥٢٥٧'>فَزِدْهُ عَلَى نِصْفِ ااْلْأَجْذَاْرِ وَهُوَ وَاْحِدٌ وَنِصْفٌ</مقطع>
       <مقطع هوية='٠٢٠٧٠'>فَتَكُونَ أَرْبَعَةً وَهُوَ جَذْرُ الْمَاْلِ وَاْلْمَاْلُ سِتَّةُ عَشَرَ</مقطع>
       <مقطع هوية='٦٠٤٣٤'>وَكُلُّ مَا كَاْنَ‎ أَكْثَرَ مِنْ مَاْلٍ أَوْ أَقَلَّ فَأَرْدَدْهُ إلَى مَاْلٍ وَاْحِدٍ</مقطع>
       <مقطع هوية='٧٠٩٣٦'>فَهَذِهِ السِّتَّةُ الضُّرُوبُ الَّتِي ذَكَرْتُهَا فِي صَدْرِ كِتَاْبِي هَذَا</مقطع>
       <مقطع هوية='٢٦٣٤٨'>وَقَدْ أَتَيْتُ عَلَى تَفْسِيرِهَا وَأَخْبَرْتُ أَنَّ مِنْهَا ثَلٰثَةُ ضُرُوْبٍ لَا تُنَصِّفُ فِيْهَا الْأَجْذَاْرَ</مقطع>
       <مقطع هوية='٧٣١٦٨'>وَقَدْ يَيَّنْتُ قِيَاْسَهَا وَاضْطِرَاْرَهَا</مقطع>

       <رأس/>
       <مقطع هوية='٨٦٢٢٢'>فَأَمَّا مَا تَحْتَاْجُ فِيْهِ إِلَى تَنْصِيْفِ الْأَجْذَاْرِ فِي الثَّلَاثَةِ الْأَبْوَاْبِ الْبَاْقِيَةِ فَقَدْ وَصَفَتُهُ بِاأَبْوَاْبٍ صَحِيْحَةٍ</مقطع>
       <مقطع هوية='٩١٨٨٠'>وَصَيَّرْتُ لِكُلِّ بَاْبٍ مِنْهَا صُوْرَةً يُسْتَدَلُّ مِنْهَا عَلَى الْعِلَّةِ فِي الْتَّصْنِيْفِ</مقطع>
       <مقطع هوية='٦٨٩٧٧'>فَأَمَّا عِلَّةُ <معادلة>مَاْلٍ وَعَشَرَةُ أَجْذَاْرٍ تَعْدِلُ تِسْعَةً وَثَلَاثِيْنَ دِرْهَمًا</معادلة>
      </مقطع>

</صفحة>
