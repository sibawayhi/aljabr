<ملف رقم="٤٢"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٢٠٦٣٨'><صفحة رقم="٤٢"/>فَيَكُونَ خَمْسَةَ أَشْيَاءَ مَقْسُومَةً عَلَى الْبَاقِي مِنَ الْعَشَرَةِ وَهُوَ عَشَرَةٌ إِلَّا شَيْئًا مَأْخُوذٌ نِصْفُهَا</مقطع>
  <مقطع هوية='٠٣٧٤٤'>وَمَعْلُومٌ أَنَّكَ إِذَا قَسَمْتَ الْخَمْسَةَ الأَشْيَاءَ عَلَى عَشَرَةِ الأَشْيَاءَ</مقطع>
  <مقطع هوية='٨٧٢٥١'>وَأَخَذْتَ نِصْفَ مَا خَرَجَ كَانَ ذٰلِكَ كَقَسَمِكَ نِصْفَ الْخَمْسَةِ الأَشْيَاءَ عَلَى الْعَشَرَةِ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٨٤٠٧٩'>فَإِذَا أَخَذْتَ نِصْفَ الْخَمْسَةِ الأَشْيَاءَ صَارَ شَيْئَيْنِ وَنِصْفًا</مقطع>
  <مقطع هوية='٦٧٦١٥'>وَهُوَ الَّذِي تُرِيدُ أَنْ تَقْسِمَهُ عَلَى عَشَرَةِ الأَشْيَاءَ يَخْرُجُ يَعْدِلُ خَمْسِينَ إِلَّا خَمْسَةَ أَشْيَاءَ</مقطع>
  <مقطع هوية='٣٠٥٦٢'>لِأَنَّهُ قَالَ تَضُمُّ إِلَيْهِ أَحَدَ الْقِسْمَيْنِ مَضْرُوبًا فِي خَمْسَةٍ فَيَكُونُ ذٰلِكَ كُلُّهُ خَمْسِينَ</مقطع>
  <مقطع هوية='٤٦٥٨٥'>وَقَدْ عَلِمْتَ أَنَّكَ مَتَى ضَرَبْتَ مَا خَرَجَ لَكَ مِنَ الْقِسْمِ فِي الْمَقْسُومِ عَلَيْهِ عَادَ الْمَالُ</مقطع>

  <مقطع هوية='٥٣١٠٥'>وَمَالِكَ شَيْئَانِ وَنِصْفٌ فَاضْرِبْ عَشَرَةً إِلَّا شَيْئًا فِي خَمْسِينَ إِلَّا خَمْسَةَ أَشْيَاءَ</مقطع>

  <مقطع هوية='٨٦٥٨٩'>فَيَكُونُ ذٰلِكَ خَمْسُمِائَةَ دِرْهَمٍ وَخَمْسَةَ أَمْوَالٍ إِلَّا مِائَةَ شَيْءٍ تَعْدِلُ شَيْئَيْنِ وَنِصْفًا</مقطع>
  <مقطع هوية='٥٢٩١٢'>فَارْدُدْ ذٰلِكَ إِلَى مَالٍ وَاحِدٍ فَيَكُونُ ذٰلِكَ مِائَةَ دِرْهَمٍ وَمَالًا إِلَّا عِشْرِينَ شَيْئًا تَعْدِلُ نِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٣٦٩١٠'>فَاجْبُرْ ذٰلِكَ الْمِائَةَ وَازِدْ الْعِشْرِينَ الشَّيْءَ عَلَى نِصْفِ الشَّيْءِ</مقطع>
  <مقطع هوية='٠٥٤٦٨'>فَيَصِيرُ مَعَكَ مِائَةَ دِرْهَمٍ وَمَالٌ تَعْدِلُ عِشْرِينَ شَيْئًا وَنِصْفَ شَيْءٍ</مقطع>
  <مقطع هوية='٠٢٠٥٠'>فَنَصِّفْ الأَشْيَاءَ وَاضْرِبْهَا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٩٩٤٣٨'>وَانْقُصْ مِنْهُ الْمِائَةَ وَخُذْ جَذْرَ مَا بَقِيَ</مقطع>
  <مقطع هوية='٠١٩٨٠'>وَانْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ وَهُوَ عَشَرَةٌ وَرُبُعٌ</مقطع>
  <مقطع هوية='٤٩٣٨٢'>فَيَبْقَى ثَمَانِيَةٌ وَهُوَ أَحَدُ الْقِسْمَيْنِ</مقطع>

  <مقطع هوية='٣٢٠٨٩'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قِسْمَيْنِ
  فَضَرَبْتَ أَحَدَ الْقِسْمَيْنِ فِي نَفْسِهِ
  فَكَانَ مِثْلَ الْآخَرِ إِحْدَى وَثَمَانِينَ مَرَّةً</معادلة></مقطع>

  <مقطع هوية='٩٤٢٧٧'><قياس>فَقِيَاسُ ذٰلِكَ</قياس> أَنْ تَقُولَ عَشَرَةً إِلَّا شَيْئًا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٣٨٥٥٨'>بِمِائَةٍ وَمَالٍ إِلَّا عِشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٤٦٦٠'>تَعْدِلُ أَحَدًا وَثَمَانِينَ شَيْئًا</مقطع>
  <مقطع هوية='٧٨٦٢٧'>فَاجْبُرِ الْمِائَةَ وَالْمَالَ بِالْعِشْرِينَ الشَّيْءِ</مقطع>
  <مقطع هوية='٠٥٢٤٠'>وَازِدْهَا عَلَى الْوَاحِدِ وَالثَّمَانِينَ (الشَّيْءِ)</مقطع>
  <مقطع هوية='٣٥٩٦٩'>فَيَكُونُ مِائَةً وَمَالًا تُعَدِّلُ مِائَةَ جَذْرٍ وَجَذْرًا</مقطع>
  <مقطع هوية='١١٩٤٩'>فَانْصِفْ الْأَجْدَارَ فَتَكُونُ خَمْسِينَ</مقطع>
  <مقطع هوية='١٥٣٤٩'>وَاضْرِبْهَا فِي مِثْلِهَا</مقطع>
</ملف>
