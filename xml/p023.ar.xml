<ملف رقم="٢٣"

    xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٧٢٦٧٥'>بَقِيَ مِنْ <صفحة رقم="٢٣"/> ضِلْعِهِ ثَلَاثَةٌ وَهُوَ جَذْرُ ذَلِكَ الْمَالِ</مقطع>

  <رأس/>
  <مقطع هوية='٢٣١٦٦'>وَإِنَّمَا نَصَّفْنَا الْعَشَرَةَ الْأَجْذَارَ وَضَرَبْنَاهَا فِي مِثْلِهَا</مقطع>
  <مقطع هوية='٥٠٣٠٨'>وَزِدْنَاهَا عَلَى الْعَدَدِ الَّذِى هُوَ تِسْعَةٌ وَثَلَاثُونَ</مقطع>
  <مقطع هوية='٥٧٨٨٧'>لِيَتِمَّ لَنَا بِنَاءُ السَّطْحِ الْأَعْظَمِ بِمَا نَقَصَ مِنْ زَوَايَاهُ الْأَرْبَعُ</مقطع>
  <مقطع هوية='٩٩٢٥٦'>لِأَنَّ كُلَّ عَدَدٍ يُضْرَبُ رُبْعُهُ فِي مِثْلِهِ ثُمَّ فِي أَرْبَعَةٍ</مقطع>
  <مقطع هوية='٧٠٣٣٢'>يَكُونُ مِثْلَ ضَرْبِ نِصْفِهِ فِي مِثْلِهِ</مقطع>
  <مقطع هوية='١١٥٩٧'>فَاسْتَغْنَيْنَا بِضَرْبِ نِصْفِ الْأَجْذَارِ فِي مِثْلِهَا عَنْ الرُّبْعُ فِي مِثْلِهِ ثُمَّ في أَرْبَعَةٍ</مقطع>
  <مقطع هوية='١٠٠٩١'>وَهَذِهِ صُورَتُهُ</مقطع>

  <رأس/>
  <مقطع هوية='٤٥٧٩٩'>وَلَهُ أَيْضًا صُورَةٌ أُخْرَى تُؤَدِّي الَى هَذَا</مقطع>
  <مقطع هوية='٨٨٥١٢'>وَهَى سَطْحُ <سطح>اٮ</سطح> وَهُوَ الْمَالُ</مقطع>
  <مقطع هوية='٠٣٣٣٦'>فَأَرَدْنَا أَنْ نَزِيْدَ عَلَيْهِ مِثْلَ عَشَرَةِ أَجْذَارِهِ</مقطع>
  <مقطع هوية='٥٣١٤٧'>فَنَصَّفْنَا الْعَشَرَةَ فَصَارَتْ خَمْسَةً</مقطع>
  <مقطع هوية='٩٣١١٤'>فَصَيَّرْنَاهَا سَطْحَيْنِ عَلَى جَنْبَتَيْ سَطْحِ <سطح>اٮ</سطح> وَهُمَا سَطْحا <سطح><جيم/> د</سطح></مقطع>
  <مقطع هوية='٣٣٣١٧'>فَصَارَ طُولُ كُلِّ سَطْحٍ مِنْهُمَا خَمْسَةَ أَذْرُعٍ</مقطع>
  <مقطع هوية='٣٨٥٣٣'>وَهُوَ نِصْفُ الْعَشَرَةِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٧٦١٨٠'>وَعَرْضُهُ مِثْلُ ضِلْعِ سَطْحِ <سطح>اٮ</سطح></مقطع>
  <مقطع هوية='٥٧٣٤٠'>فَبَقِيَتْ لَنَا مُرَبَّعَةٌ مِنْ زَوَايَا سَطْحِ <سطح>اٮ</سطح></مقطع>
  <مقطع هوية='٠٨٦٩١'>وَهِىَ خَمْسَةٌ فِي خَمْسَةٍ وَهِى نِصْفُ الْعَشَرَةِ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٧٥٨٨٦'>الَّتِى زِدْنَاهَا عَلَى جَنْبَتَيْ السَّطْحِ الْأَوَّلِ</مقطع>
  <مقطع هوية='٢٢٧٤٩'>فَعَلِمْنَا أَنَّ السَّطْحَ االْأَوَّلَ هُوَ الْمَالُ</مقطع>
  <مقطع هوية='٩٥٦٦١'>وَأَنَّ السَّطْحَيْنِ اللَّذَيْنِ عَلَى جَنْبَتَيْهِ هُمَا عَشَرَةُ أَجْذَارٍ</مقطع>
  <مقطع هوية='٠٩٥٩٦'>فَذَلِكَ كُلُّهُ تِسْعَةٌ وَثَلَاثُونَ</مقطع>
  <مقطع هوية='٠٨٩٥٤'>وَبَقِيَ الَى تَمَامِ السَّطْحِ الْأَعْظَمِ مُرَبَّعَةُ خَمْسَةٍ فِي خَمْسَةٍ فَذَلِكَ خَمْسَةٌ وَعِشْرُونَ</مقطع>
  <مقطع هوية='٥٤٦٢٣'>فَزِدْنَاهَا عَلَى تِسْعَةٍ وَثَلَاثِينَ</مقطع>
  <مقطع هوية='٩٦٨٥٤'>لِيَتِمَّ لَنَا السَّطْحُ الِاعْظَمُ الّّذي هُوَ سطح <سطح>ز<ه/></سطح></مقطع>
  <مقطع هوية='٨٣٤٣٦'>فَبَلَغَ ذَلِكَ كُلُّهُ أَرْبَعَةً وَسِتِّينَ</مقطع>
  <مقطع هوية='٤٠٨٤٠'>فَأَخَذْنَا جَذْرَهَا وَهُوَ ثَمَانِيَةٌ وَهُوَ أَحَدُ أَضْلَاعِ السَّطْحِ الْأَعْظَمُ</مقطع>
  <مقطع هوية='٩٦١٨٣'>فَاذَا نَقَصْنَا مِنْهُ مِثْلَ مَا زِدْنَا عَلَيْهِ وَهُوَ خَمْسَةٌ بَقِيَ ثَلاثَةٌ</مقطع>
  <مقطع هوية='٦٣٠٤٨'>وَهُوَ ضِلْعُ سَطْحِ <سطح>اٮ</سطح> الَّذِى هُوَ الْمَالُ</مقطع>
  <مقطع هوية='٨٧٨٧٩'>وَهُوَ جَذْرُهُ وَالْمَالُ تِسْعَةٌ</مقطع>
  <مقطع هوية='٩٦٤٣٨'>وَهَذِهِ صُورَتُهُ</مقطع>

  <صورة هوية='٠٩٨١١' عرض="0.7" ملف="../figures/fig023"/>

  <رأس/>
  <مقطع هوية='٢٥٠٩٥'>وَأَمَّا <معادلة>مَالٌ وَأَحَدٌ وَعِشْرُوْنَ دِرْهَمًا تَعْدِلُ عَشَرَةَ أَجْذَاْرِهِ</معادلة></مقطع>

