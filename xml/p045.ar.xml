<ملف رقم="٤٥"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٣٦١٠٤'><صفحة رقم="٤٥"/><قياس>فقِيَاسُهُ</قياس> أَنْ تَأْخُذَ شَيْئًا مِنَ الْعَشَرَةِ فَيَبْقَى عَشَرَةً إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٩٨٩٣١'>فَاضْرِبْ أَحَدَهُمَا فِي الْآخَرِ
  فَيَكُونَ عَشَرَةَ أَجْذَارٍ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٠٠٩٦٣'>فَهُوَ مَا خَرَجَ مِنْ ضَرْبِ أَحَدِ الْقِسْمَيْنِ فِي الْآخَرِ</مقطع>
  <مقطع هوية='٥٦٨٣١'>ثُمَّ قَسَمْتَ ذٰلِكَ عَلَى فَضْلِ مَا بَيْنَ الْقِسْمَيْنِ وَهُوَ عَشَرَةٌ إِلَّا شَيْئَيْنِ</مقطع>
  <مقطع هوية='٥٠٩٦١'>فَخَرَجَ مِنَ الْقِسْمِ خَمْسَةٌ وَرُبُعٌ</مقطع>
  <مقطع هوية='٤٨١٤٩'>وَمَتَى ضَرَبْتَ خَمْسَةً وَرُبُعًا فِي عَشَرَةٍ إِلَّا شَيْءٍ</مقطع>
  <مقطع هوية='٧٨٨٥٣'>خَرَجَ لَكَ الْمَالُ الْمَضْرُوبُ وَهُوَ عَشَرَةُ أَشْيَاءَ إِلَّا مَالٍ</مقطع>
  <مقطع هوية='٠٦٣٢٢'>فَاضْرِبْ خَمْسَةً وَرُبُعًا فِي عَشَرَةٍ إِلَّا شَيْئَيْنِ</مقطع>
  <مقطع هوية='٣٠٧٤٠'>يَكُونُ ذٰلِكَ اثْنَيْنِ وَخَمْسِينَ دِرْهَمًا وَنِصْفًا إِلَّا عَشَرَةَ أَجْذَارٍ وَنِصْفًا</مقطع>
  <مقطع هوية='٠٩٢٧٥'>تَعْدِلُ عَشَرَةَ أَجْذَارٍ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٣٤١٧٣'>فَاجْبُرِ الِاثْنَيْنِ وَالْخَمْسِينَ وَالنِّصْفَ بِالْعَشَرَةِ الْأَجْذَارِ وَالنِّصْفِ</مقطع>
  <مقطع هوية='٦٢١٢١'>وَزِدْهَا عَلَى الْعَشَرَةِ الْأَجْذَارِ إِلَّا مَالًا</مقطع>
  <مقطع هوية='٣١٠٨٩'>ثُمَّ اجْبُرْهَا بِالْمَالِ وَزِدْ الْمَالَ عَلَى اثْنَيْنِ وَخَمْسِينَ دِرْهَمًا وَنِصْفٍ</مقطع>
  <مقطع هوية='٢٦٤٦٦'>فَيَكُونُ مَعَكَ عِشْرُونَ جَذْرًا وَنِصْفُ جَذْرٍ تَعْدِلُ اثْنَيْنِ وَخَمْسِينَ دِرْهَمًا وَنِصْفًا وَمَالًا</مقطع>
  <مقطع هوية='٨١٩٧٠'>فَقَابِلْ بِهَا عَلَى ما فَسَّرْنَا فِي أَوَّلِ الْكِتَابِ</مقطع>

  <مقطع هوية='٢٧٣٤٣'>فَإِنْ قَالَ <معادلة>مَالٌ ثُلُثَا خُمُسِهِ مِثْلَ سُبُعِ جَذْرِه</معادلة></مقطع>
  <مقطع هوية='٧٥١٠١'>فَإِنَّ الْمَالَ كُلَّهُ يَعْدِلُ جَذْرًا وَنِصْفَ سُبُعِ جَذْرٍ</مقطع>
  <مقطع هوية='٢٤١٤٤'>فَالجَذْرُ أَرْبَعَةَ عَشَرَ جُزْءًا مِنْ خُمَسَةَ عَشَرَ مِنَ الْمَالِ</مقطع>
  <مقطع هوية='٧٤٠٧٩'><قياس>وَقِيَاسُهُ</قياس> أَنْ تَضْرِبَ ثُلُثَيْ خُمُسِ مَالٍ فِي سَبْعَةٍ وَنِصْفٍ لِيَتِمَّ الْمَالُ</مقطع>
  <مقطع هوية='٨٧٨٥١'>وَاضْرِبْ مَا مَعَكَ وَهُوَ سُبْعُ جَذْرٍ فِي مِثْلِ ذٰلِكَ</مقطع>
  <مقطع هوية='١٦٥١٦'>فَيَصِيرُ الْمَالُ يَعْدِلُ جَذْرًا وَنِصْفَ سُبْعِ جَذْرٍ</مقطع>
  <مقطع هوية='٨٠٢٥٩'>وَيَصِيرُ جَذْرُهُ وَاحِدًا وَنِصْفَ سُبْعٍ</مقطع>
  <مقطع هوية='٩٠١٥٠'>فَالْمَالُ وَاحِدٌ وَتِسْعَةٌ وَعِشْرُونَ جُزْءً</مقطع>
  <مقطع هوية='٨٥٩٧٥'>مِنْ مِائَةٍ وَسِتَّةٍ وَتِسْعِينَ مِنْ دِرْهَمٍ</مقطع>
  <مقطع هوية='٨٥٨٨٩'>وَثُلُثَا خُمُسِهِ يَكُونُ ثَلاَثِينَ جُزْءً مِنْ مِائَةٍ وَسِتَّةٍ وَتِسْعِينَ</مقطع>
  <مقطع هوية='٦٥٢٦٢'>وَسُبْعُ جَذْرِهِ أَيْضًا ثَلاَثُونَ جُزْءًا مِنْ مِائَةٍ وَسِتَّةٍ وَتِسْعِينَ</مقطع>

  <مقطع هوية='٧٦٠١٦'>فَإِنْ قَالَ <معادلة>مَالٌ ثَلاثَةُ أَرْبَاعِ خُمُسِهِ
  مِثْلُ أَرْبَعَةِ أَخْمَاسِ جَذْرِهِ</معادلة></مقطع>
  <مقطع هوية='٧٨٥٩٢'><قياس>قِيَاسُهُ</قياس> أَنْ تَزِيدَ عَلَى ثَلاثَةِ أَرْبَاعِ خُمُسِهِ مِثْلَ رُبُعِهَا لِيَكُونَ الْجَذْرُ تَامًّا</مقطع>
  <مقطع هوية='٧٥٨٠٤'>وَذٰلِكَ ثَلاثَةٌ وَثَلاثَةُ أَرْبَاعٍ مِنْ عِشْرِينَ</مقطع>
  <مقطع هوية='٣٩١٣٢'>فَاجْعَلْهَا أَرْبَاعًا كُلَّهَا فَتَكُونُ خَمْسَةَ عَشَرَ مِنْ ثَمَانِينَ</مقطع>

</ملف>
