<?xml version="1.0" encoding="utf-8"?>

<ملف رقم="١٧"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <فصل هوية='٦٠٦٩٦'>
    <عنوان>[الْعَدْلُ مِنْ ضُروبِ الْعَدَدِ]</عنوان>
  </فصل>

  <مقطع هوية="٢٣">فَمِنْ هَذِهِ الضُّرُوبِ الثَّلَاثَةِ مَا يَعْدِلُ بَعْضُهَا بَعْضًا</مقطع>
  <مقطع هوية="٢٤">وَهُوَ كَقَوْلِك <قبس>أَمْوَالٌ تَعْدِلُ جُذُوْرًا</قبس> وَ<قبس>أَمْوَالٌ تَعْدِلُ عَدَدًا</قبس> وَ<قبس>جُذُورٌ تَعْدِلُ عَدَدًا</قبس>
  </مقطع>

  <قسم هوية='٨١٨٢٩'>
    <عنوان>[أَموال=جذور]</عنوان>
  </قسم>
  <مقطع هوية="٢٥">فَأَمَّا الْأَمْوَالُ الَّتِي تَعْدِلُ الْجُذُوْرَ</مقطع>
  <مقطع هوية='٥٦٤٨٧'>فَمِثْلُ قَوْلِكَ <معادلة>مَالٌ يَعْدِلُ خَمْسَةَ أَجْذَارِهِ</معادلة></مقطع>
  <مقطع هوية="٢٧">فَجَذْرُ الْمَالِ خَمْسَةٌ</مقطع>
  <مقطع هوية="٢٨">وَالْمَالُ خَمْسَةٌ وَعِشْرُونَ وَهُوَ مِثْلُ خَمْسَةِ أَجْذَارِهِ</مقطع>
  <مقطع هوية="٢٩">وَكَقَوْلِكَ <معادلة>ثُلْثُ مَالٍ يَعْدِلُ أَرْبَعَةَ أَجْذَارٍ</معادلة></مقطع>
  <مقطع هوية="٣٠">فَالْمَالُ كُلُّهُ يَعْدِلُ اثْنَيْ عَشَرَ جَذْرًا</مقطع>
  <مقطع هوية="٣١">وَهُوَ مِائَةٌ وَأَرْبَعَةٌ وَأَرْبَعُونَ</مقطع>
  <مقطع هوية="٣٢">وَجَذْرُهُ اثْنَيْ عَشَرَ</مقطع>

  <مقطع هوية="٣٣">وَمِثْلُ قَوْلِكَ <معادلة>خَمْسَةُ أَمْوَالٍ تَعْدِلُ عَشَرَةَ أَجْذَارٍ</معادلة></مقطع>
  <مقطع هوية="٣٤">فَالْمَالُ الْوَاحِدُ يَعْدِلُ جَذْرَيْنِ وَجَذْرُ الْمَالِ اثْنَانِ وَالْمَالُ أَرْبَعَةٌ</مقطع>

  <رأس/>
  <مقطع هوية="٣٥">وَكَذَلِكَ مَا كَثُرَ مِنْ الْأَمْوَالِ أَوْ قَلَّ <ص مفتاح="ردّ">يُرَدُّ</ص> إلَى مَالٍ وَاحِدٍ</مقطع>
  <مقطع هوية="٣٦">وَكَذَلِكَ يُفْعَلُ بِمَا عَادَلَهَا مِنْ الْأَجْذَارِ</مقطع>
  <مقطع هوية='٣٧'><ص مفتاح="ردّ">يُرَدُّ</ص> إلَى مِثْلِ مَا يُرَدُّ إلَيْهَا الْمَالُ</مقطع>

</ملف>
