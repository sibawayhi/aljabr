<ملف رقم="٤١"

xmlns="http://www.sibawayhi.org/schema/2009/07/sibawayhi">

  <مقطع هوية='٥٤٦٣٥'>فَاجْمَعْ ذٰلِكَ فَيَصِيرُ مِائَةً <صفحة رقم="٤١"/>وَمَالِين إِلَّا عَشْرِينَ شَيْئًا يُعَادِلُ شَيْئًا مَضْرُوبًا فِي عَشَرَةٍ إِلَّا شَيْئًا</مقطع>
  <مقطع هوية='٩٨١٨٣'>وَذٰلِكَ عَشَرَةُ أَشْيَاءَ إِلَّا مَا لَا مَضْرُوبًا فِي مَا خَرَجَ مِنَ الْقِسْمَيْنِ وَهُوَ اثْنَانِ وَسِتُُّوْنََ</مقطع>
  <مقطع هوية='٤١٦٣١'>فَيَكُونُ ذٰلِكَ أَحَدًا وَعِشْرِينَ شَيْئًا وَثُلُثَ شَيْءٍ إِلَّا مَالِين وَسُدُسًا</مقطع>
  <مقطع هوية='٨٩٤١٠'>تَعْدِلُ مِائَةً وَمَالِين إِلَّا عَشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٨٦٣٣١'>فَاجْبِرْ ذٰلِكَ وَازِدْ مَالِين وَسُدُسًا عَلَى مِائَةٍ وَمَالِين إِلَّا عَشْرِينَ شَيْئًا</مقطع>
  <مقطع هوية='٨٢٣٨٨'>وَازِدْ الْعِشْرِينَ الشَّيْءِ النَّاقِصَةَ مِنَ الْمِائَةِ وَالْمَالِين عَلَى الْوَاحِدِ وَالْعِشْرِينَ الشَّيْءِ وَثُلُثِ الشَّيْءِ</مقطع>
  <مقطع هوية='١٧٧٨٩'>فَيَكُونُ مَعَكَ مِائَةً وَأَرْبَعَةَ أَمْوَالٍ وَسُدُسُ مَالٍ تَعْدِلُ أَحَدًا وَأَرْبَعِينَ شَيْئًا وَثُلُثَ شَيْءٍ</مقطع>
  <مقطع هوية='٦٣٦٦٦'>فَارْدُدْ ذٰلِكَ إِلَى مَالٍ</مقطع>

  <مقطع هوية='٤٨٦٢٨'>وَقَدْ عَلِمْتَ أَنَّ الْمَالَ الْوَاحِدَ مِنْ أَرْبَعَةِ أَمْوَالٍ وَسُدُسٍ هُوَ خُمُسُهَا وَخُمُسُ خُمُسِهَا</مقطع>

  <مقطع هوية='٥٨٠٠٨'>فَخُذْ مِنْ جَمِيعِ مَا مَعَكَ الْخُمُسَ وَخُمُسَ الْخُمُسِ</مقطع>
  <مقطع هوية='٦٧٣٧٨'>فَيَكُونُ مَعَكَ أَرْبَعَةٌ وَعِشْرُونَ وَمَالٌ تَعْدِلُ عَشَرَةَ أَجْذَارٍ</مقطع>
  <مقطع هوية='٨١٢٦٩'>لِأَنَّ الْعَشَرَةَ مِنْ أَحَدٍ وَأَرْبَعِينَ شَيْئًا وَثُلُثَ شَيْءٍ خُمُسُهَا وَخُمُسُ خُمُسِهَا</مقطع>
  <مقطع هوية='١٠٢٩٥'>فَانْصِفْ الْأَجْذَارَ وَهُوَ خَمْسَةٌ وَاضْرِبْهَا فِي مِثْلِهَا فَيَكُونُ خَمْسَةً وَعِشْرِينَ</مقطع>
  <مقطع هوية='٦٨٠٠٥'>فَانْقُصْ مِنْهَا الْأَرْبَعَةَ وَالْعِشْرِينَ الَّتِي مَعَ الْمَالِ يَبْقَى وَاحِدٌ</مقطع>
  <مقطع هوية='٧٣٨٧٨'>فَخُذْ جَذْرَهُ وَهُوَ وَاحِدٌ فَانْقُصْهُ مِنْ نِصْفِ الْأَجْذَارِ وَهِيَ خَمْسَةٌ</مقطع>
  <مقطع هوية='٤٠٤٥٦'>يَبْقَى أَرْبَعَةٌ وَهُوَ أَحَدُ الْقِسْمَيْنَ</مقطع>

  <رأس/>
  <مقطع هوية='١٥٨٧١'>وَاعْلَمْ أَنَّ كُلَّ شَيْئَيْنِ تُقَسَّمُ هَذَا عَلَى هَذَا وَهَذَا عَلَى هَذَا</مقطع>

  <مقطع هوية='١١٦٢٠'>فَإِنَّكَ إِذَا ضَرَبْتَ الَّذِي يَخْرُجُ مِنْ هَذَا فِي الَّذِي يَخْرُجُ مِنْ هَذَا</مقطع>
  <مقطع هوية='٠٥٣١١'>كَانَ وَاحِدًا أَبَدًا</مقطع>

  <مقطع هوية='٤٠٨٩٦'>فَإِنْ قَالَ <معادلة>عَشَرَةٌ قَسَمْتَهَا قَسْمَيْنِ
  وَضَرَبْتَ أَحَدَ الْقِسْمَيْنِ فِي خَمْسَةٍ
  وَقَسَمْتَهُ عَلَى الْآخَرِ
  ثُمَّ الْقَيْتَ نِصْفَ مَا اجْتَمَعَ مَعَكَ
  وَزِدْتَهُ عَلَى الْمَضْرُوبِ فِي خَمْسَةٍ
  فَكَانَ خَمْسِينَ دِرْهَمًا</معادلة></مقطع>

  <مقطع هوية='٩٠٤٨٨'><قياس>فَإِنَّ قِيَاسَ ذٰلِكَ</قياس> أَنْ تَأْخُذَ شَيْئًا مِّنَ الْعَشَرَةِ فَتَضْرِبَهُ فِي خَمْسَةٍ</مقطع>
</ملف>
